<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="ja">
<translation id="130631256467250065">変更内容は、次回のデバイスの起動時に反映されます。</translation>
<translation id="2955914891289756427">Ecosia では、障害レポートをご利用いただけません。</translation>
<translation id="2441066927880955410">保護された Ecosia ページを表示しています</translation>
<translation id="5104341700462991189">Ecosia ロゴ</translation>
<translation id="7347361780317841252">Ecosia は <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> オープンソース プロジェクトやその他の<ph name="BEGIN_LINK_OSS"/>オープンソース ソフトウェア<ph name="END_LINK_OSS"/>によって実現しました。</translation>
<translation id="8920794075861916959">このオプションを無効にするには:
          Ecosia メニュー &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          [LAN の設定]
          の順に移動して、[LAN にプロキシ サーバーを使用する] チェックボックスをオフにします。</translation>
<translation id="5177147493498374715">このページは Ecosia によってブロックされています</translation>
<translation id="583128902627777075">ファイアウォールやウイルス対策の設定で、Ecosia からネットワークへのアクセスを
        許可します。</translation>
<translation id="3913860536599484838">このオプションを無効にするには:
          Ecosia メニュー &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          の順に移動して、設定が [プロキシなし] または [直接] になっていることを確認します。</translation>
<translation id="1722634673917783018">変更内容は次に Ecosia を再起動したときに有効になります。</translation>
<translation id="8143058600367874039">Ecosia メニュー &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          の順に移動して、[<ph name="NO_PREFETCH_DESCRIPTION"/>] をオフにします。
          上記を行っても問題が解決しない場合は、パフォーマンス向上のため
          このオプションを再びオンにすることをおすすめします。</translation>
<translation id="8187289872471304532">このオプションを無効にするには:
          [アプリケーション] &gt; [システム環境設定] &gt; [ネットワーク] &gt; [詳細] &gt; [プロキシ] の順に移動して、
          選択されているプロキシの選択を解除します。</translation>
<translation id="1864711229671391928">Ecosia は正しく終了しませんでした。</translation>
</translationbundle>
