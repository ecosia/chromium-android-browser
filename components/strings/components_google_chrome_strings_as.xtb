<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="as">
<translation id="1864711229671391928">Ecosia সঠিকভাৱে হোৱা নাছিল।</translation>
<translation id="130631256467250065">আপুনি ইয়াৰ পিছৰবাৰ আপোনাৰ ডিভাইচটো ৰিষ্টাৰ্ট কৰিলে সালসলনিখিনি প্ৰয়োগ কৰা হ‘ব।</translation>
<translation id="1722634673917783018">আপুনি পৰৱৰ্তী সময়ত Ecosia পুনৰ লঞ্চ কৰিলে আপুনি কৰা সলনিসমূহ কাৰ্যকৰী হ’ব।</translation>
<translation id="7347361780317841252"><ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/>ৰ মুক্ত উৎসৰ প্ৰ’জেক্ট আৰু অন্য <ph name="BEGIN_LINK_OSS"/>মুক্ত উৎসৰ ছফ্টৱেৰ<ph name="END_LINK_OSS"/>ৰ দ্বাৰা Ecosiaক সহজসাধ্য কৰা হৈছে।</translation>
<translation id="5104341700462991189">Ecosiaৰ ল'গ'</translation>
<translation id="3444832043240812445">যদি আপুনি <ph name="BEGIN_LINK"/>ক্ৰেশ্ব ৰিপর্ট কৰা সুবিধাটো সক্ষম কৰে<ph name="END_LINK"/> তেন্তে এই পৃষ্ঠাটোৱে কেৱল আপোনাৰ শেহতীয়া ক্ৰেশ্বসমূহৰ তথ্য দেখুৱায়।</translation>
<translation id="583128902627777075">আপোনাৰ ফায়াৰৱাল বা এণ্টিভাইৰাছৰ ছেটিঙত Ecosiaক নেটৱর্ক এক্সেছ কৰিবলৈ অনুমতি দিয়ক।</translation>
<translation id="5177147493498374715">এই পৃষ্ঠাখন Ecosiaএ অৱৰোধ কৰিছে</translation>
<translation id="3913860536599484838">Ecosia মেনু &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>লৈ যাওক আৰু আপোনাৰ কনফিগাৰেশ্বন "কোনো প্ৰক্সি নাই" বা "পোনপটীয়া" হিচাপে ছেট কৰা আছেনে নাই নিশ্চিত কৰক।</translation>
<translation id="8143058600367874039">Ecosiaৰ মেনু
          &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>লৈ যাওক
          আৰু "<ph name="NO_PREFETCH_DESCRIPTION"/>"ক বাছনিৰ পৰা আঁতৰাওক
          এনে কৰিলেও যদি সমস্যাটো সমাধান নহয়, তেন্তে আমি উন্নত প্ৰদৰ্শনৰ বাবে
          আকৌ এই বিকল্পটো বাছনি কৰাৰ চুপাৰিছ কৰোঁ।</translation>
<translation id="6276216569125239216">Ecosia মেনু &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN ছেটিংলৈ যাওক আৰু 
          "আপোনাৰ LANৰ বাবে প্ৰক্সি"ক বাছনিৰ পৰা আঁতৰাওক।</translation>
<translation id="2441066927880955410">আপুনি এখন সুৰক্ষিত Ecosia পৃষ্ঠা চায় আছে</translation>
<translation id="8187289872471304532">এপ্লিকেশ্বন &gt; ছিষ্টেমৰ অগ্ৰাধিকাৰ &gt; নেটৱর্ক &gt; উন্নত &gt; প্ৰক্সিসমূহ-লৈ যাওক আৰু বাছনি কৰা যিকোনো প্ৰক্সি বাছনিৰ পৰা আঁতৰাওক।</translation>
</translationbundle>
