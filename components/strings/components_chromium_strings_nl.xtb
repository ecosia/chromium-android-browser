<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="nl">
<translation id="130631256467250065">Je wijzigingen worden doorgevoerd wanneer je het apparaat opnieuw opstart.</translation>
<translation id="2955914891289756427">Crashrapportage is niet beschikbaar in Ecosia.</translation>
<translation id="2441066927880955410">Je bekijkt een beveiligde Ecosia-pagina</translation>
<translation id="5104341700462991189">Ecosia-logo</translation>
<translation id="7347361780317841252">Ecosia wordt mogelijk gemaakt door het <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> open-sourceproject en andere <ph name="BEGIN_LINK_OSS"/>open-sourcesoftware<ph name="END_LINK_OSS"/>.</translation>
<translation id="8920794075861916959">Ga naar
          het menu 'Ecosia' &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN-instellingen
          en verwijder het vinkje uit het selectievakje bij 'Een proxyserver voor het LAN-netwerk gebruiken'.</translation>
<translation id="5177147493498374715">Deze pagina is geblokkeerd door Ecosia</translation>
<translation id="583128902627777075">Sta Ecosia toe via je firewall- of antivirusinstellingen het netwerk te gebruiken.</translation>
<translation id="3913860536599484838">Ga naar
          het menu 'Ecosia' &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          en zorg ervoor dat de configuratie is ingesteld op 'geen proxy' of 'direct'.</translation>
<translation id="1722634673917783018">Je wijzigingen worden toegepast wanneer je Ecosia opnieuw start.</translation>
<translation id="8143058600367874039">Ga naar
          het Ecosia-menu &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          en verwijder het vinkje bij '<ph name="NO_PREFETCH_DESCRIPTION"/>'.
          Als het probleem aanhoudt, adviseren we deze optie weer aan te
          vinken voor betere prestaties.</translation>
<translation id="8187289872471304532">Ga naar 'Applicaties &gt; Systeemvoorkeuren &gt; Netwerk &gt; Geavanceerd &gt; Proxy's' en verwijder de vinkjes bij proxyservers die zijn aangevinkt.</translation>
<translation id="1864711229671391928">Ecosia is niet goed afgesloten.</translation>
</translationbundle>
