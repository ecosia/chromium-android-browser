<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="cs">
<translation id="1864711229671391928">Aplikace Ecosia nebyla řádně ukončena.</translation>
<translation id="130631256467250065">Změny se projeví po příštím restartu zařízení.</translation>
<translation id="1722634673917783018">Změny se projeví po příštím restartu prohlížeče Ecosia.</translation>
<translation id="7347361780317841252">Ecosia staví na projektu s otevřeným zdrojovým kódem <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> a využívá i další <ph name="BEGIN_LINK_OSS"/>otevřený software<ph name="END_LINK_OSS"/>.</translation>
<translation id="5104341700462991189">Logo Ecosia</translation>
<translation id="3444832043240812445">Pokud zvolíte možnost <ph name="BEGIN_LINK"/>povolit zprávy o selhání<ph name="END_LINK"/>, tato stránka bude zobrazovat jen informace o posledních selháních.</translation>
<translation id="583128902627777075">V nastavení firewallu a antivirového programu povolte prohlížeči Ecosia přístup k síti.</translation>
<translation id="5177147493498374715">Tato stránka je blokována prohlížečem Ecosia</translation>
<translation id="3913860536599484838">Přejděte do
          nabídky Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          a zkontrolujte, zda je konfigurace nastavena na možnost „no proxy“ (bez proxy) nebo „direct“ (přímo).</translation>
<translation id="8143058600367874039">Přejděte do nabídky Ecosia &gt; <ph name="SETTINGS_TITLE"/> &gt; <ph name="ADVANCED_TITLE"/> a zrušte výběr možnosti <ph name="NO_PREFETCH_DESCRIPTION"/>. Pokud to však problém nevyřeší, doporučujeme vám tuto možnost znovu vybrat (za účelem zlepšení výkonu).</translation>
<translation id="6276216569125239216">Přejděte do
          nabídky Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Nastavení místní sítě (LAN)
          a zrušte zaškrtnutí políčka Použít pro síť LAN proxy server.</translation>
<translation id="2441066927880955410">Prohlížíte si zabezpečenou stránku vygenerovanou prohlížečem Ecosia</translation>
<translation id="8187289872471304532">Přejděte do nabídky
          Aplikace &gt; Nastavení systému &gt; Síť &gt; Rozšířená nastavení &gt; Servery proxy
          a zrušte výběr všech vybraných serverů proxy.</translation>
</translationbundle>
