<!DOCTYPE translationbundle>
<translationbundle lang="sk">
<translation id="130631256467250065">Zmeny sa prejavia po ďalšom reštartovaní zariadenia.</translation>
<translation id="2955914891289756427">Správy o zlyhaní nie sú v prehliadači Ecosia k dispozícii.</translation>
<translation id="2441066927880955410">Prezeráte si zabezpečenú stránku prehliadača Ecosia</translation>
<translation id="7085497353580337354">Ecosia sa pokúša upraviť nastavenia vypĺňania spôsobov platby.</translation>
<translation id="5104341700462991189">Logo prehliadača Ecosia</translation>
<translation id="1566733708869146127">Ecosia sa pokúša upraviť spôsoby platby.</translation>
<translation id="7347361780317841252">Prehliadač Ecosia mohol vzniknúť vďaka projektu s otvoreným zdrojom <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> a ďalšiemu <ph name="BEGIN_LINK_OSS"/>softvéru s otvoreným zdrojom<ph name="END_LINK_OSS"/> .</translation>
<translation id="8920794075861916959">Prejdite na
          ponuku Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          nastavenia siete LAN
          a zrušte začiarknutie políčka „Používať server proxy pre sieť LAN".</translation>
<translation id="5177147493498374715">Táto stránka bola zablokovaná prehliadačom Ecosia</translation>
<translation id="583128902627777075">Prehliadaču Ecosia povoľte prístup k sieti v nastaveniach brány firewall alebo antivírusového softvéru.</translation>
<translation id="3913860536599484838">Prejdite na
          ponuku Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          a uistite sa, že je vaša konfigurácia nastavená na hodnotu „žiadny server proxy" alebo „priame".</translation>
<translation id="6182615032232999551">Prehliadač Ecosia je založený aj na inom <ph name="BEGIN_LINK_OSS"/>softvéri open source<ph name="END_LINK_OSS"/>.</translation>
<translation id="1722634673917783018">Zmeny sa prejavia pri nasledujúcom reštartovaní prehliadača Ecosia.</translation>
<translation id="4062366803229254216">Prehliadač Ecosia potrebuje prístup k rozhraniu Bluetooth, aby mohol pokračovať 
 v párovaní. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="7273712334661186152">Prehliadač Ecosia je založený na projekte open source <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/>.</translation>
<translation id="8143058600367874039">Prejdite do
        ponuky Ecosia &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        a zrušte výber položky <ph name="NO_PREFETCH_DESCRIPTION"/>.
        Ak to problém nevyrieši, odporúčame túto možnosť vybrať,
        aby ste získali lepšiu výkonnosť.</translation>
<translation id="8187289872471304532">Prejdite na možnosť
          Aplikácie &gt; Systémové predvoľby &gt; Sieť &gt; Rozšírené nastavenia &gt; Servery proxy
          a zrušte výber všetkých vybratých serverov proxy.</translation>
<translation id="8393444759658439191">Prezeráte si zabezpečenú stránku Ecosia for Testing</translation>
<translation id="1864711229671391928">Ecosia nebol správne vypnutý.</translation>
</translationbundle>
