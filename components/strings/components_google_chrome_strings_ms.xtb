<!DOCTYPE translationbundle>
<translationbundle lang="ms">
<translation id="1864711229671391928">Ecosia tidak ditutup dengan betul.</translation>
<translation id="130631256467250065">Perubahan anda akan dilaksanakan apabila anda memulakan semula peranti anda pada masa akan datang.</translation>
<translation id="1722634673917783018">Perubahan anda akan dilaksanakan apabila anda melancarkan semula Ecosia selepas ini.</translation>
<translation id="7347361780317841252">Ecosia berjaya dilaksanakan melalui projek sumber terbuka <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> dan <ph name="BEGIN_LINK_OSS"/>perisian sumber terbuka<ph name="END_LINK_OSS"/> yang lain.</translation>
<translation id="5104341700462991189">Logo Ecosia</translation>
<translation id="3444832043240812445">Halaman ini hanya menunjukkan maklumat mengenai nahas terkini anda jika anda <ph name="BEGIN_LINK"/>mendayakan laporan nahas<ph name="END_LINK"/>.</translation>
<translation id="583128902627777075">Benarkan Ecosia mengakses rangkaian di tetapan tembok api atau
        antivirus anda.</translation>
<translation id="5177147493498374715">Halaman ini telah disekat oleh Ecosia</translation>
<translation id="3913860536599484838">Pergi ke
          menu Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          dan pastikan konfigurasi anda ditetapkan kepada "tiada proksi" atau "terus".</translation>
<translation id="8143058600367874039">Pergi ke
          menu Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          dan nyahpilih "<ph name="NO_PREFETCH_DESCRIPTION"/>."
          Jika tindakan ini tidak menyelesaikan isu ini, kami cadangkan agar memilih pilihan ini
          sekali lagi untuk prestasi yang dipertingkatkan.</translation>
<translation id="6276216569125239216">Pergi ke
          menu Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Tetapan LAN
          dan nyahpilih "Gunakan pelayan proksi untuk LAN anda".</translation>
<translation id="2441066927880955410">Anda sedang melihat halaman Ecosia yang selamat</translation>
<translation id="8187289872471304532">Pergi ke
          Apikasi &gt; Pilihan Sistem &gt; Rangkaian &gt; Terperinci &gt; Proksi
          dan nyahpilih mana-mana proksi yang telah dipilih.</translation>
