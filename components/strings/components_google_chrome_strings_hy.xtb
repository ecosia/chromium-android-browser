<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="hy">
<translation id="1864711229671391928">Ecosia-ը ճիշտ չի փակվել:</translation>
<translation id="130631256467250065">Ձեր փոփոխություններն ուժի մեջ կմտնեն հաջորդ անգամ, երբ վերագործարկեք սարքը:</translation>
<translation id="1722634673917783018">Ձեր փոփոխություններն ուժի մեջ կմտնեն հաջորդ անգամ Ecosia-ը գործարկելիս։</translation>
<translation id="7347361780317841252">Ecosia-ը ստեղծվել է <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> նախագծի և այլ <ph name="BEGIN_LINK_OSS"/>բաց կոդով ծրագրակազմերի<ph name="END_LINK_OSS"/> հիման վրա։</translation>
<translation id="5104341700462991189">Ecosia-ի պատկերանշան</translation>
<translation id="3444832043240812445">Այս էջը ցույց կտա միայն վերջին խափանումների մասին տեղեկությունները, եթե <ph name="BEGIN_LINK"/>միացնեք խափանման հաշվետվությունների ուղարկումը<ph name="END_LINK"/>:</translation>
<translation id="583128902627777075">Հրապատի կամ հակավիրուսային ծրագրի կարգավորումներում
       թույլատրեք Ecosia-ին միանալ ցանցին:</translation>
<translation id="5177147493498374715">Այս էջն արգելափակվել է Ecosia-ի կողմից</translation>
<translation id="3913860536599484838">Անցեք
          Ecosia-ի ընտրացանկ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          և համոզվեք, որ նշված է «առանց պրոքսի-սերվերի» կամ «անմիջական» կարգավուոմը:</translation>
<translation id="8143058600367874039">Անցեք
          Ecosia ընտրացանկ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          և ապանշեք «<ph name="NO_PREFETCH_DESCRIPTION"/>»-ը:
          Եթե խնդիրը չվերանա, խորհուրդ ենք տալիս կրկին ընտրել այս տարբերակը՝
          արդյունավետությունը բարձրացնելու համար:</translation>
<translation id="6276216569125239216">Անցեք
          Ecosia-ի ընտրացանկ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN-ի կարգավորումներ
          և ապանշեք «Օգտագործել պրոքսի սերվեր LAN-ի համար»:</translation>
<translation id="2441066927880955410">Դուք դիտում եք Ecosia-ի անվտանգ էջ</translation>
<translation id="8187289872471304532">Անցեք
          Applications &gt; System Preferences &gt; Network &gt; Advanced &gt; Proxies
          և ապընտեք բոլոր ընտրված պրոքսի-սերվերները:</translation>
</translationbundle>
