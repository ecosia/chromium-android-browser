<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="sq">
<translation id="130631256467250065">Ndryshimet e tua do të hyjnë në fuqi herën tjetër kur të rinisësh pajisjen.</translation>
<translation id="2955914891289756427">Raportimi i ndërprerjes aksidentale nuk ofrohet në Ecosia.</translation>
<translation id="2441066927880955410">Po shikon një faqe të sigurt të Ecosia</translation>
<translation id="5104341700462991189">Logoja e Ecosia</translation>
<translation id="7347361780317841252">Ecosia është bërë i mundur nga projekti me burim të hapur <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> dhe <ph name="BEGIN_LINK_OSS"/>softuerë të tjerë me burim të hapur<ph name="END_LINK_OSS"/>.</translation>
<translation id="8920794075861916959">Shko te
          menyja e Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Cilësimet e rrjetit LAN
          dhe anulo zgjedhjen e kutisë së kontrollit "Përdor një server përfaqësues për rrjetin LAN".</translation>
<translation id="5177147493498374715">Kjo faqe është bllokuar nga Ecosia</translation>
<translation id="583128902627777075">Lejo Ecosia të qaset në rrjet, në cilësimet e murit mbrojtës ose
      të antivirusit.</translation>
<translation id="3913860536599484838">Shko te
          menyja e Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          dhe sigurohu që konfigurimi yt të jetë i caktuar në "pa përfaqësues" ose "direkt".</translation>
<translation id="1722634673917783018">Ndryshimet e tua do të hyjnë në fuqi herën tjetër kur të rinisësh Ecosia.</translation>
<translation id="8143058600367874039">Shko te
          menyja e Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          dhe anulo zgjedhjen e "<ph name="NO_PREFETCH_DESCRIPTION"/>."
          Nëse kjo nuk e zgjidh këtë problem, rekomandojmë ta zgjedhësh përsëri këtë opsion
          për një veprimtari më të mirë funksionimi.</translation>
<translation id="8187289872471304532">Shko te Aplikacionet &gt; Preferencat e sistemit &gt; Rrjeti &gt; Të përparuara &gt; Përfaqësuesit dhe anulo zgjedhjen për çdo përfaqësues që është zgjedhur.</translation>
<translation id="1864711229671391928">Ecosia nuk u mbyll si duhet.</translation>
</translationbundle>
