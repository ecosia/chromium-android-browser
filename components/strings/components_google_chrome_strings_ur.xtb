<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="ur">
<translation id="1864711229671391928">‏Ecosia صحیح سے بند نہیں ہوا ہے۔</translation>
<translation id="130631256467250065">اپنا آلہ اگلی بار دوبارہ شروع کرنے پر آپ کی تبدیلیاں مؤثر ہوں گی۔</translation>
<translation id="1722634673917783018">‏اگلی بار جب آپ Ecosia بند کرکے دوبارہ شروع کریں گے تو آپ کی تبدیلیاں نافذ ہوں گی۔</translation>
<translation id="7347361780317841252">‏Ecosia کو <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> اوپن سورس پروجیکٹ اور دیگر <ph name="BEGIN_LINK_OSS"/>اوپن سورس سافٹ ویئر<ph name="END_LINK_OSS"/> کے ذریعے ممکن بنایا گیا ہے۔</translation>
<translation id="5104341700462991189">‏Ecosia کا لوگو</translation>
<translation id="3444832043240812445">اگر آپ <ph name="BEGIN_LINK"/>کریش کی اطلاع دہندگی فعال کرتے ہیں<ph name="END_LINK"/> تو یہ صفحہ صرف آپ کے حالیہ کریشز کی بابت معلومات کو دکھاتا ہے۔</translation>
<translation id="583128902627777075">‏Ecosia کو اپنے فائروال یا اینٹی وائرس کی
          ترتیبات میں نیٹ ورک تک رسائی حاصل کرنے کی اجازت دیں۔</translation>
<translation id="5177147493498374715">‏اس صفحے کو Ecosia نے مسدود کر دیا ہے</translation>
<translation id="3913860536599484838">‏Ecosia مینو &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          پر جائیں اور یقینی بنائیں کہ آپ کی کنفیگریشن "کوئی پراکسی نہیں" یا "ڈائریکٹ" پر سیٹ ہے۔</translation>
<translation id="8143058600367874039">‏Ecosia مینو &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          پر جائیں اور "<ph name="NO_PREFETCH_DESCRIPTION"/>" کو غیر منتخب کریں۔
          اگر اس سے مسئلہ حل نہیں ہوتا ہے تو ہم بہتر کارکردگی کیلئے یہ اختیار دوبارہ منتخب کرنے
          کی تجویز کرتے ہیں۔</translation>
<translation id="6276216569125239216">‏Ecosia مینو &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN ترتیبات
          پر جائیں
          اور "اپنے LAN کیلئے ایک پراکسی سرور استعمال کریں" کو غیر منتخب کریں۔</translation>
<translation id="2441066927880955410">‏آپ ایک محفوظ Ecosia صفحہ دیکھ رہے ہیں</translation>
<translation id="8187289872471304532">ایپلیکیشنز &gt; سسٹم کی ترجیحات &gt; نیٹ ورک &gt; جدید ترین &gt; پراکسیز پر جائیں
          اور منتخب کردہ کسی بھی پراکسی کو غیر منتخب کریں۔</translation>
</translationbundle>
