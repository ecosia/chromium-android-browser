<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="ne">
<translation id="1864711229671391928">क्रोम सही तवरले बन्द भएन।</translation>
<translation id="130631256467250065">तपाईंले अर्को पटक तपाईंको यन्त्रलाई पुन: सुरु गर्दा तपाईंका परिवर्तनहरू प्रभावकारी हुनेछन्।</translation>
<translation id="1722634673917783018">तपाईंले अर्को पटक Ecosia खोल्दा तपाईंले गर्नुभएका परिवर्तनहरू लागू हुने छन्।</translation>
<translation id="7347361780317841252"><ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> खुला स्रोतको परियोजना र अन्य <ph name="BEGIN_LINK_OSS"/>खुला स्रोतको सफ्टवेयर<ph name="END_LINK_OSS"/> प्रयोग गरी Ecosia निर्माण गरिएको हो।</translation>
<translation id="5104341700462991189">Ecosia चिन्ह</translation>
<translation id="3444832043240812445">यदि तपाइँले <ph name="BEGIN_LINK"/>क्रयास प्रतिवेदन सक्षम<ph name="END_LINK"/> गर्नुभयो बने यस पृष्ठले तपाइँका भर्खरैका क्रयासहरूमा जानकारी देखाउँछ।</translation>
<translation id="583128902627777075">Ecosia लाई आफ्नो फायरवाल वा एन्टिभाइरसका सेटिङहरूमा
          नेटवर्कमा पहुँच गर्ने अनुमति दिनुहोस्।</translation>
<translation id="5177147493498374715">Ecosia ले यो पेज ब्लक गरेको छ</translation>
<translation id="3913860536599484838">Ecosia मेनु &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          मा जानुहोस् र तपाईंको कन्फिगरेसनलाई "प्रोक्सी हुँदैन" वा "प्रत्यक्ष" मा सेट गरिएको छ भनि सुनिश्चित गर्नुहोस्।</translation>
<translation id="8143058600367874039">जानुहोस्
         क्रोम मेनु &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          र अचयन गर्नुहोस् "<ph name="NO_PREFETCH_DESCRIPTION"/>."
          यदि यसले मुद्दाको समाधान गर्दैन भने हामी सिफारिस गर्दछौं कि सुधारिएको कार्य सम्पादनका लागि तपाईं फेरि यस विकल्पलाई चयन गर्नुहोस्।</translation>
<translation id="6276216569125239216">Ecosia मेनु &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN सेटिङहरूमा जानुहोस्
          र "तपाईंको LAN को लागि एउटा प्रोक्सी सर्भर प्रयोग गर्नुहोस्" को चयन हटाउनुहोस्।</translation>
<translation id="2441066927880955410">तपाईं सुरक्षित Ecosia पेज हेर्दै हुनुहुन्छ</translation>
<translation id="8187289872471304532">यसमा जानुहोस्
          एपहरू &gt; प्रणाली प्राथमिकताहरू &gt; सञ्जाल &gt; उन्नत &gt; प्रोक्सीहरू
          र तपाइँले चयन गर्नुका कुनै पनि प्रोक्सीहरूको चयन हटाउनुहोस्।</translation>
</translationbundle>
