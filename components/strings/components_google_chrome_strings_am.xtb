<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="am">
<translation id="1864711229671391928">Ecosia በትክክል አልተዘጋም ነበር።</translation>
<translation id="130631256467250065">ለውጦችዎ መሣሪያዎን ዳግም በሚያስጀምሩበት ቀጣዩ ጊዜ ላይ ይተገበራሉ።</translation>
<translation id="4062366803229254216">Ecosia ማጣመርን ለመቀጠል የብሉቱዝ መዳረሻ ያስፈልገዋል። <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="1722634673917783018">ለውጦችዎ Ecosia ዳግም በሚያስጀምሩበት ቀጣዩ ጊዜ ላይ ይተገበራሉ።</translation>
<translation id="1566733708869146127">Ecosia የመክፈያ ዘዴዎችን ለማርትዕ እየሞከረ ነው።</translation>
<translation id="7347361780317841252">Ecosia በ<ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ክፍት ምንጭ ፕሮጀክት እና በሌላ <ph name="BEGIN_LINK_OSS"/>ክፍት ምንጭ ሶፍትዌር<ph name="END_LINK_OSS"/> ሊሰራ ችሏል።</translation>
<translation id="5104341700462991189">የEcosia ዓርማ</translation>
<translation id="3444832043240812445">ይህ ገፅ <ph name="BEGIN_LINK"/>የብልሽት ሪፖርት ማድረግ<ph name="END_LINK"/>ን ካነቁ የቅርብ ጊዜ ብልሽቶችዎን ብቻ ነው መረጃ የሚያሳየው።</translation>
<translation id="583128902627777075">Ecosia በኬላ ወይም የጸረ-ቫይረስ ቅንብሮችዎን ውስጥ አውታረ መረቡን እንዲደርስበት
        ይፍቀዱለት።</translation>
<translation id="5177147493498374715">ይህ ገፅ በEcosia ታግዷል</translation>
<translation id="3913860536599484838">ወደ
          የEcosia ምናሌ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
         ይሂዱና ውቅርዎ ወደ «ምንም ተኪ» ወይም «ቀጥታ» መዋቀሩን ያረጋግጡ።</translation>
<translation id="8143058600367874039">ወደ
       የEcosia ምናሌ &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        ይሂዱና «<ph name="NO_PREFETCH_DESCRIPTION"/>»ን አይምረጡ።
        ይሄ ችግሩን ካልፈታው ለተሻሻለ አፈጻጸም ይህን አማራጭ እንደገና መምረጥ እንመክራለን።</translation>
<translation id="6276216569125239216">Go to
          የEcosia ምናሌ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          የላን ቅንብሮች
          ይሂዱና «ለእርስዎ ላን ተኪ አገልጋይ ይጠቀሙ»ን አይምረጡ።</translation>
<translation id="2441066927880955410">ደህንነቱ የተጠበቀ የEcosia ገፅ እየተመለከቱ ነው</translation>
<translation id="8187289872471304532">ወደ
          መተግበሪያዎች &gt; የስርዓት ምርጫዎች &gt; አውታረ መረብ &gt; የላቁ &gt; ተኪዎች
          ይሂዱና የተመረጡ ማናቸውም ተኪዎችን አይምረጡ።</translation>
<translation id="7273712334661186152">Ecosia በ<ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ክፍት ምንጭ ፕሮጀክት እንዲሆን ተደርጓል።</translation>
<translation id="6182615032232999551">እንዲሁም Ecosia በሌላ <ph name="BEGIN_LINK_OSS"/>ክፍት ምንጭ ሶፍትዌር<ph name="END_LINK_OSS"/> እንዲሆን ተደርጓል።</translation>
<translation id="7085497353580337354">Ecosia የመክፈያ ዘዴዎችን ለመሙላት ቅንብሮችን ለማሻሻል እየሞከረ ነው።</translation>
</translationbundle>
