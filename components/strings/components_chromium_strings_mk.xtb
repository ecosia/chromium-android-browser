<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="mk">
<translation id="130631256467250065">Вашите промени ќе стапат на сила следниот пат кога ќе го рестартирате уредот.</translation>
<translation id="2955914891289756427">Не е достапно пријавување падови на Ecosia.</translation>
<translation id="2441066927880955410">Гледате безбедна страница на Ecosia</translation>
<translation id="5104341700462991189">Лого на Ecosia</translation>
<translation id="7347361780317841252">Ecosia е овозможен од проектот со отворен код <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> и друг <ph name="BEGIN_LINK_OSS"/>софтвер со отворен код<ph name="END_LINK_OSS"/>.</translation>
<translation id="8920794075861916959">Одете во
          менито на Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Поставки за LAN
          и поништете го изборот на полето „Употребете прокси-сервер за LAN“.</translation>
<translation id="5177147493498374715">Страницава е блокирана од Ecosia</translation>
<translation id="583128902627777075">Дозволете Ecosia да пристапи на мрежата во поставките за
        заштитен ѕид или антивирус.</translation>
<translation id="3913860536599484838">Одете на
          менито на Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          и погрижете се конфигурацијата да ви е поставена на „нема прокси“ или „директно“.</translation>
<translation id="1722634673917783018">Промените ќе стапат на сила следниот пат кога ќе го стартувате Ecosia повторно.</translation>
<translation id="8143058600367874039">Одете во
          менито на Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          и поништете го изборот на „<ph name="NO_PREFETCH_DESCRIPTION"/>“.
          Доколку со ова не се реши проблемот, препорачуваме повторно да ја изберете опцијата
          за подобра изведба.</translation>
<translation id="8187289872471304532">Отидете на
          Апликации &gt; Претпочитани вредности на системот &gt; Мрежа &gt; Напредно &gt; Проксија
           а потоа поништете го изборот на проксијата што сте ги избрале.</translation>
<translation id="1864711229671391928">Ecosia не се исклучи правилно.</translation>
</translationbundle>
