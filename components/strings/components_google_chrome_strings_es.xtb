<!DOCTYPE translationbundle>
<translationbundle lang="es">
<translation id="1864711229671391928">Ecosia no se ha cerrado correctamente.</translation>
<translation id="130631256467250065">Los cambios se aplicarán la próxima vez que reinicies el dispositivo.</translation>
<translation id="4062366803229254216">Ecosia necesita acceso al Bluetooth para continuar 
 con la vinculación. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="1722634673917783018">Los cambios se aplicarán la próxima vez que reinicies Ecosia.</translation>
<translation id="1566733708869146127">Ecosia está intentando editar los métodos de pago.</translation>
<translation id="7347361780317841252">Ecosia se ha creado gracias al proyecto de software libre <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> y a otro <ph name="BEGIN_LINK_OSS"/>software libre<ph name="END_LINK_OSS"/>.</translation>
<translation id="5104341700462991189">Logotipo de Ecosia</translation>
<translation id="3444832043240812445">Esta página solo muestra información sobre fallos recientes si se <ph name="BEGIN_LINK"/>habilitan los informes sobre fallos<ph name="END_LINK"/>.</translation>
<translation id="583128902627777075">Configura tu cortafuegos o tu antivirus para permitir el acceso de Ecosia
          a la red.</translation>
<translation id="5177147493498374715">Ecosia ha bloqueado esta página</translation>
<translation id="3913860536599484838">Accede al
          menú de Ecosia, haz clic en
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          y asegúrate de que esté seleccionada la opción de configuración sin proxy o directa.</translation>
<translation id="8143058600367874039">Accede al
          menú de Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          y desactiva la opción "<ph name="NO_PREFETCH_DESCRIPTION"/>".
          Si esto no soluciona el problema, te recomendamos que vuelvas a seleccionar esta opción
          para conseguir un mejor rendimiento.</translation>
<translation id="6276216569125239216">Accede al
          menú de Ecosia, haz clic en
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Configuración de LAN
          y desactiva la opción Usar un servidor proxy para la LAN.</translation>
<translation id="2441066927880955410">Estás viendo una página de Ecosia segura</translation>
<translation id="8187289872471304532">Accede a
          Aplicaciones &gt; Preferencias del Sistema &gt; Red &gt; Configuración avanzada &gt; Proxies
          y desactiva las casillas de verificación de los proxies seleccionados.</translation>
<translation id="7273712334661186152">Ecosia se ha podido crear gracias al proyecto de software libre <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/>.</translation>
<translation id="6182615032232999551">Ecosia también se ha podido crear gracias a otro <ph name="BEGIN_LINK_OSS"/>software libre<ph name="END_LINK_OSS"/>.</translation>
<translation id="7085497353580337354">Ecosia está intentando modificar la configuración para completar los métodos de pago.</translation>
</translationbundle>
