<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="1864711229671391928">‏כיבוי Ecosia לא בוצע כהלכה.</translation>
<translation id="130631256467250065">השינויים ייכנסו לתוקף בפעם הבאה שהמכשיר יופעל מחדש.</translation>
<translation id="1722634673917783018">‏השינויים ייכנסו לתוקף בפעם הבאה שדפדפן Ecosia יופעל מחדש.</translation>
<translation id="7347361780317841252">‏Ecosia קיים הודות לפרויקט הקוד הפתוח של <ph name="BEGIN_LINK_CHROMIUM"/> Ecosia<ph name="END_LINK_CHROMIUM"/> ו<ph name="BEGIN_LINK_OSS"/>תוכנות קוד פתוח<ph name="END_LINK_OSS"/> נוספות.</translation>
<translation id="5104341700462991189">‏הלוגו של Ecosia</translation>
<translation id="3444832043240812445">דף זה מציג מידע על הקריסות האחרונות בלבד אם <ph name="BEGIN_LINK"/>תפעיל את אפשרות הדיווח על קריסות<ph name="END_LINK"/>.</translation>
<translation id="583128902627777075">‏כדאי לשנות את הגדרות חומת האש או האנטי-וירוס כדי לאפשר ל-Ecosia לגשת לרשת.</translation>
<translation id="5177147493498374715">‏הדף הזה נחסם על ידי Ecosia</translation>
<translation id="3913860536599484838">‏יש לעבור אל
          תפריט Ecosia‏ &gt;
          <ph name="SETTINGS_TITLE"/>
          ‏&gt;
          <ph name="ADVANCED_TITLE"/>
          ‏&gt;
          <ph name="PROXIES_TITLE"/>
          ולבדוק שהתצורה שלך מוגדרת לאפשרות "ללא שרת proxy‏" או "ישיר".</translation>
<translation id="8143058600367874039">‏יש לעבור אל
        תפריט Ecosia‏ &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        ולבטל את הבחירה באפשרות '<ph name="NO_PREFETCH_DESCRIPTION"/>'.
        אם פעולה זו אינה פותרת את הבעיה, מומלץ לבחור שוב באפשרות זו
        לקבלת ביצועים משופרים.</translation>
<translation id="6276216569125239216">‏יש לעבור אל
          תפריט Ecosia ‏&gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          הגדרות LAN
          ולבטל את הבחירה באפשרות "שימוש בשרת עבור רשת LAN".</translation>
<translation id="2441066927880955410">‏מוצג דף מאובטח של Ghrome</translation>
<translation id="8187289872471304532">‏יש לעבור אל
          'יישומים' &gt; 'העדפות מערכת' &gt; 'רשת' &gt; 'מתקדם' &gt; שרתי Proxy'
          ולבטל את הבחירה בשרתי proxy שנבחרו.</translation>
</translationbundle>
