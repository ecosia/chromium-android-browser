<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="uz">
<translation id="1864711229671391928">Ecosia brauzerining ishi noto‘g‘ri tugatilgan.</translation>
<translation id="130631256467250065">O‘zgartirishlar qurimla qaytadan ishga tushirilganda kuchga kiradi.</translation>
<translation id="1722634673917783018">Oʻzgartirishlar Ecosia qaytadan ishga tushirilganda kuchga kiradi.</translation>
<translation id="7347361780317841252">Ecosia paydo boʻlishida <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ochiq kodli loyihasi va boshqa <ph name="BEGIN_LINK_OSS"/>ochiq kodli dasturiy taʼminotlarning<ph name="END_LINK_OSS"/> katta oʻrni bor.</translation>
<translation id="5104341700462991189">Ecosia logotipi</translation>
<translation id="3444832043240812445">Yaqinda yuz bergan ishdan chiqishlar haqidagi ma’lumotlar bu sahifada faqatgina <ph name="BEGIN_LINK"/>ishdan chiqishlar hisoboti funksiyasi yoniq bo‘lganda<ph name="END_LINK"/> ko‘rsatiladi.</translation>
<translation id="583128902627777075">Himoya devori yoki antivirus dasturi sozlamalari orqali Ecosia brauzeriga tarmoqqa ulanishiga ruxsat bering</translation>
<translation id="5177147493498374715">Bu sahifa Ecosia tomonidan bloklandi</translation>
<translation id="3913860536599484838">Bu yerga o‘ting:
          Ecosia menyusi &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          va “proksi-serversiz” yoki “to‘g‘ridan-to‘g‘ri” sozlamalaridan biri
          belgilanganligiga ishonch hosil qiling.</translation>
<translation id="8143058600367874039">Ecosia menyusini ochib, “<ph name="SETTINGS_TITLE"/>” &gt; “<ph name="ADVANCED_TITLE"/>” bandlarini tanlang va “<ph name="NO_PREFETCH_DESCRIPTION"/>” parametrini o‘chirib qo‘ying. Agar muammo qaytarilsa sahifalar tezroq yuklanishi uchun parametrni yana yoqib qo‘ying.</translation>
<translation id="6276216569125239216">Ecosia menyusini
tanlang &gt;
<ph name="SETTINGS_TITLE"/>
&gt;
<ph name="ADVANCED_TITLE"/>
&gt;
<ph name="PROXIES_TITLE"/>
LAN sozlamalariga kirib,
“LAN uchun proksi-serverdan foydalanish” bandidan belgini olib tashlang.</translation>
<translation id="2441066927880955410">Xavfsiz Ecosia sahifasini koʻrmoqdasiz.</translation>
<translation id="8187289872471304532">Bu yerga o‘ting
          Dasturlar &gt; Tizim sozlamalari &gt; Tarmoq &gt; Qo‘shimcha &gt; Proksi
          va barcha proksi-serverlardan bayroqchalarni yechib qo‘ying.</translation>
</translationbundle>
