<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="bs">
<translation id="130631256467250065">Vaše promjene će stupiti na snagu kada sljedeći put ponovo pokrenete uređaj.</translation>
<translation id="2955914891289756427">Izrada izvještaja o padovima aplikacije nije dostupna na Ecosiau.</translation>
<translation id="2441066927880955410">Prikazana vam je sigurna stranica Ecosiaa</translation>
<translation id="5104341700462991189">Logotip Ecosiaa</translation>
<translation id="7347361780317841252">Ecosia je dostupan zahvaljujući <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> projektu otvorenog koda i drugom <ph name="BEGIN_LINK_OSS"/>softveru otvorenog koda<ph name="END_LINK_OSS"/>.</translation>
<translation id="8920794075861916959">Idite na
          Ecosia meni &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN postavke
          i poništite odabir u polju za potvrdu "Koristi proksi server za svoj LAN".</translation>
<translation id="5177147493498374715">Ovu stranicu je blokirao Ecosia</translation>
<translation id="583128902627777075">U postavkama zaštitnog zida ili antivirusnog programa dozvolite Ecosiau da pristupi
          mreži.</translation>
<translation id="3913860536599484838">Idite u
          meni Ecosiaa&gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          i provjerite je li vaša konfiguracija postavljena na "bez proksi servera" ili "direktno".</translation>
<translation id="1722634673917783018">Vaše promjene će stupiti na snagu kada sljedeći put budete ponovo pokrenuli Ecosia.</translation>
<translation id="8143058600367874039">Idite na
          meni u Ecosiau &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          i poništite odabir za "<ph name="NO_PREFETCH_DESCRIPTION"/>."
          Ako ovo ne riješi problem, preporučujemo vam da ponovo odaberete
          ovu opcija za unapređenje performansi.</translation>
<translation id="8187289872471304532">Idite na
          Aplikacije &gt; Postavke sistema &gt; Mreža &gt; Napredno &gt; Proksiji
          i poništite odabir svih odabranih proksija.</translation>
<translation id="1864711229671391928">Ecosia se nije ispravno zatvorio.</translation>
</translationbundle>
