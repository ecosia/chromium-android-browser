<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="et">
<translation id="130631256467250065">Muudatused jõustuvad järgmine kord, kui seadme taaskäivitate.</translation>
<translation id="2955914891289756427">Krahhiaruandlus ei ole Ecosiais saadaval.</translation>
<translation id="2441066927880955410">Vaatate turvalist Ecosiai lehte</translation>
<translation id="5104341700462991189">Ecosiai logo</translation>
<translation id="7347361780317841252">Ecosiai aluseks on avatud lähtekoodiga projekt <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ja muu <ph name="BEGIN_LINK_OSS"/>avatud lähtekoodiga tarkvara<ph name="END_LINK_OSS"/>.</translation>
<translation id="8920794075861916959">Valige
          Ecosiai menüü &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN-seaded
          ja tühjendage ruut valiku „Kasutage LAN-i puhul puhverserverit” juures.</translation>
<translation id="5177147493498374715">Ecosia blokeeris selle lehe</translation>
<translation id="583128902627777075">Lubage Ecosiai juurdepääs võrgule tulemüüri või viirusetõrje
         seadetes.</translation>
<translation id="3913860536599484838">Minge
          Ecosiai menüüsse &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          ja veenduge, et konfiguratsioon on määratud valikule „Puhverserverita” või „Otse”.</translation>
<translation id="1722634673917783018">Teie muudatused jõustuvad järgmine kord, kui Ecosiai taaskäivitate.</translation>
<translation id="8143058600367874039">Avage
        Ecosiai menüü &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        ja tühistage valik „<ph name="NO_PREFETCH_DESCRIPTION"/>”.
        Kui see probleemi ei lahenda, soovitame selle valiku
        toimivuse parandamiseks uuesti teha.</translation>
<translation id="8187289872471304532">Tehke valikud
          Rakendused &gt; Süsteemieelised &gt; Võrk &gt; Täpsem &gt; Puhverserverid
          ja tühjendage kõigi valitud puhverserverite märkeruudud.</translation>
<translation id="1864711229671391928">Ecosia ei sulgunud õigesti.</translation>
</translationbundle>
