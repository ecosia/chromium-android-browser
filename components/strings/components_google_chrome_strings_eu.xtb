<!DOCTYPE translationbundle>
<translationbundle lang="eu">
<translation id="1864711229671391928">Ecosia ez da behar bezala itxi.</translation>
<translation id="130631256467250065">Aldaketek gailua abiarazten duzun hurrengo aldian izango dute eragina.</translation>
<translation id="1722634673917783018">Aldaketek Ecosia abiarazten duzun hurrengo aldian izango dute eragina.</translation>
<translation id="7347361780317841252">Kode irekiko <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> proiektuak eta <ph name="BEGIN_LINK_OSS"/>kode irekiko beste software<ph name="END_LINK_OSS"/> batzuek egiten dute Ecosia posible.</translation>
<translation id="5104341700462991189">Ecosia logotipoa</translation>
<translation id="3444832043240812445">Orri honek azken hutsegiteei buruzko informazioa soilik bistaratzen du, <ph name="BEGIN_LINK"/>hutsegiteen berri ematea gaitzen baduzu<ph name="END_LINK"/>.</translation>
<translation id="583128902627777075">Ez eman suebakiaren edo birusen aurkako softwarearen ezarpenetan sarea erabiltzeko baimena Ecosia-ri.</translation>
<translation id="5177147493498374715">Ecosia-k blokeatu du orria</translation>
<translation id="3913860536599484838">Sakatu Ecosia-ko menua &gt; <ph name="SETTINGS_TITLE"/> &gt; <ph name="ADVANCED_TITLE"/> &gt; <ph name="PROXIES_TITLE"/> eta ziurtatu konfigurazioa "proxyrik ez" edo "zuzena" gisa ezarrita dagoela.</translation>
<translation id="8143058600367874039">Sakatu
          Ecosia-ko menua &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          eta desautatu "<ph name="NO_PREFETCH_DESCRIPTION"/>."
          Arazoa horrela konpontzen ez bada, aukera hori hautatzea gomendatzen dizugu errendimendua hobetzeko.</translation>
<translation id="6276216569125239216">Joan
          Ecosia-ko menua &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN ezarpenak atalera
          eta desautatu "Erabili proxy-zerbitzaria LAN konexiorako".</translation>
<translation id="2441066927880955410">Ecosia-ko orri seguru bat ari zara ikusten</translation>
<translation id="8187289872471304532">Zoaz
          Aplikazioak &gt; Sistemaren hobespenak &gt; Sarea &gt; Aurreratua &gt; Proxyak
          atalera eta desautatu hautatutako proxy guztiak.</translation>
