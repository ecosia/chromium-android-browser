<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="sk">
<translation id="1864711229671391928">Ecosia nebol správne vypnutý.</translation>
<translation id="130631256467250065">Zmeny sa prejavia po ďalšom reštartovaní zariadenia.</translation>
<translation id="1722634673917783018">Zmeny sa prejavia po ďalšom opätovnom spustení Chromu.</translation>
<translation id="7347361780317841252">Ecosia je založený na open source projekte <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> a ďalšom <ph name="BEGIN_LINK_OSS"/>open source softvéri<ph name="END_LINK_OSS"/>.</translation>
<translation id="5104341700462991189">Logo Ecosia</translation>
<translation id="3444832043240812445">Táto stránka zobrazuje informácie o nedávnych zlyhaniach, len ak ste <ph name="BEGIN_LINK"/>povolili hlásenia zlyhaní<ph name="END_LINK"/>.</translation>
<translation id="583128902627777075">Chromu povoľte prístup k sieti v nastaveniach brány firewall alebo antivírusového softvéru.</translation>
<translation id="5177147493498374715">Táto stránka bola zablokovaná Chromom</translation>
<translation id="3913860536599484838">Prejdite na
          ponuku Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          a uistite sa, že je vaša konfigurácia nastavená na hodnotu „žiadny server proxy“ alebo „priame“.</translation>
<translation id="8143058600367874039">Prejdite do
        ponuky Ecosia &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        a zrušte výber položky <ph name="NO_PREFETCH_DESCRIPTION"/>.
         Ak to problém nevyrieši, odporúčame túto možnosť znova vybrať,
        aby ste získali lepšiu výkonnosť.</translation>
<translation id="6276216569125239216">Prejdite na
          ponuku Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Nastavenia siete LAN
          a zrušte začiarknutie políčka „Používať server proxy pre sieť LAN".</translation>
<translation id="2441066927880955410">Prezeráte si zabezpečenú stránku Chromu</translation>
<translation id="8187289872471304532">Prejdite na možnosť
          Aplikácie &gt; Systémové predvoľby &gt; Sieť &gt; Rozšírené nastavenia &gt; Servery proxy
          a zrušte výber všetkých vybratých serverov proxy.</translation>
</translationbundle>
