<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="hi">
<translation id="1864711229671391928">Ecosia सही तरीके से बंद नहीं हुआ था.</translation>
<translation id="130631256467250065">अगली बार अपना डिवाइस फिर से शुरू करने पर आपके बदलाव लागू हो जाएंगे.</translation>
<translation id="1722634673917783018">अगली बार जब आप Ecosia को फिर से लॉन्च करेंगे, तो आपके बदलाव लागू होंगे.</translation>
<translation id="7347361780317841252">Ecosia को <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ओपन सोर्स प्रोजेक्ट और अन्य <ph name="BEGIN_LINK_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_OSS"/> ने संभव बनाया है.</translation>
<translation id="5104341700462991189">Ecosia लोगो</translation>
<translation id="3444832043240812445">अगर आप <ph name="BEGIN_LINK"/>क्रैश रिपोर्ट करना चालू<ph name="END_LINK"/> करते हैं तो यह पेज सिर्फ़ आपके हाल ही के क्रैश की जानकारी दिखाएगा.</translation>
<translation id="583128902627777075">Ecosia को अपनी फ़ायरवॉल और एंटीवायरस सेटिंग में
          नेटवर्क एक्सेस करने दें.</translation>
<translation id="5177147493498374715">इस पेज को Ecosia ने ब्लॉक कर दिया है</translation>
<translation id="3913860536599484838">यहां जाएं
          क्रोमियम मेन्यू &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          और पक्का करें कि आपका कॉन्फ़िगरेशन "कोई प्रॉक्सी नहीं" या "डायरेक्ट" पर सेट है.</translation>
<translation id="8143058600367874039">यहां जाएं
          क्रोमियम मेन्यू &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          और "<ph name="NO_PREFETCH_DESCRIPTION"/>" चुना हुआ हटाएं.
          अगर इससे समस्‍या हल नहीं होती, तो बेहतर प्रदर्शन के लिए हम इस विकल्‍प को फिर से चुनने का सुझाव देते हैं.</translation>
<translation id="6276216569125239216">यहां
          Ecosia मेन्यू &gt;
         <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN सेटिंग पर जाएं
          और "अपने LAN के लिए किसी प्रॉक्सी सर्वर का इस्तेमाल करें" चेकबॉक्स को चुने हुए से हटाएं.</translation>
<translation id="2441066927880955410">आप एक सुरक्षित Ecosia पेज देख रहे हैं</translation>
<translation id="8187289872471304532">यहां
          ऐप्लिकेशन  &gt; सिस्टम प्राथमिकताएं &gt; नेटवर्क &gt; बेहतर &gt; प्रॉक्सी
          पर जाएं और चुनी गई प्रॉक्सी को न चुनें.</translation>
</translationbundle>
