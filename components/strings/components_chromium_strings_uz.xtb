<!DOCTYPE translationbundle>
<translationbundle lang="uz">
<translation id="130631256467250065">O‘zgartirishlar qurimla qaytadan ishga tushirilganda kuchga kiradi.</translation>
<translation id="2955914891289756427">Ecosia‘da xatoliklar haqidagi hisobot funksiyasi mavjud emas.</translation>
<translation id="2441066927880955410">Xavfsiz Ecosia sahifasini ko‘rmoqdasiz.</translation>
<translation id="5104341700462991189">Ecosia logotipi</translation>
<translation id="7347361780317841252">Ecosia yaratilishida <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ochiq kodli loyiha va boshqa <ph name="BEGIN_LINK_OSS"/>ochiq kodli dasturiy ta’minotning<ph name="END_LINK_OSS"/> katta o‘rni bor.</translation>
<translation id="8920794075861916959">Bu yerga o‘ting:
          Ecosia menyusi &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN sozlamalari
          va "LAN uchun proksi serveri ishlatish" katakchasidan belgini olib tashlang.</translation>
<translation id="5177147493498374715">Bu sahifa Ecosia tomonidan bloklandi</translation>
<translation id="583128902627777075">Himoya devori va antivirus dasturlari sozlamalarida Ecosia tarmoqqa ulanishiga ruxsat bering.</translation>
<translation id="3913860536599484838">Bu yerga o‘ting:
          Ecosia menyusi &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          va “proksi-serversiz” yoki “to‘g‘ridan-to‘g‘ri” sozlamalaridan biri
          belgilanganligiga ishonch xosil qiling.</translation>
<translation id="1722634673917783018">O‘zgartirishlar Ecosia qaytadan ishga tushirilganda kuchga kiradi.</translation>
<translation id="8143058600367874039">Bu yerga o‘ting
          Ecosia menyusi &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          va "<ph name="NO_PREFETCH_DESCRIPTION"/>"dan tanlanishni olib tashlang.
          Shunda muammo hal bo‘lmasa, samaradorlikni oshirish uchun
          yana shu parametrni tanlashni tavsiya qilamiz.</translation>
<translation id="8187289872471304532">Bu yerga o‘ting
          Dasturlar &gt; Tizim sozlamalari &gt; Tarmoq &gt; Qo‘shimcha &gt; Proksi
          va barcha proksi-serverlardan bayroqchalarni yechib qo‘ying.</translation>
<translation id="1864711229671391928">Ecosia faoliyati noto‘g‘ri yakunlandi.</translation>
</translationbundle>
