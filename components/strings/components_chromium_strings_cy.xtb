<!DOCTYPE translationbundle>
<translationbundle lang="cy">
<translation id="130631256467250065">Bydd eich newidiadau yn dod i rym y tro nesaf y byddwch yn ailgychwyn eich dyfais.</translation>
<translation id="2955914891289756427">Nid yw adrodd am doriadau ar gael yn Ecosia.</translation>
<translation id="2441066927880955410">Rydych yn edrych ar dudalen Ecosia ddiogel</translation>
<translation id="5104341700462991189">Logo Ecosia</translation>
<translation id="7347361780317841252">Mae Ecosia yn bosib oherwydd prosiect ffynhonnell agored <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> a <ph name="BEGIN_LINK_OSS"/>meddalwedd ffynhonnell agored<ph name="END_LINK_OSS"/> eraill.</translation>
<translation id="8920794075861916959">Ewch i
          ddewislen Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Gosodiadau LAN
          a dad-diciwch y blwch ticio "Defnyddio dirprwy weinydd ar gyfer eich LAN".</translation>
<translation id="5177147493498374715">Mae'r dudalen hon wedi'i rhwystro gan Ecosia</translation>
<translation id="583128902627777075">Caniatewch i Ecosia gael mynediad at y rhwydwaith yn eich gosodiadau wal dân neu 
         wrthfeirysau.</translation>
<translation id="3913860536599484838">Ewch i
          ddewislen Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          a gwnewch yn siŵr bod eich ffurfweddiad wedi'i osod i "dim dirprwy weinydd" neu i "uniongyrchol."</translation>
<translation id="1722634673917783018">Bydd eich newidiadau yn dod i rym y tro nesaf y byddwch yn ail-lansio Ecosia.</translation>
<translation id="8143058600367874039">Ewch i
          ddewislen Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          a dad-ddewiswch "<ph name="NO_PREFETCH_DESCRIPTION"/>."
          Os na fydd hyn yn datrys y broblem, rydym yn argymell dewis yr opsiwn hwn
          eto ar gyfer perfformiad gwell.</translation>
<translation id="8187289872471304532">Ewch i
          Rhaglenni &gt; Dewisiadau System &gt; Rhwydwaith &gt; Uwch &gt; Dirprwy Weinyddion
          a dad-diciwch unrhyw ddirprwy weinyddion sydd wedi'u ticio.</translation>
<translation id="1864711229671391928">Ni wnaeth Ecosia gau'n gywir.</translation>
</translationbundle>
