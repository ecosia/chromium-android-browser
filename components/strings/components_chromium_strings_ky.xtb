<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="ky">
<translation id="130631256467250065">Өзгөртүүлөрүңүз түзмөгүңүз өчүп күйгөндөн кийин күчүнө кирет.</translation>
<translation id="2955914891289756427">Ecosia'да каталар жөнүндө кабар берүү мүмкүн эмес.</translation>
<translation id="2441066927880955410">Коопсуз Ecosia баракчасын карап жатасыз</translation>
<translation id="7085497353580337354">Ecosia төлөм ыкмаларын толтуруу параметрлерин өзгөртүүгө аракет кылууда.</translation>
<translation id="5104341700462991189">Ecosia логотиби</translation>
<translation id="1566733708869146127">Ecosia төлөм ыкмаларын түзөтүүгө аракет кылууда.</translation>
<translation id="7347361780317841252">Ecosia <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ачык булак долбоору жана башка <ph name="BEGIN_LINK_OSS"/>ачык программа<ph name="END_LINK_OSS"/> аркылуу мүмкүн болду.</translation>
<translation id="8920794075861916959">Төмөнкүгө өтүп, 
          Ecosia меню &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN параметрлери
          жана "LAN үчүн прокси сервер колдонулсун" белгиленме кутусун тандоодон чыгарыңыз.</translation>
<translation id="5177147493498374715">Бул баракты Ecosia бөгөттөп койду</translation>
<translation id="583128902627777075">Ecosia'га коргоо системасында тармакка же антивирус параметрлерине кирүүгө уруксат
          бериңиз.</translation>
<translation id="3913860536599484838">Төмөнкүгө өтүп:
          Ecosia менюсу &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          "прокси жок" же "түздөн-түз" деген жөндөөлөр коюлгандыгын текшериңиз.</translation>
<translation id="6182615032232999551">Ecosia башка <ph name="BEGIN_LINK_OSS"/>ачык ресурс программасы<ph name="END_LINK_OSS"/> аркылуу да жеткиликтүү.</translation>
<translation id="1722634673917783018">Өзгөртүүлөрүңүз Ecosia кийинки жолу кайра ишке киргизилгенде күчүнө кирет.</translation>
<translation id="4062366803229254216">Жупташтырууну улантуу үчүн Ecosia Bluetooth'ду 
 пайдаланууга уруксат алышы керек. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="7273712334661186152">Ecosia <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ачык ресурс долбоору аркылуу түзүлдү.</translation>
<translation id="8143058600367874039">Ecosia меню &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        өтүп, "<ph name="NO_PREFETCH_DESCRIPTION"/>" дегенди тандоодон чыгарыңыз.
        Эгер ушуну менен маселе чечилбесе, иштин майнаптуулугун жогорулатуу үчүн бул параметрди  
        кайра тандаңыз.</translation>
<translation id="8187289872471304532">Төмөнкүгө өтүңүз
          Колдонмолор &gt; Системанын параметрлери &gt; Тармак &gt; Өркүндөтүлгөн &gt; Проксилер
          жана тандалган бардык проксилерди тандоодон чыгарыңыз.</translation>
<translation id="8393444759658439191">Коопсуз Ecosia for Testing баракчасын карап жатасыз</translation>
<translation id="1864711229671391928">Ecosia туура эмес жабылып калды.</translation>
</translationbundle>
