<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="my">
<translation id="1864711229671391928">Ecosia သည် မှန်ကန်စွာ ပိတ်မသွားခဲ့ပါ။</translation>
<translation id="130631256467250065">သင် ပြောင်းလဲခဲ့သည်များမျာ သင်က သင်၏ ကိရိယာကို နောက်တစ်ကြိမ် ပြန်ဖွင့်စဉ် အကျိုးသက်ရောက် လာကြပါမည်။</translation>
<translation id="1722634673917783018">သင်၏အပြောင်းအလဲများသည် Ecosia ကို နောက်တစ်ကြိမ် ပြန်ဖွင့်ချိန်တွင် သက်ရောက်မှုရှိပါမည်။</translation>
<translation id="7347361780317841252"><ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> အခမဲ့ ရင်းမြစ် စီမံကိန်းနှင့် အခြား <ph name="BEGIN_LINK_OSS"/>အခမဲ့ ရင်းမြစ် ဆော့ဖ်ဝဲ<ph name="END_LINK_OSS"/> တို့က Ecosia ကို ထုတ်လုပ်ထားသည်။</translation>
<translation id="5104341700462991189">Ecosia လိုဂို</translation>
<translation id="3444832043240812445">အကယ်၍သင် <ph name="BEGIN_LINK"/> ပျက်စီးမှု အစီရင်ခံချက် <ph name="END_LINK"/> ဖွင့်ထားလျှင် ဤစာမျက်နှာသည် မကြာသေးခင်က ပျက်စီးမှု အချက်လက်များကိုသာ ပြသည်။</translation>
<translation id="583128902627777075">သင့် Firewall သို့မဟုတ် ဗိုင်းရပ်စ်ခုခံစနစ် ဆက်တင်များအတွင်း ကွန်ရက်အသုံးပြုရန် Ecosia ကိုခွင့်ပြုပါ။</translation>
<translation id="5177147493498374715">Ecosia က ဤစာမျက်နှာကို ပိတ်ထားသည်</translation>
<translation id="3913860536599484838">သို့သွားမည်
          Ecosia menu &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          သင့်ပြုပြင်ချက်သည် "no proxy" သို့မဟုတ် "direct" ဟုသတ်မှတ်ထားကြောင်း သေချာစေပါ။</translation>
<translation id="8143058600367874039">Ecosia မီနူးကို သွားပါ &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        ပြီးတော့  "<ph name="NO_PREFETCH_DESCRIPTION"/>"အား ရွေးထားမှုကို ဖြုတ်လိုက်ပါ။
        အဲဒါက ပြဿနာကို ဖြေရှင်း မပေးသေးပါက၊ လုပ်ကိုင်မှုကို မြှင့်တင်ပေးရန် ဒီရွေးချယ်မှုကို ထပ်ပြီး ရွေးရန်ကို ကျွန်ုပ်တို့ အကြံပေးပါသည်။</translation>
<translation id="6276216569125239216">သွားရမှာက
          Ecosia မီနူး &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN ဆက်တင်များ
          ပြီးတော့ "သင်၏ LAN အတွက် ပရောက်စီ ဆာဗာ အသုံးပြုရန်" ရွေးထားမှုကို ဖြုတ်ပါ။</translation>
<translation id="2441066927880955410">သင်သည် လုံခြုံသော Ecosia စာမျက်နှာကို ကြည့်ရှုနေပါသည်</translation>
<translation id="8187289872471304532">သွားမည်
          Applications &gt; System Preferences &gt; Network &gt; Advanced &gt; Proxies
          and deselect any proxies that have been selected.</translation>
</translationbundle>
