<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="130631256467250065">ការប្តូររបស់អ្នកនឹងមានប្រសិទ្ធភាពនៅពេលដែលអ្នកចាប់ផ្តើមឧបករណ៍របស់អ្នកឡើងវិញពេលបន្ទាប់។</translation>
<translation id="2955914891289756427">ការរាយការណ៍ពីការគាំងមិនមាននៅក្នុង Ecosia ទេ។</translation>
<translation id="2441066927880955410">អ្នក​កំពុង​មើល​ទំព័រ Ecosia ដែល​មាន​សុវត្ថិភាព</translation>
<translation id="5104341700462991189">និមិត្តសញ្ញា Ecosia</translation>
<translation id="7347361780317841252">Ecosia អាចបង្កើតឡើងបានដោយគម្រោងប្រភពបើកចំហរ <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> និង <ph name="BEGIN_LINK_OSS"/>កម្មវិធីប្រភពបើកចំហរ<ph name="END_LINK_OSS"/> ផ្សេងទៀត។</translation>
<translation id="8920794075861916959">ទៅកាន់
          ម៉ឺនុយ Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          ការកំណត់ LAN
          ហើយដកការជ្រើសរើសប្រអប់ធីក "ប្រើម៉ាស៊ីនមេប្រូកស៊ីសម្រាប់ LAN របស់អ្នក"។</translation>
<translation id="5177147493498374715">ទំព័រនេះត្រូវបានទប់ស្កាត់ដោយ Ecosia</translation>
<translation id="583128902627777075">អនុញ្ញាតឲ្យ Ecosia ចូលប្រើបណ្តាញនៅក្នុងការកំណត់ firewall ឬកម្មវិធីកម្ចាត់មេរោគ
        របស់អ្នក។</translation>
<translation id="3913860536599484838">ទៅកាន់
          ម៉ឺនុយ Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          ហើយត្រូវប្រាកដថាការតំឡើងរបស់អ្នកកំណត់ទៅ "គ្មានប្រូកស៊ី" ឬ "ដោយផ្ទាល់។"</translation>
<translation id="1722634673917783018">ការផ្លាស់ប្តូររបស់អ្នកនឹងមានប្រសិទ្ធភាពនៅពេលដែលបើកដំណើរការ Ecosia ឡើងវិញពេលក្រោយ។</translation>
<translation id="8143058600367874039">ទៅកាន់
        ម៉ឺនុយ Ecosia &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        ហើយ ដកការជ្រើសរើស "<ph name="NO_PREFETCH_DESCRIPTION"/>."
        ប្រសិនបើវាមិនដោះស្រាយបញ្ហានេះ យើងអាចណែនាំការជ្រើសរើសជម្រើសនេះ
        ម្តងទៀតសម្រាប់ប្រតិបត្តិការដែលបានធ្វើឲ្យប្រសើរឡើង។</translation>
<translation id="8187289872471304532">ទៅកាន់
          កម្មវិធី &gt; ចំណូលចិត្តប្រព័ន្ធ &gt; បណ្តាញ &gt; កម្រិតខ្ពស់ &gt; ប្រូកស៊ី
          ហើយលុបការជ្រើសរើសប្រូកស៊ីណាមួយដែលបានជ្រើសរើស។</translation>
<translation id="1864711229671391928">Ecosia មិនបានបិទត្រឹមត្រូវទេ។</translation>
</translationbundle>
