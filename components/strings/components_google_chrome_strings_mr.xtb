<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="mr">
<translation id="1864711229671391928">Ecosia योग्यरित्या बंद झाले नाही.</translation>
<translation id="130631256467250065">तुम्ही आपल्या डिव्हाइसचा पुढील वेळी पुनरारंभ कराल तेव्हा तुमचे बदल प्रभावी होतील.</translation>
<translation id="1722634673917783018">पुढील वेळी तुम्ही Ecosia पुन्हा लाँच केल्यानंतर तुमचे बदल लागू होतील.</translation>
<translation id="7347361780317841252"><ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> मुक्त-स्रोत प्रोजेक्ट आणि इतर <ph name="BEGIN_LINK_OSS"/>मुक्त स्रोत सॉफ्टवेअर<ph name="END_LINK_OSS"/> द्वारे Ecosia ची निर्मिती करणे शक्य झाले.</translation>
<translation id="5104341700462991189">Ecosia लोगो</translation>
<translation id="3444832043240812445">हे पेज तुम्ही <ph name="BEGIN_LINK"/>कॅशे अहवाल सुरू<ph name="END_LINK"/> केल्यास केवळ तुम्हाला अलीकडील क्रॅशची माहिती दाखवते.</translation>
<translation id="583128902627777075">तुमच्या फायरवॉल किंवा अँटीव्हायरस सेटिंग्जमधील नेटवर्क ॲक्सेस करण्यास
        Ecosia ला परवानगी  द्या.</translation>
<translation id="5177147493498374715">हे पेज Ecosia ने ब्लॉक केले आहे</translation>
<translation id="3913860536599484838">Ecosia मेनू &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          वर जा आणि तुमचे कॉंफिगरेशन "प्रॉक्सी नाही" किंवा "प्रत्यक्ष" वर सेट केल्याचे सुनिश्चित करा.</translation>
<translation id="8143058600367874039">Ecosia मेनू &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          वर जा आणि "<ph name="NO_PREFETCH_DESCRIPTION"/>" ची निवड रद्द करा.
         हे समस्‍येचे निराकरण करीत नसल्‍यास, आम्‍ही सुधारित सुधारित कार्यप्रदर्शनासाठी पुन्हा
          हा पर्याय निवडण्याची शिफारस करतो.</translation>
<translation id="6276216569125239216">Ecosia मेनू &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN सेटिंग्ज
          वर जा आणि "आपल्या LAN साठी एक प्रॉक्सी सर्व्हर वापरा" निवड रद्द करा.</translation>
<translation id="2441066927880955410">तुम्ही एक सुरक्षित Ecosia पेज पाहत आहात</translation>
<translation id="8187289872471304532">ॲप्लिकेशन &gt; सिस्टम प्राधान्ये &gt; नेटवर्क &gt; प्रगत &gt; प्रॉक्सी
          वर जा आणि निवडलेल्या कोणत्याही प्रॉक्सींची निवड रद्द करा.</translation>
</translationbundle>
