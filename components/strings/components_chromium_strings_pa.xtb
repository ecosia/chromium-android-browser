<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="pa">
<translation id="130631256467250065">ਤੁਹਾਡੀਆਂ ਤਬਦੀਲੀਆਂ ਅਗਲੀ ਵਾਰ ਤੁਹਾਡੇ ਡਿਵਾਈਸ ਨੂੰ ਮੁੜ ਚਾਲੂ ਕਰਨ 'ਤੇ ਲਾਗੂ ਹੋਣਗੀਆਂ।</translation>
<translation id="2955914891289756427">ਕ੍ਰੈਸ਼ ਰਿਪੋਰਟਿੰਗ Ecosia ਵਿੱਚ ਉਪਲਬਧ ਨਹੀਂ ਹੈ।</translation>
<translation id="2441066927880955410">ਤੁਸੀਂ ਇੱਕ ਸੁਰੱਖਿਅਤ Ecosia ਪੰਨਾ  ਦੇਖ  ਰਹੇ ਹੋ</translation>
<translation id="5104341700462991189">Ecosia ਲੋਗੋ</translation>
<translation id="7347361780317841252">Ecosia ਨੂੰ <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ਖੁੱਲ੍ਹੇ ਸਰੋਤ ਪ੍ਰੋਜੈਕਟ ਅਤੇ ਹੋਰ <ph name="BEGIN_LINK_OSS"/>ਖੁੱਲ੍ਹੇ ਸਰੋਤ ਸਾਫ਼ਟਵੇਅਰ<ph name="END_LINK_OSS"/> ਵੱਲੋਂ ਸੰਭਵ ਬਣਾਇਆ ਗਿਆ ਹੈ।</translation>
<translation id="8920794075861916959">Ecosia ਮੀਨੂ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN ਸੈਟਿੰਗਾਂ ਤੇ ਜਾਓ
          ਅਤੇ "ਆਪਣੇ LAN ਚੈੱਕ-ਬਾਕਸ ਲਈ ਇੱਕ ਪ੍ਰੌਕਸੀ ਸਰਵਰ ਵਰਤੋ" ਨੂੰ ਅਣ-ਚੁਣਿਆ ਕਰੋ।</translation>
<translation id="5177147493498374715">ਇਸ ਪੰਨੇ ਨੂੰ Ecosia ਵੱਲੋਂ ਬਲਾਕ ਕੀਤਾ ਗਿਆ ਹੈ</translation>
<translation id="583128902627777075">Ecosia ਨੂੰ ਆਪਣੀਆਂ ਫ਼ਾਇਰਵਾਲ ਜਾਂ ਐਂਟੀਵਾਇਰਸ ਸੈਟਿੰਗਾਂ ਵਿੱਚ ਨੈੱਟਵਰਕ ਤੱਕ ਪਹੁੰਚ ਕਰਨ ਦਿਓ।</translation>
<translation id="3913860536599484838">Ecosia ਮੀਨੂ&gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/> ਤੇ ਜਾਓ 
          ਅਤੇ ਯਕੀਨੀ ਬਣਾਓ ਕਿ ਤੁਹਾਡੀ ਕੌਂਫਿਗਰੇਸ਼ਨ "ਕੋਈ ਪ੍ਰੌਕਸੀ ਨਹੀਂ" ਜਾਂ "ਡਾਇਰੈਕਟ" ਤੇ ਸੈਟ ਹੈ।</translation>
<translation id="1722634673917783018">ਤੁਹਾਡੀਆਂ ਤਬਦੀਲੀਆਂ ਅਗਲੀ ਵਾਰ ਤੁਹਾਡੇ ਵੱਲੋਂ Ecosia ਨੂੰ ਰੀਲੌਂਚ ਕਰਨ 'ਤੇ ਲਾਗੂ ਹੋਣਗੀਆਂ।</translation>
<translation id="8143058600367874039">Ecosia ਮੀਨੂ&gt; ਤੇ ਜਾਓ
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          ਅਤੇ "<ph name="NO_PREFETCH_DESCRIPTION"/>" ਨੂੰ ਅਚੋਣਵਾਂ ਕਰੋ।
          ਜੇਕਰ ਇਸ ਨਾਲ ਸਮੱਸਿਆ ਹੱਲ ਨਹੀਂ ਹੁੰਦੀ , ਤਾਂ ਅਸੀਂ ਬਿਹਤਰ ਪ੍ਰਦਰਸ਼ਨ ਲਈ ਇਸ ਚੋਣ ਨੂੰ ਦੁਬਾਰਾ
          ਚੁਣਨ ਦੀ ਸਲਾਹ ਦਿੰਦੇ ਹਾਂ।</translation>
<translation id="8187289872471304532">ਐਪਲੀਕੇਸ਼ਨਾਂ&gt; ਸਿਸਟਮ ਤਰਜੀਹਾਂ &gt; ਨੈੱਟਵਰਕ &gt; ਉੱਨਤ &gt; ਪ੍ਰੌਕਸੀਆਂ 'ਤੇ ਜਾਓ ਅਤੇ ਕਿਸੇ ਵੀ ਉਹਨਾਂ 
          ਪ੍ਰੌਕਸੀਆਂ ਨੂੰ ਅਚੋਣਵਾਂ ਕਰੋ ਜੋ ਚੁਣੀਆਂ ਗਈਆਂ ਹਨ।</translation>
<translation id="1864711229671391928">Ecosia ਸਹੀ ਢੰਗ ਨਾਲ ਬੰਦ ਨਹੀਂ ਹੋਇਆ।</translation>
</translationbundle>
