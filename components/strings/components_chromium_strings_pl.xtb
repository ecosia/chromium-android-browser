<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="pl">
<translation id="130631256467250065">Zmiany zostaną zastosowane przy następnym uruchomieniu urządzenia.</translation>
<translation id="2955914891289756427">Zgłaszanie awarii nie jest dostępne w Ecosia.</translation>
<translation id="2441066927880955410">Przeglądasz bezpieczną stronę Ecosia</translation>
<translation id="5104341700462991189">Logo Ecosia</translation>
<translation id="7347361780317841252">Stworzenie Ecosia było możliwe dzięki projektowi open source <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> i innym <ph name="BEGIN_LINK_OSS"/>programom o otwartym kodzie źródłowym<ph name="END_LINK_OSS"/>.</translation>
<translation id="8920794075861916959">Wybierz
          menu Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          Ustawienia sieci LAN
          i usuń zaznaczenie pola wyboru „Użyj serwera proxy dla sieci LAN”.</translation>
<translation id="5177147493498374715">Ta strona została zablokowana przez Ecosia</translation>
<translation id="583128902627777075">Zezwalaj Ecosia na korzystanie z sieci w ustawieniach zapory sieciowej
        lub oprogramowania antywirusowego.</translation>
<translation id="3913860536599484838">Wybierz
          menu Ecosia &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          i upewnij się, że w konfiguracji wybrano połączenie bez serwera proxy lub bezpośrednie.</translation>
<translation id="1722634673917783018">Zmiany zostaną zastosowane po ponownym uruchomieniu Ecosia.</translation>
<translation id="8143058600367874039">Wybierz
        menu Ecosia &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        i odznacz „<ph name="NO_PREFETCH_DESCRIPTION"/>”.
        Jeśli nie rozwiąże to problemu, zalecamy ponowne wybranie tej opcji,
        by poprawić wydajność.</translation>
<translation id="8187289872471304532">Wybierz
          Aplikacje &gt; Ustawienia systemowe &gt; Sieć &gt; Zaawansowane &gt; Serwery proxy
          i usuń zaznaczenie wszelkich wybranych serwerów proxy.</translation>
<translation id="1864711229671391928">Ecosia nie został poprawnie zamknięty.</translation>
</translationbundle>
