<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="kk">
<translation id="130631256467250065">Өзгерістеріңіз құрылғыңызды келесі қайта іске қосқанда күшіне енеді.</translation>
<translation id="2955914891289756427">Бұзылу туралы хабарлау мүмкіндігі Ecosia қызметінде қолжетімді емес.</translation>
<translation id="2441066927880955410">Қауіпсіз Ecosia бетін көрудесіз</translation>
<translation id="7085497353580337354">Ecosia төлеу әдістерін толтыру параметрлерін өзгерткісі келеді.</translation>
<translation id="5104341700462991189">Ecosia логотипі</translation>
<translation id="1566733708869146127">Ecosia төлеу әдістерін өзгерткісі келеді.</translation>
<translation id="7347361780317841252">Ecosia қолданбасына <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ашық бастапқы код жобасы мен басқа <ph name="BEGIN_LINK_OSS"/>ашық бастапқы код бағдарламалық жасақтамасы<ph name="END_LINK_OSS"/> арқылы қол жеткізілді.</translation>
<translation id="8920794075861916959">"Ecosia мәзірі &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN параметрлері" тармағына өтіп,
          "LAN желіңіз үшін прокси серверді пайдалану" құсбелгісін алып тастаңыз.</translation>
<translation id="5177147493498374715">Бұл бетке Ecosia тарапынан тыйым салынған.</translation>
<translation id="583128902627777075">Брандмауэр немесе антивирус параметрлерінде Ecosia жүйесіне
          желіге кіруге рұқсат беріңіз.</translation>
<translation id="3913860536599484838">Ecosia мәзірі &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
           тармағына өтіп, конфигурацияңыз "проксисіз" немесе "тікелей" күйіне орнатылғандығын тексеріңіз.</translation>
<translation id="6182615032232999551">Сонымен қатар Ecosia басқа <ph name="BEGIN_LINK_OSS"/>ашық кодты бағдарламалық құрал<ph name="END_LINK_OSS"/> арқылы қолжетімді болады.</translation>
<translation id="1722634673917783018">Өзгертулеріңіз Ecosia келесі рет қайта іске қосылғанда күшіне енеді.</translation>
<translation id="4062366803229254216">Жұптауды жалғастыру үшін Ecosia-ге Bluetooth-ты пайдалану рұқсаты керек. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="7273712334661186152">Ecosia браузері <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ашық кодты бағдарлама жобасы арқылы қолжетімді болады.</translation>
<translation id="8143058600367874039">Ecosia мәзірі &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          тармағына өтіп, "<ph name="NO_PREFETCH_DESCRIPTION"/>" таңдауын алып тастаңыз.
          Бұл мәселені шешпесе, өнімділікті жақсарту үшін осы опцияны қайта
          таңдауды ұсынамыз.</translation>
<translation id="8187289872471304532">"Қолданбалар &gt; Жүйе параметрлері &gt; Желі &gt; Кеңейтілген &gt; Прокси серверлері" тармағына өтіп,
          таңдалған барлық прокси серверлерін таңдаудан алып тастаңыз.</translation>
<translation id="8393444759658439191">Қауіпсіз Ecosia for Testing бетін көріп отырсыз.</translation>
<translation id="1864711229671391928">Ecosia дұрыс өшірілмеді.</translation>
</translationbundle>
