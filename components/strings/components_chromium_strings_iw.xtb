<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="iw">
<translation id="130631256467250065">השינויים ייכנסו לתוקף בפעם הבאה שהמכשיר יופעל מחדש.</translation>
<translation id="2955914891289756427">‏דיווח על התרסקויות אינו זמין ב-Ecosia.</translation>
<translation id="2441066927880955410">‏זהו דף מאובטח של Ecosia</translation>
<translation id="5104341700462991189">‏לוגו של Ecosia</translation>
<translation id="7347361780317841252">‏Ecosia קיים הודות לפרויקט הקוד הפתוח של <ph name="BEGIN_LINK_CHROMIUM"/> Ecosia‏<ph name="END_LINK_CHROMIUM"/> ו<ph name="BEGIN_LINK_OSS"/>תוכנות קוד פתוח<ph name="END_LINK_OSS"/> אחרות.</translation>
<translation id="8920794075861916959">‏יש לעבור אל
          תפריט Ecosia‏ &gt;
          <ph name="SETTINGS_TITLE"/>
          ‏&gt;
          <ph name="ADVANCED_TITLE"/>
          ‏&gt;
          <ph name="PROXIES_TITLE"/>
          ‏&gt;
          הגדרות LAN
          ולבטל את הבחירה באפשרות "שימוש בשרת proxy עבור רשת LAN‏".</translation>
<translation id="5177147493498374715">‏הדף הזה נחסם על ידי Ecosia</translation>
<translation id="583128902627777075">‏שינוי הגדרות חומת האש או האנטי-וירוס כדי לאפשר ל-Ecosia
          לגשת לרשת.</translation>
<translation id="3913860536599484838">‏יש לעבור אל
          תפריט Ecosia‏ &gt;
          <ph name="SETTINGS_TITLE"/>
          ‏&gt;
          <ph name="ADVANCED_TITLE"/>
          ‏&gt;
          <ph name="PROXIES_TITLE"/>
          ולבדוק שהתצורה שלך מוגדרת לאפשרות "ללא שרת proxy‏" או "ישיר".</translation>
<translation id="1722634673917783018">‏השינויים שביצעת ייכנסו לתוקף בפעם הבאה שתפעיל מחדש את Ecosia‏.</translation>
<translation id="8143058600367874039">‏יש להיכנס אל
        תפריט Ecosia &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        ולבטל את הבחירה באפשרות '<ph name="NO_PREFETCH_DESCRIPTION"/>'.
        אם פעולה זו אינה פותרת את הבעיה, מומלץ לבחור שוב באפשרות זו
        לקבלת ביצועים משופרים.</translation>
<translation id="8187289872471304532">‏יש לעבור אל
          'יישומים' &gt; 'העדפות מערכת' &gt; 'רשת' &gt; 'מתקדם' &gt; שרתי Proxy'
          ולבטל את הבחירה בשרתי proxy שנבחרו.</translation>
<translation id="1864711229671391928">‏כיבוי Ecosia לא בוצע כהלכה.</translation>
</translationbundle>
