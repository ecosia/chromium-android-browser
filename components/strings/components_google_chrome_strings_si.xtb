<!DOCTYPE translationbundle>
<translationbundle lang="si">
<translation id="1864711229671391928">Ecosia а¶ұа·’а·Җа·җа¶»а¶Ҝа·’а·Җ а·Җа·җа·ға·“а¶ёа¶§ а¶ұа·ңа·„а·җа¶ҡа·’ а·Җа·’а¶ә.</translation>
<translation id="130631256467250065">а¶”а¶¶а·ҡ а¶Ӣа¶ҙа·Ҹа¶Ӯа¶ңа¶ә а¶ұа·җа·Җа¶ӯ а¶…а¶»а¶№а¶ұ а·Җа·’а¶§ а¶”а¶¶а·ҡ а·Җа·ҷа¶ұа·ға·Ҡа¶ҡа¶ёа·Ҡ а¶¶а¶Ҫ а¶ҙа·җа·Җа·җа¶ӯа·Ҡа·Җа·ҷа¶ұа·” а¶Үа¶ӯ.</translation>
<translation id="1722634673917783018">а¶”а¶¶ а¶Ҡа·…а¶ҹ а¶…а·Җа·ға·Ҡа¶®а·Ҹа·Җа·ҡ Ecosia а¶әа·…а·’ а¶Ҝа·’а¶әа¶ӯа·Ҡ а¶ҡа¶»а¶ұ а·Җа·’а¶§ а¶”а¶¶а¶ңа·ҡ а·Җа·ҷа¶ұа·ға·Ҡ а¶ҡа·’а¶»а·“а¶ёа·Ҡ а¶¶а¶Ҫа·Ҹа¶ӯа·Ҡа¶ёа¶ҡ а·Җа¶ұа·” а¶Үа¶ӯ.</translation>
<translation id="7347361780317841252">Ecosia а·ға·‘а¶Ҝа·“а¶ёа¶§ а·„а·җа¶ҡа·’ а·Җа·–а¶әа·ҡ <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> а·Җа·’а·Җа·ҳа¶ӯ а¶ёа·–а¶Ҫа·Ҹа·Ға·ҠвҖҚа¶» а·Җа·ҠвҖҚа¶әа·Ҹа¶ҙа·ҳа¶ӯа·’а¶ә а·ға·„ а·Җа·ҷа¶ұа¶ӯа·Ҡ <ph name="BEGIN_LINK_OSS"/>а·Җа·’а·Җа·ҳа¶ӯ а¶ёа·–а¶Ҫа·Ҹа·Ға·ҠвҖҚа¶» а¶ёа·ҳа¶Ҝа·”а¶ҡа·Ҹа¶Ӯа¶ң<ph name="END_LINK_OSS"/> а¶ёа¶ңа·’а¶ұа·’.</translation>
<translation id="5104341700462991189">а¶ҡа·ҠвҖҚа¶»а·қа¶ёа·Ҡ а¶Ҫа·Ҹа¶Ӯа¶Ўа¶ұа¶ә</translation>
<translation id="3444832043240812445">а¶”а¶¶ <ph name="BEGIN_LINK"/>а¶¶а·’а¶іа·Җа·җа¶§а·”а¶ёа·Ҡ а·Җа·Ҹа¶»а·Ҡа¶ӯа·Ҹ а·ға¶¶а¶Ҫ а¶ҡа¶»<ph name="END_LINK"/> а¶Үа¶ӯа·Ҡа¶ұа¶ёа·Ҡ а¶ҙа¶ёа¶«а¶ҡа·Ҡ а¶ёа·ҷа¶ё а¶ҙа·’а¶§а·”а·Җ а¶”а¶¶а·ҡ а¶ёа·‘а¶ӯа¶ҡа¶Ҝа·“ а·ға·’а¶Ҝа·” а·Җа·– а¶¶а·’а¶іа·Җа·җа¶§а·“а¶ёа·Ҡ а¶ҙа·ҷа¶ұа·Ҡа·Җа¶ұа·” а¶Үа¶ӯ.</translation>
<translation id="583128902627777075">а¶”а¶¶а¶ңа·ҡ а·Ҷа¶әа¶»а·Ҡ а·Җа·қа¶Ҫ а·„а·Ҹ а¶ҙа·ҠвҖҚа¶»а¶ӯа·’а·Җа¶әа·’а¶»а·ғ а·ға·җа¶ҡа·ға·“а¶ёа·Ҡ а¶ӯа·”а·… Ecosia а·„а¶§ а¶ўа·Ҹа¶Ҫа¶әа¶§ а¶ҙа·’а·Җа·’а·ға·“а¶ёа¶§
          а¶…а·Җа·ға¶» а¶Ҝа·ҷа¶ұа·Ҡа¶ұ.</translation>
<translation id="5177147493498374715">а¶ёа·ҷа¶ё а¶ҙа·’а¶§а·”а·Җ Ecosia а¶ёа¶ңа·’а¶ұа·Ҡ а¶…а·Җа·„а·’а¶» а¶ҡа¶» а¶Үа¶ӯ</translation>
<translation id="3913860536599484838">а¶әа¶ұа·Ҡа¶ұ
      Ecosia а¶ёа·ҷа¶ұа·”а·Җ&gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
         а¶”а¶¶а·ҡ а·Җа·’а¶ұа·ҠвҖҚа¶әа·Ҹа·ға¶ә "а¶ҙа·ҠвҖҚа¶»а·ңа¶ҡа·Ҡа·ға·’ а¶ұа·җа¶ӯ" а·„а·қ"а·ға·ҳа¶ўа·” " а¶Ҫа·ҷа·ғ а·ға¶ҡа·ға·Ҹ а¶Үа¶ӯа·’ а¶¶а·Җа¶§ а¶ӯа·„а·Җа·”а¶»а·” а¶ҡа¶» а¶ңа¶ұа·Ҡа¶ұ.</translation>
<translation id="8143058600367874039">а¶ёа·”а¶Ҫа·’а¶ұа·Ҡа¶ё
        Ecosia а¶ёа·ҷа¶ұа·”а·Җ а·Җа·ҷа¶ӯ а¶ңа·ңа·ға·Ҡ&gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        а¶ӯа·қа¶»а·Ҹ "<ph name="NO_PREFETCH_DESCRIPTION"/>." а¶ӯа·ҡа¶»а·“а¶ё а¶үа·Җа¶ӯа·Ҡ а¶ҡа¶»а¶ұа·Ҡа¶ұ
        а¶ёа·ҷа¶әа·’а¶ұа·Ҡ а¶ұа·’а¶»а·Ҹа¶ҡа¶»а¶«а¶ә а¶ұа·ңа·Җа·”а¶ұ а·„а·ңа¶ӯа·Ҡ, а·Җа¶©а·Ҹ а¶Ҝа·’а¶әа·”а¶«а·” а¶ҡа·ҠвҖҚа¶»а·’а¶әа·Ҹа¶ҡа·Ҹа¶»а·“а¶ӯа·Ҡа·Җа¶әа¶ҡа·Ҡ а·ға¶іа·„а·Ҹ а¶ёа·ҷа¶ё а¶…а¶·а·’а¶ҙа·ҠвҖҚа¶»а·ҡа¶ӯа¶ә а¶ұа·җа·Җа¶ӯ а¶ӯа·қа¶»а¶ұа·Ҡа¶ұ.</translation>
<translation id="6276216569125239216">а¶’ а·ға¶іа·„а·ҸВ 
          Ecosia а¶ёа·ҷа¶ұа·”а·Җ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN а·ға·җа¶ҡа·ға·”а¶ёа·Ҡ
          "а¶”а¶¶а¶ңа·ҡ LAN а·ға¶іа·„а·Ҹ а¶ҙа·ҠвҖҚа¶»а·ңа¶ҡа·Ҡа·ға·’ а·ға·ҡа·Җа·Ҹа¶Ҝа·Ҹа¶әа¶ҡа¶әа¶ҡа·Ҡ а¶·а·Ҹа·Җа·’а¶ӯ а¶ҡа¶»а¶ұа·Ҡа¶ұ" а·ға¶Ҫа¶ҡа·”а¶«а·” а¶ҡа·ңа¶§а·”а·Җ а¶үа·Җа¶ӯа·Ҡ а¶ҡа¶»а¶ұа·Ҡа¶ұ.</translation>
<translation id="2441066927880955410">а¶”а¶¶а¶ңа·ҡ а¶Ҷа¶»а¶ҡа·Ҡа·Ӯа·’а¶ӯ Ecosia а¶ҙа·’а¶§а·”а·Җа¶ҡа·Ҡ а¶¶а¶Ҫа¶ёа·’а¶ұа·Ҡ а·ға·’а¶§а·“</translation>
<translation id="8187289872471304532">а¶әа·ҷа¶Ҝа·”а¶ёа·Ҡ &gt; а¶ҙа¶Ҝа·Ҡа¶°а¶ӯа·’ а¶ёа¶ұа·Ҹа¶ҙ &gt; а¶ўа·Ҹа¶Ҫа¶ә &gt; а¶Ӣа·ға·ға·Ҡ а¶ҡа·… &gt; а¶ҙа·ҠвҖҚа¶»а·ңа¶ҡа·Ҡа·ға·’ а·Җа·ҷа¶ӯ а¶ңа·ңа·ға·Ҡ
          а¶ӯа·ңа·Ҡа¶»а·Ҹ а¶Үа¶ӯа·’ а¶•а¶ұа·‘а¶ё а¶ҙа·ҠвҖҚа¶»а·ңа¶ҡа·Ҡа·ға·’а¶әа¶ҡа·Ҡ а¶ұа·ңа¶ӯа·ҷа·Ҹа·Ҡа¶»а¶ұа·Ҡа¶ұ.</translation>
</translationbundle>
