<!DOCTYPE translationbundle>
<translationbundle lang="si">
<translation id="1864711229671391928">Ecosia නිවැරදිව වැසීමට නොහැකි විය.</translation>
<translation id="130631256467250065">ඔබේ උපාංගය නැවත අරඹන විට ඔබේ වෙනස්කම් බල පැවැත්වෙනු ඇත.</translation>
<translation id="4062366803229254216">යුගල කිරීම දිගටම කර ගෙන යාමට Ecosia හට බ්ලූටූත් ප්‍රවේශය අවශ්‍යයි. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="1722634673917783018">ඔබ ඊළඟ අවස්ථාවේ Ecosia යළි දියත් කරන විට ඔබගේ වෙනස් කිරීම් බලාත්මක වනු ඇත.</translation>
<translation id="1566733708869146127">Ecosia ගෙවීම් ක්‍රම සංස්කරණය කිරීමට උත්සාහ කරයි.</translation>
<translation id="7347361780317841252">Ecosia සෑදීමට හැකි වූයේ <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> විවෘත මූලාශ්‍ර ව්‍යාපෘතිය සහ වෙනත් <ph name="BEGIN_LINK_OSS"/>විවෘත මූලාශ්‍ර මෘදුකාංග<ph name="END_LINK_OSS"/> මගිනි.</translation>
<translation id="5104341700462991189">ක්‍රෝම් ලාංඡනය</translation>
<translation id="3444832043240812445">ඔබ <ph name="BEGIN_LINK"/>බිඳවැටුම් වාර්තා සබල කර<ph name="END_LINK"/> ඇත්නම් පමණක් මෙම පිටුව ඔබේ මෑතකදී සිදු වූ බිඳවැටීම් පෙන්වනු ඇත.</translation>
<translation id="583128902627777075">ඔබගේ ෆයර් වෝල හා ප්‍රතිවයිරස සැකසීම් තුළ Ecosia හට ජාලයට පිවිසීමට
          අවසර දෙන්න.</translation>
<translation id="5177147493498374715">මෙම පිටුව Ecosia මගින් අවහිර කර ඇත</translation>
<translation id="3913860536599484838">යන්න
      Ecosia මෙනුව&gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
         ඔබේ වින්‍යාසය "ප්‍රොක්සි නැත" හෝ"සෘජු " ලෙස සකසා ඇති බවට තහවුරු කර ගන්න.</translation>
<translation id="8143058600367874039">මුලින්ම
        Ecosia මෙනුව වෙත ගොස්&gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>
        තෝරා "<ph name="NO_PREFETCH_DESCRIPTION"/>." තේරීම ඉවත් කරන්න
        මෙයින් නිරාකරණය නොවුන හොත්, වඩා දියුණු ක්‍රියාකාරීත්වයක් සඳහා මෙම අභිප්‍රේතය නැවත තෝරන්න.</translation>
<translation id="6276216569125239216">ඒ සඳහා 
          Ecosia මෙනුව &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN සැකසුම්
          "ඔබගේ LAN සඳහා ප්‍රොක්සි සේවාදායකයක් භාවිත කරන්න" සලකුණු කොටුව ඉවත් කරන්න.</translation>
<translation id="2441066927880955410">ඔබගේ ආරක්ෂිත Ecosia පිටුවක් බලමින් සිටී</translation>
<translation id="8187289872471304532">යෙදුම් &gt; පද්ධති මනාප &gt; ජාලය &gt; උසස් කළ &gt; ප්‍රොක්සි වෙත ගොස්
          තෝරා ඇති ඕනෑම ප්‍රොක්සියක් නොතෝරන්න.</translation>
<translation id="7273712334661186152">Ecosia හට <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> විවෘත මූලාශ්‍ර මෘදුකාංගය මගින් හැකියාව සලසා ඇත</translation>
<translation id="6182615032232999551">Ecosia හට වෙනත් <ph name="BEGIN_LINK_OSS"/>විවෘත මූලාශ්‍ර මෘදුකාංග<ph name="END_LINK_OSS"/> මගින් ද හැකියාව සලසා ඇත</translation>
<translation id="7085497353580337354">Ecosia ගෙවීම් ක්‍රම පිරවීම සඳහා සැකසීම් වෙනස් කිරීමට උත්සාහ දරයි.</translation>
</translationbundle>
