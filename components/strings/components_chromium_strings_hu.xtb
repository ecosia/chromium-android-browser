<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="hu">
<translation id="130631256467250065">A módosítások az eszköz következő újraindításakor lépnek életbe.</translation>
<translation id="2955914891289756427">A hibajelentések nem állnak rendelkezésre a Ecosiaban.</translation>
<translation id="2441066927880955410">Jelenleg biztonságos Ecosia-oldalt tekint meg</translation>
<translation id="7085497353580337354">A Ecosia módosítani próbálja a fizetési módok kitöltési beállításait.</translation>
<translation id="5104341700462991189">Ecosia embléma</translation>
<translation id="1566733708869146127">A Ecosia szerkeszteni próbálja a fizetési módokat.</translation>
<translation id="7347361780317841252">A Ecosia a <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> nyílt forráskódú projektnek és további <ph name="BEGIN_LINK_OSS"/>nyílt forráskódú szoftvereknek<ph name="END_LINK_OSS"/> köszönhetően jött létre.</translation>
<translation id="8920794075861916959">Lépjen ide:
          Ecosia menü &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          A helyi hálózat (LAN) beállításai,
          majd törölje a jelet a „Proxykiszolgáló használata a helyi hálózaton” jelölőnégyzetből.</translation>
<translation id="5177147493498374715">Ezt az oldalt a Ecosia blokkolja</translation>
<translation id="583128902627777075">A hálózat elérésének engedélyezése a Ecosia számára a tűzfal-
          vagy vírusirtó-beállításokban.</translation>
<translation id="3913860536599484838">Lépjen ide:
          Ecosia menü &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>,
          és gondoskodjon róla, hogy a konfiguráció beállítása „nincs proxy” vagy „közvetlen” legyen.</translation>
<translation id="6182615032232999551">A Ecosiaot létrejöttéhez más <ph name="BEGIN_LINK_OSS"/>nyílt forráskódú szoftverek<ph name="END_LINK_OSS"/> is hozzájárultak.</translation>
<translation id="1722634673917783018">Módosításai a Ecosia újraindítása után lépnek érvénybe.</translation>
<translation id="4062366803229254216">A Ecosianak Bluetooth-hozzáférésre van szükséges a párosítás 
 folytatásához. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="7273712334661186152">A Ecosia a <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> nyílt forráskódú projektnek köszönhetően jött létre.</translation>
<translation id="8143058600367874039">Lépjen ide:
        Ecosia menü &gt;
        <ph name="SETTINGS_TITLE"/>
        &gt;
        <ph name="ADVANCED_TITLE"/>,
        és törölje a jelet a(z) „<ph name="NO_PREFETCH_DESCRIPTION"/>” jelölőnégyzetből.
        Ha ettől nem szűnik meg a probléma, javasoljuk, hogy jelölje be ismét ezt a lehetőséget a jobb teljesítmény érdekében.</translation>
<translation id="8187289872471304532">Az Applications &gt; System Preferences &gt; Network &gt; Advanced &gt; Proxies (Alkalmazások &gt; Rendszerbeállítások &gt; Hálózat &gt; Speciális &gt; Proxyk) menüpont alatt törölje a jelet minden kijelölt proxy mellől.</translation>
<translation id="8393444759658439191">Jelenleg biztonságos Ecosia for Testing-oldalt tekint meg.</translation>
<translation id="1864711229671391928">A Ecosia nem záródott be megfelelően.</translation>
</translationbundle>
