<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="my">
<translation id="130631256467250065">သင် ပြောင်းလဲခဲ့သည်များမျာ သင်က သင်၏ ကိရိယာကို နောက်တစ်ကြိမ် ပြန်ဖွင့်စဉ် အကျိုးသက်ရောက် လာကြပါမည်။</translation>
<translation id="2955914891289756427">Ecosia တွင်ပျက်စီးမှု အစီရင်ခံချက် မရနိုင်ပါ။</translation>
<translation id="2441066927880955410">သင်သည် လုံခြုံသည့် Ecosia စာမျက်နှာကို ကြည့်ရှုနေပါသည်</translation>
<translation id="7085497353580337354">Ecosia သည် ငွေပေးချေနည်းလမ်းများ ဖြည့်သည့် ဆက်တင်များကို ပြင်ဆင်ရန် ကြိုးပမ်းနေသည်။</translation>
<translation id="5104341700462991189">Ecosia လိုဂို</translation>
<translation id="1566733708869146127">Ecosia က ငွေပေးချေနည်းလမ်းများကို ပြင်ရန် ကြိုးပမ်းနေသည်။</translation>
<translation id="7347361780317841252">Ecosia အား <ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> ပွင့်လင်းအရင်းမြစ် စီမံကိန်းနှင့် အခြား <ph name="BEGIN_LINK_OSS"/>ပွင့်လင်း အရင်းမြစ် ဆော့ဝဲ<ph name="END_LINK_OSS"/> မှပြုလုပ်ထားပါသည်။</translation>
<translation id="8920794075861916959">Ecosia မီးနူကို သွားပါ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          &gt;
          LAN ဆက်တင်များ
          ပြီးတော့ "သင်၏ LAN အတွက် ပရောက်စီ ဆာဗာ သုံရန်" ခြစ်ရမည့် အကွက် ရွေးထားမှုကို ပြန်ဖျက်လိုက်ပါ။</translation>
<translation id="5177147493498374715">Ecosia က ဤစာမျက်နှာကို ပိတ်ထားသည်</translation>
<translation id="583128902627777075">သင့် Firewall သို့မဟုတ် ဗိုင်းရပ်စ်ခုခံစနစ် ဆက်တင်များအတွင်း ကွန်ရက်အသုံးပြုရန် Ecosia ကိုခွင့်ပြုပါ။</translation>
<translation id="3913860536599484838">သွားရန်
          Ecosia မီနျူး &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          &gt;
          <ph name="PROXIES_TITLE"/>
          သင့်ပြုပြင်ချက်များကို "no proxy" သို့မဟုတ် "direct" ဟုသတ်မှတ်ပါ။</translation>
<translation id="6182615032232999551">အခြား <ph name="BEGIN_LINK_OSS"/>အခမဲ့ ရင်းမြစ်ဆော့ဖ်ဝဲ<ph name="END_LINK_OSS"/> ဖြင့်လည်း Ecosia ကို ထုတ်လုပ်ထားသည်။</translation>
<translation id="1722634673917783018">Ecosia ကိုသင်နောက်တစ်ကြိမ် ပြန်လည်စတင်လျှင် သင့်ပြောင်းလဲမှုများ အကျိုးသက်ရောက်မှု ရှိမည်ဖြစ်သည်။</translation>
<translation id="4062366803229254216">Ecosia သည် ဆက်လက်တွဲချိတ်ရန် ဘလူးတုသ်သုံးခွင့် 
 လိုပါသည်။ <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="7273712334661186152"><ph name="BEGIN_LINK_CHROMIUM"/>Ecosia<ph name="END_LINK_CHROMIUM"/> အခမဲ့ ရင်းမြစ်ပရောဂျက်ဖြင့် Ecosia ကို ထုတ်လုပ်ထားသည်။</translation>
<translation id="8143058600367874039">Ecosia မီနူးဆီကို သွားပါ &gt;
          <ph name="SETTINGS_TITLE"/>
          &gt;
          <ph name="ADVANCED_TITLE"/>
          ပြီးတော့ "<ph name="NO_PREFETCH_DESCRIPTION"/>"ကို ရွေးပါ။
          ၎င်းက ပြဿနာကို ဖြေရှင်းမပေးနိုင်ခဲ့သော်၊ ပိုပြီး အဆင့်မြင့်သည့် လုပ်ကိုင်မှုအတွက် ဒီရွေးချယ်မှုကို ထပ်ပြီး ရွေးချယ်ရန်ကို ကျွန်ပ်တို့ အကြံပေးလိုပါသည်။</translation>
<translation id="8187289872471304532">သွားမည်
          Applications &gt; System Preferences &gt; Network &gt; Advanced &gt; Proxies
          and deselect any proxies that have been selected.</translation>
<translation id="8393444759658439191">သင်သည် လုံခြုံသည့် Ecosia for Testing စာမျက်နှာကို ကြည့်နေခြင်းဖြစ်သည်</translation>
<translation id="1864711229671391928">Ecosia သည် မှန်ကန်စွာ ပိတ်မသွားခဲ့ပါ။</translation>
</translationbundle>
