<!-- This XML should not be inflated by anything except PromoDialog.java.

     This layout is deeply nested to account for the various bits having to flop orientations
     in landscape.  If these become more frequently used, we should investigate optimizing the
     layout.
-->
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Ecosia : modified bkg-->
    <org.chromium.components.browser_ui.widget.PromoDialogLayout
            android:id="@+id/promo_dialog_layout"
            android:layout_width="@dimen/default_promo_width"
            android:layout_height="@dimen/default_promo_height"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="@drawable/promo_dialog_background"
            app:maxWidthLandscape="@dimen/dialog_max_width"
            app:maxWidthPortrait="@dimen/dialog_max_width" >

        <org.chromium.components.browser_ui.widget.FadingEdgeScrollView
                android:id="@+id/promo_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fadeScrollbars="false" >

            <!-- This layout pivots when the dialog is wider than it is tall. -->
            <!-- Ecosia : Customizing the promo dialog to support Ecosia promos -->
            <LinearLayout
                    android:id="@+id/full_promo_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                <ImageView
                        android:id="@+id/illustration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:ignore="ContentDescription" />

                <org.chromium.components.browser_ui.widget.BoundedLinearLayout
                        android:id="@+id/scrollable_promo_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical"
                        app:maxWidthLandscape="@dimen/promo_dialog_max_content_width"
                        app:maxWidthPortrait="@dimen/promo_dialog_max_content_width" >

                    <TextView
                        android:id="@+id/header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textDirection="locale"
                        android:layout_marginTop="@dimen/promo_dialog_margin"
                        android:layout_marginBottom="@dimen/promo_dialog_margin_bottom"
                        android:textSize="@dimen/promo_header_text_size"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:fontFamily="@font/inter"
                        android:textAppearance="@style/TextAppearance.TextMediumThick" />

                    <LinearLayout
                        android:id="@+id/subheader_layout"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginBottom="0dp"
                        android:orientation="vertical">

                        <!-- Ecosia: adjust default browser promo layout (MOB-1858) -->

                        <TextView
                            android:id="@+id/subheader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textDirection="locale"
                            android:textSize="16sp"
                            android:layout_marginLeft="33dp"
                            android:textColor="@color/ecosia_text_primary"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:id="@+id/subheader_layout_desc"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="0dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/subheader_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="10dp"
                                android:src="@drawable/ecosia_check"/>

                            <org.chromium.ui.widget.TextViewWithClickableSpans
                                android:id="@+id/subheader_desc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textDirection="locale"
                                android:textSize="@dimen/promo_normal_text_size"
                                android:textColor="@color/ecosia_text_secondary"
                                android:fontFamily="@font/inter"
                                android:textStyle="normal" />
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/subheader2LayoutWrapper"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Ecosia: adjust default browser promo layout (MOB-1858) -->

                        <TextView
                            android:id="@+id/subheader2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginLeft="33dp"
                            android:textDirection="locale"
                            android:textSize="16sp"
                            android:textColor="@color/ecosia_text_primary"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/subheader2_check"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/ecosia_check"/>

                            <org.chromium.ui.widget.TextViewWithClickableSpans
                                android:id="@+id/subheader2_desc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textDirection="locale"
                                android:layout_marginStart="10dp"
                                android:textSize="@dimen/promo_normal_text_size"
                                android:textColor="@color/ecosia_text_secondary"
                                android:fontFamily="@font/inter"
                                android:textStyle="normal"
                                style="@style/TextAppearance.TextMedium.Secondary" />

                        </LinearLayout>

                    </LinearLayout>

                </org.chromium.components.browser_ui.widget.BoundedLinearLayout>
            </LinearLayout>

        </org.chromium.components.browser_ui.widget.FadingEdgeScrollView>

        <ViewStub
                android:id="@+id/footer_stub"
                android:layout="@layout/dialog_control_description"
                android:inflatedId="@+id/footer"
                android:layout_margin="@dimen/promo_dialog_padding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        <org.chromium.components.browser_ui.widget.DualControlLayout
                android:id="@+id/button_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:paddingBottom="@dimen/promo_dialog_padding"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="@dimen/promo_dialog_margin_top"
                style="@style/EcosiaButtonStyle"
                app:stackedMargin="@dimen/promo_dialog_stacked_margin" />

    </org.chromium.components.browser_ui.widget.PromoDialogLayout>

</merge>
