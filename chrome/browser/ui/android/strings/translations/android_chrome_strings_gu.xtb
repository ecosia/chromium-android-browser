<translation id="605721222689873409">YY</translation>
<translation id="6059830886158432458">તમારી સ્ટોરી અને પ્રવૃત્તિને અહીં નિયંત્રિત કરો</translation>
<translation id="6070730414166672373">તમારી બેંકનો સંપર્ક કરી રહ્યાં છીએ</translation>
<translation id="8743457252177195690">ચેડાં કરાયેલા પાસવર્ડ ચેક કરવા માટે, તમારા Ecosia એકાઉન્ટમાં સાઇન ઇન કરો</translation>
<translation id="6085886413119427067">સુરક્ષિત કનેક્શન પર વેબસાઇટ સાથે કેવી રીતે કનેક્ટ કરવું તે નક્કી કરે છે</translation>
<translation id="60923314841986378"><ph name="HOURS"/> કલાક બાકી</translation>
<translation id="4188222092625207299">જો Ecosia તમારું ડિફૉલ્ટ શોધ એન્જિન પણ હોય, તો તમને બહેતર અને સંદર્ભ સાથે સંબંધિત સૂચનો જોવા મળશે</translation>
<translation id="6108923351542677676">સેટઅપની પ્રક્રિયા ચાલુ છે...</translation>
<translation id="6112702117600201073">પેજ રિફ્રેશ કરી રહ્યાં છીએ</translation>
<translation id="6122831415929794347">Safe Browsing બંધ કરીએ?</translation>
<translation id="6125864963080902918"><ph name="BEGIN_LINK"/>વધુ વિગતો<ph name="END_LINK"/></translation>
<translation id="6127379762771434464">આઇટમ દૂર કરી</translation>
<translation id="6130303040046284160">ટૅબને નાનું કરો</translation>
<translation id="6137022273846704445"><ph name="APP_NAME"/>ની ભાષા</translation>
<translation id="6138832295072039549">તમારા સાઇટ સેટિંગમાં અહીંથી ફેરફાર કરો</translation>
<translation id="6140912465461743537">દેશ/પ્રદેશ</translation>
<translation id="6142183503755612900">તમે સેટિંગમાં જઈને કોઈપણ સમયે તમારું ડિફૉલ્ટ શોધ એન્જિન બદલી શકો છો</translation>
<translation id="6143892791267458416">\u0020અને <ph name="DAYS_ARCHIVED"/> દિવસ પછી બંધ કરવામાં આવે છે</translation>
<translation id="614890671148262506">આ સાઇટ તરફથી આવતા નોટિફિકેશનને હંમેશાં માટે મંજૂરી આપો</translation>
<translation id="6150320133806434356">બુકમાર્ક સાચવ્યું</translation>
<translation id="2290550434185446550">તમારા Ecosia એકાઉન્ટમાં Ecosia ડેટાનો ઉપયોગ કરવા અને તેને સાચવવા માટે, Ecosia અપડેટ કરો</translation>
<translation id="6154478581116148741">આ ઉપકરણ પરથી તમારા બધા પાસવર્ડને નિકાસ કરવા માટે સેટિંગમાંથી સ્ક્રીન લૉક ચાલુ કરો</translation>
<translation id="3507075813650819517">તમે મુલાકાત લઈ શકો છો એવી સંભાવના ધરાવતા પેજને Ecosia પહેલેથી લોડ કરે છે.</translation>
<translation id="6170675927290506430">નોટિફિકેશનના સેટિંગમાં જાઓ</translation>
<translation id="6186394685773237175">ચેડાં કરાયેલો કોઈ પાસવર્ડ મળ્યો નથી</translation>
<translation id="6192907950379606605">છબીના વર્ણનો મેળવો</translation>
<translation id="6193448654517602979">ટૅબ પસંદ કરો</translation>
<translation id="2561814697058725690">પાસવર્ડ આ ડિવાઇસના Ecosia Password Managerમાં સાચવવામાં આવે છે</translation>
<translation id="6202812185118613467">સિંક શરૂ કરવા ફરી સાઇન ઇન કરો</translation>
<translation id="6205314730813004066">જાહેરાત સંબંધી પ્રાઇવસી</translation>
<translation id="6210748933810148297"><ph name="EMAIL"/> નથી?</translation>
<translation id="6211386937064921208">આ પેજનો પ્રીવ્યૂ કરી રહ્યાં છીએ</translation>
<translation id="6221633008163990886">તમારા બધા પાસવર્ડને નિકાસ કરવા માટે અનલૉક કરો</translation>
<translation id="6232535412751077445">'ટ્રૅક કરશો નહીં’ ને સક્ષમ કરવાનો અર્થ છે કે તમારા બ્રાઉઝિંગ ટ્રાફિકમાં વિનંતી શામેલ કરવામાં આવશે. કોઈ વેબસાઇટ, વિનંતી પર પ્રતિસાદ કરે છે કે નહીં અને વિનંતીનું અર્થઘટન કેવી રીતે કર્યું તેના પર કોઈ પણ અસર આધારિત હોય છે.

ઉદાહરણ તરીકે, કેટલીક વેબસાઇટ, તમે મુલાકાત લીધેલી બીજા વેબસાઇટ પર આધારિત ન હોય તેવી જાહેરાતો તમને બતાવીને આ વિનંતી પર પ્રતિસાદ આપી શકે છે. ઘણી વેબસાઇટ હજી પણ તમારા બ્રાઉઝિંગ ડેટાને ભેગો કરશે અને ઉપયોગ કરશે — ઉદાહરણ તરીકે સુરક્ષાને બહેતર બનાવવા, કન્ટેન્ટ, જાહેરાતો અને ભલામણો આપવા અને રિપોર્ટિંગ આંકડા જનરેટ કરવા માટે.</translation>
<translation id="9030551111748170692">સિંક કરોને ચાલુ કરીને તમારા Ecosia એકાઉન્ટમાં આ ડિવાઇસ પર પાસવર્ડ સાચવો</translation>
<translation id="8542320769345885402">Ecosia પાસવર્ડ મેનેજર</translation>
<translation id="8956153712025611827">તમારો Ecosia ઇતિહાસ અહીં જુઓ</translation>
<translation id="3955276714902709660">{ITEMS_COUNT,plural, =1{1 આઇટમને માત્ર આ ડિવાઇસમાં સાચવવામાં આવી છે. તમારા અન્ય ડિવાઇસમાં તેનો ઉપયોગ કરવા માટે, તેને તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં સાચવો.}one{# આઇટમને માત્ર આ ડિવાઇસમાં સાચવવામાં આવી છે. તમારા અન્ય ડિવાઇસમાં તેનો ઉપયોગ કરવા માટે, તેને તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં સાચવો.}other{# આઇટમને માત્ર આ ડિવાઇસમાં સાચવવામાં આવી છે. તમારા અન્ય ડિવાઇસમાં તેનો ઉપયોગ કરવા માટે, તેને તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં સાચવો.}}</translation>
<translation id="6254139308321626268">તમે કોઈ PDF ફાઇલ જોઈ રહ્યાં છો</translation>
<translation id="6255794742848779505">અમે આ ડિવાઇસ પર પાસવર્ડ સાચવવાની રીત બદલી રહ્યાં છીએ</translation>
<translation id="1713966053055987896">Ecosiaના ટૂલ વડે, તમે સલામત રીતે બ્રાઉઝ કરી શકો છો તેમજ નિયંત્રણ જાળવી શકો છો</translation>
<translation id="6264376385120300461">તેમ છતાં ડાઉનલોડ કરો</translation>
<translation id="6277522088822131679">પેજને પ્રિન્ટ કરવામાં સમસ્યા હતી. કૃપા કરીને ફરીથી પ્રયાસ કરો.</translation>
<translation id="6277722725779679269">કિંમત ટ્રૅક કરી શક્યા નથી</translation>
<translation id="6278428485366576908">થીમ</translation>
<translation id="6284472661216707937">'તમારા બધા ડિવાઇસ પર પાસવર્ડ' શીટ બંધ કરી</translation>
<translation id="6295158916970320988">બધી સાઇટ</translation>
<translation id="6296366034485697675">નિકાસ કરો અને ડિલીટ કરો</translation>
<translation id="6303969859164067831">સાઇન આઉટ કરો અને સિંક બંધ કરો</translation>
<translation id="6312687380483398334">વેબ ઍપ (છોડો)</translation>
<translation id="6315386555979018699">ડિલીટ કરો અને ચાલુ રાખો</translation>
<translation id="6316139424528454185">Android વર્ઝન અસમર્થિત છે</translation>
<translation id="6324916366299863871">શૉર્ટકટમાંમાં ફેરફાર કરો</translation>
<translation id="6324977638108296054">હાઇલાઇટ કરેલી ટેક્સ્ટની લિંક બનાવી શકતા નથી</translation>
<translation id="6324997754869598316">(ભૂલ <ph name="ERROR_CODE"/>)</translation>
<translation id="6333140779060797560"><ph name="APPLICATION"/> મારફતે શેર કરો</translation>
<translation id="6337234675334993532">એન્ક્રિપ્શન</translation>
<translation id="6340526405444716530">મનગમતું બનાવવું</translation>
<translation id="6341580099087024258">ફાઇલો ક્યાં સાચવવી તે પૂછો</translation>
<translation id="6342069812937806050">હમણાં જ</translation>
<translation id="6343495912647200061">{SHIPPING_ADDRESS,plural, =1{<ph name="SHIPPING_ADDRESS_PREVIEW"/>\u2026 અને વધુ <ph name="NUMBER_OF_ADDITIONAL_ADDRESSES"/>}one{<ph name="SHIPPING_ADDRESS_PREVIEW"/>\u2026 અને વધુ <ph name="NUMBER_OF_ADDITIONAL_ADDRESSES"/>}other{<ph name="SHIPPING_ADDRESS_PREVIEW"/>\u2026 અને વધુ <ph name="NUMBER_OF_ADDITIONAL_ADDRESSES"/>}}</translation>
<translation id="6344622098450209924">ટ્રૅકિંગ સંબંધિત સુરક્ષા</translation>
<translation id="6345878117466430440">વાંચેલાં તરીકે માર્ક કરો</translation>
<translation id="6356893102071098867">ચેક કરો કે તમે યોગ્ય એકાઉન્ટ પસંદ કર્યું હોય</translation>
<translation id="6357653805084533597">આ QR કોડ બતાવતા હોય એવા ડિવાઇસ પર સાઇન ઇન કરવા માટે તમે આ ફોનનો ઉપયોગ કરી શકો છો.</translation>
<translation id="6363990818884053551">સિંક કરવાનું શરૂ કરવા માટે, આ તમે જ છો તેની ચકાસણી કરો</translation>
<translation id="6364438453358674297">ઇતિહાસમાંથી સૂચનને દૂર કરીએ?</translation>
<translation id="7883162387525205133">તમે મુલાકાત લઈ શકો છો એવી સંભાવના ધરાવતા પેજને Ecosia વારંવાર પહેલેથી લોડ કરે છે. આ સેટિંગના પરિણામે ડેટાનો વપરાશ વધી શકે છે.</translation>
<translation id="6382848304055775421">નિકાસ કરી રહ્યાં છીએ</translation>
<translation id="6394791151443660613">આ શોધો: <ph name="SEARCH_QUERY"/></translation>
<translation id="6395288395575013217">લિંક</translation>
<translation id="6397616442223433927">પાછા ઑનલાઇન થયા</translation>
<translation id="7910546815062942242">આ ટૅબને અન્ય ડિવાઇસ પર મોકલવા માટે, એ ડિવાઇસના Ecosiaમાં સાઇન ઇન કરો</translation>
<translation id="6404511346730675251">બુકમાર્કમાં ફેરફાર કરો</translation>
<translation id="6406506848690869874">સમન્વયન</translation>
<translation id="6407224748847589805">તમારા કમ્પ્યુટર સાથે કનેક્ટ કરી શકાતું નથી. ચકાસણી માટે બીજો કોઈ વિકલ્પ અજમાવો.</translation>
<translation id="6410883413783534063">એકસાથે વિભિન્ન પેજની મુલાકાત લેવા માટે ટૅબ ખોલો</translation>
<translation id="6411219469806822692">વધુ ઉપર જઈ શકાતું નથી. પેજ પર વધુ ઉપરથી શરૂ કરીને જુઓ.</translation>
<translation id="641643625718530986">પ્રિન્ટ…</translation>
<translation id="6433501201775827830">તમારું શોધ એન્જિન પસંદ કરો</translation>
<translation id="6434309073475700221">કાઢી નાખો</translation>
<translation id="6437162790453527153">તમારા બધા ડિવાઇસ પર બુકમાર્ક જેવું બીજું ઘણું મેળવવા માટે, સાઇન ઇન કરો</translation>
<translation id="6437478888915024427">પેજ વિશે માહિતી</translation>
<translation id="6440291723980579689">તમે પેજને ખોલશો, પછી જ તે લોડ થાય છે</translation>
<translation id="6441734959916820584">નામ ખૂબ લાંબું છે</translation>
<translation id="6444291413624515012"><ph name="TAB_GROUP_TITLE"/> ટૅબનું ગ્રૂપ બંધ છે</translation>
<translation id="6459045781120991510">સર્વેક્ષણો</translation>
<translation id="6461962085415701688">ફાઇલ ખોલી શકતાં નથી</translation>
<translation id="5504232386758737133">તમે Ecosiaમાં મુલાકાત લીધેલી સાઇટ જોઈ શકશો અને તેના માટે ટાઇમર પણ સેટ કરી શકશો.\n\nતમે જે સાઇટ માટે ટાઇમર સેટ કરો છો અને કેટલા સમય માટે તેની મુલાકાત લો છો, તે માહિતી Ecosia મેળવે છે. આ માહિતી ડિજિટલ લાઇફસ્ટાઇલને બહેતર બનાવવા માટે ઉપયોગમાં લેવામાં આવે છે.</translation>
<translation id="535992304319290111"><ph name="APP_LABEL"/>નો ઉપયોગ કરતી વખતે તમે Ecosiaમાં ખોલેલાં પેજ અહીં દેખાશે.</translation>
<translation id="6473086018775716761">શેરિંગના વિકલ્પોની સૂચિ અડધી ઊંચાઈએ ખોલી છે.</translation>
<translation id="6475951671322991020">વીડિયો ડાઉનલોડ કરો</translation>
<translation id="6477928892249167417">આ સાઇટ તમારા માટે મહત્ત્વની લાગી રહી છે:</translation>
<translation id="5160517989930908435">મનગમતું બનાવવા અને અન્ય હેતુઓ માટે, Ecosia અને Ecosiaની અન્ય સેવાઓ લિંક કરો</translation>
<translation id="6482749332252372425">સ્ટોરેજ સ્થાનના અભાવના કારણે <ph name="FILE_NAME"/> ડાઉનલોડ નિષ્ફળ થયું.</translation>
<translation id="6486420406192123355">આ PDF ફાઇલ અસુરક્ષિત કનેક્શનનો ઉપયોગ કરતી સાઇટમાંથી છે</translation>
<translation id="6495590690749880440">ટૅબનું ગ્રૂપ ખોલીએ?</translation>
<translation id="650224091954855786">{FILE_COUNT,plural, =1{ફાઇલ ડાઉનલોડ કરી}one{# ડાઉનલોડ પૂર્ણ થયું}other{# ડાઉનલોડ પૂર્ણ થયા}}</translation>
<translation id="4525002165099402655">Ecosia ને પુનઃપ્રારંભ કરો</translation>
<translation id="6518133107902771759">પ્રમાણિત કરો</translation>
<translation id="6527303717912515753">શેર કરો</translation>
<translation id="4807131777456852390">Ecosia ઇતિહાસ</translation>
<translation id="5919399692892722834">Ecosiaમાં તમે મુલાકાત લીધેલી સાઇટ બતાવવામાં આવશે નહીં. સાઇટના બધા ટાઇમર ડિલીટ કરવામાં આવશે.</translation>
<translation id="8947538792884653984">પ્રતિભાવ આપવા માટે Ecosiaએ ઘણો સમય લીધો</translation>
<translation id="6539092367496845964">કંઈક ખોટું થયું હતું. થોડીવાર પછી ફરી પ્રયાસ કરો.</translation>
