<translation id="6883906387682976294">આ સાઇટમાંથી નોટિફિકેશનને અનસબ્સ્ક્રાઇબ કરો</translation>
<translation id="688398477366397178">તમે જે ભાષાઓ બોલો છો તે વેબસાઇટને જણાવો. જ્યારે શક્ય હશે, ત્યારે તેઓ તે ભાષાઓમાં કન્ટેન્ટ બતાવશે.</translation>
<translation id="6885933993535178919">{NUM_SITES,plural, =1{1 સાઇટમાંથી અનસબ્સ્ક્રાઇબ કરો}one{# સાઇટમાંથી અનસબ્સ્ક્રાઇબ કરો}other{# સાઇટમાંથી અનસબ્સ્ક્રાઇબ કરો}}</translation>
<translation id="6886500155621657325">{ITEMS_COUNT,plural, =1{1 પાસવર્ડ}one{# પાસવર્ડ}other{# પાસવર્ડ}}</translation>
<translation id="4695303165601859581">તમે સાઇન આઉટ કરો ત્યારબાદ તમારા Ecosia એકાઉન્ટમાંના તમારા બુકમાર્ક, પાસવર્ડ વગેરેને આ ડિવાઇસમાંથી કાઢી નાખવામાં આવશે.</translation>
<translation id="688738109438487280">અસ્તિત્વમાંના ડેટાને <ph name="TO_ACCOUNT"/> માં ઉમેરો.</translation>
<translation id="6891726759199484455">તમારો પાસવર્ડ કૉપિ કરવા માટે અનલૉક કરો</translation>
<translation id="6896758677409633944">કૉપિ કરો</translation>
<translation id="5231851830766522243">તમારા Ecosia એકાઉન્ટમાંનો Ecosiaનો બધો ડેટા એન્ક્રિપ્ટ કરવા માટે તમારા પોતાના પાસફ્રેઝનો ઉપયોગ કરો</translation>
<translation id="6900532703269623216">વધારેલું સંરક્ષણ</translation>
<translation id="6903907808598579934">સમન્વયન ચાલુ કરો</translation>
<translation id="3562892488571021413">ખાતરી કરો કે તમે હંમેશાં તમારા Ecosia એકાઉન્ટમાં પાસવર્ડનો ઉપયોગ કરી શકો</translation>
<translation id="6908230663105268638"><ph name="SITE_NAME"/> માટે નોટિફિકેશનની મંજૂરી આપેલી છે</translation>
<translation id="6908998565271542516">કોઈ વેબસાઇટને પૂરી ઊંચાઈ સુધી ખોલવાની મંજૂરી આપવાનો અથવા ન આપવાનો વિકલ્પ</translation>
<translation id="6909589135458168665">પહેલેથી લોડ કરેલા પેજ</translation>
<translation id="6910211073230771657">કાઢી નાખ્યું</translation>
<translation id="6918398787259831832">જો આ સમસ્યા આવવાનું ચાલુ રહે, તો <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/>માંથી <ph name="BEGIN_LINK"/>વધુ માહિતી મેળવો<ph name="END_LINK"/>.</translation>
<translation id="3418461046616805755"><ph name="PERMISSION"/> <ph name="SEPARATOR"/> Ecosia દ્વારા આ પરવાનગીઓ કાઢી નાખવામાં આવી કારણ કે તમે તાજેતરમાં મુલાકાત લીધી ન હતી</translation>
<translation id="774426900652550245">તમારા ડિવાઇસ અને તમારા Ecosia એકાઉન્ટમાં સાચવવામાં આવેલા બધા સુરક્ષા કોડ ડિલીટ કરવામાં આવશે</translation>
<translation id="6937524809504266803">મનગમતું બનાવવું અને લિંક કરવું</translation>
<translation id="6937876069006524083">ઉપનામ (વૈકલ્પિક)</translation>
<translation id="6942665639005891494">સેટિંગ મેનૂ વિકલ્પનો ઉપયોગ કરીને ડિફૉલ્ટ ડાઉનલોડ સ્થાનને કોઈપણ સમયે બદલો</translation>
<translation id="694267552845942083">તમે હાલમાં તમારા સિંક સેટિંગને કસ્ટમાઇઝ કરી રહ્યાં છો. સિંક ચાલુ કરવાનું પૂર્ણ કરવા માટે, સ્ક્રીનની નીચેની બાજુએ કન્ફર્મ કરો બટન પર ટૅપ કરો. ઉપર નૅવિગેટ કરો</translation>
<translation id="6945221475159498467">પસંદ કરો</translation>
<translation id="6955535239952325894">મેનેજ કરાયેલા બ્રાઉઝર પર આ સેટિંગ બંધ કરવામાં આવ્યું છે</translation>
<translation id="6963766334940102469">બુકમાર્ક ડિલીટ કરો</translation>
<translation id="6964300328304469089">હાલમાં <ph name="NAME"/>, <ph name="EMAIL"/> પસંદ કર્યું છે. એકાઉન્ટ પસંદ કરો.</translation>
<translation id="696447261358045621">છૂપો મોડ છોડો</translation>
<translation id="6965382102122355670">બરાબર, સમજાઇ ગયું</translation>
<translation id="6966660124354134532">કોઈ પ્રોડક્ટને ટ્રૅક કરવા કે ટ્રૅક કરવાનું બંધ કરવા માટે ટૅપ કરો.</translation>
<translation id="6971862865055170158">મંજૂરી આપશો નહીં</translation>
<translation id="6978717888677691380">તમે બ્લૉક કરેલી સાઇટ</translation>
<translation id="6979737339423435258">હંમેશાં</translation>
<translation id="6987047470128880212">છૂપી ટૅબ આ ડિવાઇસ પર ઉપલબ્ધ નથી</translation>
<translation id="6965850010249179378">તમારા પાસવર્ડ CSV ફાઇલ તરીકે ડાઉનલોડ કરવામાં આવશે. ઍપ સહિત ફાઇલને ઍક્સેસ કરી શકતી કોઈપણ વ્યક્તિ તેમને જોઈ શકશે. નિકાસ કરેલા પાસવર્ડ Ecosiaમાંથી ડિલીટ કરવામાં આવશે.</translation>
<translation id="6996145122199359148">આ પેજ ડાઉનલોડ કરો</translation>
<translation id="7013762323294215682">આ પાસકી તમારા Password Managerમાં સાચવવામાં આવશે. આ પાસકીની ઍક્સેસ ધરાવનારી કોઈપણ વ્યક્તિ તેનો ઉપયોગ કરી શકશે.</translation>
<translation id="7020741890149022655">વાંચન સૂચિમાં ઉમેરો <ph name="BEGIN_NEW"/>નવું<ph name="END_NEW"/></translation>
<translation id="7022756207310403729">બ્રાઉઝરમાં ખોલો</translation>
<translation id="7025769836128625875">આ એક પ્રાયોગિક AI સુવિધા છે અને તે હંમેશાં સચોટ ન હોઈ શકે. <ph name="BEGIN_LINK"/>વધુ જાણો<ph name="END_LINK"/></translation>
<translation id="7027549951530753705"><ph name="ITEM_TITLE"/> રિસ્ટોર કર્યું</translation>
<translation id="7029809446516969842">પાસવર્ડ</translation>
<translation id="7035701931849773472">અન્ય વિકલ્પો</translation>
<translation id="7053983685419859001">અવરોધિત કરો</translation>
<translation id="7054588988317389591">છબીના વર્ણનો મેળવીએ?</translation>
<translation id="7055152154916055070">રીડાયરેક્ટ કરવાનું બ્લૉક કરવામાં આવ્યું છે:</translation>
<translation id="957879804052862322">સંપૂર્ણ Ecosia ઇતિહાસ ખોલો</translation>
<translation id="7063006564040364415">સમન્વયન સર્વર સાથે કનેક્ટ કરી શકાયું નથી</translation>
<translation id="7071521146534760487">એકાઉન્ટને મેનેજ કરો</translation>
<translation id="707155805709242880">શું સિંક કરવું તે નીચે પસંદ કરો</translation>
<translation id="707702207692430409">{BOOKMARK_COUNT,plural, =1{તમારા એકાઉન્ટ, <ph name="ACCOUNT_EMAIL"/>માં "<ph name="FOLDER_NAME"/>"માં બુકમાર્ક સાચવવામાં આવ્યું.}one{તમારા એકાઉન્ટ, <ph name="ACCOUNT_EMAIL"/>માં "<ph name="FOLDER_NAME"/>"માં બુકમાર્ક સાચવવામાં આવ્યું.}other{તમારા એકાઉન્ટ, <ph name="ACCOUNT_EMAIL"/>માં "<ph name="FOLDER_NAME"/>"માં બુકમાર્ક સાચવવામાં આવ્યા.}}</translation>
<translation id="7077143737582773186">SD કાર્ડ</translation>
<translation id="367768781427598154">આ ડિવાઇસમાંનો તમારો Ecosia ડેટા પણ ડિલીટ કરો</translation>
<translation id="3198203037316384981">Ecosiaની સેવાઓમાં વધુ મનગમતા બનાવેલા અનુભવો આપવા માટે, Ecosia ઇતિહાસ શામેલ કરવો કે નહીં, તે પસંદ કરો</translation>
<translation id="3668984177324025605">Ecosia અપ ટૂ ડેટ છે</translation>
<translation id="7094933634769755999">અચોક્કસ</translation>
<translation id="7105047059074518658">તમામ ડિવાઇસ પર વધુ સરળતાથી બ્રાઉઝ કરવા માટે સાઇન ઇન કરો</translation>
<translation id="7106762743910369165">તમારી સંસ્થા દ્વારા તમારું બ્રાઉઝર મેનેજ કરવામાં આવે છે</translation>
<translation id="2599470265570291167">તમે જુઓ છો તે જાહેરાતો માટે Ecosia તમને વધુ નિયંત્રણો આપે છે અને સાઇટ તમને મનગમતી બનાવેલી જાહેરાતો બતાવે ત્યારે તે તમારા વિશે શું જાણી શકે છે તેને મર્યાદિત કરે છે.</translation>
<translation id="7136902389402789299">{NUM_SITES,plural, =1{1 સાઇટની પરવાનગીઓનો રિવ્યૂ કર્યો}one{# સાઇટની પરવાનગીઓનો રિવ્યૂ કર્યો}other{# સાઇટની પરવાનગીઓનો રિવ્યૂ કર્યો}}</translation>
<translation id="7138678301420049075">અન્ય</translation>
<translation id="7140829094791862589">મેન્યુઅલ ક્રમે સૉર્ટ કરો</translation>
<translation id="7146622961999026732">આ સાઇટ અને ઍપ તમારા માટે મહત્ત્વના લાગી રહ્યાં છે:</translation>
<translation id="7148400116894863598"><ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/>માંથી <ph name="BEGIN_LINK"/>વધુ માહિતી મેળવો<ph name="END_LINK"/>.</translation>
<translation id="7149893636342594995">છેલ્લા 24 કલાક</translation>
<translation id="7489955933719041273">પાસફ્રેઝ એન્ક્રિપ્શનમાં Ecosia Payની ચુકવણી પદ્ધતિઓ અને સરનામા શામેલ હોતા નથી.

આ સેટિંગ બદલવા માટે, <ph name="BEGIN_LINK"/>તમારા એકાઉન્ટમાંનો Ecosia ડેટા ડિલીટ કરો<ph name="END_LINK"/>.</translation>
<translation id="7161230316646448869">બધા ડિવાઇસ પર તમારા બુકમાર્ક, ઇતિહાસ અને વધુ સિંક કરો</translation>
<translation id="7168323970702333693"><ph name="USER_NAME"/> તરીકે સાઇન ઇન થયા. સેટિંગ ખોલે છે.</translation>
<translation id="7173114856073700355">સેટિંગ ખોલો</translation>
<translation id="7173338713290252554">સમગ્ર વેબ પર કિંમતનો ઇતિહાસ</translation>
<translation id="7177466738963138057">તમે આને થોડા સમય પછી સેટિંગમાં જઈને બદલી શકો છો</translation>
<translation id="7177873915659574692">QR કોડ બનાવી શકતાં નથી. URL <ph name="CHARACTER_LIMIT"/>થી વધુ અક્ષરો ધરાવે છે.</translation>
<translation id="7180611975245234373">રિફ્રેશ કરો</translation>
<translation id="7182051712900867547">કોઈ અલગ એકાઉન્ટનો ઉપયોગ કરો</translation>
<translation id="7183517696921903380">ઍપ ફિલ્ટર શીટ ખુલ્લી છે.</translation>
<translation id="7183693674623539380">ટૅબનું ગ્રૂપ - <ph name="TITLE_OF_GROUP"/></translation>
<translation id="168235947103475509">Ecosiaની તમામ સેવાઓમાં તમારા અન્ય ડેટા સાથે બ્રાઉઝિંગ ઇતિહાસનો ઉપયોગ કેવી રીતે થાય તે નિયંત્રિત કરો</translation>
<translation id="7191430249889272776">ટૅબ બૅકગ્રાઉન્ડમાં ખોલવામાં આવી છે.</translation>
<translation id="7192397795254933433">{NUM_PASSWORDS,plural, =1{તમારે હમણાં જ આ બદલવો જોઈએ}one{તમારે હમણાં જ આ બદલવો જોઈએ}other{તમારે હમણાં જ આ બદલવા જોઈએ}}</translation>
<translation id="7196215469483532480">પ્રાઇવસી સંબંધિત માર્ગદર્શિકાની સમજૂતી પૂરી ઊંચાઈ સુધી ખોલી છે</translation>
<translation id="4541072205817472223">બાળકો માટે Ecosiaનું કન્ટેન્ટ - બંધ છે</translation>
<translation id="7207760545532569765"><ph name="TAB_COUNT"/> ટૅબને નવી બૅકગ્રાઉન્ડ ટૅબ તરીકે રિસ્ટોર કરો.</translation>
<translation id="4213475784010618648">જ્યારે તમે Ecosia છોડશો, ત્યારે છૂપી ટૅબ લૉક થઈ જશે</translation>
<translation id="7221869452894271364">આ પેજને ફરીથી લોડ કરો</translation>
<translation id="7377345817883064067">Ecosia અને <ph name="CHROME_CHANNEL"/> માટે માત્ર આ ડિવાઇસમાં સચવાયેલા બધા પાસવર્ડ મર્જ કરવામાં આવ્યા. તમે બન્ને ઍપ પર સાચવેલા તમારા બધા પાસવર્ડ ઑટોમૅટિક રીતે ભરી શકો છો.</translation>
<translation id="7227218174981371415">{FILE_COUNT,plural, =1{1 ડાઉનલોડ બાકી}one{# ડાઉનલોડ બાકી}other{# ડાઉનલોડ બાકી}}</translation>
<translation id="7230064152164845085">છૂપા મોડ પર સ્વિચ કરો</translation>
<translation id="72415438529550637">પાસવર્ડ સૂચવવાની સુવિધા બંધ છે.</translation>
<translation id="7252076891734325316">તમારા ફોનને કમ્પ્યુટરની નજીક રાખો</translation>
<translation id="7746113300198616534">તમારા Android ડિવાઇસમાં કદાચ આ જ સેટિંગ શામેલ હોઈ શકે. જો Ecosiaમાં અને તમારા Android ડિવાઇસ પર જાહેરાત માપણીની સુવિધા ચાલુ કરેલી હોય, તો કંપની તમે મુલાકાત લો છો તેવી સમગ્ર વેબસાઇટ પર અને તમે ઉપયોગ કરો છો તેવી ઍપ પર જાહેરાતની અસરકારકતાની માપણી કરી શકે છે.</translation>
<translation id="727288900855680735"><ph name="ONE_TIME_CODE"/>ને <ph name="ORIGIN"/> પર સબમિટ કરીએ?</translation>
<translation id="7274013316676448362">અવરોધિત સાઇટ</translation>
<translation id="6227253381946134794">Ecosia 4 અઠવાડિયાથી વધુ જૂના વિષયોને ઑટોમૅટિક રીતે ડિલીટ કરે છે. જેમ-જેમ તમે બ્રાઉઝ કરતા જશો, તેમ-તેમ સૂચિમાં કોઈ વિષય ફરીથી દેખાઈ શકે છે. અથવા અન્ય સાઇટ સાથે Ecosia શેર ન કરે એવું જો તમે ઇચ્છતા હો, તો તમે તેવા વિષયોને બ્લૉક કરી શકો છો. <ph name="BEGIN_LINK"/>Ecosiaમાં તમારી જાહેરાત સંબંધિત પ્રાઇવસી મેનેજ કરવા<ph name="END_LINK"/> વિશે વધુ જાણો.</translation>
<translation id="1093466113453425743">જેમ-જેમ તમે ટાઇપ કરો, તેમ-તેમ Ecosia ઍડ્રેસ બાર અથવા શોધ બૉક્સનું કન્ટેન્ટ તમારા ડિફૉલ્ટ શોધ એન્જિનને મોકલે છે</translation>
<translation id="5936018754638445903">તમે Ecosiaની સૌથી સશક્ત સુરક્ષા ધરાવો છો</translation>
<translation id="7289303553784750393">જો તમે ઑનલાઇન હો પરંતુ આ સમસ્યા આવવાનું ચાલુ રહે, તો તમે <ph name="SITE_ETLD_PLUS_ONE"/> પર ચાલુ રાખવા માટે અન્ય રીતો અજમાવી શકો છો.</translation>
<translation id="7290209999329137901">નામ બદલવું ઉપલબ્ધ નથી</translation>
<translation id="7291910923717764901">આ પેજ માટે છબીના વર્ણનો ઉમેર્યા</translation>
<translation id="7293429513719260019">ભાષા પસંદ કરો</translation>
<translation id="729975465115245577">તમારા ઉપકરણ પાસે પાસવર્ડ ફાઇલને સ્ટોર કરવા માટેની ઍપ નથી.</translation>
<translation id="6341784462006514012">તમારા Android ડિવાઇસમાં કદાચ આના જેવું કોઈ સેટિંગ શામેલ હોઈ શકે. જો Ecosiaમાં અને તમારા Android ડિવાઇસ પર આ સેટિંગ ચાલુ કરેલું હોય, તો કંપની તમે મુલાકાત લો છો તેવી સમગ્ર વેબસાઇટ પર અને તમે ઉપયોગ કરો છો તેવી ઍપ પર જાહેરાતની અસરકારકતાની માપણી કરી શકે છે.</translation>
<translation id="6771275120898607766">{PASSWORDS_COUNT,plural, =1{1 પાસવર્ડને માત્ર આ ડિવાઇસમાં સાચવવામાં આવ્યો છે. તમારા અન્ય ડિવાઇસમાં તેનો ઉપયોગ કરવા માટે, તેને તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં સાચવો.}one{# પાસવર્ડને માત્ર આ ડિવાઇસમાં સાચવવામાં આવ્યો છે. તમારા અન્ય ડિવાઇસમાં તેનો ઉપયોગ કરવા માટે, તેને તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં સાચવો.}other{# પાસવર્ડને માત્ર આ ડિવાઇસમાં સાચવવામાં આવ્યા છે. તમારા અન્ય ડિવાઇસમાં તેનો ઉપયોગ કરવા માટે, તેને તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં સાચવો.}}</translation>
<translation id="7772269964949115688">ઑફલાઇન. Ecosia તમારા પાસવર્ડ ચેક કરી શકતું નથી.</translation>
<translation id="7313188324932846546">સિંકની સુવિધા સેટઅપ કરવાનો પ્રયાસ કરો</translation>
<translation id="7324354302972299151">“Do Not Track"ની વિનંતી મોકલો</translation>
<translation id="7332075081379534664">સાઇન-ઇન કરવામાં સફળ રહ્યાં</translation>
<translation id="7333041109965360609">નોટિફિકેશનમાંથી અનસબ્સ્ક્રાઇબ કર્યું</translation>
<translation id="6289104048607747048">Ecosiaનું સૌથી વધુ સંબંધિત કન્ટેન્ટ મેળવવા માટે સિંક કરો</translation>
<translation id="7336259382292148213">બરાબર લાગે છે</translation>
<translation id="7339898014177206373">નવી વિન્ડો</translation>
<translation id="7340958967809483333">Discover માટેના વિકલ્પો</translation>
<translation id="7352339641508007922">લાંબો સ્ક્રીનશૉટ લેવા માટે ખેંચો</translation>
<translation id="7352651011704765696">કંઈક ખોટું થયું હતું</translation>
<translation id="7352939065658542140">વીડિયો</translation>
<translation id="7353894246028566792">{NUM_SELECTED,plural, =1{પસંદ કરેલ 1 આઇટમ શેર કરો}one{પસંદ કરેલ # આઇટમ શેર કરો}other{પસંદ કરેલ # આઇટમ શેર કરો}}</translation>
<translation id="7359002509206457351">ચુકવણી પદ્ધતિઓને ઍક્સેસ કરો</translation>
<translation id="7363349185727752629">તમારી પ્રાઇવસીની પસંદગીઓની માર્ગદર્શિકા</translation>
<translation id="7364103838544876661">બ્રાઉઝિંગ ડેટા ડિલીટ કરવા માટેના વધુ વિકલ્પો</translation>
<translation id="7375125077091615385">પ્રકાર:</translation>
<translation id="7376560087009844242">પેજની વધુ ટેક્સ્ટને શામેલ કરીને, 'શોધવા માટે ટચ કરો'માં તમે કદાચ બહેતર પરિણામો જોઈ શકશો. આમાં ફેરફાર કરવા માટે, તમે કોઈપણ સમયે <ph name="BEGIN_LINK"/>સેટિંગ<ph name="END_LINK"/>ની મુલાકાત લઈ શકો છો.</translation>
<translation id="7379900596734708416">સાઇટ માટેની ઘેરી થીમ ઉપલબ્ધ છે</translation>
<translation id="7388615499319468910">જાહેરાતોના પર્ફોર્મન્સ સંબંધી બાબતો સાઇટ અને જાહેરાતકર્તાઓ સમજી શકે છે. આ સેટિંગ બંધ છે.</translation>
<translation id="7400003506822844357">{FILE_COUNT,plural, =1{સૂચિમાં અન્ય 1 ફાઇલ છે}one{સૂચિમાં અન્ય # ફાઇલ છે}other{સૂચિમાં અન્ય # ફાઇલ છે}}</translation>
<translation id="7400418766976504921">URL</translation>
<translation id="4389314006449194072">Ecosia પ્રથમ વાર ઉપયોગ કર્યાનો અનુભવ</translation>
<translation id="2880126334528443983">Ecosia એકાઉન્ટ વપરાશકર્તા</translation>
<translation id="741204030948306876">હા, હું સંમત છું</translation>
<translation id="7419565702166471774">હંમેશાં સુરક્ષિત કનેક્શનનો ઉપયોગ કરો</translation>
<translation id="7431991332293347422">શોધ અને અન્ય બાબતોને તમને મનગમતી બનાવવા માટે તમારા બ્રાઉઝિંગ ઇતિહાસનો ઉપયોગ કરવાની રીત નિયંત્રિત કરો</translation>
<translation id="7435356471928173109">તમારા વ્યવસ્થાપક દ્વારા આ સુવિધા બંધ કરવામાં આવી છે</translation>
<translation id="2421263730139898714">Ecosiaમાંથી સાઇન આઉટ કરો</translation>
<translation id="8869845956664841796">તમને મોટાભાગની સાઇટમાંથી સાઇન આઉટ કરે છે. તમે તમારા Ecosia એકાઉન્ટમાંથી સાઇન આઉટ નહીં થાઓ.</translation>
<translation id="7453810262525006706">બાજુના વ્યૂને નાનું કરો</translation>
<translation id="7454641608352164238">પર્યાપ્ત જગ્યા નથી</translation>
<translation id="7454744349230173024">તમારી સંસ્થા દ્વારા પાસવર્ડ સાચવવાનું બંધ કરવામાં આવ્યું છે</translation>
<translation id="7455988709578031708">તમારા બ્રાઉઝિંગ ઇતિહાસના આધારે. આ સેટિંગ ચાલુ છે.</translation>
<translation id="7456774706094330779">પહેલેથી લોડ કરવાનો વિસ્તૃત મોડ</translation>
<translation id="7466328545712777810">જો કોઈપણ સાઇટ પર કિંમતમાં ઘટાડો થાય, તો તમને નોટિફિકેશન મળશે</translation>
<translation id="7466431077154602932">કૉમ્પેક્ટ વ્યૂ</translation>
<translation id="7474822150871987353">પેજને છોડ્યા વિના વેબસાઇટ પરના વિષયો વિશે જાણો. પેજ પરના એક કે તેનાથી વધુ શબ્દોની શોધ કરવા માટે તેમને પસંદ કરો.</translation>
<translation id="7475192538862203634">જો તમે આ વારંવાર જોઈ રહ્યાં છો, તો આ <ph name="BEGIN_LINK"/>સૂચનો<ph name="END_LINK"/>ને અજમાવી જુઓ.</translation>
<translation id="7475688122056506577">SD કાર્ડ મળ્યું નથી. તમારી અમુક ફાઇલો ખૂટતી હોઈ શકે છે.</translation>
<translation id="7479104141328977413">ટૅબ મેનેજમેન્ટ</translation>
<translation id="7481312909269577407">ફોર્વર્ડ કરો</translation>
<translation id="7482656565088326534">પ્રીવ્યૂ ટૅબ</translation>
<translation id="7484997419527351112">Discover - બંધ</translation>
<translation id="7485033510383818941">ફીડનું કન્ટેન્ટ રિફ્રેશ કરવા માટે, પેજ પર નીચેની તરફ સ્વાઇપ કરો</translation>
<translation id="5134450672222694011">Ecosia Lens આ ડિવાઇસ પર ઉપલબ્ધ નથી</translation>
<translation id="7493994139787901920"><ph name="VERSION"/> (અપડેટ કર્યું <ph name="TIME_SINCE_UPDATE"/>)</translation>
<translation id="7497755084107113646">આ વિષયને સંભવિત વિષયોની સૂચિમાં પાછો ઉમેરવામાં આવ્યો છે</translation>
<translation id="7498271377022651285">કૃપા કરીને રાહ જુઓ…</translation>
<translation id="1543666170923152009">બધી વેબસાઇટ પર તમારા Ecosia એકાઉન્ટમાંથી સાઇન આઉટ કરવા માટે, <ph name="BEGIN_LINK1"/>Ecosiaમાંથી સાઇન આઉટ કરો<ph name="END_LINK1"/>.</translation>
<translation id="750228856503700085">અપડેટ અનુપલબ્ધ છે</translation>
<translation id="7507207699631365376">આ પ્રદાતાની <ph name="BEGIN_LINK"/>પ્રાઇવસી પૉલિસી<ph name="END_LINK"/> જુઓ</translation>
<translation id="7514365320538308">ડાઉનલોડ કરો</translation>
<translation id="5884056559808821062">તમારા Ecosia એકાઉન્ટમાં પાસવર્ડ માટે Ecosiaના ડિફૉલ્ટ એન્ક્રિપ્શનનો ઉપયોગ કરો</translation>
<translation id="7518079994230200553">આ વિકલ્પ અત્યારે અનુપલબ્ધ છે.</translation>
<translation id="751961395872307827">સાઇટ સાથે કનેક્ટ કરી શકાતું નથી</translation>
<translation id="752220631458524187">તમારું કામ પૂર્ણ થાય ત્યારે એટલે ડિસ્કનેક્ટ કરો</translation>
<translation id="2741811083151548841">Ecosia Lensનો ઉપયોગ કરીને તમારા કૅમેરા વડે શોધો</translation>
<translation id="7525248386620136756"><ph name="TAB_GROUPS_AND_TABS_PART"/> બંધ છે અને સાચવ્યું છે</translation>
<translation id="752731652852882757">છૂપા મોડનો ઉપયોગ કરતી વખતે બ્લૉક કરો</translation>
<translation id="4398163776074393810">Ecosiaનું વર્ઝન ચેક કરી શકાતું નથી</translation>
<translation id="7557508262441527045">સાઇન આઉટ કર્યું</translation>
<translation id="7577900504646297215">રુચિઓ મેનેજ કરો</translation>
<translation id="757855969265046257">{FILES,plural, =1{<ph name="FILES_DOWNLOADED_ONE"/> ફાઇલ ડાઉનલોડ કરી}one{<ph name="FILES_DOWNLOADED_MANY"/> ફાઇલ ડાઉનલોડ કરી}other{<ph name="FILES_DOWNLOADED_MANY"/> ફાઇલ ડાઉનલોડ કરી}}</translation>
<translation id="7581273696622423628">સર્વેક્ષણમાં ભાગ લો</translation>
<translation id="7583262514280211622">તમને તમારી વાંચન સૂચિ અહીં મળશે</translation>
<translation id="758603037873046260">આ પેજ સાચવવા માટે, સાઇન ઇન કરો</translation>
<translation id="7588219262685291874">જ્યારે તમારા ડિવાઇસનું બૅટરી સેવર ચાલુ હોય ત્યારે ઘેરી થીમ ચાલુ કરો</translation>
