<translation id="3120688161506885479">Ecosiaનો તમારી રીતે ઉપયોગ કરો</translation>
<translation id="8664979001105139458">ફાઇલનું નામ પહેલેથી અસ્તિત્વમાં છે</translation>
<translation id="8676276370198826499"><ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/> વડે <ph name="SITE_ETLD_PLUS_ONE"/> માટે સાઇન અપ કરો</translation>
<translation id="8676789164135894283">સાઇન ઇન માટેની ચકાસણીઓ</translation>
<translation id="8683039184091909753">છબી</translation>
<translation id="869891660844655955">સમાપ્તિ તારીખ</translation>
<translation id="8699120352855309748">આ ભાષાઓનો અનુવાદ કરવાનું ઑફર કરશો નહીં</translation>
<translation id="8712637175834984815">સમજાઈ ગયું</translation>
<translation id="8723453889042591629">આ પેજનો ઝડપથી અનુવાદ કરો. આ શૉર્ટકટમાં ફેરફાર કરવા માટે, ટચ કરીને થોડીવાર દબાવી રાખો.</translation>
<translation id="8725066075913043281">ફરી પ્રયાસ કરો</translation>
<translation id="8731268612289859741">સિક્યુરિટી કોડ</translation>
<translation id="8746155870861185046">હાઇલાઇટ કરેલી ટેક્સ્ટ શેર કરો</translation>
<translation id="8748850008226585750">સામગ્રીઓ છુપાવેલ છે</translation>
<translation id="8754448020583829686">લિંક વિના કૉપિ કરો</translation>
<translation id="8756969031206844760">પાસવર્ડ અપડેટ કરીએ?</translation>
<translation id="7516782607673411695">જ્યારે તમે ઍડ્રેસ બાર અથવા શોધ બૉક્સમાં ટાઇપ કરો છો, ત્યારે બહેતર સૂચનો મેળવવા માટે Ecosia તમે જે ટાઇપ કરો છો તેને તમારા ડિફૉલ્ટ શોધ એન્જિનને મોકલે છે. આ સુવિધા છૂપા મોડમાં કામ કરતી નથી.</translation>
<translation id="8766529642647037772">શું આના જેવી હાઇલાઇટ કરેલી લિંક બનાવીએ?</translation>
<translation id="8773160212632396039">વિનંતી પર પ્રક્રિયા ચાલુ છે</translation>
<translation id="8788265440806329501">નૅવિગેશન ઇતિહાસ બંધ છે</translation>
<translation id="8788968922598763114">છેલ્લે બંધ કરેલ ટૅબ ફરીથી ખોલો</translation>
<translation id="8790193082819560975">કોઈ નવા ટૅબમાં, પ્રોડક્ટની ખરીદી કરવાના વિકલ્પો શોધવા માટે ટૅપ કરો.</translation>
<translation id="879027982257117598">ઉદાહરણ તરીકે, જો તમે લાંબા-અંતરની દોડ માટેના શૂઝ વેચતી કોઈ સાઇટની મુલાકાત લો છો, તો તે સાઇટ કદાચ એવું નક્કી કરી શકે તે તમને મૅરેથન દોડવામાં રૂચિ છે. એના પછી, જો તમે કોઈ અલગ સાઇટની મુલાકાત લો, તો તે સાઇટ તમને પહેલી સાઇટ દ્વારા સૂચવવામાં આવેલી દોડવાના શૂઝની જાહેરાત બતાવી શકે છે.</translation>
<translation id="8798449543960971550">વાંચેલાં</translation>
<translation id="8803526663383843427">જ્યારે ચાલુ હોય</translation>
<translation id="8110732635799837671">{ITEMS_COUNT,plural, =1{તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં આઇટમ સાચવી.}one{તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં આઇટમ સાચવી.}other{તમારા Ecosia એકાઉન્ટ <ph name="ACCOUNT_EMAIL"/>માં આઇટમ સાચવી.}}</translation>
<translation id="8812260976093120287">કેટલીક વેબસાઇટ પર, તમે સમર્થિત ચુકવણી ઍપ્લિકેશનો વડે ચુકવણી કરી શકો છો.</translation>
<translation id="8816556050903368450">આ લિંક સહિત: <ph name="ORIGIN"/></translation>
<translation id="881688628773363275">પ્રીવ્યૂ ટૅબનું કન્ટેન્ટ જોઈ શકાતું નથી.</translation>
<translation id="8820817407110198400">બુકમાર્ક</translation>
<translation id="7138820763504877850">દુરુપયોગ કરનારી અને ઉપયોગમાં ન લેવાતી સાઇટમાંથી Ecosia ઑટોમૅટિક રીતે પરવાનગીઓ કાઢી નાખે છે</translation>
<translation id="8835786707922974220">ખાતરી કરો કે તમે તમારા સાચવેલા પાસવર્ડ ગમે ત્યારે ઍક્સેસ કરી શકો છો</translation>
<translation id="883806473910249246">કન્ટેન્ટ ડાઉનલોડ કરતી વખતે એક ભૂલ આવી.</translation>
<translation id="8840953339110955557">આ પેજ ઑનલાઇન વર્ઝનથી અલગ હોય શકે છે.</translation>
<translation id="8847988622838149491">USB</translation>
<translation id="8849001918648564819">છુપાવેલી</translation>
<translation id="8853345339104747198"><ph name="TAB_TITLE"/>, ટેબ</translation>
<translation id="8854223127042600341">તમારી ઑફલાઇન ફાઇલો જુઓ</translation>
<translation id="885480114717186641">તમે <ph name="HOST_NAME"/> માટે ડેસ્કટૉપ સાઇટની વિનંતી કરી શકો છો</translation>
<translation id="8856607253650333758">વર્ણનો મેળવો</translation>
<translation id="8856931513242997049">નોટિફિકેશનની પરવાનગી સંબંધી ફ્લો બંધ કર્યો</translation>
<translation id="8863714995118816041"><ph name="SITE_NAME"/>ને ફરી પરવાનગીઓ આપવામાં આવી</translation>
<translation id="4219359180077009212">તમારા એકાઉન્ટમાંનો Ecosia ડેટા</translation>
<translation id="8888527824584402177">તમે <ph name="DAYS_INACTIVE"/> દિવસ સુધી ઉપયોગ ન કર્યો હોય તેવા ટૅબ અહીં ખસેડવામાં આવે છે<ph name="AUTODELETE_SECTION"/>. <ph name="SETTINGS_TITLE"/>માં તમે આને કોઈપણ સમયે બદલી શકો છો.</translation>
<translation id="6440224594925781372">વેબ પરના નવા જોખમો શોધી કાઢવા અને દરેક વ્યક્તિની સુરક્ષિતતામાં સહાય કરવા માટે, તમે મુલાકાત લેતા અમુક પેજના URLs, સિસ્ટમની મર્યાદિત માહિતી અને પેજનું અમુક કન્ટેન્ટ Ecosiaને મોકલે છે.</translation>
<translation id="8909135823018751308">શેર કરો…</translation>
<translation id="8921980840204105660">તમારા અન્ય ડિવાઇસમાંના તમારા બધા બુકમાર્ક મેળવવા માટે, સિંક કરો</translation>
<translation id="8922289737868596582">વધુ વિકલ્પો બટનની મદદથી પેજ ડાઉનલોડ કરો, જેથી તમે ઇન્ટરનેટ વિના પણ તેનો ઉપયોગ કરી શકો</translation>
<translation id="8924575305646776101"><ph name="BEGIN_LINK"/>વધુ જાણો<ph name="END_LINK"/></translation>
<translation id="892496902842311796"><ph name="LANG"/> ભાષા તૈયાર છે</translation>
<translation id="933062161752570629">તમારી Ecosiaની પ્રવૃત્તિને ડિજિટલ લાઇફસ્ટાઇલમાંથી કાઢી નાખીએ?</translation>
<translation id="2937601471338058080">તમારા સેટિંગને આધારે, Ecosia તમને કુકી, તમારા વર્તમાન URL અને તમારા લોકેશન પણ મોકલી શકે છે</translation>
<translation id="8942627711005830162">અન્ય વિંડોમાં ખોલો</translation>
<translation id="8945143127965743188"><ph name="LANG"/> - આ ભાષા ડાઉનલોડ કરી શકાઈ નથી. થોડા સમય પછી ફરી પ્રયાસ કરો.</translation>
<translation id="8963117664422609631">સાઇટ સેટિંગ પર જાઓ</translation>
<translation id="8965591936373831584">બાકી</translation>
<translation id="8968085728801125376">{TAB_COUNT,plural, =1{<ph name="INCOGNITO_TAB_COUNT"/> છૂપું અને વધુ <ph name="TAB_COUNT_ONE"/> ટૅબ બંધ કરવામાં આવશે}one{<ph name="INCOGNITO_TAB_COUNT"/> છૂપું અને વધુ <ph name="TAB_COUNT_MANY"/> ટૅબ બંધ કરવામાં આવશે}other{<ph name="INCOGNITO_TAB_COUNT"/> છૂપા અને વધુ <ph name="TAB_COUNT_MANY"/> ટૅબ બંધ કરવામાં આવશે}}</translation>
<translation id="8970887620466824814">કંઈક ખોટું થયું.</translation>
<translation id="8972098258593396643">ડિફૉલ્ટ ફોલ્ડરમાં ડાઉનલોડ કરીએ?</translation>
<translation id="8982113230057126145">આ સારાંશ તમને નાપસંદ હોવાનો પ્રતિસાદ થમ્બ્સ ડાઉન દ્વારા સબમિટ કરવામાં આવે છે</translation>
<translation id="4093829554570026639">તમારો ડેટા તમારા પાસફ્રેઝ વડે એન્ક્રિપ્ટ કરવામાં આવ્યો છે. તમારા Ecosia એકાઉન્ટમાં Ecosia ડેટાનો ઉપયોગ કરવા અને તેને સાચવવા માટે, તમારો પાસફ્રેઝ દાખલ કરો.</translation>
<translation id="8993760627012879038">છુપા મોડમાં એક નવું ટૅબ ખોલો</translation>
<translation id="8996847606757455498">કોઈ અન્ય પ્રદાતા પસંદ કરો</translation>
<translation id="8998289560386111590">તમારા ડિવાઇસ પર ઉપલબ્ધ નથી</translation>
<translation id="8998837250940831980">ટૅબ નાનું કરી શક્યા નથી. થોડા સમય પછી ફરી પ્રયાસ કરો.</translation>
<translation id="1965890888219750903">Ecosiaના છૂપા ટૅબમાં ખોલો</translation>
<translation id="9007002441981613214">સાચવેલા પાસવર્ડ સાથેની સમસ્યા સુધારો</translation>
<translation id="6803269306497583249">જોખમકારક જણાતી હોય એવી સાઇટ, ડાઉનલોડ અને એક્સ્ટેન્શન સામે રક્ષણ આપે છે. જો કોઈ પેજ કંઈપણ શંકાસ્પદ કરે છે, તો URL અને પેજ કન્ટેન્ટના બિટ Ecosia Safe Browsingને મોકલવામાં આવે છે.</translation>
<translation id="9019199799064251516">કાર પ્રોફાઇલ લૉક વિના ચાલુ રાખીએ?</translation>
<translation id="9022774213089566801">વારંવાર મુલાકાત લેવાયેલ</translation>
<translation id="9022871169049522985">સાઇટ અને જાહેરાતકર્તાઓ તેમની જાહેરાતોના કાર્યપ્રદર્શનની માપણી કરી શકે છે</translation>
<translation id="9035378196785279980">આમાં ખસેડો\u2026</translation>
<translation id="9042893549633094279">પ્રાઇવસી અને સુરક્ષા</translation>
<translation id="9050666287014529139">પાસફ્રેઝ</translation>
<translation id="9055497320631373736">આ સાઇટને સંભવિત સાઇટની સૂચિમાં પાછી ઉમેરવામાં આવી છે</translation>
<translation id="9063523880881406963">વિનંતી ડેસ્કટૉપ સાઇટ બંધ કરો</translation>
<translation id="9065203028668620118">ફેરફાર કરો</translation>
<translation id="577797479093866049">Ecosiaને મહત્ત્વનો ન લાગતો હોય તેવો સ્ટોર કરેલો ડેટા (દા.ત., કોઇ સાચવેલા સેટિંગ ન હોય તેવી અથવા વારંવાર મુલાકાત ન લેવાતી હોય તેવી સાઇટ)</translation>
<translation id="9067341854474068781">સંપૂર્ણ ઊંચાઈએ કોઈ પાસકી શીટ ખુલ્લી નથી</translation>
<translation id="906781307897697745"><ph name="PRODUCT_NAME"/>માં</translation>
<translation id="9069999660519089861">વાંચ્યા વગરનું કોઈ પેજ નથી</translation>
<translation id="9070377983101773829">વૉઇસ શોધ શરૂ કરો</translation>
<translation id="9074739597929991885">બ્લૂટૂથ</translation>
<translation id="9081543426177426948">છૂપા મોડમાં તમે મુલાકાત લો છો એ સાઇટ સચવાતી નથી</translation>
<translation id="9086302186042011942">સમન્વય કરી રહ્યું છે</translation>
<translation id="9086455579313502267">નેટવર્ક ઍક્સેસ કરવામાં અક્ષમ છે</translation>
<translation id="1628842721003175423">સૌથી વધુ મનગમતો બનાવેલો અનુભવ મેળવવા માટે, વેબ અને ઍપ ઍક્ટિવિટી તેમજ લિંક કરેલી Ecosia સેવાઓમાં Ecosiaનો સમાવેશ કરો</translation>
<translation id="9099220545925418560">તમારા બ્રાઉઝિંગ ઇતિહાસના આધારે. આ સેટિંગ બંધ છે.</translation>
<translation id="9100610230175265781">પાસફ્રેઝ આવશ્યક છે</translation>
<translation id="9101137867221042551">મેનેજમેન્ટ</translation>
<translation id="9102803872260866941">પ્રીવ્યૂની ટૅબ ખોલવામાં આવી</translation>
<translation id="9102864637938129124">જાહેરાતોના પર્ફોર્મન્સ સંબંધી બાબતો સાઇટ અને જાહેરાતકર્તાઓ સમજી શકે છે. આ સેટિંગ ચાલુ છે.</translation>
<translation id="9104217018994036254">ટૅબ જે ડિવાઇસ સાથે શેર કરવું છે તેની સૂચિ.</translation>
<translation id="9104858485806491627">{INACTIVE_TIME_DAYS,plural, =1{1 દિવસ કે તેથી વધુ સમયથી ઉપયોગ થયો નથી}one{# દિવસ કે તેથી વધુ સમયથી ઉપયોગ થયો નથી}other{# દિવસ કે તેથી વધુ સમયથી ઉપયોગ થયો નથી}}</translation>
<translation id="9106148373857059373">બુકમાર્ક સાચવવાનો ફ્લો બંધ છે</translation>
<translation id="9108312223223904744">સિક્યુરિટી કી તરીકે ફોનનો ઉપયોગ</translation>
<translation id="9108808586816295166">સુરક્ષિત DNS હંમેશાં ઉપલબ્ધ ન હોઈ શકે</translation>
<translation id="9131209053278896908">બ્લૉક કરેલી સાઇટ અહીં દેખાય છે</translation>
<translation id="9133397713400217035">ઑફલાઇનમાં શોધખોળ કરો</translation>
<translation id="9143389653531441385"><ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/> વડે સાઇન અપ કરો</translation>
<translation id="9148126808321036104">ફરીથી સાઇન ઇન કરો </translation>
<translation id="9157212632995922070"><ph name="SITE_ETLD_PLUS_ONE"/> પર ચાલુ રાખવા માટે, કોઈ એકાઉન્ટ પસંદ કરો</translation>
<translation id="9158770349521403363">માત્ર કન્ટેન્ટ શેર કરો</translation>
<translation id="9159716826369098114"><ph name="TAB_COUNT"/> ટૅબવાળા ટૅબના ગ્રૂપને નવા બૅકગ્રાઉન્ડ ટૅબના ગ્રૂપ તરીકે રિસ્ટોર કરો.</translation>
<translation id="9169507124922466868">નૅવિગેશન ઇતિહાસ અડધા ભાગમાં ખુલ્લો છે</translation>
<translation id="2926455547526018397">Ecosia બીટા</translation>
<translation id="9190276265094487094">તમને તમારા સિંક કરેલા તમામ ડિવાઇસ પર તમારો ઇતિહાસ મળશે, જેથી તમે જે કરતા હતા તે ચાલુ રાખી શકો</translation>
<translation id="9191906083913361689">તમે તમારા બુકમાર્ક, વાંચન સૂચિ કે પાસવર્ડ મેનેજરમાં આ આઇટમને જોઈ તેમજ તેને મેનેજ પણ કરી શકો છો</translation>
<translation id="9199368092038462496">{NUM_MINS,plural, =1{1 મિનિટ પહેલાં ચેક કર્યું}one{# મિનિટ પહેલાં ચેક કર્યું}other{# મિનિટ પહેલાં ચેક કર્યું}}</translation>
<translation id="9204021776105550328">ડિલીટ કરી રહ્યાં છીએ</translation>
<translation id="9204836675896933765">1 ફાઇલ બાકી છે</translation>
<translation id="9205933215779845960">એ પેજ મળતું નથી. તમારી જોડણી ચેક કરો અથવા <ph name="SEARCH_ENGINE"/> પર પ્રયાસ કરો.</translation>
<translation id="9206873250291191720">A</translation>
<translation id="9209888181064652401">કૉલ કરી શકતા નથી</translation>
<translation id="9212845824145208577">વધુ નીચે જઈ શકતા નથી. પેજ પર વધુ નીચેથી શરૂ કરીને જુઓ.</translation>
<translation id="9218430445555521422">ડિફોલ્ટ તરીકે સેટ કરો</translation>
<translation id="9219103736887031265">છબીઓ</translation>
<translation id="381222140349506861">જ્યારે કોઈ સાઇટ દ્વારા તેમના પેજ પર લિંકને ખાનગી રીતે પહેલેથી લોડ કરવાનું કહેવામાં આવે, ત્યારે Ecosia, કુકી વિના Ecosiaના સર્વર મારફતે પેજને એન્ક્રિપ્ટ અને પહેલેથી લોડ કરે છે. આ પહેલેથી લોડ કરેલી સાઇટથી તમારી ઓળખ છુપાવે છે.</translation>
<translation id="977697318811126474">ડિજિટલ લાઇફસ્ટાઇલમાંથી તમારી Ecosiaની પ્રવૃત્તિને કેવી રીતે કાઢવી</translation>
<translation id="3222259846700748461">Ecosia પર લાઇટ મોડનો ઉપયોગ કરો</translation>
<translation id="928550791203542716"><ph name="SITE_NAME"/> ફૉલો કરી રહ્યાં છીએ</translation>
<translation id="930124987204876019">ઇતિહાસ, કુકી, સાઇટનો ડેટા, કૅશ મેમરી ડિલીટ કરો…</translation>
<translation id="93533588269984624">બધા પાસવર્ડ તમારા ડિવાઇસ પર ડાઉનલોડ કરવામાં આવશે અને <ph name="CHROME_CHANNEL"/>માંથી કાઢી નાખવામાં આવશે</translation>
<translation id="938850635132480979">ભૂલ: <ph name="ERROR_CODE"/></translation>
<translation id="939598580284253335">પાસફ્રેઝ દાખલ કરો</translation>
<translation id="1444447230218534566">Ecosia, ચાઇનામાં શોધ માટે <ph name="BEGIN_BOLD"/>Sogou<ph name="END_BOLD"/>નો ઉપયોગ કરી શકે છે. તમે આને <ph name="BEGIN_LINK"/>સેટિંગ<ph name="END_LINK"/>માં બદલી શકો છો.</translation>
<translation id="961856697154696964">બ્રાઉઝિંગ ડેટા ડિલીટ કરો</translation>
<translation id="966131775676567255">એકાઉન્ટ ડેટા ડિલીટ કરી રહ્યાં છીએ</translation>
<translation id="96681097142096641">શું સરળ કરેલું પેજ જોવું છે?</translation>
<translation id="970715775301869095"><ph name="MINUTES"/> મિનિટ બાકી</translation>
<translation id="981121421437150478">ઑફલાઇન</translation>
<translation id="983192555821071799">બધા ટેબ્સ બંધ કરો</translation>
<translation id="987264212798334818">સામાન્ય</translation>
<translation id="988091779042748639">તમારા ડિવાઇસમાંથી છૂપા મોડનો બ્રાઉઝિંગ ઇતિહાસ ડિલીટ કરવા માટે, તમામ છૂપા ટૅબ બંધ કરો.</translation>
<translation id="992745192656291733"><ph name="TAB_COUNT"/> ટૅબ</translation>
<translation id="996149300115483134">ફીડ કાર્ડ મેનૂ બંધ છે</translation>
</translationbundle>
