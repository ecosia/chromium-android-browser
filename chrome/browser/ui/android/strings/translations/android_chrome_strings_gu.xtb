<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="gu">
<translation id="1011749477052068769">અહીં ખસેડો</translation>
<translation id="1014147525163127655"><ph name="ORIGIN"/> માટે આ ડિવાઇસ પર કોઈપણ પાસકી ઉપલબ્ધ નથી</translation>
<translation id="1016498331642356377">તમારા અવાજ વડે ઝડપથી શોધો. આ શૉર્ટકટમાં ફેરફાર કરવા માટે, ટચ કરીને થોડીવાર દબાવી રાખો.</translation>
<translation id="1017104654974573432">કોઈ સમસ્યા પસંદ કરો</translation>
<translation id="932641430818191661">Ecosia Dev</translation>
<translation id="1028699632127661925"><ph name="DEVICE_NAME"/> પર મોકલી રહ્યાં છીએ...</translation>
<translation id="103269572468856066">આ સાઇટ અને ઍપમાંથી પણ ડેટા સાફ કરીએ?</translation>
<translation id="1034259925032978114">વિન્ડો ખુલ્લી છે</translation>
<translation id="1036348656032585052">બંધ કરો</translation>
<translation id="1045899828449635435">આ સાઇટમાંથી પણ ડેટા સાફ કરીએ?</translation>
<translation id="1049743911850919806">છૂપી</translation>
<translation id="1058669287135776095">તમે ઑફલાઇન છો. તમારું ઇન્ટરનેટ કનેક્શન ચેક કરો અને ફરી પ્રયાસ કરો.</translation>
<translation id="10614374240317010">ક્યારેય ન સચવાયેલું</translation>
<translation id="107147699690128016">જો તમે ફાઇલનું એક્સ્ટેંશન બદલશો, તો તે કોઈ અલગ ઍપ્લિકેશનમાં ખુલી શકે છે અને તમારા ડિવાઇસ માટે નુકસાનકારક હોવાનું સંભવિત હોય શકે.</translation>
<translation id="1080365971383768617">તમારા બધા ડિવાઇસમાંના પાસવર્ડ</translation>
<translation id="1082920045291562218">સારાંશ વિશે પ્રતિસાદની શીટ બંધ રાખીને શેર કરો</translation>
<translation id="1089606299949659462">રિવ્યૂ પૂર્ણ થયો!</translation>
<translation id="1094555143448724771">તમારા અન્ય ડિવાઇસમાંના ટૅબ જોવા માટે, તમારા ટૅબ અને ઇતિહાસ સિંક કરો</translation>
<translation id="1095761715416917775">ખાતરી કરો કે તમે તમારો સિંક કરેલો ડેટા ગમે ત્યારે ઍક્સેસ કરી શકો છો</translation>
<translation id="1100066534610197918">ગ્રૂપમાં નવા ટૅબમાં ખોલો</translation>
<translation id="3843522391028367098">Ecosiaને બહેતર બનાવવામાં સહાય કરશો?</translation>
<translation id="1105960400813249514">સ્ક્રીન કૅપ્ચર</translation>
<translation id="1108214977745280468">પેજની જાણકારી જુઓ</translation>
<translation id="1108938384783527433">ઇતિહાસ સિંક કરો</translation>
<translation id="1111673857033749125">તમારા અન્ય ડિવાઇસ પર સાચવેલા બુકમાર્ક અહીં દેખાશે.</translation>
<translation id="1113597929977215864">સરળ દૃશ્ય બતાવો</translation>
<translation id="1126696498560056882">આ ડિવાઇસ પરના એકાઉન્ટ મેનેજ કરો</translation>
<translation id="1129510026454351943">વિગતો: <ph name="ERROR_DESCRIPTION"/></translation>
<translation id="1135018701024399762">છૂપો મોડ, તમારા ડિવાઇસનો ઉપયોગ કરતા અન્ય લોકોથી તમારા બ્રાઉઝિંગને ખાનગી રાખે છે</translation>
<translation id="1138458427267715730">સમગ્ર વેબ પર કોઈપણ સાઇટ પર કિંમતમાં ઘટાડો થાય ત્યારે અલર્ટ મેળવો</translation>
<translation id="1142732900304639782">આ સાઇટનો અનુવાદ કરવાનું ઑફર કરશો નહીં</translation>
<translation id="1145536944570833626">અસ્તિત્વમાંના ડેટાને ડિલીટ કરો.</translation>
<translation id="4660751904385798997"><ph name="APP_NAME"/> Ecosiaમાં ખુલશે. આગળ વધીને, તમે <ph name="BEGIN_LINK1"/>Ecosiaની સેવાની શરતો<ph name="END_LINK1"/> અને <ph name="BEGIN_LINK2"/>Ecosia તથા EcosiaOSની વધારાની સેવાની શરતો<ph name="END_LINK2"/> સાથે સંમત થાઓ છો.</translation>
<translation id="115483310321669804"><ph name="PASSWORD"/> પાસવર્ડનો ઉપયોગ કરો</translation>
<translation id="1173894706177603556">નામ બદલો</translation>
<translation id="7055227556544680407">સ્ક્રીન નાની થાય ત્યારે દરેક વખતે Ecosia, મોબાઇલ સાઇટની વિનંતી કરશે</translation>
<translation id="3714562792078225517">તમારા ઍડમિનિસ્ટ્રેટર તમારી પ્રોફાઇલ અને બ્રાઉઝરમાં રિમોટલી ફેરફાર કરી શકે, રિપોર્ટિંગ મારફતે બ્રાઉઝર વિશેની માહિતીનું વિશ્લેષણ કરી શકે અને અન્ય જરૂરી કાર્યો કરી શકે. આ ડિવાઇસ પરની પ્રવૃત્તિ Ecosiaની બહારથી પણ મેનેજ કરી શકાય છે.</translation>
<translation id="1177863135347784049">કસ્ટમ</translation>
<translation id="1181037720776840403">કાઢી નાખો</translation>
<translation id="7268485703452612365">તમે હંમેશાં તમારા Ecosia એકાઉન્ટમાં પાસવર્ડનો ઉપયોગ કરી શકો તેની ખાતરી કરવા માટે, આ તમે જ છો તેની ચકાસણી કરો</translation>
<translation id="1187810343066461819">આ કારમાંથી બુકમાર્ક, ઇતિહાસ અને બીજું ઘણું પણ ડિલીટ કરો</translation>
<translation id="1193729455103054076">શું સશક્ત પાસવર્ડનો ઉપયોગ કરીએ?</translation>
<translation id="1197267115302279827">બુકમાર્ક ખસેડો</translation>
<translation id="1197761954713363183">પાસકી કન્ફર્મેશન શીટ બંધ છે</translation>
<translation id="1201402288615127009">આગલું</translation>
<translation id="1202892408424955784">ટ્રૅક કરેલી પ્રોડક્ટ</translation>
<translation id="1204037785786432551">ડાઉનલોડ કરવાની લિંક</translation>
<translation id="1206892813135768548">લિંક ટેક્સ્ટ કૉપિ કરો</translation>
<translation id="1209206284964581585">હમણાં માટે છુપાવો</translation>
<translation id="1227058898775614466">નૅવિગેશન ઇતિહાસ</translation>
<translation id="1231733316453485619">સિંક કરવાનું ચાલુ કરીએ?</translation>
<translation id="123724288017357924">કૅશ કરેલ કન્ટેન્ટને અવગણીને વર્તમાન પેજ ફરીથી લોડ કરો</translation>
<translation id="1239792311949352652">આ પેજ ઝડપથી શેર કરો. આ શૉર્ટકટમાં ફેરફાર કરવા માટે, સેટિંગ પર જાઓ.</translation>
<translation id="1240288207750131269"><ph name="LANG"/> લોડ કરી રહ્યાં છીએ</translation>
<translation id="1240903469550363138">આગળ વધવા માટે, <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/> તમારું નામ, ઇમેઇલ ઍડ્રેસ અને પ્રોફાઇલ ફોટો આ સાઇટ સાથે શેર કરશે. આ સાઇટની <ph name="BEGIN_LINK1"/>પ્રાઇવસી પૉલિસી<ph name="END_LINK1"/> અને <ph name="BEGIN_LINK2"/>સેવાની શરતો<ph name="END_LINK2"/> જુઓ.</translation>
<translation id="124116460088058876">વધુ ભાષાઓ</translation>
<translation id="9134721617178648690"><ph name="CHROME_CHANNEL"/> માટેના તમારા પાસવર્ડને Ecosia Password Managerમાંથી ડિલીટ કરવામાં આવશે. તમે હમણાં જ ડાઉનલોડ કરેલી પાસવર્ડ ફાઇલને તમે સાચવી રાખશો.</translation>
<translation id="1242883863226959074">ડિવાઇસ</translation>
<translation id="124678866338384709">વર્તમાન ટૅબ બંધ કરો</translation>
<translation id="1246905108078336582">શું ક્લિપબોર્ડમાંથી સૂચન કાઢી નાખીએ?</translation>
<translation id="2409024862870951151">Ecosia ડૂડલ: <ph name="DOODLE_DESCRIPTION"/></translation>
<translation id="6704387139626747884">તમને 'ફૉલો કરી રહ્યાં છો'માં <ph name="SITE_NAME"/> પરથી અને વિશેનું કન્ટેન્ટ જોવા મળશે. તમે જે સાઇટ અને શોધને ફૉલો કરો છો, તેને તમારા Ecosia એકાઉન્ટમાં સાચવવામાં આવે છે. તમે જેને ફૉલો કરો છો, તેને ગમે ત્યારે તમારા સેટિંગમાં મેનેજ કરી શકો છો.</translation>
<translation id="1263231323834454256">વાચન સૂચિ</translation>
<translation id="1269129608791067105">તમને તમારો ઇતિહાસ અહીં મળશે</translation>
<translation id="1273937721055267968"><ph name="DOMAIN"/>ને બ્લૉક કરો</translation>
<translation id="1283039547216852943">વિસ્તૃત કરવા માટે ટૅપ કરો</translation>
<translation id="4227417915430429516">તમને તમારા Ecosia એકાઉન્ટમાં સાઇન ઇન કરવાનું કહેવામાં આવશે</translation>
<translation id="129553762522093515">તાજેતરમાં બંધ કરેલા</translation>
<translation id="1298077576058087471">60% જેટલો ડેટા બચાવો, આજના સમાચાર વાંચો</translation>
<translation id="1303339473099049190">તે પાસવર્ડ શોધી શકતા નથી. તમારી જોડણી ચેક કરો અને ફરીથી પ્રયાસ કરો.</translation>
<translation id="1303507811548703290"><ph name="DOMAIN"/> - <ph name="DEVICE_NAME"/> પરથી મોકલેલ</translation>
<translation id="1320912611264252795">બુકમાર્ક સાચવવાના ફ્લોના ફોલ્ડરો સંપૂર્ણ ઊંચાઈએ ખુલ્લા છે</translation>
<translation id="1327257854815634930">નૅવિગેશન ઇતિહાસ ખુલ્લો છે</translation>
<translation id="6409182381851869366">Ecosia અપડેટ કરી શકાતું નથી. વધુ વિકલ્પો</translation>
<translation id="7387640788761891716">Ecosia સુવિધાના શૉર્ટકટ્સ</translation>
<translation id="1333491156693005331">તાજેતરમાં ચેક કર્યું</translation>
<translation id="1336996151357442890"><ph name="SITE_NAME"/>માંથી અનસબ્સ્ક્રાઇબ કર્યું. તમને તમારી આગલી મુલાકાત વખતે ફરી પૂછવામાં આવશે.</translation>
<translation id="1344653310988386453">હાઇલાઇટ કરેલી ટેક્સ્ટની લિંક શામેલ કરો</translation>
<translation id="1347468774581902829">પ્રવૃત્તિ મેનેજ કરો</translation>
<translation id="1355088659320425659">ઇતિહાસ અને ટૅબ</translation>
<translation id="1360432990279830238">સાઇન આઉટ કરી સિંકનો વિકલ્પ બંધ કરવો છે?</translation>
<translation id="1363028406613469049">ટ્રૅક</translation>
<translation id="1366525380420346469">જ્યારે ચાલુ હોય</translation>
<translation id="1373696734384179344">પસંદ કરેલ કન્ટેન્ટ ડાઉનલોડ કરવા માટે મેમરી અપૂરતી છે.</translation>
<translation id="1376578503827013741">ગણતરી કરી રહ્યાં છે…</translation>
<translation id="1381838868249179644">તમને સુરક્ષિત રાખવામાં સહાય કરવા માટે, અમુક સાઇટ પરથી પરવાનગીઓ દૂર કરવામાં આવી હતી</translation>
<translation id="1382912999714108023">તમારી હાલની માહિતી દેખાઈ રહી નથી? તેને અપડેટ કરવા માટે, કૃપા કરીને તમારી બેંકનો સંપર્ક કરો.</translation>
<translation id="1383876407941801731">શોધો</translation>
<translation id="7232210716147326162">Ecosia Lensથી છબીનો અનુવાદ કરો <ph name="BEGIN_NEW"/>નવું<ph name="END_NEW"/></translation>
<translation id="1386674309198842382"><ph name="LAST_UPDATED"/> દિવસ પહેલાં સક્રિય હતું</translation>
<translation id="3197188669144915057">Ecosiaમાં અન્ય ઍપ દ્વારા ખોલવામાં આવતી લિંકનો ઇતિહાસ કદાચ તમે જોઈ શકશો. તમારા Ecosia એકાઉન્ટમાં <ph name="BEGIN_LINK"/>myactivity.google.com<ph name="END_LINK"/> પર બ્રાઉઝિંગ ઇતિહાસના અન્ય સ્વરૂપો હોઈ શકે છે.</translation>
<translation id="13931502444227376">આગળ વધવા માટે, <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/> તમારું નામ, ઇમેઇલ ઍડ્રેસ અને પ્રોફાઇલ ફોટો આ સાઇટ સાથે શેર કરશે. આ સાઇટની <ph name="BEGIN_LINK1"/>સેવાની શરતો<ph name="END_LINK1"/> જુઓ.</translation>
<translation id="139752016751285248">સંપૂર્ણ ઊંચાઈએ કિંમત વિશે જાણકારીની બોટમ શીટ ખુલ્લી છે</translation>
<translation id="1397811292916898096"><ph name="PRODUCT_NAME"/> વડે શોધો</translation>
<translation id="4763881925804540198">તમારા Ecosia એકાઉન્ટમાં <ph name="BEGIN_LINK1"/>Ecosiaનો કયો ડેટા સાચવવામાં આવે છે<ph name="END_LINK1"/> તેને તમે મેનેજ કરી શકો છો.

તમારા Ecosiaના અનુભવને બહેતર બનાવવા માટે ડેટાનો ઉપયોગ કરતા વધુ સેટિંગ માટે, <ph name="BEGIN_LINK2"/>Ecosiaની સેવાઓ<ph name="END_LINK2"/> પર જાઓ.</translation>
<translation id="1407069428457324124">ઘેરી થીમ</translation>
<translation id="1407135791313364759">બધું ખોલો</translation>
<translation id="1409879593029778104"><ph name="FILE_NAME"/> ડાઉનલોડ રોકાયું કારણકે ફાઇલ પહેલેથી અસ્તિત્વ ધરાવે છે.</translation>
<translation id="4363365393364353042">તમારા Ecosia એકાઉન્ટમાં ડેટા સાચવો</translation>
<translation id="6964061674612004654">Ecosiaનો સંપર્ક કરી રહ્યાં છીએ. આમાં એક મિનિટ લાગી શકે છે…</translation>
<translation id="1416550906796893042">ઍપ્લિકેશન વર્ઝન</translation>
<translation id="1428770807407000502">સિંક બંધ કરીએ?</translation>
<translation id="1430915738399379752">પ્રિન્ટ</translation>
<translation id="1435593198351412143">ઑટોમૅટિક રીતે PDFs ખોલો</translation>
<translation id="1436784010935106834">દૂર કરેલું</translation>
<translation id="1437543266176261764"><ph name="APP_NAME"/>માં ચાલી રહી છે</translation>
<translation id="1448440926884431741">Bookmarksમાં તમારી ટ્રૅક કરેલી પ્રોડક્ટની ગોઠવણ કરો</translation>
<translation id="1460751212339734034">સમય બચાવો, ઓછું ટાઇપ કરો</translation>
<translation id="4495896981653463885">Ecosiaની ભાષા પસંદ કરો</translation>
<translation id="1477626028522505441">સર્વર સમસ્યાઓને કારણે <ph name="FILE_NAME"/> ડાઉનલોડ નિષ્ફળ થયું.</translation>
<translation id="1941108915529342820">તમારો અમુક ઇતિહાસ કદાચ અહીં જોવા ન પણ મળી શકે. તમારો બધો Ecosia ઇતિહાસ જોવા માટે, સંપૂર્ણ Ecosia ઇતિહાસ ખોલો.</translation>
<translation id="148482509007564431">બુકમાર્ક સાચવવાનો ફ્લો</translation>
<translation id="1492417797159476138">તમે આ સાઇટ માટે પહેલેથી જ વપરાશકર્તા નામ સાચવ્યું છે</translation>
<translation id="1493287004536771723">તમે <ph name="SITE_NAME"/>ને ફૉલો કરી રહ્યાં છો</translation>
<translation id="7483916309257149513">તમારા પાસવર્ડ મેનેજ કરવા માટે, Ecosia Play સેવાઓ અપડેટ કરો</translation>
<translation id="1506061864768559482">શોધ એન્જિન</translation>
<translation id="1513352483775369820">બુકમાર્ક અને વેબ ઇતિહાસ</translation>
<translation id="1513814250881909472">તમારા અન્ય ડિવાઇસમાંની તમારી બધી ટૅબ મેળવવા માટે, સિંક કરો</translation>
<translation id="1513858653616922153">પાસવર્ડ ડિલીટ કરો</translation>
<translation id="1521774566618522728">આજે સક્રિય છે</translation>
<translation id="731393269144004006">Ecosiaનું નવું વર્ઝન ઉપલબ્ધ છે</translation>
<translation id="3859982555016625909">ચુકવણી પદ્ધતિઓ અને સરનામા એન્ક્રિપ્ટ કરવામાં આવશે નહીં. Ecosiaમાંથી બ્રાઉઝિંગ ઇતિહાસ સિંક થશે નહીં.
તમારો પાસફ્રેઝ ધરાવતી કોઈ વ્યક્તિ જ તમારો એન્ક્રિપ્ટેડ ડેટા વાંચી શકે છે. Ecosiaને પાસફ્રેઝ મોકલવામાં આવતો નથી કે તેમાં સ્ટોર કરવામાં આવતો નથી. જો તમે તમારો પાસફ્રેઝ ભૂલી જાઓ અથવા આ સેટિંગ બદલવા માગતા હો, તો <ph name="BEGIN_LINK"/>તમારા એકાઉન્ટમાંનો Ecosiaનો ડેટા સાફ કરો<ph name="END_LINK"/>.</translation>
<translation id="4189121201919273114">તમારું Ecosia એકાઉન્ટ મેનેજ કરવા માટે, "એકાઉન્ટ મેનેજ કરો" બટન પર ટૅપ કરો</translation>
<translation id="154513667535157406">આ સારાંશ તમને પસંદ હોવાનો પ્રતિસાદ થમ્બ્સ અપ દ્વારા સબમિટ કરવામાં આવે છે</translation>
<translation id="1549000191223877751">અન્ય વિંડો પર ખસેડો</translation>
<translation id="5598074261782651109">Ecosia અપડેટ કરો</translation>
<translation id="5435543125910633212">તમે જે રીતે કરો છો, તે રીતે Ecosiaનો ઉપયોગ કરતા લોકો માટે તેને બહેતર બનાવવામાં સહાય કરો</translation>
<translation id="1558391695376153246">છૂપી ટૅબ બંધ કરો</translation>
<translation id="1568636008098739136">આ પેજનું કન્ટેન્ટ સાંભળો. આ શૉર્ટકટમાં ફેરફાર કરવા માટે, ટચ કરીને થોડીવાર દબાવી રાખો.</translation>
<translation id="1571304935088121812">વપરાશકર્તાનામ કૉપિ કરો</translation>
<translation id="8640521265177023622">અત્યારે, આ ડિવાઇસ પર સાચવવામાં આવેલા પાસવર્ડનો ઉપયોગ Ecosiaની બધી ચૅનલ પર કરી શકાતો નથી. Ecosia 125 પછીના વર્ઝનમાં, તમારા ડિવાઇસ પર Ecosia અને <ph name="CHROME_CHANNEL"/> માટે સાચવેલા પાસવર્ડ મર્જ કરવામાં આવશે અને તેનો ઉપયોગ બન્ને ઍપમાં કરી શકાશે.</translation>
<translation id="1594635596540195766">નીચે આપેલી સૂચિમાં સૂચવેલી <ph name="SUGGESTIONS_COUNT"/> આઇટમ છે.</translation>
<translation id="1598163867407640634"><ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/> સાથે <ph name="SITE_ETLD_PLUS_ONE"/>નો ઉપયોગ કરો</translation>
<translation id="3933450988084434644">ચાલુ હોય, ત્યારે તમારા Ecosia એકાઉન્ટમાં ડેટાનો ઉપયોગ કરે છે અને તેને સાચવે છે. બંધ હોય ત્યારે, ડેટા ફક્ત આ ડિવાઇસ પર સાચવવામાં આવે છે.</translation>
<translation id="1628019612362412531">{NUM_SELECTED,plural, =1{પસંદ કરેલ 1 આઇટમ દૂર કરો}one{પસંદ કરેલ # આઇટમ દૂર કરો}other{પસંદ કરેલ # આઇટમ દૂર કરો}}</translation>
<translation id="1641113438599504367">સલામત બ્રાઉઝિંગ</translation>
<translation id="164269334534774161">તમે <ph name="CREATION_TIME"/>માંથી આ પેજની ઑફલાઇન કૉપિ જોઈ રહ્યા છો</translation>
<translation id="1644574205037202324">ઇતિહાસ</translation>
<translation id="1645262572857218659"><ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/> વડે સાઇન ઇન કરો</translation>
<translation id="1670399744444387456">મૂળભૂત</translation>
<translation id="1671236975893690980">ડાઉનલોડ બાકી…</translation>
<translation id="1672586136351118594">ફરીથી બતાવશો નહીં</translation>
<translation id="8751021997919823850">Ecosia Lens વડે છબી ખરીદો <ph name="BEGIN_NEW"/>નવું<ph name="END_NEW"/></translation>
<translation id="2236988473283378668">ટૂંક સમયમાં, તમને 'ફૉલો કરી રહ્યાં છો'માં <ph name="SITE_NAME"/> પરથી અને વિશેનું કન્ટેન્ટ જોવા મળશે. તમે જે સાઇટ અને શોધને ફૉલો કરો છો, તેને તમારા Ecosia એકાઉન્ટમાં સાચવવામાં આવે છે. તમે જેને ફૉલો કરો છો, તેને ગમે ત્યારે તમારા સેટિંગમાં મેનેજ કરી શકો છો.</translation>
<translation id="1689333818294560261">ઉપનામ</translation>
<translation id="1696555181932908973"><ph name="SITE_ETLD_PLUS_ONE"/> પર ચાલુ રાખવા માટે અન્ય રીતો અજમાવી શકો છો.</translation>
<translation id="1702543251015153180">તમારી ઘેરી થીમ માટેના સેટિંગમાં ફેરફાર કરીએ?</translation>
<translation id="1702907158640575240">મેનેજ કરવામાં આવતું બ્રાઉઝર</translation>
<translation id="1710099199314114079">ટૅબ સ્વિચ કરો કે બંધ કરો</translation>
<translation id="1718835860248848330">છેલ્લા એક કલાક</translation>
<translation id="1724977129262658800">તમારા પાસવર્ડમાં ફેરફાર કરવા માટે અનલૉક કરો</translation>
<translation id="8159444392185260734">તમે મુલાકાત લઈ શકો છો એવી સંભાવના ધરાવતા પેજને Ecosia જ્યારે પહેલેથી લોડ કરે, ત્યારે તમે ઝડપથી બ્રાઉઝ અને શોધ કરી શકો છો</translation>
<translation id="1728803206919861584">છૂપા સિવાયના મોડમાં પાસકી સાચવીએ?</translation>
<translation id="1747593111377567311">{NUM_SITES,plural, =1{1 સાઇટ દ્વારા તાજેતરમાં અનેક નોટિફિકેશન મોકલવામાં આવ્યા હતા}one{# સાઇટ દ્વારા તાજેતરમાં અનેક નોટિફિકેશન મોકલવામાં આવ્યા હતા}other{# સાઇટ દ્વારા તાજેતરમાં અનેક નોટિફિકેશન મોકલવામાં આવ્યા હતા}}</translation>
<translation id="1749561566933687563">તમારા બુકમાર્કને સિંક કરો</translation>
<translation id="4978404166749998360">તમારા Ecosia એકાઉન્ટમાં પાસવર્ડનો ઉપયોગ કરવાનું ચાલુ રાખો</translation>
<translation id="1750259112639922169">ટૅબનું ગ્રૂપ - <ph name="TAB_COUNT"/> ટૅબ</translation>
<translation id="17513872634828108">ટેબ્સ ખોલો</translation>
<translation id="1755203724116202818">કોઈ જાહેરાતનું પર્ફોર્મન્સ માપવા માટે, સાઇટની વચ્ચે મર્યાદિત પ્રકારના ડેટાને શેર કરવામાં આવે છે, જેમ કે સાઇટની મુલાકાત લીધા પછી તમે કોઈ ખરીદી કરી છે કે નહીં.</translation>
<translation id="1710654037603625078">Ecosia Password Manager સંબંધિત અપડેટ</translation>
<translation id="1760873718737761808">{FILE_COUNT,plural, =1{પેજ, સૂચિમાં 1 પેજ છે}one{પેજ, સૂચિમાં # પેજ છે}other{પેજ, સૂચિમાં # પેજ છે}}</translation>
<translation id="6468778501126990435">Ecosiaના તમારા વપરાશ વિશેની માહિતી Ecosiaને મોકલવામાં આવે છે, પરંતુ તે તમારાથી સંકળાયેલી રહેતી નથી\n\nજો Ecosia ક્રૅશ થાય, તો ક્રૅશ વિશેની વિગતોમાં થોડી વ્યક્તિગત માહિતી શામેલ કરવામાં આવી શકે છે\n\nજો તમે તમારો ઇતિહાસ તમારા Ecosia એકાઉન્ટ સાથે સિંક કરો, તો મેટ્રિકમાં તમે મુલાકાત લેતા હો તે URLs વિશેની માહિતી શામેલ કરવામાં આવી શકે છે</translation>
<translation id="1778457539567749232">વાંચ્યા વગરનું તરીકે માર્ક કરો</translation>
<translation id="1779766957982586368">વિન્ડો બંધ કરો</translation>
<translation id="1780023393214832643">પાસવર્ડ <ph name="USERNAME"/>માં સાચવ્યા</translation>
<translation id="1791662854739702043">ઇન્સ્ટોલ કરેલું</translation>
<translation id="1792959175193046959">ડિફૉલ્ટ ડાઉનલોડ સ્થાનને કોઈપણ સમયે બદલો</translation>
<translation id="1796666869097395659">પછીથી ટૅબ પર પાછા ફરવા માટે તેને નાનું કરો</translation>
<translation id="1807246157184219062">આછું</translation>
<translation id="1807709131360304325">એક નવી વિન્ડો ખોલો</translation>
<translation id="1810845389119482123">સિંકનું પ્રારંભિક સેટઅપ પૂર્ણ થયું નથી</translation>
<translation id="1812027881030482584"><ph name="SITE_ETLD_PLUS_ONE"/> પર <ph name="IDENTITY_PROVIDER_ETLD_PLUS_ONE"/>નો ઉપયોગ કરવાનું ચાલુ રાખી શકાતું નથી</translation>
<translation id="1027459482851943710">Ecosia Payમાંથી ચુકવણી પદ્ધતિઓ અને સરનામા એન્ક્રિપ્ટ કરવામાં આવશે નહીં. Ecosiaમાંથી બ્રાઉઝિંગ ઇતિહાસ સિંક થશે નહીં.
તમારો પાસફ્રેઝ ધરાવતી કોઈ વ્યક્તિ જ તમારો એન્ક્રિપ્ટેડ ડેટા વાંચી શકે છે. Ecosiaને પાસફ્રેઝ મોકલવામાં આવતો નથી કે તેમાં સ્ટોર કરવામાં આવતો નથી. જો તમે તમારો પાસફ્રેઝ ભૂલી જાઓ અથવા આ સેટિંગ બદલવા માગતા હો, તો <ph name="BEGIN_LINK"/>તમારા એકાઉન્ટમાંનો Ecosiaનો ડેટા ડિલીટ કરો<ph name="END_LINK"/>.</translation>
<translation id="1829244130665387512">આ પેજમાં શોધો</translation>
<translation id="1832459821645506983">હા, સંમત છું</translation>
<translation id="1365513153660530997">તમારા ડેટાને સુરક્ષિત કરવા માટે, Ecosiaને તમે તાજેતરમાં મુલાકાત લીધી ન હોય તેવી સાઇટમાંથી પરવાનગીઓ દૂર કરવા દો</translation>
<translation id="4275005407042916625">Ecosiaનું સૌથી વધુ સંબંધિત કન્ટેન્ટ મેળવવા માટે સિંક કરો</translation>
<translation id="3716077980817684849">Ecosia બ્રાઉઝરમાં ખોલો</translation>
<translation id="7268098999602465369">Ecosia જૂનું થઈ ગયું છે</translation>
<translation id="1877073879466606884">તમે જે પ્રોફાઇલમાં સાઇન ઇન કરેલું છે તે મેનેજ કરેલી પ્રોફાઇલ છે. તમારા ઍડમિનિસ્ટ્રેટર તમારી પ્રોફાઇલના સેટિંગમાં રિમોટલી ફેરફાર કરી શકે, રિપોર્ટિંગ મારફતે બ્રાઉઝર વિશેની માહિતીનું વિશ્લેષણ કરી શકે અને અન્ય જરૂરી કાર્યો કરી શકે.</translation>
<translation id="1883903952484604915">મારી ફાઇલો</translation>
<translation id="189358972401248634">અન્ય ભાષાઓ</translation>
<translation id="1899175549411605574">કિંમત વિશે જાણકારીની બોટમ શીટ</translation>
<translation id="1900260903084164610">આગળ વધીને, તમે <ph name="BEGIN_TOS_LINK"/>સેવાની શરતો<ph name="END_TOS_LINK"/> સાથે સંમત થાઓ છો.</translation>
<translation id="9102417284224414175">તમે મુલાકાત લો છો તે URLsને તમારા Ecosia એકાઉન્ટમાં સાચવવામાં આવે છે</translation>
<translation id="1910950723001426294">શેરિંગના વિકલ્પોની સૂચિ બંધ છે.</translation>
<translation id="191726024256261717">પરવાનગીઓ રિવ્યૂ કરો</translation>
<translation id="734114499997461221">Ecosiaમાં સાઇન-ઇનની મંજૂરી આપો</translation>
<translation id="1922362554271624559">સૂચવેલી ભાષાઓ</translation>
<translation id="1924255092154549435">ટૅબ મોટું કરવામાં આવ્યું છે</translation>
<translation id="1925021887439448749">કસ્ટમ વેબ ઍડ્રેસ દાખલ કરો</translation>
<translation id="1928618076168182477">વિઝ્યુઅલ વ્યૂ બતાવી રહ્યાં છે</translation>
<translation id="1928696683969751773">અપડેટ</translation>
<translation id="1933845786846280168">પસંદ કરેલ ટૅબ</translation>
<translation id="6997789686795879511">પાસવર્ડ ટૂંક સમયમાં કામ કરવાનું બંધ કરશે કારણ કે Ecosia Play સેવાઓ ઉપલબ્ધ નથી. તમારા સાચવેલા પાસવર્ડ કામ કરવાનું બંધ કરે તે પહેલાં તમે તેની કૉપિ બનાવી શકો છો. <ph name="BEGIN_LINK"/>વધુ જાણો<ph name="END_LINK"/></translation>
