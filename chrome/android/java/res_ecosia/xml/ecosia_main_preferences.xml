<?xml version="1.0" encoding="utf-8"?>

<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orderingFromXml="false">

    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:key="default_browser"
        android:order="1"
        android:title="@string/default_browser_title"
        android:layout="@layout/ecosia_preference_item_color_icon"
        android:icon="@drawable/ecosia_icon_settings_default"/>
    <PreferenceCategory
        android:key="basics_section"
        android:order="3"
        android:title="@string/prefs_section_basics"
        android:layout="@layout/ecosia_preference_category" />
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.password_manager.settings.PasswordSettings"
        android:key="passwords"
        android:order="5"
        android:title="@string/password_settings_title"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_password"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.autofill.settings.AutofillPaymentMethodsFragment"
        android:key="autofill_payment_methods"
        android:order="6"
        android:title="@string/autofill_payment_methods"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_payment"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.autofill.settings.AutofillProfilesFragment"
        android:key="autofill_addresses"
        android:order="7"
        android:title="@string/autofill_addresses_settings_title"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_address"/>
    <!-- android:order="8" is reserved for "Privacy" behind the privacy-elevated-android flag. -->
    <!-- Ecosia MOB-1158: Deactivate safe browsing
    <Preference
        android:fragment="org.chromium.chrome.browser.safety_check.SafetyCheckSettingsFragment"
        android:key="safety_check"
        android:order="9"
        android:title="@string/prefs_safety_check"/-->
    <Preference
        android:fragment="org.chromium.chrome.browser.notifications.settings.NotificationSettings"
        android:key="notifications"
        android:order="10"
        android:title="@string/prefs_notifications"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_notification"/>
    <Preference
        android:fragment="org.chromium.chrome.browser.night_mode.settings.ThemeSettingsFragment"
        android:key="ui_theme"
        android:order="12"
        android:title="@string/theme_settings"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_theme"/>

    <PreferenceCategory
        android:key="advanced_section"
        android:order="13"
        android:title="@string/prefs_section_advanced"
        android:layout="@layout/ecosia_preference_category"/>
    <Preference
        android:fragment="org.chromium.chrome.browser.privacy.settings.PrivacySettings"
        android:key="privacy"
        android:order="14"
        android:title="@string/prefs_privacy_menu_item"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_privacy"/>
    <Preference
        android:fragment="org.chromium.components.adblock.settings.AdblockSettingsFragment"
        android:key="adblock"
        android:order="15"
        android:title="@string/adblock_settings_title"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_adblock"/>
    <Preference
        android:fragment="org.chromium.components.browser_ui.accessibility.AccessibilitySettings"
        android:key="accessibility"
        android:order="16"
        android:title="@string/prefs_accessibility"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_accessibility"/>
    <Preference
        android:fragment="org.chromium.components.browser_ui.site_settings.SiteSettings"
        android:key="content_settings"
        android:order="17"
        android:title="@string/prefs_site_settings"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_site"/>
    <Preference
        android:fragment="org.chromium.chrome.browser.language.settings.LanguageSettings"
        android:key="languages"
        android:order="18"
        android:title="@string/language_settings"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_languages"/>
    <org.chromium.components.browser_ui.settings.ChromeBasePreference
        android:fragment="org.chromium.chrome.browser.download.settings.DownloadSettings"
        android:key="downloads"
        android:order="19"
        android:title="@string/menu_downloads"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_downloads"/>
    <Preference
        android:fragment="org.chromium.chrome.browser.tracing.settings.DeveloperSettings"
        android:key="developer"
        android:order="20"
        app:isPreferenceVisible="false"
        android:title="Developer options"/>
    <Preference
        android:fragment="org.ecosia.preferences.EcosiaAboutPreferences"
        android:key="about_ecosia"
        android:order="21"
        android:title="@string/prefs_about_ecosia"
        android:layout="@layout/ecosia_preference_item_mono_icon"
        android:icon="@drawable/ecosia_icon_settings_about"/>
</PreferenceScreen>
