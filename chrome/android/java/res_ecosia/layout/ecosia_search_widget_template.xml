<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/text_container"
        android:layout_width="match_parent"
        android:layout_height="@dimen/widget_height"
        android:background="@drawable/search_background"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/widget_padding"
        android:paddingEnd="@dimen/widget_padding">

    <ImageView
        android:id="@+id/image_ecosia_logo"
        android:padding="4dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_width="@dimen/widget_ecosia_logo_size"
        android:layout_height="@dimen/widget_ecosia_logo_size"
        android:src="@drawable/ic_ecosia_search_widget_logo"
        android:background="@drawable/ic_ecosia_search_widget_logo_bg"
        android:contentDescription="@null"/>

    <ImageView
        android:id="@+id/image_search"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:layout_width="@dimen/widget_search_icon_size"
        android:layout_height="@dimen/widget_search_icon_size"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_ecosia_search_widget_action"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/title"
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/image_ecosia_logo"
        android:layout_toStartOf="@id/image_search"
        android:layout_marginStart="@dimen/widget_padding"
        android:layout_centerVertical="true"
        android:text="@string/search_view_hint"
        android:textColor="@color/ecosia_text_primary"
        android:textSize="@dimen/search_view_text_size"
        android:maxLines="1"
        android:ellipsize="end"/>

</RelativeLayout>
