<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:layout_marginTop="24dp"
    android:layout_marginLeft="50dp"
    android:layout_marginRight="50dp"
    android:gravity="center_horizontal"
    android:background="@drawable/ecosia_treecounter_bg">

    <org.ecosia.ntp.TreeCounterProgressbar
        android:id="@+id/progress_bar"
        android:layout_width="300dp"
        android:layout_height="150dp"
        android:layout_centerHorizontal="true"/>

    <RelativeLayout
        android:id="@+id/info_help_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/img_tree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:src="@drawable/onboarding_tree"/>

        <TextView
            android:id="@+id/text_treecount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/img_tree"
            android:fontFamily="@font/FoundersGroteskCondensed"
            android:textSize="34sp"
            android:layout_centerHorizontal="true"
            android:textStyle="bold"
            android:textColor="@color/ecosia_text_primary"/>

        <TextView
            android:id="@+id/text_trees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_treecount"
            android:fontFamily="@font/inter"
            android:text="@string/onboarding_page_1_card_b_text"
            android:textColor="@color/ecosia_text_primary"
            android:layout_centerHorizontal="true"
            android:textSize="16sp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/text_trees"
            android:layout_marginTop="12dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/how_it_works"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="@string/ecosia_how_it_works"
                android:textStyle="bold"
                android:textColor="@color/button_primary_default"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/info_help"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/how_it_works"
                android:layout_marginLeft="4dp"
                android:layout_marginTop="2dp"
                android:layout_toRightOf="@+id/how_it_works"/>

        </RelativeLayout>

    </RelativeLayout>

</RelativeLayout>
