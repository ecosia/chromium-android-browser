<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/referrals_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/ecosia_more_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="9">

        <RelativeLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <ImageView
                    android:id="@+id/img_tree"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ecosia_referrals_icon" />

            </RelativeLayout>

        </RelativeLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:layout_weight="5">

            <TextView
                android:id="@+id/referrals_card_top_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textSize="24sp"
                android:textColor="@color/ecosia_text_primary"/>

            <TextView
                android:id="@+id/referrals_card_bottom_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:textColor="@color/ecosia_text_secondary"/>

        </LinearLayout>

        <TextView
            android:id="@+id/right_text_view"
            android:layout_weight="4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone"
            android:gravity="end"
            android:fontFamily="@font/inter"
            android:textColor="@color/ecosia_button_primary_default"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
