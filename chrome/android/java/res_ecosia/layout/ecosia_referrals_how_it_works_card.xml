<?xml version="1.0" encoding="utf-8"?>

<TableLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="16sp">

    <TableRow>
        <ImageView
            android:id="@+id/image_view"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_ecosia_share"
            android:contentDescription="@string/ecosia_referrals_share_icon_description"
            />

        <TextView
            android:layout_weight="1"
            android:id="@+id/title_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:textSize="16sp"
            android:textColor="@color/ecosia_text_primary"
            />
    </TableRow>

    <TableRow>
        <View android:layout_width="24dp" android:layout_height="24dp" />
        <TextView
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:id="@+id/description_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/ecosia_text_secondary"
            />
    </TableRow>

</TableLayout>