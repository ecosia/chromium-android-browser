<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/impact_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@color/ecosia_more_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <include layout="@layout/ecosia_ntp_personal_impact_progress_view" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/personal_impact_top_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textSize="24sp"
                android:textColor="@color/ecosia_text_primary"/>

            <TextView
                android:id="@+id/personal_impact_bottom_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:textColor="@color/ecosia_text_secondary"/>

        </LinearLayout>

        <TextView
            android:id="@+id/right_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="end"
            android:fontFamily="@font/inter"
            android:textColor="@color/button_primary_default"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
