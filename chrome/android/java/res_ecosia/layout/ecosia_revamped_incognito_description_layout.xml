<org.chromium.chrome.browser.ntp.IncognitoDescriptionView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/revamped_incognito_ntp_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="@dimen/md_incognito_ntp_padding_left"
    android:paddingEnd="@dimen/md_incognito_ntp_padding_left">

    <ImageView
        android:id="@+id/revamped_incognito_ntp_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:gravity="center"
        android:importantForAccessibility="no"
        android:src="@drawable/incognito_desc"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/FoundersGroteskCondensed"
        android:gravity="center"
        android:text="@string/incognito_title"
        android:textSize="28sp"
        android:textColor="@color/ecosia_text_primary_dark"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:gravity="center"
        android:text="@string/incognito_desc"
        android:textSize="14sp"
        android:textColor="@color/ecosia_text_secondary_dark"
        android:lineSpacingExtra="@dimen/md_incognito_ntp_line_spacing"/>


</org.chromium.chrome.browser.ntp.IncognitoDescriptionView>
