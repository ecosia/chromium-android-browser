<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ntp_impact_tooltip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/ecosia_tooltip">

    <TextView
        android:id="@+id/tooltip_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tooltip_close_button"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="8dp"
        android:gravity="start|center_vertical"
        android:fontFamily="@font/inter"
        android:fontWeight="500"
        android:text="@string/ecosia_counter_popup"
        android:textColor="@color/ecosia_your_impact_tooltip_text"
        android:textSize="16sp"
        android:lineSpacingExtra="4sp" />

    <ImageView
        android:id="@+id/tooltip_close_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@+id/tooltip_text"
        app:layout_constraintTop_toTopOf="@+id/tooltip_text"
        app:layout_constraintBottom_toBottomOf="@+id/tooltip_text"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ecosia_icon_close"
        android:tint="@color/ecosia_your_impact_tooltip_text" />

</androidx.constraintlayout.widget.ConstraintLayout>
