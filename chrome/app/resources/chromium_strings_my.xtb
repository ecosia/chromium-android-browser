<!DOCTYPE translationbundle>
<translationbundle lang="my">
<translation id="1026101648481255140">ထည့်သွင်းမှု ဆက်လုပ်ရန်</translation>
<translation id="8933665254023068908">&amp;EcosiaOS အပ်ဒိတ်လုပ်ရန်အတွက် ပြန်ဖွင့်ရန်</translation>
<translation id="1065672644894730302">သင့်စိတ်ကြိုက်များ ဖတ်၍မရပါ။

အချို့အင်္ဂရပ်များ မရရှိနိုင်ပါ၊ စိတ်ကြိုက်များသို့ ပြောင်းလဲခြင်းများ သိမ်းမည်မဟုတ်ပါ။</translation>
<translation id="1098170124587656448">ဒေတာပေါက်ကြားမှု၊ ဘေးကင်းမှုမရှိသော နောက်ဆက်တွဲနှင့် အခြားအန္တရာယ်များမှ သင့်ကိုလုံခြုံအောင် Chromium က ကူညီပေးနိုင်သည်</translation>
<translation id="3632544319066562282">Ecosia သည် သင်၏ စကားဝှက်များကို တင်ပို့လိုသည်။ ၎င်းကို ခွင့်ပြုရန် သင်၏ Windows စကားဝှက်ကို ထည့်ပါ။</translation>
<translation id="113122355610423240">Chromium သည် သင်၏ မူရင်းဘရောင်ဇာဖြစ်သည်</translation>
<translation id="1131805035311359397">သင်၏စကားဝှက်များတွင် ဒေတာပေါက်ကြားမှုနှင့် အခြားသော လုံခြုံရေးပြဿနာများ ရှိ၊ မရှိ စစ်ဆေးရန် <ph name="BEGIN_LINK"/>Chromium သို့ လက်မှတ်ထိုးဝင်ပါ<ph name="END_LINK"/>။</translation>
<translation id="1185134272377778587">Chromium အကြောင်း</translation>
<translation id="1203500561924088507">ထည့်သွင်းသည့်အတွက် ကျေးဇူးတင်ပါသည်။ <ph name="BUNDLE_NAME"/> အသုံးမပြုမီ သင့်ဘရောင်ဇာကို ပြန်စရမည်။</translation>
<translation id="1231839967188101156">ဖွင့်ထားပါက Chromium သည် အသုံးမပြုသည့်တဘ်များရှိ မှတ်ဉာဏ်ကို နေရာလွတ်ပြုလုပ်သည်။ ၎င်းက အသုံးပြုနေသည့်တဘ်နှင့် အခြားအက်ပ်များအား ကွန်ပျူတာရင်းမြစ် ပိုပေးပြီး Chromium ကို မြန်ဆန်စေသည်။ အသုံးမပြုသည့်တဘ်များသို့ ပြန်သွားသောအခါ ၎င်းတို့က အလိုအလျောက် ပြန်လည်လုပ်ဆောင်လာမည်။ <ph name="BEGIN_LINK"/>ပိုမိုလေ့လာရန်<ph name="END_LINK"/></translation>
<translation id="2298752889004612764">မှတ်ဉာဏ်ချွေတာစနစ်က Ecosia ကို ပိုမြန်စေသည်</translation>
<translation id="319566061277127356">သင်၏ Ecosia ပရိုဖိုင်အသစ်ကို စနစ်ထည့်သွင်းပါ</translation>
<translation id="2549591663512786020">Ecosia က စကားဝှက်များကို ပြရန် ကြိုးစားနေသည်။</translation>
<translation id="727568860157522676">သင်သည် Ecosia သို့ဝင်ရောက်ပြီးဖြစ်သည်!</translation>
<translation id="6650631555168164414">Ecosia ကို အကောင်းဆုံး အသုံးချနိုင်သည်</translation>
<translation id="1861504561909287316">Ecosia တဘ် မျှဝေခြင်း</translation>
<translation id="6896860023874996542">သင့်ပတ်ဝန်းကျင်၏ 3D မြေပုံ ပြုလုပ်ရန် Ecosia က သင့်ကင်မရာကို အသုံးပြုခွင့် လိုအပ်သည်</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{အပ်ဒိတ်ကို အသုံးပြုနိုင်ရန်အတွက် Ecosia ကို ပြန်လည်စတင်ရန် သင်၏စီမံခန့်ခွဲသူက တောင်းဆိုထားပါသည်}=1{အပ်ဒိတ်ကို အသုံးပြုနိုင်ရန်အတွက် Ecosia ကို ပြန်လည်စတင်ရန် သင်၏စီမံခန့်ခွဲသူက တောင်းဆိုထားပါသည်။ သင်၏ရုပ်ဖျက် ဝင်ဒိုးကို ပြန်ဖွင့်မည် မဟုတ်ပါ။}other{အပ်ဒိတ်ကို အသုံးပြုနိုင်ရန်အတွက် Ecosia ကို ပြန်လည်စတင်ရန် သင်၏စီမံခန့်ခွဲသူက တောင်းဆိုထားပါသည်။ သင်၏ရုပ်ဖျက် ဝင်ဒိုး # ခုကို ပြန်ဖွင့်မည် မဟုတ်ပါ။}}</translation>
<translation id="1625909126243026060">အဓိကကျသော ကိုယ်ရေးအချက်အလက်နှင့် လုံခြုံရေး ထိန်းချုပ်မှုများကို Chromium တွင် ကြည့်နိုင်သည်</translation>
<translation id="931416298178634530">ဤအကောင့်ကို တစ်ကြိမ်သာအသုံးပြုလိုပါက Ecosia ဘရောင်ဇာတွင် <ph name="GUEST_LINK_BEGIN"/>ဧည့်သည်မုဒ်<ph name="GUEST_LINK_END"/> သုံးနိုင်သည်။ အခြားတစ်ယောက်အတွက် အကောင့်ထည့်လိုပါက သင်၏ <ph name="DEVICE_TYPE"/> တွင် <ph name="LINK_BEGIN"/>ပုဂ္ဂိုလ်အသစ်ကို ထည့်နိုင်သည်<ph name="LINK_END"/>။

ဝဘ်ဆိုက်နှင့် အက်ပ်များကို ပေးထားသော ခွင့်ပြုချက်များက ဤအကောင့်တွင် အကျုံးဝင်နိုင်သည်။ <ph name="SETTINGS_LINK_BEGIN"/>ဆက်တင်များ<ph name="SETTINGS_LINK_END"/> တွင် သင်၏ Ecosia Account များကို စီမံနိုင်သည်။</translation>
<translation id="1640672724030957280">ဒေါင်းလုဒ်လုပ်နေသည်…</translation>
<translation id="6876820794875877783">ပိုလုံခြုံသော Ecosia ဗားရှင်း အသစ် ရနိုင်ပါသည်။</translation>
<translation id="1118786556671181978">ကြော်ငြာပြရန်သုံးသည့် သင်စိတ်ဝင်စားသော ဝဘ်ဆိုက်များ၏ အကြောင်းအရာများကို ကြည့်ကာ ဖယ်ရှားနိုင်သည်။ သင့်လတ်တလော ကြည့်ရှုခြင်းမှတ်တမ်းအပေါ်မူတည်၍ သင့်စိတ်ဝင်စားမှုများကို Ecosia က ခန့်မှန်းသည်။</translation>
<translation id="8454595950895325762">Ecosia ကို နောက်ခံမှာ အလုပ်လုပ်ပါစေ</translation>
<translation id="9125443060066914183">Ecosia ပိုပြီး လုံခြုံစေရန် အတွက်၊ ကျွန်ုပ်တို့သည် <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>ထဲမှာ ဖေါ်ပြမထားသည့်၊ သင် မသိဘဲနှင့် ထည့်ပေးထားတာ ဖြစ်နိုင်သည့်၊ တိုးချဲ့မှု အချို့ကို ပိတ်ထားပါသည်။</translation>
<translation id="6984747211123632080">Ecosia ကို ပြန်လည်တပ်ဆင်ရန်</translation>
<translation id="185970820835152459">သင်လက်မှတ်ထိုးဝင်ထားသော Google Account များကို စီမံနိုင်သည်။ Chromium ဘရောင်ဇာ၊ Play Store၊ Gmail စသည်တို့အတွက် သင်၏ Google Account များကို သုံးသည်။ မိသားစုဝင်ကဲ့သို့ တစ်စုံတစ်ယောက်အတွက် အကောင့်ထည့်လိုပါက ၎င်းအစား ထိုပုဂ္ဂိုလ်အသစ်ကို သင့် <ph name="DEVICE_TYPE"/> တွင် ထည့်ပါ။ <ph name="LINK_BEGIN"/>ပိုမိုလေ့လာရန်<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">ဝဘ်ဆိုက်များသည် သင်၏စိတ်ဝင်စားမှုများကို Chromium တွင် သိမ်းနိုင်သည်။ ဥပမာ မာရသွန်အတွက် ရှူးဖိနပ်ဝယ်ရန် ဝဘ်ဆိုက်တွင်ဝင်ကြည့်ပါက ဝဘ်ဆိုက်သည် သင်၏စိတ်ဝင်စားမှုကို မာရသွန်ပြေးခြင်းအဖြစ် သတ်မှတ်နိုင်သည်။ နောင်တွင် ပြိုင်ပွဲအတွက်စာရင်းသွင်းရန် အခြားဝဘ်ဆိုက်သို့ ဝင်ကြည့်သောအခါ ထိုဝဘ်ဆိုက်က သင်၏စိတ်ဝင်စားမှုများပေါ် အခြေခံပြီး အပြေးဖိနပ်ကြော်ငြာကို ပြနိုင်သည်။</translation>
<translation id="4239392394637574967">သင်သည်  စီမံကွပ်ကဲထားသည့် အကောင့် ထဲသို့ လက်မှတ် ထိုးဝင်နေကာ စီမံအုပ်ချုပ်သူအား
 သင့် Ecosia ပရိုဖိုင်ကို ထိန်းချုပ်ခွင့်ကို လွှဲပေးနေသည်။ သင်၏ အက်ပ်များ၊စာညှပ်များ၊ မှတ်တမ်း၊ စကားဝှက်များ၊ နှင့် အခြား ဆက်တင်များလို သင်၏ Ecosia ဒေတာများမှာ <ph name="USER_NAME"/> သို့ ထာဝရ ချိတ်တွဲလျက် ရှိလာကြမည်။ သင်သည်  ဒီဒေတာကို Ecosia အကောင့်များ ဒိုင်ခွက်မှ တစ်ဆင့် ဖျက်လို့ ရနိုင်သော်လည်း၊ သင်သည် ၎င်းဒေတာကို အခြား အကောင့်နှင့် ဆက်စပ်၍ မရနိုင်ပါ။ သင်သည် သင်၏ ရှိနေဆဲ Ecosia ဒေတာကို ထားရှိရန် အတွက် ပရိုဖိုင် အသစ်ကို ပြုလုပ်ရန် ရွေးနိုင်ပါသည်။ ပိုမို လေ့လာရန်။ <ph name="LEARN_MORE"/></translation>
<translation id="1911763535808217981">၎င်းကိုပိတ်ခြင်းဖြင့် Chromium တွင် လက်မှတ်ထိုးမဝင်ဘဲ Gmail ကဲ့သို့ Google ဝဘ်ဆိုက်များသို့ လက်မှတ်ထိုးဝင်နိုင်ပါသည်</translation>
<translation id="18064594488616674">Ecosia သည် မတုံ့ပြန်ပါ။ ယခု ပြန်ပြီး ဖွင့်တင်ရမလား?</translation>
<translation id="8047394653992042491">အပ်ဒိတ်ပြီးဆုံးရန် EcosiaOS ကို ပြန်စရမည်။</translation>
<translation id="5337919616446681032">ဤအကောင့်ကို တစ်ကြိမ်သာအသုံးပြုလိုပါက Ecosia ဘရောင်ဇာတွင် ‘ဧည့်သည်မုဒ်’ သုံးနိုင်သည်။ အခြားတစ်ယောက်အတွက် အကောင့်ထည့်လိုပါက သင်၏ <ph name="DEVICE_TYPE"/> တွင် <ph name="LINK_BEGIN"/>ပုဂ္ဂိုလ်အသစ်ကို ထည့်နိုင်သည်<ph name="LINK_END"/>။

ဝဘ်ဆိုက်နှင့် အက်ပ်များကို ပေးထားသော ခွင့်ပြုချက်များက ဤအကောင့်တွင် အကျုံးဝင်နိုင်သည်။ <ph name="SETTINGS_LINK_BEGIN"/>ဆက်တင်များ<ph name="SETTINGS_LINK_END"/> တွင် သင်၏ Ecosia Account များကို စီမံနိုင်သည်။</translation>
<translation id="1953553007165777902">ဒေါင်းလုဒ်လုပ်နေသည်… <ph name="MINUTE"/> မိနစ် ကျန်သည်</translation>
<translation id="1966382378801805537">Chromium သည် မူရင်းဘရောင်ဇာကို ဆုံးဖြတ်ပေးခြင်းသော်လည်းကောင်း သတ်မှတ်ခြင်းသော်လည်းကောင်း ပြုလုပ်၍မရပါ</translation>
<translation id="2008474315282236005">၎င်းသည် ဤစက်ပစ္စည်းမှ အကြောင်းအရာ ၁ ခုကို ဖျက်လိုက်ပါမည်။ သင့်ဒေတာကို နောက်မှ ပြန်ယူရန် Chromium သို့ <ph name="USER_EMAIL"/> အဖြစ် လက်မှတ်ထိုးဝင်ပါ။</translation>
<translation id="2018879682492276940">ထည့်သွင်းမှု မအောင်မြင်ပါ။ ထပ်စမ်းကြည့်ပါ။</translation>
<translation id="2020032459870799438">သင်၏အခြားစကားဝှက်များတွင် ဒေတာပေါက်ကြားမှုနှင့် အခြားသော လုံခြုံရေးပြဿနာများ ရှိ၊ မရှိ စစ်ဆေးရန် <ph name="BEGIN_LINK"/>Chromium သို့ လက်မှတ်ထိုးဝင်ပါ<ph name="END_LINK"/>။</translation>
<translation id="2049376729098081731">Google ဝန်ဆောင်မှုများရှိ ပုဂ္ဂိုလ်ရေးသီးသန့် အတွေ့အကြုံများ ပိုရရှိရန်အတွက် Chromium မှတ်တမ်းကို ထည့်၊ မထည့် ရွေးနိုင်သည်</translation>
