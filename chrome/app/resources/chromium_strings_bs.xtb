<translation id="7348818664647668234">{0,plural, =0{Ažuriranje za Ecosia je dostupno}=1{Ažuriranje za Ecosia je dostupno}one{Ažuriranje za Ecosia je dostupno # dan}few{Ažuriranje za Ecosia je dostupno # dana}other{Ažuriranje za Ecosia je dostupno # dana}}</translation>
<translation id="5643865575100044307">Uvijek izbrišite podatke web lokacije s uređaja kada zatvorite Chromium</translation>
<translation id="5982672133249369264">Ponovo pokrenite Ecosia sada</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="5698481217667032250">Prikaži Chromium na ovom jeziku.</translation>
<translation id="569897634095159764">Nije moguće povezati se s internetom. Proksi server zahtijeva autentifikaciju.</translation>
<translation id="5761096224651992291">Niste je posjetili već neko vrijeme. Chromium je uklonio odobrenja "<ph name="PERMISSION_1"/>", "<ph name="PERMISSION_2"/>" i "<ph name="PERMISSION_3"/>"</translation>
<translation id="1818520302923047971">Prilagodite i kontrolirajte Ecosia. Postavite Ecosia kao zadani preglednik.</translation>
<translation id="5809516625706423866">Nije moguće povezati se s internetom. HTTP 401 nije ovlašten. Provjerite konfiguraciju proksi servera.</translation>
<translation id="1027331268335328576">Dobro došli u Ecosia</translation>
<translation id="2942675027725878581">Ecosia je otkrio da ove stavke sadržavaju zlonamjerni softver:</translation>
<translation id="5889361821821684993">Chromium redovno provjerava ima li vaš preglednik najsigurnije postavke. Obavijestit ćemo vas ako nešto bude potrebno pregledati.</translation>
<translation id="5895138241574237353">Ponovo pokreni</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> – prijava na mrežu</translation>
<translation id="5924017743176219022">Povezivanje s internetom...</translation>
<translation id="719484593754925816">Ecosia može deaktivirati ovu karticu da poboljša iskustvo preglédanja i oslobodi resurse.</translation>
<translation id="5941711191222866238">Minimiziraj</translation>
<translation id="5972142260211327093">Ako vas je Chromium nasumično ubacio u aktivni probni period, vaša historija pregledanja utiče na oglase koje vidite i interesovanja, kao što je procijenjeno u nastavku. Da zaštiti vašu privatnost, Chromium automatski briše interesovanja na mjesečnoj osnovi. Interesovanja se osvježavaju ukoliko ih ne uklonite.</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{Organizacija automatski zatvara Ecosia kada se ne koristi 1 minutu.}one{Organizacija automatski zatvara Ecosia kada se ne koristi # minutu.}few{Organizacija automatski zatvara Ecosia kada se ne koristi # minute.}other{Organizacija automatski zatvara Ecosia kada se ne koristi # minuta.}}</translation>
<translation id="5704599732514791330">Ažurirajte Ecosia da započnete sinhronizaciju</translation>
<translation id="5988505247484123880">Uobičajeno je da web lokacije koje posjetite pamte stvari koje vas interesiraju radi personalizacije vašeg iskustva. Web lokacije mogu pohranjivati informacije o vašim interesovanjima i u Chromiumu.</translation>
<translation id="6003112304606738118">Preuzimanje… Preostalo je <ph name="HOURS"/> h</translation>
<translation id="8347473600923066837">Možete otvoriti oznake, način rada za čitanje i drugo iz menija Ecosiaa u gornjem desnom uglu</translation>
<translation id="6040143037577758943">Zatvori</translation>
<translation id="6058380562449900225">Da zaštitite podatke, omogućite Chromiumu da ukloni odobrenja s web lokacija koje u posljednje vrijeme niste posjetili. Ovo ne zaustavlja slanje obavještenja.</translation>
<translation id="7303930050538184306">&amp;Otvori u Ecosiau</translation>
<translation id="2227704215309956084">Ekstenzija <ph name="EXTENSION_NAME"/> je dodana u Ecosia</translation>
<translation id="2905159584855395810">Ubrzajte Ecosia</translation>
<translation id="608006075545470555">Dodajte radni profil na ovaj preglednik</translation>
<translation id="8296565077892323223">Prilagodite i kontrolirajte Ecosia. Dostupno je ažuriranje.</translation>
<translation id="6102072151902574948">Kada je postavka uključena, Chromium štedi energiju baterije ograničavanjem pozadinske aktivnosti i vizuelnih efekata, poput glatkog klizanja i broja slika u sekundi videozapisa.</translation>
<translation id="8419312540998601274">Uključeno • Ecosia ne može potvrditi odakle dolazi ova ekstenzija</translation>
<translation id="6419542773162312746">Dozvoli ekstenziju za prikaz zahtjeva za pristup na alatnoj traci Ecosiaa</translation>
<translation id="4021894801595982809">Ecosia će sačuvati ovu lozinku na vašem Ecosia računu. Nećete je morati zapamtiti.</translation>
<translation id="1936361330890313940">Fajl <ph name="FILE_NAME"/> je opasan pa ga je Ecosia blokirao.</translation>
<translation id="2446603005062458629">Ecosia će se uskoro zatvoriti i izbrisati podatke</translation>
<translation id="6134968993075716475">Sigurno pregledanje je isključeno. Chromium preporučuje da ga uključite.</translation>
<translation id="4032832945953542360">Ovdje možete prebacivati između Ecosia profila</translation>
<translation id="615103374448673771">Ako dozvolite kolačiće, Chromium ih može koristiti prilikom predučitavanja</translation>
<translation id="5032126307005935789">Fajl je možda opasan<ph name="LINE_BREAK"/>Ecosia može provjeriti ovo preuzimanje za vas ako unesete lozinku. Informacije o fajlu se šalju na Sigurno pregledanje na Ecosiau, ali sadržaj fajla i lozinka ostaju na vašem uređaju.</translation>
<translation id="6182736845697986886">Instalacija nije uspjela zbog interne greške na serveru za ažuriranje.</translation>
<translation id="2346323077583431428">Provjerite jeste li prijavljeni u Ecosia na svom uređaju <ph name="TARGET_DEVICE_NAME"/> i zatim pokušajte poslati ponovo.</translation>
<translation id="2995860351618948435">Na ovom računaru se već nalazi novija verzija Ecosiaa. Ako softver ne funkcionira, deinstalirajte Ecosia i pokušajte ponovo.</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia će se sada ponovo pokrenuti}=1{Ecosia će se ponovo pokrenuti za 1 sekundu}one{Ecosia će se ponovo pokrenuti za # sekundu}few{Ecosia će se ponovo pokrenuti za # sekunde}other{Ecosia će se ponovo pokrenuti za # sekundi}}</translation>
<translation id="1809194740315140401">Ecosiau je potrebno odobrenje za pristup pohrani radi preuzimanja fajlova</translation>
<translation id="6245734527075554892">Provjerava URL-ove s listom nesigurnih web lokacija pohranjenih u Chromiumu</translation>
<translation id="4662363689050405237">Postavi Ecosia kao zadani preglednik</translation>
<translation id="6266342355635466082">Chromium ne može provjeravati ima li ažuriranja. Predlažemo da provjerite internetsku vezu.</translation>
<translation id="6268381023930128611">Odjaviti se iz Chromiuma?</translation>
<translation id="4618410489751241263">Ove kartice koriste dodatne izvore. Da poboljšate performanse, dozvolite Ecosiau da ih učini neaktivnima.</translation>
<translation id="6416551953415159186">Prilagodite svoj Ecosia profil</translation>
<translation id="6290827346642914212">Dajte naziv Chromium profilu</translation>
<translation id="4882579364090762302">Ekstenzija želi da se prijavite u Ecosia</translation>
<translation id="3625533701824359646">Moguće je da je fajl <ph name="FILE_NAME"/> opasan, pa ga je Ecosia blokirao.</translation>
<translation id="4943938785458240142">Ecosia koristi vašu kameru.</translation>
<translation id="6327105987658262776">Ažuriranje nije dostupno.</translation>
<translation id="6450895420388847775">U toku je druga radnja u Ecosiau. Pokušajte ponovo kasnije.</translation>
<translation id="464306605599005355">Sada je lakše koristiti Ecosia s vašim Ecosia računom i na dijeljenim računarima.</translation>
<translation id="6735145163744656874">Ecosia može učiniti ove kartice neaktivnima da poboljša iskustvo pregledanja i ubrza stvari.</translation>
<translation id="1284343625991453987">Prečica Ecosiaa</translation>
<translation id="7051119589302096163">Ecosia je blokirao ovo preuzimanje jer se fajl ne preuzima često i možda je opasan</translation>
<translation id="7908111389403807005">Jeste li sigurni da želite deinstalirati Ecosia?</translation>
<translation id="6375219077595103062">Dodajte prečicu za Upravitelj lozinki</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>Kako koristimo ove podatke:<ph name="END_BOLD"/> Ecosia može procijeniti vaša interesovanja. Kasnije, web lokacija koju ste posjetili može zatražiti od Ecosiaa da pogleda vaša interesovanja radi personalizacije oglasa koje vidite.</translation>
<translation id="7578952608547569314">Logotip Ecosiaa na ekranu računara.</translation>
<translation id="3939060118711873999">Ecosia je novi preglednik koji pokreće web stranice i aplikacije brzinom svjetlosti. On je brz, stabilan i jednostavan za upotrebu. Krećite se internetom u sigurnijem okruženju, zaštićeni od zlonamjernih softvera i krađe identiteta zahvaljujući elementima koji su ugrađeni u Ecosia.</translation>
<translation id="5404489723475681578">Ponovo pokrenite EcosiaOS</translation>
<translation id="6443470774889161065">Chromium predučitava još više stranica za koje postoji vjerovatnoća da ćete ih posjetiti kako bi se brže učitavale prilikom posjete</translation>
<translation id="7877883466657693294">Isključeno • Ecosia ne može potvrditi odakle dolazi ova ekstenzija</translation>
<translation id="4410570812343670816">Dobro došli u Ecosia profile</translation>
<translation id="4371259280767924562">Ukloni račun iz Ecosiaa</translation>
<translation id="524314285625975879">Također kontrolira koja stranica se prikazuje kada pokrenete Ecosia.</translation>
<translation id="648319183876919572">Poboljšano Sigurno pregledanje vas bolje štiti od opasnih web lokacija i preuzimanja</translation>
<translation id="6496553866814956056">Deinstaliraj Ecosia</translation>
<translation id="788366290112401490">Prečice se otvaraju u Ecosiau</translation>
<translation id="1773882594264682232">Dok ste prijavljeni, lozinke i drugo s Ecosia računa možete koristiti u Ecosiau. Ovo možete promijeniti bilo kada u postavkama.</translation>
<translation id="2280934980919215876">Vaš organizacija zatvara Ecosia kada se ne koristi <ph name="TIMEOUT_DURATION"/>. Podaci o pregledanju su izbrisani. Ovo može uključivati historiju, automatsko popunjavanje i preuzimanja.</translation>
<translation id="8608092457636055141">Svaki profil sadrži svoje Ecosia informacije, poput oznaka, historije, lozinki i još mnogo toga</translation>
<translation id="6563921047760808519">Saznajte više o tome <ph name="BEGIN_LINK"/>kako Chromium štiti privatnost vaših podataka<ph name="END_LINK"/></translation>
<translation id="3592624492063123732">Možete se prebaciti da vidite lozinke s drugog Ecosia profila</translation>
<translation id="6570579332384693436">Zbog ispravke pravopisnih grešaka, Chromium šalje Googleu tekst koji napišete u polja.</translation>
<translation id="6533266716128249922">Idi u postavke obavještenja Ecosiaa</translation>
<translation id="1722634673917783018">Vaše promjene će stupiti na snagu kada sljedeći put budete ponovo pokrenuli Ecosia.</translation>
<translation id="2537426042760364251">Ecosiau je potrebno odobrenje za kameru radi kreiranja 3D mape vašeg okruženja</translation>
<translation id="6663852025006259149">Web lokacije će vjerovatno funkcionirati kako očekujete, ali vas neće zapamtiti nakon što zatvorite sve prozore Chromiuma</translation>
<translation id="6669284030132180248">Ako sačuvate oznake i na svoj Google račun možete pratiti cijene proizvoda u Chromiumu i primati obavještenja kada cijena padne</translation>
<translation id="6676384891291319759">Pristupite internetu</translation>
<translation id="8067423333018528301">EcosiaOS nije sinhronizirao vaše podatke zbog greške prilikom prijave.</translation>
<translation id="6692797197837897398">Chromium vam daje veću kontrolu nad oglasima koji vam se prikazuju i ograničava koje web lokacije mogu saznati informacije o vama kada vam prikažu personalizirane oglase</translation>
<translation id="2173571365716863400">Ecosiau je za ovu web lokaciju potrebno odobrenje za mikrofon</translation>
<translation id="6712881677154121168">Greška prilikom preuzimanja: <ph name="DOWNLOAD_ERROR"/></translation>
<translation id="6648664289472946060">Ne možete koristiti profil jer pripada novijoj verziji Ecosiaa.

Moguće je da neke funkcije neće biti dostupne. Odredite drugi direktorij profila ili koristite noviju verziju Ecosiaa.</translation>
<translation id="6729124504294600478">Da dobijete personalizaciju i druge funkcije, uključite Chromium u Aktivnosti na webu i u aplikacijama te na povezanim Googleovim uslugama</translation>
<translation id="4870057811531036437">Ecosia je već instaliran za sve korisnike na računaru.</translation>
<translation id="4512092435423703529">Prijavite se, a zatim uključite sinhronizaciju da pristupite svojim Ecosia stvarima na svim svojim uređajima.</translation>
<translation id="674245979920622322">Niste je posjetili već neko vrijeme. Chromium je uklonio odobrenja "<ph name="PERMISSION_1"/>", "<ph name="PERMISSION_2"/>" i još <ph name="COUNT"/></translation>
<translation id="7972668220031382654">Ecosia preporučuje skeniranje ovog fajla jer bi mogao biti opasan.</translation>
<translation id="2441303983090031276">EcosiaOS omogućava dodatni <ph name="BEGIN_LINK_CROS_OSS"/>softver otvorenog koda<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="1263466865695943046">Ecosia vas obavještava ako sigurnost vaših lozinki bude ugrožena</translation>
<translation id="684888714667046800">Nije moguće povezati se s internetom. Ako koristite zaštitni zid, vodite računa da <ph name="PRODUCT_EXE_NAME"/> bude na listi dozvoljenih.</translation>
<translation id="4600924482853773728">Ecosia – <ph name="PAGE_TITLE"/></translation>
<translation id="1490060441084292633">Ecosia je otkrio da "<ph name="EXTENSION_NAME"/>" sadržava zlonamjerni softver</translation>
<translation id="6929417474050522668">Tokom probnog perioda, mjerenje oglasa omogućava web lokacijama koje posjećujete da zatraže informaciju iz Chromiuma koja će im pomoći da izmjere performanse svojih oglasa. Mjerenje oglasa ograničava unakrsno praćenje web lokacija prenoseći minimalnu količinu informacija između njih.</translation>
<translation id="6940431691900807093">Kasnije, web lokacija koju ste posjetili može zatražiti od Chromiuma da pogleda vaša interesovanja radi personalizacije oglasa koji vam se prikazuju. Chromium može dijeliti najviše 3 interesovanja.</translation>
<translation id="8283315171506895091">Otvori link u anonim&amp;nom prozoru Ecosiaa</translation>
<translation id="6978145336957848883">Slabe lozinke je lako pogoditi. Dozvolite Chromiumu da <ph name="BEGIN_LINK"/>kreira i zapamti jake lozinke za vas<ph name="END_LINK"/>.</translation>
<translation id="6981396265751285733">Kada je postavka uključena, Chromium oslobađa memoriju od neaktivnih kartica. Time se aktivnim karticama i drugim aplikacijama pruža više računarskih resursa i ubrzava rad Chromiuma. Neaktivne kartice se automatski ponovo aktiviraju kada se vratite na njih.</translation>
<translation id="2149148292984034533">Uslovi korištenja EcosiaOS-a</translation>
<translation id="1831192335802727557">Ecosiau treba odobrenje za pristup mikrofonu za ovu web lokaciju.</translation>
<translation id="7011190694940573312">Instalacija nije uspjela jer ova verzija operativnog sistema nije podržana.</translation>
<translation id="7024536598735240744">Greška prilikom otpakivanja: <ph name="UNPACK_ERROR"/>.</translation>
<translation id="7025789849649390912">Instalacija je zaustavljena.</translation>
<translation id="762525592078244189">Prilagodite Ecosia sebi</translation>
<translation id="5598074261782651109">Ažuriraj Ecosia</translation>
<translation id="2838372953389311551">Ako slika ne sadrži koristan opis, Ecosia će ga pokušati pružiti. Slike se šalju Ecosiau radi kreiranja opisa.</translation>
<translation id="550507036977517224">Prilagodite Ecosia for Testing</translation>
<translation id="9091453616111683919">Uklanjanje ekstenzije <ph name="EXTENSION_NAME"/> iz Ecosiaa</translation>
<translation id="5137471865755621561">Vaša organizacija briše podatke Ecosiaa kada se ne koristi <ph name="TIMEOUT_DURATION"/>. Ovo može uključivati historiju, automatsko popunjavanje i preuzimanja.</translation>
<translation id="219546601381787154">Ecosiau je za ovu web lokaciju potrebno odobrenje za kameru</translation>
<translation id="2542649989941327712">Pokretanje Ecosiaa nije uspjelo. Pokušajte ponovo.</translation>
<translation id="7197677400338048821">Chromium ne može provjeravati vaše lozinke. Pokušajte ponovo za 24 sata.</translation>
<translation id="3784023996375784431">Koristite Ecosia svaki put kada kliknete na linkove u porukama, dokumentima i drugim aplikacijama</translation>
<translation id="7311066525704006840">Upravitelj zadataka za Ecosia</translation>
<translation id="3816260943154642689">Vaša interesovanja prema Ecosiaovoj procjeni</translation>
<translation id="1720431815870023289">{NUM_EXTENSIONS,plural, =1{Ecosia preporučuje da je uklonite}one{Ecosia preporučuje da ih uklonite}few{Ecosia preporučuje da ih uklonite}other{Ecosia preporučuje da ih uklonite}}</translation>
<translation id="7309928523159922338">Mjerenje oglasa omogućava web lokacijama koje posjećujete da zatraže informaciju iz Chromiuma koja će im pomoći da izmjere performanse svojih oglasa. Mjerenje oglasa ograničava unakrsno praćenje web lokacija prenoseći minimalnu količinu informacija između njih.</translation>
<translation id="731795002583552498">Ažuriranje Chromiuma</translation>
<translation id="6673288084648462613">Vaš fajl s postavkama je oštećen ili nevažeći.

Ecosia ne može vratiti vaše postavke.</translation>
<translation id="7339898014177206373">Novi prozor</translation>
<translation id="4960252760049500399">Vaš web, oznake i ostali sadržaji s Ecosiaa se nalaze ovdje.</translation>
<translation id="7158975242722498086">Administrator sistema je konfigurirao Ecosia da otvori preglednik <ph name="ALTERNATIVE_BROWSER_NAME"/> radi pristupa web lokaciji <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="6632508343667825745">Ecosia je blokirao preuzimanje jer fajl može nanijeti štetu ličnom računu i računima za društvene mreže, uključujući <ph name="USER_EMAIL"/></translation>
<translation id="6180968682827452331">Ta ekstenzija više nije podržana. Ecosia preporučuje da je uklonite.</translation>
<translation id="5622136942112821750">S Ecosia profilima možete odvojiti sve svoje Ecosia stvari. Tako ćete lakše razdvojiti posao i zabavu.</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> – Ecosia Dev</translation>
<translation id="5055330219314726197">Ecosiau treba odobrenje za pristup vašoj kameri na ovoj web lokaciji</translation>
<translation id="7458892263350425044">Da koristite mikrofon, odobrite Chromiumu pristup u <ph name="BEGIN_LINK"/>postavkama sistema<ph name="END_LINK"/></translation>
<translation id="1975037445584526511">Da primate buduća ažuriranja za Ecosia, trebat će vam Windows 10 ili novija verzija. Računar koristi Windows 7.</translation>
<translation id="7467949745582939695">Ponovo pokrenuti Chromium?</translation>
<translation id="80155189677487610">Nije moguće instalirati istu verziju Ecosiaa koja je trenutno pokrenuta. Zatvorite Ecosia i pokušajte ponovo.</translation>
<translation id="751935028865900641">Web lokacije vjerovatno neće funkcionirati kako se očekuje. Kada zatvorite sve prozore Chromiuma, odjavit ćete se s većine web lokacija, osim s Google računa ako ste prijavljeni u Chromium.</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia će se ponovo pokrenuti za 1 minutu}one{Ecosia će se ponovo pokrenuti za # minutu}few{Ecosia će se ponovo pokrenuti za # minuta}other{Ecosia će se ponovo pokrenuti za # minuta}}</translation>
<translation id="8228132389897276908">Da podijelite prozor, dozvolite snimanje ekrana za Ecosia u Postavkama sistema</translation>
<translation id="7582945390259497898">Chromium može procijeniti vaša interesovanja. Kasnije, web lokacija koju ste posjetili može zatražiti od Chromiuma da pogleda vaša interesovanja radi personalizacije oglasa koje vidite.</translation>
<translation id="7583399374488819119">Alat za instaliranje preglednika <ph name="COMPANY_NAME"/></translation>
<translation id="7585391435984513350">Niste je posjetili već neko vrijeme. Chromium je uklonio odobrenje "<ph name="PERMISSION"/>"</translation>
<translation id="4061472199368124600">Ecosia koristi vašu kameru i mikrofon.</translation>
<translation id="170259281605734125">Ecosia je sada još bolji</translation>
<translation id="7649070708921625228">Pomoć</translation>
<translation id="675365189802108507">O ovim funkcijama možete saznati više u postavkama Ecosiaa.</translation>
<translation id="1508200558303644420">Ecosia nije vaš zadani preglednik</translation>
<translation id="7174674455569790401">Sinhronizirajte i personalizirajte Ecosia na svim uređajima</translation>
<translation id="7699779824407626136">Ažuriranje Chromiuma</translation>
<translation id="7745317241717453663">Na ovaj način će se podaci o pregledanju izbrisati s ovog uređaja. Za preuzimanje podataka kasnije prijavite se u Chromium kao korisnik <ph name="USER_EMAIL"/>.</translation>
<translation id="7747138024166251722">Aplikacija za instaliranje nije uspjela kreirati privremeni direktorij. Provjerite imate li slobodnog prostora na disku kao i odobrenje da instalirate softver.</translation>
<translation id="6161025257729272170">Ubrzajte Ecosia</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> – Ecosia Canary</translation>
<translation id="7803986347287457849">Otežajte osobama s pristupom vašem internetskom saobraćaju da vide koje web lokacije posjećujete. Chromium koristi sigurnu vezu da potraži IP adresu web lokacije u DNS-u (Sistem naziva domena).</translation>
<translation id="8301840715671593762">Ecosia profil s ovim računom već postoji na ovom uređaju</translation>
<translation id="7845233973568007926">Hvala što ste instalirali. Morate ponovo instalirati računar prije nego što možete koristiti <ph name="BUNDLE_NAME"/>.</translation>
<translation id="7859018312476869945">Kad pišete u traci za adresu ili u okviru za pretraživanje, Chromium šalje ono što upišete zadanom pretraživaču radi dobijanja boljih prijedloga. Ovo je isključeno u anonimnom načinu rada.</translation>
<translation id="3268039966078382323">Ecosia nije ažuriran na najnoviju verziju tako da propuštate prednosti novih funkcija i ispravke sigurnosnih propusta.</translation>
<translation id="7872446069773932638">Preuzimanje… Preostalo je <ph name="SECONDS"/> s</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Kako možete upravljati svojim podacima:<ph name="END_BOLD"/> Da zaštitimo vašu privatnosti, automatski brišemo interesovanja koja su starija od 4 sedmice. Kada nastavite koristiti preglednik, interesovanje se može ponovo pojaviti na listi. Ili možete ukloniti interesovanja koja ne želite dati Ecosiau na razmatranje.</translation>
<translation id="4638085384909702681">Postavite Ecosia kao zadani preglednik</translation>
<translation id="7934340546140346950">Chromium automatski nadograđuje nesigurne veze na HTTPS kada je moguće</translation>
<translation id="2412381038247037703">Bili ste prijavljeni na Ecosia kao <ph name="USER_EMAIL_ADDRESS"/>. Koristite isti račun da se ponovo prijavite.</translation>
<translation id="7975919845073681630">Ovo je sekundarno instaliranje Chromiuma i stoga on ne može biti vaš zadani preglednik.</translation>
<translation id="851583113375911087">Ekstenzije, aplikacije i teme iz nepoznatih izvora mogu naštetiti vašem uređaju. Ecosia preporučuje da ih instalirate samo iz: <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/></translation>
<translation id="488806616089631539">Kada Ecosia dobije pristup, web lokacije će vam moći zatražiti pristup.</translation>
<translation id="80471789339884597">Hvala što ste instalirali. Morate ponovo pokrenuti sve preglednike prije nego što možete koristiti <ph name="BUNDLE_NAME"/>.</translation>
<translation id="8086881907087796310">Instalacija nije uspjela jer vaš računar ne ispunjava minimalne hardverske zahtjeve.</translation>
<translation id="1528748166720431933"><ph name="PAGE_TITLE"/> – Ecosia for Testing</translation>
<translation id="5661123757512626239">Ecosiau je za ovu web lokaciju potrebno odobrenje za lokaciju</translation>
<translation id="143614250230771428">EcosiaOS nije mogao sinhronizirati podatke zato što sinhronizacija nije dostupna za vašu domenu.</translation>
<translation id="813913629614996137">Pokretanje…</translation>
<translation id="588828970866589779">Uključite dodatnu zaštitu za Ecosiaov pokretač programskih jezika JavaScript i WebAssembly</translation>
<translation id="6491651957026506753">Ovaj fajl je opasan pa ga je Ecosia blokirao.</translation>
<translation id="8223363452568144035">Da koristite kameru, odobrite Chromiumu pristup u <ph name="BEGIN_LINK"/>postavkama sistema<ph name="END_LINK"/></translation>
<translation id="7433581196371819898">Ecosia ne može potvrditi odakle potiče ova ekstenzija te može biti nesigurna. Uklonite je iz Ecosiaa da više ne može vidjeti i mijenjati vaše podatke na web lokacijama koje posjećujete, uključujući lične informacije.</translation>
<translation id="2046160555506209000">Ako slika ne sadrži koristan opis, Ecosia će ga pokušati pružiti. Slike se šalju Ecosiau radi kreiranja opisa. To možete isključiti u postavkama kad god želite.</translation>
<translation id="3260765223735049374">Prijaviti se u Ecosia na novom profilu?</translation>
<translation id="8266560134891435528">Chromium ne može provjeravati vaše lozinke jer niste prijavljeni</translation>
<translation id="8286943863733751221"><ph name="BEGIN_LINK"/>Chromium vas upozorava<ph name="END_LINK"/> o nesigurnim web lokacijama i preuzimanjima</translation>
<translation id="5994043198751001258">Vaš organizacija zatvara Ecosia kada se ne koristi <ph name="TIMEOUT_DURATION"/>.</translation>
<translation id="8330519371938183845">Prijavite se da sinhronizirate i personalizirate Chrome na svim svojim uređajima</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> je prethodno koristio/la Ecosia</translation>
<translation id="4337034173783952373">Prijavite se, a zatim uključite sinhronizaciju da pristupite svojim stvarima s Ecosia preglednika na svim svojim uređajima</translation>
<translation id="8655983536493871574">Da primate buduća ažuriranja za Ecosia, trebat će vam Windows 10 ili novija verzija. Računar koristi Windows 8.</translation>
<translation id="8355171755788522183">Autorska prava <ph name="YEAR"/> Ecosia. Sva prava su zadržana.</translation>
<translation id="4395802781633621239">Da dobijate lozinke i drugo na svim svojim uređajima, prijavite se u Ecosia. Ova lozinka će se sačuvati na Ecosia račun nakon što se prijavite.</translation>
<translation id="8268239447047453615">Zatim ćete morati ponovo pokrenuti Ecosia.</translation>
<translation id="5167067155585861308">Ecosia vam preporučuje da je uklonite. <ph name="BEGIN_LINK"/>Saznajte više o podržanim ekstenzijama<ph name="END_LINK"/></translation>
<translation id="8863497461138396324">Programer je opozvao objavljivanje ove ekstenzije i može biti nesigurna. Uklonite je s Ecosiaa kako više ne bi mogla vidjeti i mijenjati vaše podatke na web lokacijama koje posjećujete, uključujući vaše lične informacije.</translation>
<translation id="6826163993811146231">{0,plural, =1{Ponovo pokreni Ecosia u roku od jednog dana}one{Ponovo pokreni Ecosia u roku od # dana}few{Ponovo pokreni Ecosia u roku od # dana}other{Ponovo pokreni Ecosia u roku od # dana}}</translation>
<translation id="4033006861724039519">Arhiva alata za instaliranje je oštećena ili nevažeća. Ponovo preuzmite Ecosia.</translation>
<translation id="2829233304432701500">Za Ecosia je potreban Windows 10 ili noviji operativni sistem.</translation>
<translation id="8975930032513941502">Nije obavezno: Pomozite nam da poboljšamo funkcije i performanse EcosiaOS-a automatskim slanjem podataka o dijagnostici i korištenju Ecosiau.</translation>
<translation id="2695952268686253864">Ecosia nije ažuriran</translation>
<translation id="8522801943730206384">Chromium može provjeravati vaše lozinke kada ih sačuvate</translation>
<translation id="8550334526674375523">Ovaj radni profil je u potpunosti odvojen od vašeg ličnog profila.</translation>
<translation id="8555465886620020932">Greška usluge: <ph name="SERVICE_ERROR"/>.</translation>
<translation id="8568283329061645092">Chromium može provjeravati vaše lozinke kada se prijavljujete putem Google računa</translation>
<translation id="4817309082638621362">Više organizacija upravlja Ecosiaom</translation>
<translation id="7129808598331559748">Autorska prava <ph name="YEAR"/> Autori Ecosiaa. Sva prava zadržana.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>Kako koristimo ove podatke:<ph name="END_BOLD"/> Web lokacije mogu pohranjivati informacije o vašim interesovanjima u Ecosiau. Naprimjer, ako posjetite web lokaciju da kupite obuću za maraton, ta web lokacija može definirati vaše interesovanje za trčanje maratona. Kasnije, kada posjetite drugu web lokaciju da se registrirate za utrku, ta web lokacija vam može prikazati oglas koji prikazuje obuću za trčanje, na osnovu vaših interesovanja.</translation>
<translation id="8109744984354428711">Pokretanje Ecosiaa...</translation>
<translation id="2402290209407843024">Instalacija nije uspjela zbog neodređene greške. Ponovo preuzmite Ecosia.</translation>
<translation id="8648201657708811153">Google Chrome for Testing nije moguće postaviti kao zadani preglednik.</translation>
<translation id="6665128960039431910">Također kontrolira koja stranica će se prikazati kada pokrenete Ecosia ili budete pretraživali iz višenamjenskog okvira.</translation>
<translation id="2000339487270823788">Ovo je vaš Ecosia</translation>
<translation id="7045045549868370797">Prijaviti se u Ecosia?</translation>
<translation id="878572486461146056">Greška prilikom instaliranja: administrator mreže je primijenio pravila grupe koja sprečavaju instalaciju: <ph name="INSTALL_ERROR"/></translation>
<translation id="7273750863406285983">Ecosia traži odobrenje za pristup vašoj kameri i mikrofonu na ovoj web lokaciji</translation>
<translation id="1485302026917450654">Prijaviti se u Ecosia?</translation>
<translation id="8826492472752484139">Kliknite na "Upravitelj lozinki"</translation>
<translation id="5267683457871579197">Sistem EcosiaOS</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>Koji podaci se koriste:<ph name="END_BOLD"/> vaša historija pregledanja, zapisi o web lokacijama koje ste posjetili koristeći Ecosia na ovom uređaju.</translation>
<translation id="8862326446509486874">Nemate odgovarajuća prava za instalaciju na nivou sistema. Pokušajte ponovo pokrenuti instalaciju kao administrator.</translation>
<translation id="8880203542552872219">Ako jeste, uredite sačuvanu lozinku u Chromiumu da se podudara s novom lozinkom.</translation>
<translation id="3966234175958887595">Ecosia pokušava prikazati lozinke. Upišite Windows lozinku da ovo omogućite.</translation>
<translation id="8931379085695076764">Chromium može procijeniti vaša interesovanja na osnovu historije pregledanja tokom proteklih nekoliko sedmica. Ta informacija ostaje na vašem uređaju.</translation>
<translation id="6346154190168496057">Nije moguće ažurirati Ecosia</translation>
<translation id="93440396576488794">Logotip za Ecosia Enterprise</translation>
<translation id="8986207147630327271">Dodajete radni profil na ovaj preglednik i dajte administratoru kontrolu samo nad radnim profilom.</translation>
<translation id="2985399486579137606">Upravljajte profilima u Ecosiau</translation>
<translation id="1597547208646178091">Kako bi Ecosia bio sigurniji, onemogućili smo sljedeću ekstenziju koja nije navedena na stranici <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> i koja je dodana bez vašeg znanja.</translation>
<translation id="2388751143175762498">Prijavite se u Ecosia</translation>
<translation id="231621248561775155">Ecosia je blokirao preuzimanje jer arhivski fajl uključuje druge fajlove koji možda sakrivaju zlonamjerni softver</translation>
<translation id="9062666675513499497">Prijava u Chromium prilikom prijave na druge Googleove usluge</translation>
<translation id="5312730628132049495">Prijavite se u Ecosia. Ako se želite prijaviti na račun samo jedanput, možete <ph name="GUEST_LINK_BEGIN"/>koristiti uređaj kao gost<ph name="GUEST_LINK_END"/>.</translation>
<translation id="5061261337583604526">Ecosia je automatski zatvoren</translation>
<translation id="7268098999602465369">Ecosia nije ažuriran</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia će se ponovo pokrenuti za jedan sat}one{Ecosia će se ponovo pokrenuti za # sat}few{Ecosia će se ponovo pokrenuti za # sata}other{Ecosia će se ponovo pokrenuti za # sati}}</translation>
<translation id="8963533629322868062">Da primate buduća ažuriranja za Ecosia, trebat će vam Windows 10 ili novija verzija. Računar koristi Windows 8.1.</translation>
<translation id="7774247008790177839">Otvori link u novoj &amp;kartici Ecosiaa</translation>
<translation id="911206726377975832">Također izbrisati podatke pregledanja?</translation>
<translation id="7580831958727159171">Tokom probnih perioda možete vidjeti i uklanjati teme koje vas zanimaju, a koje web lokacije koriste da vam prikazuju oglase. Ecosia procjenjuje vaša interesovanja na osnovu vaše nedavne historije pregledanja.</translation>
<translation id="8901409988302458368">Vaš administrator sistema je konfigurirao Ecosia da otvori alternativni preglednik za pristup URL-u<ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="1523806373970723624">Ponovo pokrenite da ažurirate &amp;Ecosia</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="4767994371234572952">Prilagodite Ecosia sebi</translation>
<translation id="6933283849886243832">Ecosia možda neće ispravno raditi jer više nije podržan na sistemima Windows XP ili Windows Vista</translation>
<translation id="942598560705308788">Certifikati kojima upravlja Chromium</translation>
<translation id="8078678931242443254">Ko koristi Ecosia?</translation>
<translation id="12795904718916112">Odaberite maksimalnu sigurnost koju nudi Ecosia</translation>
<translation id="983803489796659991">Instalacija nije uspjela jer server za ažuriranje nema podatke o raspršivanju za aplikaciju.</translation>
<translation id="5612740201368556834">Koristi Ecosia bez računa</translation>
<translation id="6235001546696543832">Autori Ecosiaa</translation>
<translation id="992780518932311116">Da koristite lokaciju, odobrite Chromiumu pristup u <ph name="BEGIN_LINK"/>postavkama sistema<ph name="END_LINK"/></translation>
</translationbundle>
