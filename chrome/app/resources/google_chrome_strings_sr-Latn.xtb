<!DOCTYPE translationbundle>
<translationbundle lang="sr-Latn">
<translation id="4033006861724039519">Arhiva programa za instalaciju je oštećena ili nevažeća. Preuzmite Ecosia ponovo.</translation>
<translation id="1026101648481255140">Nastavi instalaciju</translation>
<translation id="8296565077892323223">Prilagodite i kontrolišite Ecosia. Dostupno je ažuriranje.</translation>
<translation id="2804130178228362015">Na računaru postoji štetan softver. Ecosia može da ga ukloni, vrati podešavanja i onemogući dodatke da bi pregledač mogao ponovo da radi uobičajeno.</translation>
<translation id="1065672644894730302">Podešavanja ne mogu da se pročitaju.

Neke funkcije su možda nedostupne i promene podešavanja neće biti sačuvane.</translation>
<translation id="8055222671516987714">Korisnik <ph name="USER_EMAIL_ADDRESS"/> je prethodno koristio Ecosia</translation>
<translation id="2000339487270823788">Ovo je vaš Ecosia</translation>
<translation id="8078678931242443254">Ko koristi Ecosia?</translation>
<translation id="6346154190168496057">Ne možete da ažurirate Ecosia</translation>
<translation id="1152920704813762236">O Chrome OS-u</translation>
<translation id="7303930050538184306">&amp;Otvori u Ecosia-u</translation>
<translation id="1203500561924088507">Hvala vam na instalaciji. Potrebno je da restartujete pregledač pre nego što počnete da koristite <ph name="BUNDLE_NAME"/>.</translation>
<translation id="6650631555168164414">Možete da uživate u Ecosia-u na najbolji način</translation>
<translation id="1523806373970723624">Ponovo pokreni da bi se &amp;Ecosia ažurirao</translation>
<translation id="5279514147510747661">Sačekajte da Ecosia instalira najnovija ažuriranja sistema.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> zahteva da pročitate i prihvatite sledeće Uslove korišćenja usluge pre korišćenja ovog uređaja. Ovi uslovi ne proširuju, menjaju niti ograničavaju Uslove za Ecosia OS Flex.</translation>
<translation id="8067423333018528301">Ecosia OS ne može da sinhronizuje podatke zbog greške pri prijavljivanju.</translation>
<translation id="2926455547526018397">Ecosia beta</translation>
<translation id="2995860351618948435">Ovaj računar već ima noviju verziju Ecosia pregledača. Ako softver ne funkcioniše, deinstalirajte Ecosia i pokušajte ponovo.</translation>
<translation id="824192326282906244">Možete da se predomislite u bilo kom trenutku u Ecosia podešavanjima. Probe se obavljaju paralelno uz trenutni način prikazivanja oglasa, pa nećete odmah videti promene.</translation>
<translation id="4696685525015809740">Ecosia Canary aplikacije</translation>
<translation id="3697186779259384993">Prilagodite novi Ecosia profil</translation>
<translation id="4062366803229254216">Ecosia zahteva pristup Bluetooth-u radi nastavljanja sa 
 uparivanjem. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="2441303983090031276">Ecosia OS je moguć zahvaljujući dodatnom <ph name="BEGIN_LINK_CROS_OSS"/>softveru sa otvorenim kodom<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="5598074261782651109">Ažuriraj Ecosia</translation>
<translation id="847970842635669371">Korisnik <ph name="EXISTING_USER"/> je već prijavljen na ovaj Ecosia profil. Ovim će se napraviti nov Ecosia profil za <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="4943938785458240142">Ecosia koristi kameru.</translation>
<translation id="1936361330890313940">Datoteka <ph name="FILE_NAME"/> je opasna, pa ju je Ecosia blokirao.</translation>
<translation id="1597911401261118146">Da biste proverili da li su lozinke bezbedne od upada u podatke i drugih bezbednosnih problema, <ph name="BEGIN_LINK"/>prijavite se u Chrome<ph name="END_LINK"/>.</translation>
<translation id="5591151834004774364">Ecosia je blokirao ovaj fajl arhive jer možda krije malver</translation>
<translation id="1597547208646178091">Da bismo učinili Ecosia bezbednijim, onemogućili smo sledeći dodatak koji <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> ne navodi i koji je možda dodat bez vašeg znanja.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Kako možete da upravljate podacima:<ph name="END_BOLD"/> Radi zaštite privatnosti automatski brišemo interesovanja starija od 4 nedelje. Kada nastavite da pregledate, interesovanje će se možda ponovo pojaviti na listi. Možete i da uklanjate interesovanja za koja ne želite da ih Ecosia uzima u obzir.</translation>
<translation id="1628000112320670027">Pronađite pomoć za Chrome</translation>
<translation id="1640672724030957280">Preuzimanje...</translation>
<translation id="1662146548738125461">O Chrome OS Flex-u</translation>
<translation id="5500958820122281144">Otvori link u Ecosia prozoru bez arhi&amp;viranja</translation>
<translation id="7602423871874451395">Ecosia ne može da čita podatke iz svog direktorijuma sa podacima niti da ih u njih upisuje:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{Administrator je konfigurisao Ecosia da se zatvara ako je neaktivan duže od 1 minuta.}one{Administrator je konfigurisao Ecosia da se zatvara ako je neaktivan duže od # minuta.}few{Administrator je konfigurisao Ecosia da se zatvara ako je neaktivan duže od # minuta.}other{Administrator je konfigurisao Ecosia da se zatvara ako je neaktivan duže od # minuta.}}</translation>
<translation id="3939060118711873999">Ecosia je veb pregledač koji veb-stranice i aplikacije pokreće brzinom svetlosti. On je brz, stabilan i lak za korišćenje. Još bezbednije pregledajte Veb uz pomoć zaštite od malvera i „pecanja“ koja je ugrađena u Ecosia.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ponovo ćemo pokrenuti Ecosia za jedan sat}one{Ponovo ćemo pokrenuti Ecosia za # sat}few{Ponovo ćemo pokrenuti Ecosia za # sata}other{Ponovo ćemo pokrenuti Ecosia za # sati}}</translation>
<translation id="4021894801595982809">Ecosia će sačuvati ovu lozinku na Ecosia nalogu. Nećete morati da je pamtite.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">Uverite se da ste prijavljeni u Ecosia na uređaju <ph name="TARGET_DEVICE_NAME"/> i probajte da pošaljete ponovo.</translation>
<translation id="1812689907177901597">Kada to uključite, možete da se prijavljujete na Google sajtove, kao što je Gmail, ali se ne prijavljujete u Chrome</translation>
<translation id="5055330219314726197">Ecosia traži dozvolu da pristupi kameri za ovaj sajt</translation>
<translation id="1508200558303644420">Ecosia nije podrazumevani pregledač</translation>
<translation id="8135642897811755229">Ecosia beta (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia je zastareo</translation>
<translation id="1919130412786645364">Dozvoli prijavljivanje u Chrome</translation>
<translation id="6235917057647038042">Da biste dobijali buduća Ecosia ažuriranja, treba vam macOS 10.13 ili novija verzija. Ovaj računar koristi macOS 10.12.</translation>
<translation id="1953553007165777902">Preuzima se... Još <ph name="MINUTE"/> min</translation>
<translation id="8608092457636055141">Svaki profil zadržava sopstvene Ecosia podatke, poput obeleživača, istorije, lozinki i drugog sadržaja</translation>
<translation id="2018879682492276940">Instalacija nije uspela. Probajte ponovo.</translation>
<translation id="7375011918167125899">Drugi nalog je već prijavljen. Da bi vam pregledanje bilo razdvojeno, Ecosia može da napravi zaseban profil za vas.</translation>
<translation id="207902854391093810">Dok probni periodi traju, Merenje oglasa omogućava sajtovima koje posećujete da od Chrome-a zatraže informacije koje sajtu pomažu da meri učinak oglasa. Merenje oglasa ograničava praćenje na više sajtova tako što prenosi što manje informacija između sajtova.</translation>
<translation id="8655983536493871574">Da biste dobijali buduća Ecosia ažuriranja, treba vam Windows 10 ili novija verzija. Ovaj računar koristi Windows 8.</translation>
<translation id="3590393640971125498">Ecosia OS Flex uslovi</translation>
<translation id="864244542982029641">Želite li ipak da zatvorite Ecosia?</translation>
<translation id="3791194915692553395">Ecosia OS Flex je omogućen zahvaljujući dodatnom <ph name="BEGIN_LINK_CROS_OSS"/>softveru sa otvorenim kodom<ph name="END_LINK_CROS_OSS"/>, kao što je <ph name="BEGIN_LINK_LINUX_OSS"/>Linux okruženje za programiranje<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="2120620239521071941">Ovim ćete izbrisati <ph name="ITEMS_COUNT"/> stavke(i) sa ovog uređaja. Da biste kasnije vratili podatke, prijavite se u Chrome kao <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">Ponovo pokreni da bi se &amp;Ecosia ažurirao</translation>
<translation id="2123055963409958220">Pomozite da poboljšamo Chrome tako što ćete poslati izveštaj o <ph name="BEGIN_LINK"/>aktuelnim podešavanjima<ph name="END_LINK"/></translation>
<translation id="2131230230468101642">Radi zaštite privatnosti automatski brišemo interesovanja starija od 4 nedelje. Kada nastavite da pregledate, interesovanje će se možda ponovo pojaviti na listi. Možete i da uklanjate interesovanja za koja ne želite da ih Chrome uzima u obzir.</translation>
<translation id="5404489723475681578">Restartujte Ecosia OS</translation>
<translation id="5982672133249369264">Ponovo pokrenite Ecosia</translation>
<translation id="2174917724755363426">Instalacija nije dovršena. Želite stvarno da je otkažete?</translation>
<translation id="223889379102603431">Informacije o tome kako Chrome upravlja sertifikatima osnovnog nivoa</translation>
<translation id="4337034173783952373">Da biste pristupali Ecosia pregledaču na svim uređajima, prijavite se, pa uključite sinhronizaciju</translation>
<translation id="4735588186234302898">Nedostaju šifre za Ecosia API. Neke funkcije Ecosia-a će biti onemogućene.</translation>
<translation id="7908111389403807005">Da li stvarno želite da deinstalirate Ecosia?</translation>
<translation id="2309047409763057870">Ovo je sekundarna instalacija Google Chrome-a pa ne možete da ga podesite kao podrazumevani pregledač.</translation>
<translation id="7613817989637275906">Ecosia je otkrio malver u ovim dodacima:</translation>
<translation id="7273750863406285983">Ecosia traži dozvolu da pristupi kameri i mikrofonu za ovaj sajt</translation>
<translation id="234869673307233423">Chrome ne može da vam proverava lozinke. Probajte ponovo kasnije.</translation>
<translation id="5707346538075088068">Administrator poslovnog profila može da ukloni sve podatke Ecosia-a koji se generišu tokom korišćenja ovog profila (poput pravljenja obeleživača, istorije, lozinki i drugih podešavanja). <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">Nastavi</translation>
<translation id="3959732324458144441">Sistem Ecosia OS</translation>
<translation id="3632544319066562282">Ecosia želi da izveze lozinke. Unesite lozinku za Windows da biste to omogućili.</translation>
<translation id="2485422356828889247">Deinstaliraj</translation>
<translation id="2534507159460261402">Google Pay (kopirano u Chrome)</translation>
<translation id="2559253115192232574">Sajt koji kasnije posetite može da zatraži od Chrome-a pristup vašim interesovanjima da bi personalizovao oglase koji vam se prikazuju. Chrome može da deli najviše 3 interesovanja.</translation>
<translation id="2563121210305478421">Želite ponovo da pokrenete Chrome?</translation>
<translation id="5824812022890208563">Korisnik <ph name="EXISTING_USER"/> je već prijavljen na ovaj Ecosia profil. Da bi vam pregledanje bilo razdvojeno, Ecosia može da napravi zaseban profil za vas.</translation>
<translation id="80155189677487610">Nije moguće instalirati verziju Ecosia pregledača koja je ista kao trenutno pokrenuta verzija. Zatvorite Ecosia i pokušajte ponovo.</translation>
<translation id="2586406160782125153">Ovim ćete izbrisati podatke pregledanja sa uređaja. Da biste kasnije vratili podatke, prijavite se u Chrome kao <ph name="USER_EMAIL"/>.</translation>
<translation id="6391863622742187823">Preuzmite sadržaj iz Ecosia pregledača sa: <ph name="ACCOUNT_EMAIL"/></translation>
<translation id="2622559029861875898">Chrome ne može da traži ažuriranja. Proverite internet vezu.</translation>
<translation id="1761341660094265938">Ecosia OS</translation>
<translation id="7774247008790177839">Otvori link u novoj Ecosia &amp;kartici</translation>
<translation id="9178613517891824246">Pomozite nam da poboljšamo Ecosia tako što ćete Ecosia-u slati izveštaje o otkazivanju i <ph name="UMA_LINK"/></translation>
<translation id="815199437159352723">Ovaj dodatak je promenio stranicu koja se prikazuje kada pokrenete Ecosia.</translation>
<translation id="1676748966275099244">Upozorenje: Ecosia ne može da spreči dodatke da snimaju vašu istoriju pregledanja. Da biste onemogućili ovaj dodatak u režimu bez arhiviranja, poništite izbor ove opcije.</translation>
<translation id="1831192335802727557">Ecosia traži dozvolu da pristupi mikrofonu za ovaj sajt</translation>
<translation id="2770231113462710648">Promeni podrazumevani pregledač u:</translation>
<translation id="2775140325783767197">Chrome ne može da vam proverava lozinke. Proverite internet vezu.</translation>
<translation id="2799223571221894425">Ponovo pokreni</translation>
<translation id="2847461019998147611">Prikazuj Google Chrome na ovom jeziku</translation>
<translation id="8109744984354428711">Pokreće se Ecosia...</translation>
