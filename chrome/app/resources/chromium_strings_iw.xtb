<translation id="8522801943730206384">‏ל-Chromium יש אפשרות לבדוק את הסיסמאות שלך רק אם שמרת אותן</translation>
<translation id="8550334526674375523">פרופיל העבודה שלך נפרד לחלוטין מהפרופיל האישי שלך.</translation>
<translation id="8555465886620020932">שגיאה בשירות: <ph name="SERVICE_ERROR"/>.</translation>
<translation id="8568283329061645092">‏Chromium יכול לבדוק את הסיסמאות כשנכנסים באמצעות חשבון Google</translation>
<translation id="4817309082638621362">‏מספר ארגונים מנהלים את Ecosia</translation>
<translation id="7129808598331559748">‏Copyright <ph name="YEAR"/> The Ecosia Authors. כל הזכויות שמורות.</translation>
<translation id="1851101453239911251">‏<ph name="BEGIN_BOLD"/>איך אנחנו משתמשים בנתונים האלה:<ph name="END_BOLD"/> אתרים יכולים לשמור מידע ב-Ecosia לגבי תחומי העניין שלך. לדוגמה, אם ביקרת באתר כדי לקנות נעליים למרתון, האתר עשוי להגדיר 'ריצת מרתון' כתחום עניין שלך. לאחר מכן, בביקור באתר שונה, למשל כדי להירשם למרוץ, יכול להיות שתוצג לך מודעה לנעלי ריצה על סמך תחומי העניין שלך.</translation>
<translation id="8109744984354428711">‏הפעלת Ecosia מתבצעת...</translation>
<translation id="2402290209407843024">‏ההתקנה נכשלה בשל שגיאה לא מזוהה. יש להוריד שוב את Ecosia.</translation>
<translation id="8648201657708811153">‏לא ניתן להגדיר את Google Chrome for Testing כדפדפן ברירת המחדל.</translation>
<translation id="6665128960039431910">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Ecosia או מבצעים חיפוש מסרגל הכתובות.</translation>
<translation id="2000339487270823788">‏זהו ה-Ecosia שלך</translation>
<translation id="7045045549868370797">‏להיכנס אל Ecosia?</translation>
<translation id="878572486461146056">שגיאת התקנה: מנהל הרשת החיל מדיניות קבוצתית שמונעת את ההתקנה: <ph name="INSTALL_ERROR"/></translation>
<translation id="7273750863406285983">‏Ecosia זקוק להרשאת גישה אל המצלמה והמיקרופון בשביל האתר הזה</translation>
<translation id="1485302026917450654">‏להיכנס אל Ecosia?</translation>
<translation id="8826492472752484139">לוחצים על 'מנהל הסיסמאות'</translation>
<translation id="5267683457871579197">‏מערכת EcosiaOS</translation>
<translation id="4565616259974605182">‏<ph name="BEGIN_BOLD"/>באילו נתונים נעשה שימוש:<ph name="END_BOLD"/> היסטוריית הגלישה – תיעוד האתרים שביקרת בהם באמצעות Ecosia במכשיר הזה.</translation>
<translation id="8862326446509486874">אין לך זכויות שמתאימות להתקנה ברמת המערכת. יש לנסות להפעיל שוב את המתקין כמנהל מערכת.</translation>
<translation id="8880203542552872219">‏אם שינית את הסיסמה הזו, יש לערוך את הסיסמה השמורה ב-Chromium כך שהיא תתאים לסיסמה החדשה שלך.</translation>
<translation id="3966234175958887595">‏Ecosia מנסה להציג סיסמאות. יש להקליד את הסיסמה שלך ל-Windows כדי לאפשר זאת.</translation>
<translation id="8931379085695076764">‏Chromium יכול להעריך מהם תחומי העניין שלך על סמך היסטוריית הגלישה שלך מהשבועות האחרונים. המידע הזה נשאר במכשיר שלך.</translation>
<translation id="6346154190168496057">‏לא ניתן לעדכן את Ecosia</translation>
<translation id="93440396576488794">‏הלוגו של Ecosia Enterprise</translation>
<translation id="8986207147630327271">בחרת להוסיף פרופיל עבודה לדפדפן זה ולתת למנהל המערכת שליטה רק על פרופיל העבודה.</translation>
<translation id="2985399486579137606">‏ניהול הפרופילים ב-Ecosia</translation>
<translation id="1597547208646178091">‏כדי לשפר את האבטחה של Ecosia, השבתנו את התוסף הבא שאינו רשום ב-<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> וייתכן שנוסף ללא ידיעתך.</translation>
<translation id="2388751143175762498">‏כניסה אל Ecosia</translation>
<translation id="231621248561775155">‏‫Ecosia חסם את ההורדה הזו כי קובץ הארכיון כולל קבצים אחרים שעלולים להסתיר תוכנות זדוניות</translation>
<translation id="9062666675513499497">‏כניסה אל Chromium כשנכנסים לשירותי Google אחרים</translation>
<translation id="5312730628132049495">‏יש להיכנס אל Ecosia. אם רוצים להיכנס לחשבון באופן חד-פעמי בלבד, אפשר <ph name="GUEST_LINK_BEGIN"/>להשתמש במכשיר כאורח<ph name="GUEST_LINK_END"/>.</translation>
<translation id="5061261337583604526">‏Ecosia נסגר באופן אוטומטי</translation>
<translation id="7268098999602465369">‏Ecosia אינו מעודכן</translation>
<translation id="6022879254514691681">{0,plural, =1{‏Ecosia יופעל מחדש בעוד שעה}one{‏Ecosia יופעל מחדש בעוד # שעות}two{‏Ecosia יופעל מחדש בעוד # שעות}other{‏Ecosia יופעל מחדש בעוד # שעות}}</translation>
<translation id="8963533629322868062">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.1.</translation>
<translation id="7774247008790177839">‏פתיחת הקישור &amp;בכרטיסיית Ecosia חדשה</translation>
<translation id="911206726377975832">למחוק גם את נתוני הגלישה שלך?</translation>
<translation id="7580831958727159171">‏במהלך הפעולה של גרסאות הניסיון, תהיה לך אפשרות לראות ולהסיר את תחומי העניין שלפיהם האתרים הציגו לך את המודעות. ההערכה של תחומי העניין ב-Ecosia מתבססת על היסטוריית הגלישה שלך מהזמן האחרון.</translation>
<translation id="8901409988302458368">‏לפי הגדרת מנהל המערכת, Ecosia יפתח דפדפן חלופי כדי לגשת אל <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="1523806373970723624">‏הפעלה מחדש לצורך עדכון &amp;Ecosia</translation>
<translation id="2470806471563820591">‏Ecosia ‏(mDNS-In)</translation>
<translation id="4767994371234572952">‏אפשר להתאים אישית את Ecosia בדרך שנוחה לך</translation>
<translation id="6933283849886243832">‏ייתכן ש-Ecosia לא יפעל כראוי כי הוא כבר לא נתמך ב-Windows XP וב-Windows Vista</translation>
<translation id="942598560705308788">‏אישורים שמנוהלים על ידי Chromium</translation>
<translation id="8078678931242443254">‏מי משתמש/ת ב-Ecosia?</translation>
<translation id="12795904718916112">‏רוצה להשיג את רמת האבטחה הגבוהה ביותר של Ecosia?</translation>
<translation id="983803489796659991">‏ההתקנה נכשלה כי שרת העדכון לא מכיל נתוני גיבוב (hash) של האפליקציה.</translation>
<translation id="5612740201368556834">‏שימוש ב-Ecosia ללא חשבון</translation>
<translation id="6235001546696543832">‏מחברי Ecosia</translation>
<translation id="992780518932311116">‏כדי להשתמש בשירותי המיקום, צריך להיכנס אל <ph name="BEGIN_LINK"/>הגדרות המערכת<ph name="END_LINK"/> ולתת ל-Chromium גישה</translation>
</translationbundle>
