<translation id="7309928523159922338">‏מדידת המודעות מאפשרת לאתרים שביקרת בהם לבקש מ-Chromium מידע שיעזור לבעלי האתרים למדוד את הביצועים של המודעות שלהם. מדידת המודעות מגבילה את המעקב באתרים שונים על ידי העברת כמות קטנה ככל האפשר של מידע בין אתרים.</translation>
<translation id="731795002583552498">‏העדכון של Chromium‏ מתבצע</translation>
<translation id="6673288084648462613">‏קובץ ההעדפות שלך פגום או לא חוקי. 

Ecosia לא יכול לשחזר את ההגדרות שלך.</translation>
<translation id="7339898014177206373">חלון חדש</translation>
<translation id="4960252760049500399">‏היסטוריית האתרים, הסימניות ונתונים נוספים מ-Ecosia נמצאים כאן.</translation>
<translation id="7158975242722498086">‏לפי הגדרת מנהל המערכת, Ecosia יפתח את<ph name="ALTERNATIVE_BROWSER_NAME"/> כדי לגשת אל <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="6632508343667825745">‏‫Ecosia חסם את ההורדה הזו כי הקובץ יכול לפגוע בחשבונות האישיים ובחשבונות שלך ברשתות החברתיות, כולל <ph name="USER_EMAIL"/></translation>
<translation id="6180968682827452331">‏התוסף הזה כבר לא נתמך. ההמלצה של Ecosia היא להסיר אותו.</translation>
<translation id="5622136942112821750">‏באמצעות פרופילים ב-Ecosia, מפרידים את כל הפריטים ב-Ecosia. באופן הזה קל יותר להפריד בין עבודה לפנאי.</translation>
<translation id="3879865245128287988">‏<ph name="PAGE_TITLE"/> - Ecosia בגרסת פיתוח</translation>
<translation id="5055330219314726197">‏Ecosia זקוק להרשאת גישה למצלמה בשביל האתר הזה</translation>
<translation id="7458892263350425044">‏כדי להשתמש במיקרופון, צריך להיכנס אל <ph name="BEGIN_LINK"/>הגדרות המערכת<ph name="END_LINK"/> ולתת ל-Chromium גישה</translation>
<translation id="1975037445584526511">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 7.</translation>
<translation id="7467949745582939695">‏להפעיל את Chromium מחדש?</translation>
<translation id="80155189677487610">‏לא ניתן להתקין את אותה גרסת Ecosia שפועלת כרגע. יש לסגור את Ecosia ולנסות שוב.</translation>
<translation id="751935028865900641">‏סביר להניח שאתרים יפעלו כצפוי. אם סוגרים את כל החלונות של Chromium, מתבצעת יציאה מהחשבון ברוב האתרים, חוץ מחשבון Google אם הוא מחובר ל-Chromium.</translation>
<translation id="7558678848273505235">{0,plural, =1{‏Ecosia יופעל מחדש בעוד דקה}one{‏Ecosia יופעל מחדש בעוד # דקות}two{‏Ecosia יופעל מחדש בעוד # דקות}other{‏Ecosia יופעל מחדש בעוד # דקות}}</translation>
<translation id="8228132389897276908">‏כדי לשתף את החלון, צריך לאפשר הקלטת מסך ב-Ecosia בקטע 'העדפות המערכת'</translation>
<translation id="7582945390259497898">‏Chromium יכול להעריך מהם תחומי העניין שלך. לאחר מכן, אתר שבו ביקרת יכול לשלוח בקשה ל-Chromium כדי לגלות מהם תחומי העניין שלך ולהתאים אישית את המודעות שמוצגות לך.</translation>
