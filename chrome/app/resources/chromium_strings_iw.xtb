<translation id="7745317241717453663">‏פעולה זו תמחק את נתוני הגלישה מהמכשיר. כדי לשחזר את הנתונים מאוחר יותר, יש להיכנס אל Chromium עם <ph name="USER_EMAIL"/>.</translation>
<translation id="7747138024166251722">המתקין לא הצליח ליצור ספרייה זמנית. יש לבדוק את המקום הפנוי בדיסק ואת האישור להתקנת תוכנה.</translation>
<translation id="6161025257729272170">‏שיפור המהירות ב-Ecosia</translation>
<translation id="5669882610631815446">‏<ph name="PAGE_TITLE"/> – Ecosia בגרסת Canary</translation>
<translation id="8301840715671593762">‏כבר קיים במכשיר פרופיל Ecosia עם החשבון הזה.</translation>
<translation id="7845233973568007926">תודה שהתקנת. עליך להפעיל מחדש את המחשב לפני השימוש ב-<ph name="BUNDLE_NAME"/>.</translation>
<translation id="3268039966078382323">‏עדכון Ecosia לגרסה האחרונה לא הצליח, ולכן אין לך גישה אל תכונות חדשות ותיקוני אבטחה.</translation>
<translation id="7872446069773932638">מתבצעת הורדה… יש עוד <ph name="SECONDS"/> שנ'</translation>
<translation id="5875641815673321623">‏<ph name="BEGIN_BOLD"/>איך ניתן לנהל את הנתונים שלך:<ph name="END_BOLD"/> כדי להגן על הפרטיות שלך, תחומי עניין שהוגדרו לפני יותר מ-4 שבועות נמחקים אוטומטית. עם המשך הגלישה, תחום עניין כלשהו עשוי להופיע שוב ברשימה. יש גם אפשרות להסיר תחומי עניין מ-Ecosia כדי שלא יילקחו בחשבון.</translation>
<translation id="2412381038247037703">‏נכנסת ל-Ecosia כ-<ph name="USER_EMAIL_ADDRESS"/>. יש להשתמש באותו חשבון כדי להיכנס שוב.</translation>
<translation id="7975919845073681630">‏זוהי התקנה משנית של Chromium, ולא ניתן להפוך אותו לדפדפן ברירת המחדל שלך.</translation>
<translation id="851583113375911087">‏תוספים, אפליקציות ועיצובים ממקורות לא מוכרים עלולים להזיק למכשיר. ההמלצה של Ecosia היא להתקין אותם רק מ<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/></translation>
<translation id="488806616089631539">‏אחרי מתן גישה ל-Ecosia, אתרים יוכלו לבקש ממך גישה.</translation>
<translation id="80471789339884597">תודה שהתקנת. עליך להפעיל מחדש את כל הדפדפנים לפני השימוש ב-<ph name="BUNDLE_NAME"/>.</translation>
<translation id="5661123757512626239">‏נדרשת הרשאת מיקום ב-Ecosia עבור האתר הזה</translation>
<translation id="143614250230771428">‏לא בוצע סנכרון של הנתונים ב-EcosiaOS כי אפשרות הסנכרון לא זמינה עבור הדומיין שלך.</translation>
<translation id="813913629614996137">מתבצע אתחול...</translation>
<translation id="6491651957026506753">‏Ecosia‏ חסם את הקובץ הזה כי הוא מסוכן.</translation>
<translation id="796435732739009892">‏סוג הקובץ הזה מסוכן ולכן הקובץ נחסם על ידי Ecosia</translation>
<translation id="2046160555506209000">‏אם אין לתמונה תיאור מועיל, Ecosia ינסה לספק לך תיאור. כדי ליצור תיאורים, התמונות נשלחות אל Ecosia. אפשר להשבית את האפשרות הזו בכל זמן דרך ההגדרות.</translation>
<translation id="8266560134891435528">‏Chromium לא יכול לבדוק את הסיסמאות שלך כי לא נכנסת לחשבון</translation>
<translation id="8633885040939757689">‏Ecosia מנסה להעתיק את הסיסמאות.</translation>
<translation id="2243562167758283214">‏Ecosia‏ חסם את הקובץ הזה כי הוא עלול להיות מסוכן.</translation>
<translation id="8330519371938183845">‏כניסה לחשבון תסנכרן ותתאים אישית את Chromium בכל המכשירים שברשותך</translation>
<translation id="8055222671516987714">‏בכתובת <ph name="USER_EMAIL_ADDRESS"/> השתמשו בעבר ב-Ecosia</translation>
<translation id="4337034173783952373">‏כדי לגשת אל פריטים שונים בדפדפן Ecosia שלך מכל המכשירים, צריך להיכנס לחשבון ולהפעיל את הסנכרון</translation>
<translation id="8655983536493871574">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.</translation>
<translation id="6826163993811146231">{0,plural, =1{‏צריך להפעיל מחדש את Ecosia בתוך יום אחד}one{‏צריך להפעיל מחדש את Ecosia בתוך # ימים}two{‏צריך להפעיל מחדש את Ecosia בתוך # ימים}other{‏צריך להפעיל מחדש את Ecosia בתוך # ימים}}</translation>
<translation id="4033006861724039519">‏הארכיון של המתקין פגום או שאינו חוקי. יש להוריד שוב את Ecosia.</translation>
<translation id="8975930032513941502">‏אופציונלי: שליחה אוטומטית של נתוני אבחון ונתוני שימוש במכשיר אל Ecosia תעזור לשפר את התכונות ואת הביצועים של EcosiaOS.</translation>
<translation id="2695952268686253864">‏Ecosia אינו מעודכן</translation>
<translation id="8550334526674375523">פרופיל העבודה שלך נפרד לחלוטין מהפרופיל האישי שלך.</translation>
<translation id="4281355161119203663">‏אחד מההורים השבית ב-Ecosia את ההגדרה "הרשאות לאתרים, אפליקציות ותוספים". לא ניתן להוסיף את ה<ph name="EXTENSION_TYPE_PARAMETER"/>.</translation>
<translation id="6235917057647038042">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-macOS מגרסה 10.13 ואילך. במחשב הזה מותקנת מערכת ההפעלה macOS 10.12.</translation>
<translation id="8568283329061645092">‏Chromium יכול לבדוק את הסיסמאות כשנכנסים באמצעות חשבון Google</translation>
<translation id="8574036838419011058">‏כשהתכונה מופעלת, Chromium חוסך בחיי הסוללה על ידי הגבלת הפעילות ברקע והאפקטים החזותיים, כמו גלילה חלקה וקצב פריימים של סרטונים. <ph name="BEGIN_LINK"/>מידע נוסף<ph name="END_LINK"/></translation>
<translation id="7129808598331559748">‏Copyright <ph name="YEAR"/> The Ecosia Authors. כל הזכויות שמורות.</translation>
<translation id="1851101453239911251">‏<ph name="BEGIN_BOLD"/>איך אנחנו משתמשים בנתונים האלה:<ph name="END_BOLD"/> אתרים יכולים לשמור מידע ב-Ecosia לגבי תחומי העניין שלך. לדוגמה, אם ביקרת באתר כדי לקנות נעליים למרתון, האתר עשוי להגדיר 'ריצת מרתון' כתחום עניין שלך. לאחר מכן, בביקור באתר שונה, למשל כדי להירשם למרוץ, יכול להיות שתוצג לך מודעה לנעלי ריצה על סמך תחומי העניין שלך.</translation>
<translation id="8109744984354428711">‏הפעלת Ecosia מתבצעת...</translation>
<translation id="2402290209407843024">‏ההתקנה נכשלה בשל שגיאה לא מזוהה. יש להוריד שוב את Ecosia.</translation>
<translation id="6665128960039431910">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Ecosia או מבצעים חיפוש מסרגל הכתובות.</translation>
<translation id="2000339487270823788">‏זהו ה-Ecosia שלך</translation>
<translation id="7273750863406285983">‏Ecosia זקוק להרשאת גישה אל המצלמה והמיקרופון בשביל האתר הזה</translation>
<translation id="5267683457871579197">‏מערכת EcosiaOS</translation>
<translation id="4565616259974605182">‏<ph name="BEGIN_BOLD"/>באילו נתונים נעשה שימוש:<ph name="END_BOLD"/> היסטוריית הגלישה – תיעוד האתרים שביקרת בהם באמצעות Ecosia במכשיר הזה.</translation>
<translation id="8862326446509486874">אין לך זכויות שמתאימות להתקנה ברמת המערכת. יש לנסות להפעיל שוב את המתקין כמנהל מערכת.</translation>
<translation id="8880203542552872219">‏אם שינית את הסיסמה הזו, יש לערוך את הסיסמה השמורה ב-Chromium כך שהיא תתאים לסיסמה החדשה שלך.</translation>
<translation id="6078545897140861225">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Ecosia או לוחצים על הלחצן 'דף הבית'.</translation>
<translation id="3966234175958887595">‏Ecosia מנסה להציג סיסמאות. יש להקליד את הסיסמה שלך ל-Windows כדי לאפשר זאת.</translation>
<translation id="8931379085695076764">‏Chromium יכול להעריך מהם תחומי העניין שלך על סמך היסטוריית הגלישה שלך מהשבועות האחרונים. המידע הזה נשאר במכשיר שלך.</translation>
<translation id="6346154190168496057">‏לא ניתן לעדכן את Ecosia</translation>
<translation id="93440396576488794">‏הלוגו של Ecosia Enterprise</translation>
<translation id="8986207147630327271">בחרת להוסיף פרופיל עבודה לדפדפן זה ולתת למנהל המערכת שליטה רק על פרופיל העבודה.</translation>
<translation id="1597547208646178091">‏כדי לשפר את האבטחה של Ecosia, השבתנו את התוסף הבא שאינו רשום ב-<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> וייתכן שנוסף ללא ידיעתך.</translation>
<translation id="2388751143175762498">‏כניסה אל Ecosia</translation>
<translation id="7268098999602465369">‏Ecosia אינו מעודכן</translation>
<translation id="6022879254514691681">{0,plural, =1{‏Ecosia יופעל מחדש בעוד שעה}one{‏Ecosia יופעל מחדש בעוד # שעות}two{‏Ecosia יופעל מחדש בעוד # שעות}other{‏Ecosia יופעל מחדש בעוד # שעות}}</translation>
<translation id="8963533629322868062">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.1.</translation>
<translation id="7774247008790177839">‏פתיחת הקישור &amp;בכרטיסיית Ecosia חדשה</translation>
<translation id="911206726377975832">למחוק גם את נתוני הגלישה שלך?</translation>
<translation id="7580831958727159171">‏במהלך הפעולה של גרסאות הניסיון, תהיה לך אפשרות לראות ולהסיר את תחומי העניין שלפיהם האתרים הציגו לך את המודעות. ההערכה של תחומי העניין ב-Ecosia מתבססת על היסטוריית הגלישה שלך מהזמן האחרון.</translation>
<translation id="8901409988302458368">‏לפי הגדרת מנהל המערכת, Ecosia יפתח דפדפן חלופי כדי לגשת אל <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="1523806373970723624">‏הפעלה מחדש לצורך עדכון &amp;Ecosia</translation>
<translation id="2470806471563820591">‏Ecosia ‏(mDNS-In)</translation>
<translation id="6933283849886243832">‏ייתכן ש-Ecosia לא יפעל כראוי כי הוא כבר לא נתמך ב-Windows XP וב-Windows Vista</translation>
<translation id="942598560705308788">‏אישורים שמנוהלים על ידי Chromium</translation>
<translation id="6718055545215052843">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-macOS מגרסה 10.13 ואילך. במחשב הזה פועלת מערכת ההפעלה ‎OS X 10.11.</translation>
<translation id="8078678931242443254">‏מי משתמש/ת ב-Ecosia?</translation>
<translation id="12795904718916112">‏רוצה להשיג את רמת האבטחה הגבוהה ביותר של Ecosia?</translation>
<translation id="9792300276217204">‏ניקוי נתונים מאתרים מהמכשיר בכל פעם שסוגרים את Chromium</translation>
<translation id="6235001546696543832">‏מחברי Ecosia</translation>
</translationbundle>
