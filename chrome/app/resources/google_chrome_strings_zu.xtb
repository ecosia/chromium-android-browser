<translation id="6161025257729272170">Yenza i-Ecosia isheshe</translation>
<translation id="9165312115453649251">Isistimu ye-EcosiaOS Flex</translation>
<translation id="8685318202174822382">Qhubeka kuphrofayela entsha ye-Ecosia?</translation>
<translation id="6750954913813541382">Ukuze kulungiswe amaphutha okupeletwa, i-Chrome ithumela umbhalo owuthayiphayo kusiphequluli ku-Google</translation>
<translation id="88039520238670574">Phuma ku-Ecosia noma kunjalo?</translation>
<translation id="6794858689789885890">Yisule njalo idatha yesayithi kudivayisi yakho lapho uvala i-Chrome</translation>
<translation id="8583650869792032882">Umyalo wokubophezeleka ngaphakathi kwe-Ecosia Canary ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="6007450464504026705">I-Ecosia yakhelwe ukusebenza ngezakhi ezifana Nesongi Samandla Nesilondolozi Senkumbulo</translation>
<translation id="684888714667046800">Ayikwazi ukuxhuma ku-inthanethi. Uma usebenzisa uhlelo lokuvikela, sicela uqinisekise ukuthi i-<ph name="PRODUCT_EXE_NAME"/> ikuhlelo lwabagunyaziwe.</translation>
<translation id="588828970866589779">Vula ukuvikela okwengeziwe ku-JavaScript ye-Ecosia kanye nenjini ye-WebAssembly</translation>
<translation id="6881299373831449287">Ibuyekeza i-Chrome</translation>
<translation id="6800892712521842441">Izinhlelo zokusebenza ze-beta ye-Ecosia</translation>
<translation id="4371259280767924562">Susa i-akhawunti kuEcosia</translation>
<translation id="5267683457871579197">Isistimu ye-EcosiaOS</translation>
<translation id="8963533629322868062">Ukuze uthole izibuyekezo zesikhathi esizayo ze-Ecosia, uzodinga i-Windows 10 noma yakamuva. Le khompyutha isebenzisa i-Windows 8.1.</translation>
<translation id="2128110540135015661">Idatha yokuphequlula yalo muntu izosuswa kusukela kule divayisi. Ukuze uphinde uthole idatha, ngena ngemvume ku-Ecosia njengo-<ph name="USER_EMAIL"/>.</translation>
<translation id="2434044214904689670">Umyalo wokubophezeleka ngaphakathi kwe-beta yeEcosia ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="6583697665130212310">Funda ukuthi kungani i-Ecosia ivimba amanye amafayela, ivula kuthebhu entsha</translation>
<translation id="7011190694940573312">Ukufakwa kwehlulekile ngenxa yokuthi lolu hlobo lwesistimu yokusebenza alusekelwe.</translation>
<translation id="7024536598735240744">Iphutha lokuvula: <ph name="UNPACK_ERROR"/>.</translation>
<translation id="7025789849649390912">Ukufaka Kumisiwe.</translation>
<translation id="4032832945953542360">Ungashintsha phakathi kwamaphrofayela we-Ecosia lapha</translation>
<translation id="931416298178634530">Uma ufuna ukusebenzisa le akhawunti kanye kuphela, ungasebenzisa <ph name="GUEST_LINK_BEGIN"/>Imodi Yesivakashi<ph name="GUEST_LINK_END"/> kwibhrawuza ye-Ecosia. Uma ufuna ukwengeza i-akhawunti yothile, <ph name="LINK_BEGIN"/>engeza umuntu omusha<ph name="LINK_END"/> ku-<ph name="DEVICE_TYPE"/> yakho.

Izimvume ozinikezile kakade amawebhusayithi nama-app zingase zisebenze kule akhawunti. Ungakwazi nokuphatha ama-Ecosia Account wakho kokuthi <ph name="SETTINGS_LINK_BEGIN"/>Amasethingi<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="7048502283602470098">Hlola i-AI</translation>
<translation id="762525592078244189">Yenza i-Ecosia Ibe Ngeyakho</translation>
<translation id="2379593823746842972">I-Ecosia izosula idatha yokubhrawuza maduze</translation>
<translation id="7085332316435785646">Khetha ukuthi ufake phakathi umlando we-Chrome ukuze uthole umuzwa womuntu siqu kumasevisi e-Google</translation>
<translation id="7088681679121566888">I-Chrome isesimweni sakamuva</translation>
<translation id="1318059253725731825">I-Ecosia isebenzisa imakrofoni yakho.</translation>
<translation id="8933665254023068908">Qalisa kabusha ukuze ubuyekeze i-&amp;EcosiaOS</translation>
<translation id="2394629668475473296">Ukuze wabelane ngesikrini sakho, vumela ukurekhodwa kwesikrini kwe-Ecosia Kokuncanyelwayo Kwesistimu</translation>
<translation id="7311066525704006840">Isiphathi somsebenzi - i-Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{Isibuyekezo esisha se-Ecosia siyatholakala futhi sizosetshenziswa maduze ngemuva kokuthi uqalise kabusha.}=1{Isibuyekezo esisha se-Ecosia siyatholakala futhi sizosetshenziswa maduze ngemuva kokuthi uqalise kabusha. Iwindi lakho le-Incognito ngeke liphinde livuleke.}one{Isibuyekezo esisha se-Ecosia siyatholakala futhi sizosetshenziswa maduze ngemuva kokuthi uqalise kabusha. Amawindi akho angu-# e-Incognito ngeke aze aphinde avuleke.}other{Isibuyekezo esisha se-Ecosia siyatholakala futhi sizosetshenziswa maduze ngemuva kokuthi uqalise kabusha. Amawindi akho angu-# e-Incognito ngeke aze aphinde avuleke.}}</translation>
<translation id="7155997830309522122">Uma kunjalo, sicela uhlele iphasiwedi yakho elondoloziwe ku-Chrome ukuze ifane nephasiwedi yakho entsha.</translation>
<translation id="1027331268335328576">Siyakwamukela ku-Ecosia</translation>
<translation id="675365189802108507">Ungafunda kabanzi mayelana nalezi zakhi kumasethingi we-Ecosia.</translation>
<translation id="5994043198751001258">Inhlangano yakho ivala i-Ecosia uma ingasetshenziswa isikhathi eingu-<ph name="TIMEOUT_DURATION"/>.</translation>
<translation id="4239392394637574967">Ungena ngemvume nge-akhawunti ephethwe futhi ukunikezela ukulawula kwayo ngaphezulu kwephrofayela yakho ye-Ecosia. Idatha yakho ye-Ecosia, efana nezinhlelo zakho zokusebenza, amabhukhimakhi, umlando, amaphasiwedi, nezinye izilungiselelo zizobophezeleka unaphakade ku-<ph name="USER_NAME"/>. Uzokwazi ukususa le datha nge-deshibhodi yama-akhawunti we-Ecosia, kodwa ngeke uze ukwazi ukuhlobanisa le datha nenye i-akhawunti. Ngokuzikhethela ungadala iphrofayela entsha ukuze ugcine idatha yakho ekhona ye-Ecosia ihlukanisiwe. <ph name="LEARN_MORE"/></translation>
<translation id="6994161374830839635">I-<ph name="MANAGER"/> iphatha iEcosia</translation>
<translation id="7295052994004373688">Lolu limi lusetshenziswe ukubonisa i-Google Chrome UI</translation>
<translation id="7296210096911315575">Ukusebenzisa okubalulekile nolwazi lokuphepha</translation>
<translation id="7898621536417126731">Enye idatha yakho yeEcosia ayikalondolozwa kuEcosia Account. Zama ukulinda imizuzu embalwa ngaphambi kokuphuma ngemvume. Uma uphuma ngemvume manje, le datha izosulwa.</translation>
<translation id="5549921590305750618">I-Ecosia idinga ukufinyelela kusitoreji ukuze ilande amafayela</translation>
<translation id="7339898014177206373">Iwindi elisha</translation>
<translation id="680371069849762427">Ukuphequlula Ngokuphepha Okugqamile kunikeza ukuvikeleka kwe-inthanethi okuqine kakhulu kwe-Ecosia okuzokugcina uphephile njengoba ubhrawuza</translation>
<translation id="7394745511930161845">Sungula itimu yakho nge-AI ukunikeza ibhrawuza yakho ukubukeka okuhlukile</translation>
<translation id="2412381038247037703">Ubukade ungene ngemvume ku-Ecosia njengo-<ph name="USER_EMAIL_ADDRESS"/>. Sicela usebenzise i-akhawunti efanayo ukuze uphinde ungene ngemvume.</translation>
<translation id="1224748120031661633">Chofoza imenyu ye-Ecosia</translation>
<translation id="7655708678113012665">{NUM_DEVICES,plural, =0{Idivayisi e-1 ye-USB ibifinyelelwa yisandiso se-Ecosia esisodwa noma eziningi}=1{Idivayisi e-1 ye-USB ifinyelelwa yisandiso se-Ecosia esisodwa noma eziningi}one{Amadivayisi angu-# e-USB abefinyelelwa yisandiso se-Ecosia esisodwa noma eziningi}other{Amadivayisi angu-# e-USB abefinyelelwa yisandiso se-Ecosia esisodwa noma eziningi}}</translation>
<translation id="3307959934543585795">I-Ecosia ingase ingasebenzi kahle ngoba ayisasekelwa kulokhu kusatshalaliswa kwe-Linux</translation>
<translation id="2421263730139898714">Phuma ku-Ecosia</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{Inhlangano yakho ivala i-Ecosia ngokuzenzekelayo uma ingasetshenziswanga umzuzu o-1.}one{Inhlangano yakho ivala i-Ecosia ngokuzenzekelayo uma ingasetshenziswanga imizuzu engu-#.}other{Inhlangano yakho ivala i-Ecosia ngokuzenzekelayo uma ingasetshenziswanga imizuzu engu-#.}}</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{Inhlangano yakho isula idatha yokubhrawuza ngokuzenzekelayo uma i-Ecosia ingasetshenziswanga umzuzu o-1. Lokhu kungase kuhlanganise umlando, ukugcwalisa okuzenzakalelayo, nokudawuniloda. Amathebhu akho azohlala evulekile.}one{Inhlangano yakho isula idatha yokubhrawuza ngokuzenzekelayo uma i-Ecosia ingasetshenziswanga imizuzu engu-#. Lokhu kungase kuhlanganise umlando, ukugcwalisa okuzenzakalelayo, nokudawuniloda. Amathebhu akho azohlala evulekile.}other{Inhlangano yakho isula idatha yokubhrawuza ngokuzenzekelayo uma i-Ecosia ingasetshenziswanga imizuzu engu-#. Lokhu kungase kuhlanganise umlando, ukugcwalisa okuzenzakalelayo, nokudawuniloda. Amathebhu akho azohlala evulekile.}}</translation>
<translation id="7477130805345743099">I-Chrome izokuxwayisa ngaphambi kokulayisha noma iyiphi isayithi isebenzisa uxhumo olungavikelekile</translation>
<translation id="12795904718916112">Thola isivikelo esinamandla kakhulu se-Ecosia</translation>
<translation id="4427878468534147875">Ngenkathi ungene ngemvume, ungasebenzisa amaphasiwedi akho nokuningi ukusuka kuEcosia Account yakho kuEcosia. I-<ph name="SHORTCUT"/> ingashintsha amasethingi wakho wamasevisi eEcosia.</translation>
<translation id="932641430818191661">I-Ecosia Dev</translation>
<translation id="7877883466657693294">Kuvaliwe • I-Ecosia ayikwazi ukuqinisekisa ukuthi lesi sandiso sivela kuphi</translation>
<translation id="7583399374488819119">Isifaki Se-<ph name="COMPANY_NAME"/></translation>
<translation id="8275632261262434570">I-EcosiaOS Flex</translation>
<translation id="1027331268335328576">Siyakwamukela ku-Ecosia</translation>
<translation id="8411844745163855310">I-<ph name="MANAGER"/> idinga ukuthi ufunde uphinde wamukele Imigomo Yesevisi elandelayo ngaphambi kokusebenzisa le divayisi. Le migomo ayinwebeki, ayiguquki, noma ikhawulela Imigomo ye-EcosiaOS.</translation>
<translation id="1263466865695943046">I-Ecosia ikuvumela ukuthi wazi uma amaphasiwedi akho afakwa engcupheni</translation>
<translation id="7158975242722498086">Umlawuli wakho wesistimu ulungiselele i-Ecosia ukuthi ivule i-<ph name="ALTERNATIVE_BROWSER_NAME"/> ukuze ifinyelele ku-<ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="7649070708921625228">Usizo</translation>
<translation id="93440396576488794">Ilogo yebhizinisi le-Ecosia</translation>
<translation id="361644486359722423">I-Ecosia ivimbele lokhu kudawuniloda ngoba uvale Ukuphequlula Okuphephile futhi ifayela alikwazi ukuqinisekiswa</translation>
<translation id="7655455401911432608">Umlando wakho wokubhrawuza, irekhodi lamasayithi owavakashele usebenzisa i-Chrome kule divayisi.</translation>
<translation id="8196791276481156937">Susa i-akhawunti kuEcosia</translation>
<translation id="7661924425853052955">Awukavakashi kamuva nje. I-Chrome isuse i-<ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/>, nokungu-<ph name="COUNT"/> ngaphezulu</translation>
<translation id="7668816516367091728">Yenza imisebenzi efana nokuhumusha, ukubala, nokuningi ngokuqondile kusukela kubha yekheli</translation>
<translation id="3376578942612115781">I-akhawunti yeEcosia idinga ukuqinisekiswa kabusha</translation>
<translation id="769538538642757151">I-Chrome izokwazisa uma kukhona okudinga ukubuyekezwa kwakho</translation>
<translation id="7747138024166251722">Isifaki asikwazanga ukudala umkhombandlela wesikhashana. Sicela uhlolele isikhala esikhululekile sediski nemvume ukuze ufake isofthiwe.</translation>
<translation id="4871843754042758264">Chofoza igama lakho ukuze uvule i-Ecosia uphinde uqale ukudlulisa amehlo.</translation>
<translation id="7763983146198734674">Londoloza amaphasiwedi akho uphinde uwafinyelele usendleleni</translation>
<translation id="2046160555506209000">Uma isithombe singenayo incazelo ephelele, i-Ecosia izozama ukukunikezela eyodwa. Ukuze udale izincazelo, izithombe zithunyelwa ku-Ecosia. Ungavala lokhu kuzilungiselelo noma kunini.</translation>
<translation id="5661123757512626239">I-Ecosia idinga imvume yendawo kule sayithi</translation>
<translation id="5288148671319098666">I-Ecosia idizayinelwe ukushesha futhi ivikeleke kuwo wonkana amadivayisi akho — kusukela efonini yakho ukuya ekhompyutheni yakho.</translation>
<translation id="7722016758804384514">Iphrofayela ibonakala isetshenziswa enye inqubo ye-Ecosia (<ph name="PROCESS_ID"/>) kwenye ikhompyutha (<ph name="HOST_NAME"/>).  I-Ecosia ikhiye iphrofayela ukuze ingamosheki. Uma uqinisekile ukuthi azikho ezinye izinqubo ezisebenzisa le phrofayela, ungavula iphrofayela uphinde uqalise kabusha i-Ecosia.</translation>
<translation id="1047556320128249268">I-Ecosia izama ukukopisha amaphasiwedi. Thayipha amaphasiwedi akho e-Windows ukuze uvumele lokhu.</translation>
<translation id="4685983030787735093">I-Ecosia ikulethela ubuchwepheshe bakamuva bokubhrawuza okungcono</translation>
<translation id="4199684616787081033">Susa kusuka ku-Ecosia...</translation>
<translation id="2402290209407843024">Ukufakwa kuhlulekile ngenxa yephutha elingacacisiwe. Sicela ulande i-Ecosia futhi.</translation>
<translation id="7836610565365456468">Guqula ibhrawuza yakho ngamatimu anomfutho akhuthazwe amaciko, imvelo, nokuningi</translation>
<translation id="7845233973568007926">Siyabonga ngokufaka. Kufanele uqalise kabusha ikhompyutha yakho ngaphambi kokusebenzisa i-<ph name="BUNDLE_NAME"/>.</translation>
<translation id="937989526647879266">I-AI ku-Ecosia isiza ukwenza iwebhu isheshe, iphephe futhi ifinyeleleke kakhulu</translation>
<translation id="7872446069773932638">Iyadawuniloda... kusele imizuzwana engu-<ph name="SECONDS"/></translation>
<translation id="2381210243314074423">Siyakwamukela ku-Ecosia, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">Uma wabelana ngekhompyutha, abangani nomndeni bangadlulisa amehlo ngokuhlukene baphinde basethe i-Ecosia ngendlela nje abayifunayo.</translation>
<translation id="4727435569202742773">Umuntu othile ngaphambilini ungene ngemvume ku-Ecosia kule khompuyutha njengo-<ph name="ACCOUNT_EMAIL_LAST"/>. Sicela udale umsebenzisi omusha we-Ecosia ukuze ugcine ulwazi lwakho luhlukile.</translation>
<translation id="7917876797003313048">Ungaphatha ama-akhawunti we-Google wakho angene ngemvume. Ama-akhawunti wakho we-Google asetshenziselwe i-browser ye-Chrome, i-Play Store, i-Gmail, nokuningi. Uma ufuna ukungeza i-akhawunti yomuntu othile, njengelungu lomndeni, engeza umuntu omusha ku-<ph name="DEVICE_TYPE"/> yakho kunalokho. <ph name="LINK_BEGIN"/>Funda kabanzi<ph name="LINK_END"/></translation>
<translation id="7112125772061727648">I-Ecosia ivimbele lokhu kudawuniloda ngoba ifayela liyakhohlisa futhi lingase lenze izinguquko ezingalindelekile kudivayisi yakho</translation>
<translation id="7947083960301164556">Buka Okusha</translation>
<translation id="4278262067490419012">I-EcosiaOS Flex idinga ukuqalwa kabusha ukuze isibuyekezo sisebenze.</translation>
<translation id="3140530394740845618">Phatha Amaphrofayela e-Ecosia</translation>
<translation id="7962368738413920945">Amasayithi cishe azosebenza njengoba ulindele kodwa ngeke akukhumbule ngemva kokuvala wonke amawindi e-Chrome</translation>
<translation id="5781596646235827063">Le khompuyutha ngeke isathola izibuyekezo ze-Ecosia ngoba i-Windows XP ne-Windows Vista azisasekelwa</translation>
<translation id="7783708361278795460">Ku-Ecosia Password Manager ekule divayisi</translation>
<translation id="6984747211123632080">Phinda ufake i-Ecosia</translation>
<translation id="7787479292144635608">Sebenzisa i-Ecosia ngaphandle kwe-akhawunti</translation>
<translation id="2838372953389311551">Uma isithombe singenayo incazelo ephelele, i-Ecosia izozama ukukunikezela eyodwa. Ukuze udale izincazelo, izithombe zithunyelwa ku-Ecosia.</translation>
<translation id="8863497461138396324">Lesi sandiso sisuswe ukushicilela ngunjiniyela waso, futhi kungenzeka sibe esingaphephile. Sisuse ku-Ecosia ukuze singasakwazi ukubona nokushintsha idatha yakho kumasayithi owavakashelayo, okufaka phakathi ulwazi lwakho lomuntu siqu.</translation>
<translation id="4882579364090762302">Isandiso sifuna ukuthi ungene kuEcosia</translation>
<translation id="80471789339884597">Siyabonga ngokufaka. Kufanele uqalise kabusha wonke amabhrawuza akho ngaphambi kokusebenzisa i-<ph name="BUNDLE_NAME"/>.</translation>
<translation id="8347473600923066837">Ungavula amabhukhimakhi, imodi yokufunda, nokuningi kusukela kumenyu ye-Ecosia ngaphezulu ngakwesokudla</translation>
<translation id="8275632261262434570">I-EcosiaOS Flex</translation>
<translation id="5251710252516682805">Amanye Amaphrofayili e-Ecosia</translation>
<translation id="8086881907087796310">Ukufakwa kwehlulekile ngenxa yokuthi ikhompyutha yakho ayihlangabezani nezimfuneko zenani elincane lehadiwe.</translation>
<translation id="2200308425865645682">I-Ecosia idinga ukuqinisekisa ukuthi uwena ngaphambi kokuthi idatha ethile ilondolozwe ku-Ecosia Account yakho futhi isetshenziswe kuwo wonke amadivayisi akho. Uma uphuma ngemvume, le datha izohlala kule divayisi.</translation>
<translation id="7221868538334633215">Mayelana ne-Ecosia</translation>
<translation id="813913629614996137">Iyaqalisa...</translation>
<translation id="5612740201368556834">Sebenzisa i-Ecosia Ngaphandle kwe-Akhawunti</translation>
<translation id="4061472199368124600">I-Ecosia isebenzisa ikhamela yakho nemakrofoni.</translation>
<translation id="8296229475165428335">Ungavula amabhukhimakhi, imodi yokufunda, nokuningi kusukela kumenyu ye-Ecosia</translation>
<translation id="8267953129876836456">Uma ivuliwe, i-Chrome ilayisha kuqala amakhasi okwenza ukuphequlula nokusesha kusheshe.</translation>
<translation id="8270775718612349140">Izitifiketi eziphethwe i-Chrome</translation>
<translation id="3966234175958887595">I-Ecosia izama ukubonisa amaphasiwedi. Thayipha iphasiwedi yakho ye-Windows ukuze uvumele lokhu.</translation>
<translation id="3216284932113164802">Habe! I-Ecosia iphahlazekile. Qalisa kabusha manje?</translation>
<translation id="9943971783680417">Engeza isinqamuleli Kumphathi Wephasiwedi Ye-Ecosia</translation>
<translation id="8336463659890584292">Lapho isayithi icela ukulayisha kusengaphambili ngasese amalinki ekhasini layo, i-Chrome isebenzisa amaseva e-Google. Lokhu kusiza umazisi wakho kusayithi elayishwe ngaphambilini, kodwa i-Google ifunda ukuthi yimaphi amasayithi alayishwa ngaphambilini.</translation>
<translation id="6491651957026506753">Leli fayela liyingozi, ngakho-ke i-Ecosia ilivimbile.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>Indlela esisebenzisa ngayo le datha:<ph name="END_BOLD"/> Amasayithi angagcina ulwazi nge-Ecosia mayelana nezintshisekelo zakho. Ngokwesibonelo, uma uvakashela isayithi ukuze uthenge izicathulo zomjaho webanga elide, isayithi lingachaza intshisekelo yakho njengokugijima umjaho. Kamuva, uma uvakashela isayithi elihlukile ukuze ubhalisele umjaho, lelo sayithi lingakubonisa isikhangiso sezicathulo zokugijima ezisekelwe kuzintshisekelo zakho.</translation>
<translation id="8355171755788522183">© <ph name="YEAR"/> Ecosia. Wonke amalungelo agodliwe.</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>Indlela esisebenzisa ngayo le datha:<ph name="END_BOLD"/> I-Ecosia ingalinganisela izintshisekelo zakho. Kamuva, isayithi olivakashelayo lingacela i-Ecosia ukuthi ibone izintshisekelo zakho ukuze yenze izikhangiso ozibonayo ngokwezifiso zakho.</translation>
<translation id="5883025779824839861">Qhubeka nokusebenzisa i-Ecosia</translation>
<translation id="8394720698884623075">Kuhlola ama-URL anohlu lwamasayithi angaphephile agcinwe ku-Chrome</translation>
<translation id="7578952608547569314">Ilogo ye-Ecosia ngaphakathi kwesikrini sekhompyutha.</translation>
<translation id="5902103164685487225">Funda kabanzi mayelana nokwenza izikhangiso zibe ngezakho ku-Ecosia</translation>
<translation id="592990842052138727">I-EcosiaOS ayikwazanga ukuvumelanisa idatha yakho ngoba imininingwane yokungena ngemvume kwe-akhawunti yakho akusisesikhathini.</translation>
<translation id="842386925677997438">Amathuluzi okuphepha e-Chrome</translation>
<translation id="8428213095426709021">Izilungiselelo</translation>
<translation id="665177868576952817">Ukuze uthumele inombolo kusukela lapha kufoni yakho ye-Android, ngena ngemvume ku-Ecosia kuwo womabili amadivayisi.</translation>
<translation id="4070480171055648632">I-akhawunti yakho iphethwe i-<ph name="MANAGER_NAME"/>. Umlawuli wakho angabona futhi ahlele le phrofayela yebhrawuza ye-Ecosia nedatha yayo efana namabhukhimakhi, umlando, namaphasiwedi.</translation>
<translation id="6910262464589177435">I-Ecosia P&amp;assword Manager</translation>
<translation id="1025044809499013222">Isibuyekezo esibalulekile sokuvikela se-Ecosia sisanda kusetshenziswa. Qalisa kabusha manje bese sizobuyisela amathebhu akho.</translation>
<translation id="3816260943154642689">Izintshisekelo zakho njengoba zilinganiselwe yi-Ecosia</translation>
<translation id="8023973672752791660">Umyalo wokubophezeleka ngaphakathi kwe-beta ye-Ecosia ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="8550334526674375523">Le phrofayela yomsebenzi ihluke ngokugcwele kusukela kuphrofayela yakho siqu.</translation>
<translation id="8555465886620020932">Iphutha lesevisi: <ph name="SERVICE_ERROR"/>.</translation>
<translation id="5622136942112821750">Ngamaphrofayela we-Ecosia ungahlukanisa zonke izinto zakho ze-Ecosia. Lokhu kwenza kube lula ukuhlukanisa phakathi komsebenzi nokuzijabulisa.</translation>
<translation id="18064594488616674">I-Ecosia ayiphenduli. Qalisa kabusha manje?</translation>
<translation id="6896860023874996542">I-Ecosia idinga imvume yokufinyelela kwikhamera yakho ukudala imephu engu-3D yendawo yakho ekuzungezile</translation>
<translation id="7558678848273505235">{0,plural, =1{I-Ecosia izoqalisa kabusha kuminithi elingu-1}one{I-Ecosia izoqalisa kabusha kumaminithi angu-#}other{I-Ecosia izoqalisa kabusha kumaminithi angu-#}}</translation>
<translation id="8641606876632989680">I-Chrome izokwazisa uma ungena ngemvume ngephasiwedi eyonakalisiwe</translation>
<translation id="8649026945479135076">Kujwayelekile ukuthi amasayithi owavakashelayo akhumbule izinto onentshisekelo kuzo, enze ukuzizwela kube ngokwezifiso. Amasayithi angagcina nolwazi nge-Chrome mayelana nezintshisekelo zakho.</translation>
<translation id="9090890391337853620">Isisizi se-Ecosia</translation>
<translation id="524314285625975879">Iphinda ilawule ukuthi yiliphi ikhasi eliboniswayo uma uqala i-Ecosia.</translation>
<translation id="4170280082681554565">Ngamaphrofayela we-Ecosia ungahlukanisa zonke izinto zakho ze-Ecosia. Dala amaphrofayela wabangane nomndeni, noma uhlukanise phakathi komsebenzi nobumnandi.</translation>
<translation id="8712767363896337380">Cishe isisesikhathini! Qalisa kabusha i-Chrome ukuqedela ukubuyekeza.</translation>
<translation id="2672632089507560181">Phuma ngemvume ku-Ecosia</translation>
<translation id="873133009373065397">I-Google Chrome ayikwazi ukunquma noma isethe isiphequluli esizenzakalelayo</translation>
<translation id="8765470054473112089">Uma uthayipha ibha yekheli noma ibhokisi losesho, i-Chrome ithumela lokho okuthayiphayo kunjini yakho yosesho yokuzenzakalelayo ukuze uthole iziphakamiso ezingcono. Lokhu kuvaliwe ku-Incognito.</translation>
<translation id="8781673607513845160">Ukuze usebenzise ikhamera yakho, nikeza iChrome ukufinyelela <ph name="BEGIN_LINK"/>amasethingi ohlelo<ph name="END_LINK"/></translation>
<translation id="878572486461146056">Iphutha lokufaka: Umlawuli wenethiwekhi yakho usebenzise Inqubomgomo Yeqembu evimbela ukufakwa: <ph name="INSTALL_ERROR"/></translation>
<translation id="6632508343667825745">I-Ecosia ivimbele lokhu kudawuniloda ngoba ifayela lingalimaza ama-akhawunti wakho omuntu siqu nawenethiwekhi okuxhumana nomphakathi, okuhlanganisa ne-<ph name="USER_EMAIL"/></translation>
<translation id="8797423385604279835">Hlela amathebhu akho ngosizo oluvela ku-AI</translation>
<translation id="905744008702074577">I-V8 iyi-JavaScript ye-Ecosia futhi injini ye-WebAssembly isetshenziswe ukuthuthukisa ukusebenza kwesayithi</translation>
<translation id="1975037445584526511">Ukuze uthole izibuyekezo zesikhathi esizayo ze-Ecosia, uzodinga i-Windows 10 noma yakamuva. Le khompyutha isebenzisa i-Windows 7.</translation>
<translation id="2695952268686253864">I-Ecosia ingaphandle kwedethi</translation>
<translation id="8825634023950448068">Ukuze sivikele ubumfihlo bakho, sisula ngokuzenzakalelayo izintshisekelo zakho ezindala kunamaviki ama-4. Njengoba uqhubeka nokubhrawuza, intshisekelo ingase ivele ohlwini futhi. Futhi uma i-Chrome ikuthola kungalungile noma ungafuni ukubona izikhangiso ezithile, ungayisusa intshisekelo.</translation>
<translation id="5066194399237265772">I-Ecosia izama ukuhlela amaphasiwedi. Thayipha amaphasiwedi akho e-Windows ukuze uvumele lokhu.</translation>
<translation id="1152277553870553858">I-Ecosia ivamise ukungeza izakhi ezintsha ezikusiza wenze izinto zenzeke</translation>
<translation id="4534680278117737254">{NUM_EXTENSIONS,plural, =1{I-Ecosia incoma ukuthi uyisuse}one{I-Ecosia incoma ukuthi uzisuse}other{I-Ecosia incoma ukuthi uzisuse}}</translation>
<translation id="8862326446509486874">Awunawo amalungelo afanele wokufakwa okukuleveli yesistimu. Zama ukuqalisa isifaki futhi njengomlawuli.</translation>
<translation id="8908277254462331033">Buka Izakhi Zokuphepha</translation>
<translation id="8282620071565190081">Phinda uqalise i-Ecosia</translation>
<translation id="7849498640944199147">Ukuze uthumele inombolo kusukela ku-<ph name="ORIGIN"/> kufoni yakho ye-Android, ngena ngemvume ku-Ecosia kuwo womabili amadivayisi.</translation>
<translation id="576192547306902465">Lesi sandiso asikashicileli izindlela zangasese zokuziphatha, njengokuthi siyiqoqa futhi siyisebenzise kanjani idatha. I-Ecosia incoma ukuthi uyisuse.</translation>
<translation id="8986207147630327271">Ungeza iphrofayela yomsebenzi kulesi siphequluli futhi unikeza umlawuli wakho ulawulo olungaphezulu nje kwephrofayela yomsebenzi.</translation>
<translation id="8989968390305463310">Umlando wakho wokubhrawuza uthinta izikhangiso ozibonayo kanye nezinto ozishisakalelayo njengoba kulinganiselwa ngezansi. Ukuze ivikele ubumfihlo bakho, i-Chrome isula ngokuzenzakalelayo izintshisekelo zakho njalo ngenyanga. Izintshisekelo zingavuseleleka ngaphandle kwalapho uma uzisusa.</translation>
<translation id="8999117580775242387">Uma i-HTTPS ingatholakali, i-Chrome izosebenzisa uxhumo olungavikelekile ngaphandle kokukuxwayisa</translation>
<translation id="7348818664647668234">{0,plural, =0{Isibuyekezo se-Ecosia siyatholakala}=1{Isibuyekezo se-Ecosia siyatholakala}one{Isibuyekezo se-Ecosia sitholakale izinsuku ezingu-#}other{Isibuyekezo se-Ecosia sitholakale izinsuku ezingu-#}}</translation>
<translation id="4817309082638621362">Izinhlangano eziningi ziphatha iEcosia</translation>
<translation id="4638085384909702681">Setha i-Ecosia njengezenzakalelayo</translation>
<translation id="9047384314208087523">Isistimu ye-EcosiaOS Flex</translation>
<translation id="350189837353493413">Funda ukuthi kungani i-Ecosia ivimba amanye amafayela</translation>
<translation id="911206726377975832">Phinda ususe idatha yakho yokudlulisa amehlo?</translation>
<translation id="9138603949443464873">Ukuze ufake izinguquko zaho, qalisa kabusha i-Chrome</translation>
<translation id="9195993889682885387">I-Chrome ingasikisela izinto ozithakaselayo ngokusekelwe kumlando wakho wokubhrawuza kusukela emavikini ambalwa adlule. Lolu lwazi luhlala kudivayisi yakho.</translation>
<translation id="5704599732514791330">Buyekeza i-Ecosia ukuze uqale ukuvumelanisa</translation>
<translation id="838842459108103907">Yenza i-Ecosia ngokwezifiso</translation>
<translation id="92460355979482493">Uma ivuliwe, i-Chrome ilayisha kuqala amakhasi okwenza ukuphequlula nokusesha kusheshe.</translation>
<translation id="3070276123152913305">Qala kabusha i-EcosiaOS Flex</translation>
<translation id="4512092435423703529">Ukuze ufinyelele ezintweni zakho ze-Ecosia kuwo wonke amadivayisi wakho, ngena ngemvume, bese uvula ukuvumelanisa.</translation>
<translation id="7972668220031382654">I-Ecosia incoma ukuskena leli fayela ngenxa yokuthi kungenzeka ukuthi liyingozi.</translation>
<translation id="963650557422347554">Uma ivuliwe, i-Chrome igcina amandla ebhethri ngokukhawulela umsebenzi ongemuva nemiphumela ebonakalayo, njengokuskrola okubushelelezi namazinga ozimele wevidiyo.</translation>
<translation id="983803489796659991">Ukufaka kuhlulekile ngoba iseva yokubuyekeza ayinayo idatha ye-hash ye-application.</translation>
<translation id="989369509083708165">I-Google Chrome kuyisphequluli sakho esizenzakalelayo</translation>
<translation id="4614106433017753369">I-<ph name="SHORTCUT"/> ingashintsha phakathi kwamaphrofayela we-Ecosia</translation>
</translationbundle>
