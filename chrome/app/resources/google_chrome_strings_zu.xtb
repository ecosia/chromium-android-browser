<translation id="5357908757303442841">Ku-Ecosia Password Manager kule divayisi</translation>
<translation id="8859253218356192164">I-EcosiaOS Flex yenzeka ngenxa <ph name="BEGIN_LINK_CROS_OSS"/>yesofthiwe yomthombo ovulekile eyengeziwe<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="1485302026917450654">Ngena Ngemvume ku-Ecosia?</translation>
<translation id="6676384891291319759">Finyelela i-inthanethi?</translation>
<translation id="4586967042094107073">Vumela i-Ecosia isebenze ngemuva</translation>
<translation id="2173571365716863400">I-Ecosia idinga imvume yemakrofoni kule sayithi</translation>
