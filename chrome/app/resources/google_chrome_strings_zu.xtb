<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - I-Ecosia</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia Beta</translation>
<translation id="4154538917942874814">Umyalo obophezeleke ngaphakathi we-Ecosia ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="8542320769345885402">Umphathi Wephasiwedi ye-Ecosia</translation>
<translation id="6273793429163604305">Guqani...</translation>
<translation id="675229436434399924">Izinhlelo zokusebenza ze-Ecosia Dev</translation>
<translation id="4870057811531036437">I-Ecosia isivele ifakelwe bonke abasebenzisi kukhompuyutha yakho.</translation>
<translation id="330264384086604869">Susa kusuka ku-Ecosia</translation>
<translation id="6327105987658262776">Asikho isibuyekezo esitholakalayo.</translation>
<translation id="6412673304250309937">Kuhlola ama-URL anohlu lwamasayithi angaphephile agcinwe ku-Chrome. Uma isayithi lizama ukuntshontsha iphasiwedi yakho, noma uma ulanda ifayela eliyingozi, i-Chrome ingathumela nama-URL, kuhlanganise nokuthile okuqukethwe kulelo khasi, Ekuphequluleni Okuphephile.</translation>
<translation id="4781882243268600858">Shintshela kuphrofayela ye-Ecosia ekhona kakade?</translation>
<translation id="2537426042760364251">I-Ecosia idinga imvume yekhamera ukudala imephu ye-3D yendawo yakho ekuzungezile</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia Dev</translation>
<translation id="5357908757303442841">Ku-Ecosia Password Manager kule divayisi</translation>
<translation id="8859253218356192164">I-EcosiaOS Flex yenzeka ngenxa <ph name="BEGIN_LINK_CROS_OSS"/>yesofthiwe yomthombo ovulekile eyengeziwe<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="6676384891291319759">Finyelela i-inthanethi?</translation>
<translation id="4586967042094107073">Vumela i-Ecosia isebenze ngemuva</translation>
<translation id="2173571365716863400">I-Ecosia idinga imvume yemakrofoni kule sayithi</translation>
<translation id="6161025257729272170">Yenza i-Ecosia isheshe</translation>
<translation id="9165312115453649251">Isistimu ye-EcosiaOS Flex</translation>
<translation id="8685318202174822382">Qhubeka kuphrofayela entsha ye-Ecosia?</translation>
<translation id="6750954913813541382">Ukuze kulungiswe amaphutha okupeletwa, i-Chrome ithumela umbhalo owuthayiphayo kusiphequluli ku-Google</translation>
<translation id="88039520238670574">Phuma ku-Ecosia noma kunjalo?</translation>
<translation id="8583650869792032882">Umyalo wokubophezeleka ngaphakathi kwe-Ecosia Canary ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="6881299373831449287">Ibuyekeza i-Chrome</translation>
<translation id="6800892712521842441">Izinhlelo zokusebenza ze-beta ye-Ecosia</translation>
<translation id="5267683457871579197">Isistimu ye-EcosiaOS</translation>
<translation id="8963533629322868062">Ukuze uthole izibuyekezo zesikhathi esizayo ze-Ecosia, uzodinga i-Windows 10 noma yakamuva. Le khompyutha isebenzisa i-Windows 8.1.</translation>
<translation id="2128110540135015661">Idatha yokuphequlula yalo muntu izosuswa kusukela kule divayisi. Ukuze uphinde uthole idatha, ngena ngemvume ku-Ecosia njengo-<ph name="USER_EMAIL"/>.</translation>
<translation id="2434044214904689670">Umyalo wokubophezeleka ngaphakathi kwe-beta yeEcosia ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="7482156490649194631">I-Ecosia ibuyekeziwe, kodwa awukayisebenzisi ngokungenani izinsuku ezingu-30.</translation>
<translation id="7025789849649390912">Ukufaka Kumisiwe.</translation>
<translation id="4032832945953542360">Ungashintsha phakathi kwamaphrofayela we-Ecosia lapha</translation>
<translation id="931416298178634530">Uma ufuna ukusebenzisa le akhawunti kanye kuphela, ungasebenzisa <ph name="GUEST_LINK_BEGIN"/>Imodi Yesivakashi<ph name="GUEST_LINK_END"/> kwibhrawuza ye-Ecosia. Uma ufuna ukwengeza i-akhawunti yothile, <ph name="LINK_BEGIN"/>engeza umuntu omusha<ph name="LINK_END"/> ku-<ph name="DEVICE_TYPE"/> yakho.

Izimvume ozinikezile kakade amawebhusayithi nama-app zingase zisebenze kule akhawunti. Ungakwazi nokuphatha ama-Ecosia Account wakho kokuthi <ph name="SETTINGS_LINK_BEGIN"/>Amasethingi<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="4281355161119203663">Umzali wakho uvale "Izimvume zamasayithi, izinhlelo zokusebenza, nezandiso" ze-Ecosia. Ukwengeza le <ph name="EXTENSION_TYPE_PARAMETER"/> akuvumelekile.</translation>
<translation id="7085332316435785646">Khetha ukuthi ufake phakathi umlando we-Chrome ukuze uthole umuzwa womuntu siqu kumasevisi e-Google</translation>
