<translation id="3744202345691150878">Thola usizo nge-ChromeOS</translation>
<translation id="4600924482853773728">I-Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="4969069484658032230">I-EcosiaOS Flex ayikwazanga ukuvumelanisa idatha yakho ngenxa yephutha lokungena ngemvume.</translation>
<translation id="1761341660094265938">I-EcosiaOS</translation>
<translation id="2829233304432701500">I-Ecosia idinga i-Windows 7 noma ngaphezulu.</translation>
<translation id="3952510753191144456">Lokhu kuzodalela u-<ph name="USER_EMAIL_ADDRESS"/> iphrofayela entsha ye-Ecosia</translation>
<translation id="4019094010333463261">I-Ecosia idinga ukufinyelela kwe-Bluetooth ukuze ihlole amadivayisi we-Bluetooth. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="8534308095039131078">Sicela uvale wonke amawindi we-Ecosia bese uzama futhi.</translation>
<translation id="3865754807470779944">Inguqulo ye-Chrome i-<ph name="PRODUCT_VERSION"/> ifakiwe</translation>
<translation id="8283315171506895091">Vula isixhumanisi kuwindi le-Ecosia inco&amp;gnito</translation>
<translation id="6496553866814956056">Khipha i-Ecosia</translation>
<translation id="3941890832296813527">Iphutha lokufaka: Igama lefayela lesifaki alivumelekile noma alisekelwe.</translation>
<translation id="4459596553899864514">IEcosia ifuna ukusula idatha yakho Yomphathi Wephasiwedi yeEcosia. Thayipha iphasiwedi yakho yeWindows ukuze uvumele lokhu.</translation>
<translation id="8846463365332065180">I-Ecosia ihlala ishesha ngezakhi ezinika amandla ukusebenza</translation>
<translation id="1118786556671181978">Ungabona futhi ususe izihloko zesayithi ongaba nentshisekelo kuzo ezisetshenziswa ukukubonisa izikhangiso. I-Ecosia izolinganisa ongaba nentshisekelo kukho ngokusekelwe kumlando wakho wakamuva wokubhrawuza.</translation>
<translation id="8047394653992042491">I-EcosiaOS idinga ukuqaliswa kabusha ukuze yenze kusebenze isibuyekezo.</translation>
<translation id="4050175100176540509">Ukuthuthukiswa kokuphepha okubalulekile nezici ezintsha kuyathokala kunguqulo yakamuva.</translation>
<translation id="4817913198787198451">Yenza ngokwezifiso futhi lawula i-Ecosia</translation>
<translation id="4395802781633621239">Ukuze uthole amaphasiwedi akho kanye nokwengeziwe kuwo wonke amadivayisi akho, ngena ngemvume kuEcosia. Le phasiwedi izolondolozwa kuEcosia Account yakho ngemva kokungena ngemvume.</translation>
<translation id="1330085168384841023">Ukuze wabelane ngewindi lakho, vumela ukurekhodwa kwesikrini kweEcosia Kokuncanyelwayo Kwesistimu.</translation>
<translation id="3708834841667355707">I-Ecosia ihlola izakhi ezintsha ezivumela amasayithi ukuthi alethe ukuzizwisa kokubhrawuza okufanayo kusetshenziswa ulwazi lwakho oluncane</translation>
<translation id="319566061277127356">Setha iphrofayela yakho entsha ye-Ecosia</translation>
<translation id="7433581196371819898">I-Ecosia ayikwazi ukuqinisekisa ukuthi lesi sandiso sivelaphi, futhi kungenzeka ukuthi asiphephile. Sisuse ku-Ecosia ukuze singasakwazi ukubona nokushintsha idatha yakho kumasayithi owavakashelayo, okufaka phakathi ulwazi lomuntu siqu.</translation>
<translation id="2198589091447191935">I-Ecosia iyashesha ukuqalisa futhi izathi ezisebenzisa i-JavaScript kufanele zisebenze njengoba ziklanyiwe (okunconywayo)</translation>
<translation id="7105712012505419722">Ungena ngemvume nge-akhawunti ephethwe futhi unikeza umlawuli wayo ukulawula okungaphezulu kwephrofayela yakho ye-Ecosia. Idatha yakho ye-Ecosia, efana nezinhlelo zokusebenza zakho, amabhukhimakhi, umlando, amaphasiwedi, nezinye izilungiselelo zizoboshezelwa ngonaphakade ku-<ph name="USER_NAME"/>. Uzokwazi ukususa le datha nge-Ecosia ama-Akhawunti we-Ideshibhodi, kodwa ngeke uze ukwazi ukuhlobanisa le datha nenye i-akhawunti. <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">Iyafaka...</translation>
<translation id="7691143774653486474">Isifaki sihlulekile ukungaminyanisi ingobo yomlando. Sicela ulande i-Ecosia futhi.</translation>
<translation id="2446603005062458629">I-Ecosia izovala maduzane futhi isule idatha</translation>
<translation id="4173512894976930765">Amasayithi cishe azosebenza njengokulindelwe. Uzophuma ngemvume kumasayithi amaningi uma uvala wonke amawindi e-Chrome, ngaphandle kwe-Google Account yakho uma ungene ngemvume ku-Chrome.</translation>
<translation id="2745180350547322293">I-Ecosia ivimbele lokhu kulanda ngoba isayithi alisebenzisi uxhumano oluvikelekile futhi kungenzeka ukuthi ifayela lonaniwe.</translation>
<translation id="6826163993811146231">{0,plural, =1{Qalisa kabusha i-Ecosia phakathi nosuku}one{Qalisa kabusha i-Ecosia phakathi kwezinsuku ezingu-#}other{Qalisa kabusha i-Ecosia phakathi kwezinsuku ezingu-#}}</translation>
<translation id="4205939740494406371">I-Chrome ayikwazi ukuhlola amaphasiwedi akho. Zama futhi ngemva kwamahora angu-24 noma <ph name="BEGIN_LINK"/>hlola amaphasiwedi ku-akhawunti yakho ye-Google<ph name="END_LINK"/>.</translation>
<translation id="4222932583846282852">Iyakhansela...</translation>
<translation id="4224210481850767180">Ukufaka kukhanseliwe.</translation>
<translation id="3554373328288278512">I-Ecosia idinga izimvume zekhamera nemakrofoni kule sayithi</translation>
<translation id="424864128008805179">Phuma ngemvume ku-Chrome?</translation>
<translation id="8384922154025337808">Xhumanisa idatha yakho ye-Ecosia kule akhawunti?</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>Iyiphi idatha esetshenziswayo:<ph name="END_BOLD"/> Umlando wakho wokubhrawuza, irekhodi lamasayithi owavakashele usebenzisa i-Ecosia kule divayisi.</translation>
<translation id="4281844954008187215">Imigomo yesevisi</translation>
<translation id="4293420128516039005">Ngena ngemvume ukuze uvumelanise uphinde wenze kube ngeyakho i-Chrome kuwo onke amadivayisi akho</translation>
<translation id="6419542773162312746">Vumela isandiso ukuze ubonise izicelo zokufinyelela kubha yamathuluzi ye-Ecosia</translation>
<translation id="8864449561723972619">I-Ecosia Dev (mDNS-In)</translation>
<translation id="4329315893554541805">Ukuze uthole ukwenza ngokomuntu ngamunye nezinye izakhi, ezifaka i-Chrome Kumsebenzi wewebhu nowe-app nakumasevisi alinkiwe e-Google</translation>
<translation id="4334294535648607276">Ukulanda kuqedile.</translation>
<translation id="4335235004908507846">I-Chrome ingasiza ukukugcina uphephile kusukela ekuphulweni kwedatha, izandiso ezimbi, nokuningi</translation>
<translation id="2227704215309956084">I-<ph name="EXTENSION_NAME"/> ingezwe ku-Ecosia</translation>
<translation id="4348548358339558429">Ukuze uthole ukwenza ngokomuntu ngamunye, okufaka i-Chrome Kumsebenzi Wewebhu nowe-App</translation>
<translation id="197803137365953132">I-Ecosia ivimbele lokhu kudawuniloda ngoba ifayela lingalimaza ama-akhawunti wakho omuntu siqu nawenethiwekhi yokuxhumana nomphakathi</translation>
<translation id="4384570495110188418">I-Chrome ayikwazi ukuhlola amaphasiwedi akho ngoba awungenanga ngemvume</translation>
<translation id="4389991535395284064">Uma ubhrawuza ngemodi ye-Incognito, i-Chrome izokuxwayisa ngaphambi kokulayisha isayithi isebenzisa uxhumo olungavikelekile.</translation>
<translation id="4427306783828095590">Isivikelo esithuthukisiwe senza okuningi ukuvimba ubugebengu bokweba imininingwane ebucayi kanye uhlelo olungayilungele ikhompyutha</translation>
<translation id="4434353761996769206">Iphutha lesifaki: <ph name="INSTALLER_ERROR"/></translation>
<translation id="2297526912548649074">Ngena ngemvume kuEcosia njengo-<ph name="USER_EMAIL"/></translation>
<translation id="9035946286843935549">I-Ecosia - Inethiwekhi Yokungena ngemvume - <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">Okunye ukusebenza ku-Ecosia kuyenzeka manje. Sicela uzame futhi emuva kwesikhathi.</translation>
<translation id="4459234553906210702">Isilinganiso sesikhangiso sivumela amasayithi owavakashelayo ukuba acele ulwazi ku-Chrome olusiza isayithi ukukala ukusebenza kwezikhangiso zawo. Isilinganiso sesikhangiso sikhawulela ukulandelela indawo yonke ngokudlulisa ulwazi oluncane ngangokunokwenzeka phakathi kwamasayithi.</translation>
<translation id="4501471624619070934">Ukufaka kuhlulekile ngoba ukufinyelela kukhawulelwe kuleli zwe.</translation>
<translation id="4567424176335768812">Ungene ngemvume njengo-<ph name="USER_EMAIL_ADDRESS"/>. Manje ungakwazi ukufinyelela amabhukhimakhi, umlando, nezinye izilungiselelo kuwo wonke amadivayisi wakho ongene kuwo ngemvume.</translation>
<translation id="6533266716128249922">Hamba kuzilungiselelo zesaziso se-Ecosia</translation>
<translation id="7562371913339616107">IEcosia ingenza lawa mathebhu angasebenzi ukuthuthukisa okwenzekayo lapho ubhrawuza iphinde ikhulule izinsiza.</translation>
<translation id="488806616089631539">Uma i-Ecosia inokufinyelela, amawebhusayithi azokwazi ukukucela ukufinyelela.</translation>
<translation id="3268039966078382323">I-Ecosia ayikwazanga ukubuyekezela kwinguqulo yakamuva, ngakho-ke uyalahlekelwa kuzici ezintsha nokulungiswa kokuphepha.</translation>
<translation id="4624065194742029982">I-Chrome Incognito</translation>
<translation id="4690206707618474800">Okokuzikhethela: Siza ukuthuthukisa izakhi nokusebenza kwe-EcosiaOS Flex ngokuthumela ngokuzenzekelayo idatha yokuxilongwa nokusetshenziswa ku-Ecosia.</translation>
<translation id="9125443060066914183">Ukwenza i-Ecosia ivikeleke, sikhubaze ezinye izandiso ezingafakwanga kuhlu lwe-<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> futhi okungenzeka zifakwe ngaphandle kolwazi lakho.</translation>
<translation id="4680828127924988555">Khansela Ukufaka</translation>
<translation id="8236553889322631924">Izandiso, ama-app, namatimu asuka emithonjeni engaziwa angalimaza idivayisi yakho. I-Ecosia incoma ukuwafaka kuphela kusuka ku-Ecosia Web Store</translation>
<translation id="4710245680469034439">Qondanisa nomuntu siqu ibhrawuza yakho namatimu akhuthazwe imvelo, amaqoqo amaciko nokuningi</translation>
<translation id="4724676981607797757">Ukufaka kuhlulekile ngenxa yephutha lephrothokholi engasekelwe.</translation>
<translation id="3305517118160815955">Ukufaka kuhlulekile ngenxa yephutha elingacacisiwe. Uma ngabe i-Ecosia isebenza okwamanje, sicela uyivale uphinde uzame futhi.</translation>
<translation id="4747730611090640388">I-Chrome ingalinganisela izintshisekelo zakho.  Kamuva, isayithi olivakashelayo lingacela i-Chrome ukuthi ibone izintshisekelo zakho ukuze yenze izikhangiso ozibonayo ngokwezifiso zakho.</translation>
<translation id="827222962844006655">I-Ecosia Canary (mDNS-In)</translation>
<translation id="3543284013834505767">Lokhu kusebenzisa isihloli sokupeleta esifanayo naleso esisetshenziswe kusesho lwe-Ecosia. Umbhalo owuthayiphayo kusiphequluli uthunyelwa ku-Ecosia. Ungahlala ushintsha le mpatho kuzilungiselelo.</translation>
<translation id="4793679854893018356">Funda ukuthi i-Chrome ikugcina kanjani uphephile</translation>
<translation id="8957938953005153147">I-Ecosia izama ukufaka esikhundleni samaphasiwedi akhona. Thayipha iphasiwedi yakho ye-Windows ukuze uvumele lokhu.</translation>
<translation id="8144706290339578682">I-EcosiaOS Flex ayikwazanga ukuvumelanisa idatha yakho ngoba Ukuvumelanisa akutholakali esizindeni sakho.</translation>
<translation id="7984841734836997333">U-<ph name="EXISTING_USER"/> usevele ungene ngemvume.  Ukugcina ukubhrawuza kwakho kuhlukile, ngena ngemvume ku-Ecosia kuphrofayela yakho njengo-<ph name="USER_EMAIL_ADDRESS"/>.</translation>
<translation id="4264506519284061030">Inhlangano yakho ingabona iphinde iphathe idatha yopheqululo kuphrofayela yakho yomsebenzi, efana namabhukhimakhi, umlando, namaphasiwedi akho. Ayikwazi ukubona idatha yopheqululo kumaphrofayela omuntu siqu e-Ecosia.</translation>
<translation id="8701027951719712428">Ukuze uthole izibuyekezo zesikhathi esizayo ze-Ecosia, uzodinga i-macOS 11 noma eyakamuva. Le khompyutha isebenzisa i-macOS 10.15.</translation>
<translation id="4873783916118289636">Buyekeza izilawuli eziyinhloko zobumfihlo nokuvikeleka ku-Chrome</translation>
<translation id="8454595950895325762">Vumela i-Ecosia isebenze ngemuva</translation>
<translation id="489671036945006830">Vula isixhumanisi ku&amp;thebhu entsha ye-Ecosia</translation>
<translation id="6566258574866003581">I-Ecosia incoma ukuthi ubuyekeze lesi sandiso</translation>
<translation id="4951177103388687412">Hlala uhlelekile futhi ugxilile ngosizo lwamaqembu ethebhu</translation>
<translation id="5581150090232500900">Setha i-Ecosia njengesiphequluli sakho sokuzenzakalelayo</translation>
<translation id="6495878830719404098">Ku-Ecosia</translation>
<translation id="6113625922434842626">I-EcosiaOS Flex ayikwazanga ukuvumelanisa idatha yakho ngoba imininingwane yokungena ngemvume ku-akhawunti yakho iphelelwe isikhathi.</translation>
<translation id="4410570812343670816">Siyakwamukela kumaphrofayela we-Ecosia</translation>
<translation id="4970880042055371251">Uhlobo lwe-ChromeOS</translation>
<translation id="8570641140903702642">I-Canary ye-Ecosia</translation>
<translation id="6735145163744656874">IEcosia ingenza lawa mathebhu angasebenzi ukuze ithuthukise okwenzekayo lapho ubhrawuza iphinde igcine izinto zishesha.</translation>
<translation id="2569934116750022163">Chofoza okuthi “Ecosia Password Manager”</translation>
<translation id="5120334927898581447">Ngena ngemvume ku-Chrome uma ungena ngemvume kwamanye amasevisi e-Google</translation>
<translation id="5126049312684316860">I-Chrome ilayisha kusengaphambili amakhasi engeziwe ongase uwavakashele, ukuze alayishe ngokushesha kakhudlwana lapho uwavakashela</translation>
<translation id="7782767522222146179">Thola izinhlelo zokusebenza ezinhle, amageyimu, izandiso namatimu e-Ecosia.</translation>
<translation id="6416551953415159186">Yenza ngokwezifiso iphrofayela yakho ye-Ecosia</translation>
<translation id="719484593754925816">IEcosia ingenza le thebhu ingasebenzi ukuze ithuthukise umuzwa wakho wokubhrawuza futhi ikhulule izinsiza.</translation>
<translation id="1859120614572957305">Siyakwamukela ku-Ecosia; iwindi elisha lesiphequluli livuliwe</translation>
<translation id="6648664289472946060">Iphrofayela yakho ayikwazi ukusetshenziswa ngoba isuka kunguqulo entsha ye-Ecosia.

Ezinye izici kungenzeka zingatholakali. Sicela ucacise umkhombandlela wephrofayela ehlukile noma usebenzise inguqulo entsha ye-Ecosia.</translation>
<translation id="5201744974236816379">isibuyekezo se-Chrome</translation>
<translation id="6960183526681645011">Uma wabelana ngedivayisi, abangane nomndeni bangaphequlula ngokwehlukile baphinde basethe i-Ecosia ngendlela abayifunayo.</translation>
<translation id="3784023996375784431">Sebenzisa i-Ecosia noma nini lapho uchofoza amalinki emiyalezweni, kumadokhumenti, nakwamanye ama-app</translation>
<translation id="1869027055332251164">Izihambeli zingasebenzisa i-Ecosia ngaphandle kokushiya noma yini ngemuva.</translation>
<translation id="5320351714793324716">Uma uvumela amakhukhi, i-Chrome ingase iwasebenzise lapho ilayisha kusengaphambili</translation>
<translation id="143614250230771428">I-EcosiaOS ayikwazanga ukuvumelanisa idatha yakho ngoba ukuvumelanisa akutholakaleli isizinda sakho.</translation>
<translation id="1809194740315140401">I-Ecosia idinga imvume yokufinyelela kusitoreji ukuze idawunilode amafayela</translation>
<translation id="8975930032513941502">Ongakukhetha: Siza ekuthuthukiseni izakhi nokusebenza kwe-EcosiaOS ngokuthumela ngokuzenzekelayo idatha yokusetshenziswa neyokuxilonga ku-Ecosia.</translation>
<translation id="5357889879764279201">Thola usizo nge-ChromeOS Flex</translation>
<translation id="5368118228313795342">Ikhodi eyengeziwe: <ph name="EXTRA_CODE"/>.</translation>
<translation id="6665128960039431910">Iphinda ilawule ukuthi yiliphi ikhasi eliboniswayo uma uqala i-Ecosia noma usesho kusuka ku-Omnibox.</translation>
<translation id="1861504561909287316">Yabelana ngethebhu ye-Ecosia</translation>
<translation id="5412485296464121825">Amasayithi angagcina ulwazi nge-Chrome mayelana nezintshisekelo zakho. Ngokwesibonelo, uma uvakashela isayithi ukuze uthenge izicathulo zomjaho webanga elide, isayithi lingachaza intshisekelo yakho njengokugijima umjaho. Kamuva, uma uvakashela isayithi elihlukile ukuze ubhalisele umjaho, lelo sayithi lingakubonisa isikhangiso sezicathulo zokugijima ezisekelwe kuzintshisekelo zakho.</translation>
<translation id="6673288084648462613">Ifayela lakho lokuncamelayo limoshekile noma alivumelekile. 

I-Ecosia ayikwazi ukuthola izilungiselelo zakho.</translation>
<translation id="5468572406162360320">Ukusiza ukuthuthukisa lezi zakhi, i-Chrome ithumela ukusebenzisana kwakho nazo ku-Google. Le datha ingase ifundwe, icutshungulwe, futhi ichazwe ababuyekezi abangabantu.</translation>
<translation id="5524761631371622910">Uma izivivinyo zivuliwe futhi i-Chrome ikubeke ngokungahleliwe ekuzameni okusebenzayo, umlando wakho wokubhrawuza uthinta izikhangiso ozibonayo kanye nezinto ozithakaselayo njengoba kusikiselwa ngezansi. Ukuze ivikele ubumfihlo bakho, i-Chrome isula izintshisekelo zakho njalo ngenyanga.</translation>
<translation id="2905159584855395810">Yenza I-Ecosia Isheshe</translation>
<translation id="2470806471563820591">I-Ecosia (mDNS-In)</translation>
<translation id="5167067155585861308">IEcosia incoma ukuthi uyisuse. <ph name="BEGIN_LINK"/>Funda kabanzi mayelana nezandiso ezisekelwayo<ph name="END_LINK"/></translation>
<translation id="7005470355724599337">I-Ecosia yenza okuningi ukukugcina uphephile ku-inthanethi</translation>
<translation id="3625533701824359646">I-<ph name="FILE_NAME"/> kungenzeka ibe ingozi, ngakho-ke i-Ecosia iyivimbile.</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{Umlawuli wakho ucela ukuthi uqalise kabusha i-Ecosia ukuze kusetshenziswe lesi sibuyekezo}=1{Umlawuli wakho ucela ukuthi uqalise kabusha i-Ecosia ukuze kusetshenziswe lesi sibuyekezo. Iwindi lakho le-Incognito ngeke liphinde livuleke.}one{Umlawuli wakho ucela ukuthi uqalise kabusha i-Ecosia ukuze kusetshenziswe lesi sibuyekezo. Amawindi akho angu-# e-Incognito ngeke aze aphinde avuleke.}other{Umlawuli wakho ucela ukuthi uqalise kabusha i-Ecosia ukuze kusetshenziswe lesi sibuyekezo. Amawindi akho angu-# e-Incognito ngeke aze aphinde avuleke.}}</translation>
<translation id="8544776492099331022">Yenza ngokwezifiso futhi lawula i-Ecosia. Okuthile kudinga ukuthi ukunake - chofoza ngemininingwane.</translation>
<translation id="4811228173434336381">I-Ecosia</translation>
<translation id="569897634095159764">Ayikwazi ukuxhuma ku-inthanethi Iseva elibamba idinga ukufakazela ubuqiniso.</translation>
<translation id="570005089986962444">Uma ivuliwe, i-Chrome ikhulula inkumbulo kumathebhu angasebenzi. Lokhu kunikeza amathebhu asebenzayo namanye ama-app izinsiza zekhompyutha ezengeziwe futhi kugcina i-Chrome ishesha. Amathebhu akho angasebenzi aphinde asebenze ngokuzenzakalelayo uma ubuyela kuwo.</translation>
<translation id="5581150090232500900">Setha i-Ecosia njengesiphequluli sakho esizenzakalelayo</translation>
<translation id="5727531838415286053">Uma i-Chrome ikubeke ngokungahleliwe esivivinyweni esisebenzayo, umlando wakho wokuphequlula uthinta izikhangiso ozibonayo kanye nezinto ozithakaselayo njengoba kusikiselwa ngezansi. Ukuze ivikele ubumfihlo bakho, i-Chrome isula izintshisekelo zakho njalo ngenyanga. Izintshisekelo ziyavuseleleka ngaphandle kwalapho uma uzisusa.</translation>
<translation id="5736850870166430177">Uma isayithi lizama ukuntshontsha iphasiwedi yakho, noma uma udawuniloda ifayela eliyingozi, i-Chrome ingathumela nama-URL, kuhlanganise nokuthile okuqukethwe kulelo khasi, Ekuphequluleni Okuphephile</translation>
<translation id="8301840715671593762">Iphrofayela ye-Ecosia enale akhawunti isikhona akakade kule divayisi</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia Canary</translation>
<translation id="2542649989941327712">Ayikwazanga ukuqalisa i-Ecosia. Zama futhi.</translation>
<translation id="5809516625706423866">Ayikwazi ukuxhuma ku-inthanethi I-HTTP 401 Ayigunyaziwe. Sicela uchekhe ukulungiselelwa kommeleli wakho.</translation>
<translation id="9091453616111683919">Susa <ph name="EXTENSION_NAME"/> kuEcosia</translation>
<translation id="1773882594264682232">Ngenkathi ungene ngemvume, ungasebenzisa amaphasiwedi akho nokuningi ukusuka kuEcosia Account yakho kuEcosia. Ungashintsha lokhu noma kunini emasethingini.</translation>
<translation id="5513857521842828996">Uzophuma ngemvume emasayithini amaningi uma uvala wonke amawindi e-Ecosia, ngaphandle kwe-Ecosia Account yakho uma ungene ngemvume ku-Ecosia. Ukuvumela amasayithi akukhumbule, <ph name="SETTINGS_LINK"/>.</translation>
<translation id="586971344380992563"><ph name="BEGIN_LINK"/>I-Chrome ikuxwayisa<ph name="END_LINK"/> mayelana namasayithi angaphephile kanye nokudawunilodiwe</translation>
<translation id="5895138241574237353">Qalisa kabusha</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - Inethiwekhi Yokugena ngemvume</translation>
<translation id="5924017743176219022">Ixhuma Ku-inthanethi...</translation>
<translation id="5932997892801542621">Uma uthayipha ibha yekheli noma ibhokisi losesho, i-Chrome ithumela lokho okuthayiphayo ku-Google Drive ukuze ithole iziphakamiso zezinto. Lokhu kuvaliwe ku-Incognito.</translation>
<translation id="4960252760049500399">Iwebhu yakho, amabhukhimakhi, nezinye izinto ze-Ecosia zihlala lapha.</translation>
<translation id="5941711191222866238">Nciphisa</translation>
<translation id="4662363689050405237">Yenza i-Ecosia ibe isiphequluli sokuzenzakalelayo</translation>
<translation id="1284343625991453987">Isinqamuleli se-Ecosia</translation>
<translation id="5953954252731207958">Awukavakashi kamuva nje. I-Chrome isuse i-<ph name="PERMISSION"/></translation>
<translation id="6003112304606738118">Iyadawuniloda... Kusele amahora angu-<ph name="HOURS"/></translation>
<translation id="6014316319780893079"><ph name="BEGIN_LINK"/>Ngamathuluzi avela ku-Chrome<ph name="END_LINK"/>, ungabhrawuza ngokuphepha uhlale ulawula</translation>
<translation id="4767994371234572952">Yenza i-Ecosia kube eyakho</translation>
<translation id="5490755016715767023">I-Ecosia izoqala kabusha emizuzwaneni engu-<ph name="REMAINING_TIME"/></translation>
<translation id="6040143037577758943">Vala</translation>
<translation id="6070348360322141662">Ngokuvikela okungeziwe, i-Google Chromium izobethela idatha yakho</translation>
<translation id="608006075545470555">Engeza Iphrofayela Yomsebenzi kulesi siphequluli</translation>
<translation id="6097822892606850415">Bhala ngokuzethemba okuningi ngosizo lwe-AI</translation>
<translation id="170259281605734125">I-Ecosia isanda kuba ngcono</translation>
<translation id="6134085236017727171">Ukuze usebenzise imakrofoni yakho, nikeza iChrome ukufinyelela <ph name="BEGIN_LINK"/>amasethingi ohlelo<ph name="END_LINK"/></translation>
<translation id="4618410489751241263">Lawa mathebhu asebenzisa izinsiza ezengeziwe. Ukuze uthuthukise ukusebenza kwakho, vumela iEcosia iwenze ingasebenzi.</translation>
<translation id="6145313976051292476">Vula ama-PDF ku-Chrome</translation>
<translation id="5137471865755621561">Inhlangano yakho isula idatha ye-Ecosia uma ingasetshenziswa isikhathi esingu-<ph name="TIMEOUT_DURATION"/>. Lokhu kungase kuhlanganise umlando, ukugcwalisa ngokuzenzakalelayo, nokudawuniloda.</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - I-Ecosia</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia Beta</translation>
<translation id="51576365410323372">Le thebhu isebenzisa izinsiza ezengeziwe. Ukuze uthuthukise ukusebenza kwakho, vumela iEcosia ikwenze kungasebenzi.</translation>
<translation id="6182736845697986886">Ukufaka kuhlulekile ngenxa yephutha langaphakathi leseva yokubuyekeza.</translation>
<translation id="6200139057479872438">Awukavakashi kamuva nje. I-Chrome isuse i-<ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/></translation>
<translation id="7845247414826995986">Ukuze wabelane ngesikrini sakho, vumela ukurekhodwa kwesikrini kweEcosia Kokuncanyelwayo Kwesistimu.</translation>
<translation id="4154538917942874814">Umyalo obophezeleke ngaphakathi we-Ecosia ukuze kuvunyelwe ithrafikhi ye-mDNS.</translation>
<translation id="5736558630107498475">I-Ecosia izovala maduze</translation>
<translation id="8542320769345885402">Umphathi Wephasiwedi ye-Ecosia</translation>
<translation id="6251759518630934363">Ikuxwayisa mayelana namasayithi ayingozi, ngisho nalawo i-Google ebingazi ngawo ngaphambili, ngokuhlaziya idatha eningi evela kumasayithi kunokuvikela okujwayelekile. Ungakhetha ukweqa izexwayiso ze-Chrome.</translation>
<translation id="8561406087076314604">Umzali wakho uvale "Izimvume zamasayithi, ama-app, nezandiso" ze-Ecosia</translation>
<translation id="1818520302923047971">Enza ngokwezifiso uphinde ulawule i-Ecosia. Setha i-Ecosia njengokwakho okuzenzakalelayo.</translation>
<translation id="6669755086687029198">Setha i-Ecosia njengokuzenzakalelayo kwakho ukuze wenze ngokuphephile, usungule, uphinde uhlole ku-inthanethi</translation>
<translation id="675229436434399924">Izinhlelo zokusebenza ze-Ecosia Dev</translation>
<translation id="4870057811531036437">I-Ecosia isivele ifakelwe bonke abasebenzisi kukhompuyutha yakho.</translation>
<translation id="378302976931789177">I-Ecosia idinga imvume yokumepha indawo ekuzungezile futhi ilandelele izandla zakho</translation>
<translation id="790624108224468719">Isandiso esithi "<ph name="EXTENSION_NAME"/>" sifuna ukuthi ungene ngemvume kuEcosia</translation>
<translation id="330264384086604869">Susa kusuka ku-Ecosia</translation>
<translation id="6327105987658262776">Asikho isibuyekezo esitholakalayo.</translation>
<translation id="7455175614937447568">Ngenkathi le thebhu ingasebenzi, inkumbulo iye yenzelwa isikhala ukugcina i-Ecosia ishesha. Ungakhetha ukungahlanganisi le sayithi ekutheni ibe engasebenzi.</translation>
<translation id="6412673304250309937">Kuhlola ama-URL anohlu lwamasayithi angaphephile agcinwe ku-Chrome. Uma isayithi lizama ukuntshontsha iphasiwedi yakho, noma uma ulanda ifayela eliyingozi, i-Chrome ingathumela nama-URL, kuhlanganise nokuthile okuqukethwe kulelo khasi, Ekuphequluleni Okuphephile.</translation>
<translation id="7757263274906217411">{COUNT,plural, =1{Inhlangano yakho ivala i-Ecosia ngokuzenzekelayo uma ingasetshenziswanga umzuzu o-1. Idatha yokubhrawuza isuliwe. Lokhu kungase kuhlanganise umlando, ukugcwalisa ngokuzenzakalelayo, nokudawuniloda.}one{Inhlangano yakho ivala i-Ecosia ngokuzenzekelayo uma ingasetshenziswanga imizuzu engu-#. Idatha yokubhrawuza isuliwe. Lokhu kungase kuhlanganise umlando, ukugcwalisa ngokuzenzakalelayo, nokudawuniloda.}other{Inhlangano yakho ivala i-Ecosia ngokuzenzekelayo uma ingasetshenziswanga imizuzu engu-#. Idatha yokubhrawuza isuliwe. Lokhu kungase kuhlanganise umlando, ukugcwalisa ngokuzenzakalelayo, nokudawuniloda.}}</translation>
