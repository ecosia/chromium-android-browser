<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="bn">
<translation id="1026101648481255140">ইনস্টলেশন আবার চালু করুন</translation>
<translation id="8933665254023068908">&amp;EcosiaOS আপডেট করতে আবার লঞ্চ করুন</translation>
<translation id="6566258574866003581">এই এক্সটেনশন পর্যালোচনা করার জন্য Ecosia সাজেশন দেয়</translation>
<translation id="1042552502243217427">কোনও সাইট তার পৃষ্ঠায় লিঙ্ক ব্যক্তিগতভাবে প্রিলোড করতে বললে, Chromium, Google সার্ভার ব্যবহার করে। এর ফলে প্রিলোড করা সাইটের থেকে আপনার পরিচয় লুকানো থাকে, কিন্তু Google জানতে পারে কোন সাইটগুলি প্রিলোড করা হয়েছে।</translation>
<translation id="1065672644894730302">আপনার অভিরুচিগুলি পড়া যাবে না৷ কিছু বৈশিষ্ট্য অনুপলব্ধ থাকতে পারে ও অভিরুচিগুলিতে করা পরিবর্তনগুলি সংরক্ষিত হবে না৷</translation>
<translation id="8561406087076314604">তোমার অভিভাবক Ecosia-এর জন্য "সাইট, অ্যাপ ও এক্সটেনশনের অনুমতি" বন্ধ করে দিয়েছেন</translation>
<translation id="1098170124587656448">ডেটার নিরাপত্তা লঙ্ঘন, এক্সটেনশন এবং আরও অনেক কিছুর থেকে Chrome আপনাকে সুরক্ষিত রাখতে সাহায্য করে</translation>
<translation id="3632544319066562282">Ecosia আপনার পাসওয়ার্ড এক্সপোর্ট করতে চাইছে। অনুমতি দিতে Windows এর পাসওয়ার্ড টাইপ করুন।</translation>
<translation id="113122355610423240">Chromium আপনার ডিফল্ট ব্রাউজার</translation>
<translation id="1131805035311359397">আপনার পাসওয়ার্ড ডেটার নিরাপত্তা লঙ্ঘন এবং অন্যান্য নিরাপত্তা সংক্রান্ত সমস্যা থেকে সুরক্ষিত কিনা তা চেক করতে <ph name="BEGIN_LINK"/>Chromium-এ সাইন-ইন করুন<ph name="END_LINK"/>।</translation>
<translation id="1224748120031661633">Ecosia মেনুতে ক্লিক করুন</translation>
<translation id="1184145431117212167">আপনার Windows-এর ভার্সনে কাজ করছে না তাই ইনস্টল করা যায়নি।</translation>
<translation id="1185134272377778587">Chromium সম্পর্কে</translation>
<translation id="1330085168384841023">আপনার উইন্ডো শেয়ার করতে, সিস্টেম প্রেফারেন্স থেকে Ecosia-এর জন্য স্ক্রিন রেকর্ডিং চালু করতে হবে।</translation>
<translation id="1203500561924088507">ইনস্টল করার জন্য ধন্যবাদ। <ph name="BUNDLE_NAME"/> ব্যবহার করার আগে আপনাকে অবশ্যই ব্রাউজার রিস্টার্ট করতে হবে।</translation>
<translation id="7455175614937447568">Ecosia যাতে দ্রুত কাজ করে সেই জন্য এই ট্যাব বন্ধ থাকাকালীন মেমরি খালি করা হয়েছে। এই সাইটটি অ্যাক্টিভ রাখার বিকল্প সব সময় বেছে নিতে পারবেন।</translation>
<translation id="9068280473864300215">এই ফাইলটি বিপজ্জনক, তাই Ecosia এই ডাউনলোডটি ব্লক করে দিয়েছে</translation>
<translation id="126567311906253476">Gmail বা YouTube-এর মতো Google পরিষেবায় <ph name="USER_EMAIL"/> দিয়ে সাইন-ইন করার সময় আপনি একই অ্যাকাউন্ট দিয়ে Chromium-এ অটোমেটিক সাইন-ইন করতে পারবেন</translation>
<translation id="1290883685122687410">সেট-আপ সংক্রান্ত সমস্যা: <ph name="METAINSTALLER_EXIT_CODE"/>। <ph name="WINDOWS_ERROR"/></translation>
<translation id="319566061277127356">আপনার নতুন Ecosia প্রোফাইল সেট আপ করুন</translation>
<translation id="4019094010333463261">ব্লুটুথ ডিভাইসগুলি এক্সপ্লোর করতে 
 Ecosia-কে ব্লুটুথের অ্যাক্সেস দিতে হবে। <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="5405885279794834338">এছাড়া, Ecosia থেকেও ডেটা মুছে দিন (<ph name="URL"/>)</translation>
<translation id="727568860157522676">আপনি Ecosia এ প্রবেশ করেছেন!</translation>
<translation id="1478370723027452770">Chrome for Testing ব্যবহার করে সহায়তা পান</translation>
<translation id="1497802159252041924">ইনস্টলেশন সংক্রান্ত সমস্যা: <ph name="INSTALL_ERROR"/></translation>
<translation id="1861504561909287316">একটি Ecosia ট্যাব শেয়ার করুন</translation>
<translation id="6896860023874996542">আপনার আশেপাশের 3D ম্যাপ তৈরি করতে এই সাইটটির জন্য Ecosia-কে আপনার ক্যামেরা অ্যাক্সেস করার অনুমতি দিতে হবে</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{এই এক্সটেনশন আর কাজ করবে না। Ecosia আপনাকে এটি সরিয়ে দেওয়ার সাজেশন দেয়।}one{এইসব এক্সটেনশন আর কাজ করবে না। Ecosia আপনাকে এগুলি সরিয়ে দেওয়ার সাজেশন দেয়।}other{এইসব এক্সটেনশন আর কাজ করবে না। Ecosia আপনাকে এগুলি সরিয়ে দেওয়ার সাজেশন দেয়।}}</translation>
<translation id="1574377791422810894">Chromium-এর নিরাপত্তা টুল</translation>
<translation id="2200308425865645682">আপনার Ecosia অ্যাকাউন্টে কিছু ডেটা সেভ এবং সবকটি ডিভাইসে তা ব্যবহার করতে পারার আগে, Ecosia-কে আপনার পরিচয় যাচাই করতে দিতে হবে। আপনি সাইন-আউট করলে, এই ডেটা এই ডিভাইসে থেকে যাবে।</translation>
<translation id="7304240387834227637">Ecosia আপনার Password Manager সম্পর্কিত ডেটা মুছতে চায়। এটি করার অনুমতি দিতে, আপনার Windows-এর পাসওয়ার্ড টাইপ করুন।</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে Ecosia আবার চালু করতে বলছেন}=1{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে Ecosia আবার চালু করতে বলছেন। আপনার ছদ্মবেশী উইন্ডো আবার খুলবে না।}one{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে Ecosia আবার চালু করতে বলছেন। আপনার #টি ছদ্মবেশী উইন্ডো আবার খুলবে না।}other{একটি আপডেট প্রয়োগ করতে আপনার অ্যাডমিনিস্ট্রেটর আপনাকে Ecosia আবার চালু করতে বলছেন। আপনার #টি ছদ্মবেশী উইন্ডো আবার খুলবে না।}}</translation>
<translation id="1625909126243026060">Chromium-এ মূল গোপনীয়তা এবং নিরাপত্তা নিয়ন্ত্রণ পর্যালোচনা করুন</translation>
<translation id="931416298178634530">শুধু একবারের জন্য এই অ্যাকাউন্ট ব্যবহার করলে, আপনি Ecosia ব্রাউজার থেকে <ph name="GUEST_LINK_BEGIN"/>গেস্ট মোড<ph name="GUEST_LINK_END"/> ব্যবহার করতে পারবেন। অন্য কোনও ব্যক্তির জন্য অ্যাকাউন্ট যোগ করতে চাইলে, <ph name="DEVICE_TYPE"/>-এ <ph name="LINK_BEGIN"/>নতুন ব্যক্তিকে যোগ করুন<ph name="LINK_END"/>।

বিভিন্ন ওয়েবসাইট ও অ্যাপকে আপনার আগে দেওয়া অনুমতি এই অ্যাকাউন্টের ক্ষেত্রেও প্রযোজ্য হবে। <ph name="SETTINGS_LINK_BEGIN"/>সেটিংস<ph name="SETTINGS_LINK_END"/> থেকে আপনার Ecosia অ্যাকাউন্ট ম্যানেজ করতে পারবেন।</translation>
<translation id="1640672724030957280">ডাউনলোড হচ্ছে...</translation>
<translation id="1715127912119967311">এইসব ফিচার উন্নত করতে, Chromium, এগুলির সাথে আপনার ইন্ট্যার‌্যাকশন সংক্রান্ত তথ্য Google-এর কাছে পাঠায়। এই ডেটা হিউম্যান রিভিউয়ারের দ্বারা পড়া, প্রসেস করা ও অ্যানোটেট করা হতে পারে।</translation>
<translation id="1722488837206509557">এর ফলে আপনি উপলভ্য় ডিভাইসগুলি থেকে বেছে নিতে পারবেন এবং সেগুলিতে কন্টেন্ট দেখাতে পারবেন।</translation>
<translation id="1118786556671181978">আগ্রহের যেসব বিষয়ের উপর ভিত্তি করে সাইট আপনাকে বিজ্ঞাপন দেখায়, আপনি সেগুলি দেখতে ও সরিয়ে দিতে পারবেন। Ecosia আপনার সাম্প্রতিক ব্রাউজিং ইতিহাসের উপর ভিত্তি করে আপনার আগ্রহ সম্পর্কে ধারণা করতে পারে।</translation>
<translation id="2379593823746842972">Ecosia শীঘ্রই ব্রাউজ করা ডেটা মুছে ফেলবে</translation>
<translation id="1736443181683099871">Chromium নেভিগেশনকে HTTPS-তে আপগ্রেড করার চেষ্টা করবে</translation>
<translation id="5490755016715767023">Ecosia <ph name="REMAINING_TIME"/>-এর মধ্যে রিস্টার্ট হবে</translation>
<translation id="1749104137266986751">HTTPS উপলভ্য না থাকলে, Chromium আপনাকে সতর্ক না করেই অসুরক্ষিত কানেকশন ব্যবহার করবে</translation>
<translation id="8454595950895325762">Ecosia-কে ব্যাকগ্রাউন্ডে চলতে দিন</translation>
<translation id="9125443060066914183">Ecosia কে আরও নিরাপদ করতে, আমরা কিছু এক্সটেনশান অক্ষম করেছি যা <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> এ তালিকাবদ্ধ করা হয়নি এবং হয়ত আপনাকে না জানিয়ে যোগ করা হয়েছে৷</translation>
<translation id="6984747211123632080">Ecosia আবার ইন্সটল করুন</translation>
<translation id="1251415775728969647">Ecosia <ph name="AUTHENTICATION_PURPOSE"/>-এর চেষ্টা করছে</translation>
<translation id="1761584959558744002">শুধুমাত্র এই ডিভাইস থেকে ব্রাউজ করা ডেটা মুছে দিতে, তা নিজের Ecosia অ্যাকাউন্টে রেখে দেওয়ার সময়, <ph name="BEGIN_LINK"/>Ecosia থেকে সাইন-আউট করুন<ph name="END_LINK"/>।</translation>
<translation id="185970820835152459">আপনার সাইন-ইন করা Google অ্যাকাউন্ট ম্যানেজ করতে পারবেন। Chromium ব্রাউজার, Play Store, Gmail সহ আরও অনেক কিছুর জন্য আপনার Google অ্যাকাউন্ট ব্যবহার করা হয়। পরিবারের সদস্যের মতো অন্য কারও অ্যাকাউন্ট যোগ করতে চাইলে, তার পরিবর্তে আপনার <ph name="DEVICE_TYPE"/>-এ নতুন ব্যক্তিকে যোগ করুন। <ph name="LINK_BEGIN"/>আরও জানুন<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">Chromium-এর মাধ্যমে আপনার আগ্রহের বিষয়ে তথ্যগুলি সাইট স্টোর করতে পারে। যেমন, আপনি যদি ম্যারাথনের জন্য জুতো কেনার একটি সাইট ভিজিট করেন, তাহলে সাইটটি আপনার আগ্রহকে ম্যারাথন দৌড় হিসেবে বিবেচনা করবে। পরে আপনি যদি রেসের জন্য রেজিস্ট্রেশন করতে অন্য একটি সাইটে যান, তাহলে আপনার আগ্রহের উপর ভিত্তি করে সাইটটি আপনাকে দৌড়ানোর জুতোর বিজ্ঞাপন দেখাবে।</translation>
<translation id="4239392394637574967">আপনি একটি পরিচালিত অ্যাকাউন্টের মাধ্যমে সাইন-ইন করুন করছেন এবং এর অ্যাডমিনিস্ট্রেটরকে আপনার Ecosia প্রোফাইলের উপরে নিয়ন্ত্রণ দিচ্ছেন৷ আপনার Ecosia ডেটা, যেমন অ্যাপ, বুকমার্ক, ইতিহাস, পাসওয়ার্ড এবং অন্যান্য সেটিংস <ph name="USER_NAME"/> এতে স্থায়ীভাবে সম্পৃক্ত হবে৷ আপনি Ecosia অ্যাকাউন্টগুলির ড্যাশবোর্ডের মাধ্যমে এই ডেটাগুলি মুছতে চালু হবেন, কিন্তু অন্য অ্যাকাউন্টের সাথে এই ডেটা সংশ্লিষ্ট করতে পারবেন না৷ বিকল্প হিসেবে আপনি আপনার বিদ্যমান Ecosia তথ্য আলাদা রাখার জন্য একটি নতুন প্রোফাইল তৈরি করতে পারেন৷ <ph name="LEARN_MORE"/></translation>
<translation id="1906696617298807388">আপনি অ্যাড্রেস বার বা সার্চ বক্সে টাইপ করার সময়, আপনি যা টাইপ করেন, আইটেম সম্পর্কিত সাজেশন পেতে Chromium সেটি Google Drive-এ পাঠাবে। এটি 'ছদ্মবেশী' মোডে বন্ধ করা আছে।</translation>
