<translation id="2173571365716863400">‏Ecosia برای این سایت به اجازه میکروفون نیاز دارد</translation>
<translation id="6712881677154121168">خطای بارگیری: <ph name="DOWNLOAD_ERROR"/>.</translation>
<translation id="6161025257729272170">‏سرعت Ecosia را افزایش دهید</translation>
<translation id="9165312115453649251">‏سیستم EcosiaOS Flex</translation>
<translation id="8685318202174822382">‏در نمایه جدیدی از Ecosia ادامه می‌دهید؟</translation>
<translation id="6750954913813541382">‏Chrome برای رفع غلط‌های املایی، نوشتاری را که در مرورگر تایپ می‌کنید به Google ارسال می‌کند</translation>
<translation id="88039520238670574">‏درهرصورت از Ecosia خارج می‌شوید؟</translation>
<translation id="6794858689789885890">‏داده‌های سایت همواره بعداز بستن Chrome از دستگاه حذف شود</translation>
<translation id="8583650869792032882">‏قانون ترافیک ورودی برای Ecosia Canary به منظور اجازه به ترافیک mDNS .</translation>
<translation id="6007450464504026705">‏‫Ecosia با ویژگی‌هایی مثل «بهینه‌سازی انرژی» و «بهینه‌سازی حافظه»، برای داشتن بهترین عملکرد ساخته شده است</translation>
<translation id="684888714667046800">نمی‌توان به اینترنت متصل شد. اگر از دیوار آتش استفاده می‌کنید، لطفاً مطمئن شوید <ph name="PRODUCT_EXE_NAME"/> در فهرست مجازها باشد.</translation>
<translation id="588828970866589779">‏روشن کردن محافظت بیشتر در موتور WebAssembly و جاوا اسکریپت Ecosia</translation>
<translation id="6881299373831449287">‏درحال به‌روزرسانی Chrome</translation>
<translation id="6800892712521842441">‏برنامه‌های Ecosia نسخه بتا</translation>
<translation id="4371259280767924562">‏برداشتن حساب از Ecosia</translation>
<translation id="5267683457871579197">‏سیستم EcosiaOS</translation>
<translation id="8963533629322868062">‏برای دریافت به‌روزرسانی‌های آتی Ecosia، باید Windows 10 یا بالاتر داشته باشید. این رایانه از Windows 8.1 استفاده می‌کند.</translation>
<translation id="2128110540135015661">‏داده‌های محصول مرور این فرد از این دستگاه حذف می‌شود. برای بازیابی داده‌ها، با نام <ph name="USER_EMAIL"/> به سیستم Ecosia وارد شوید.</translation>
<translation id="2434044214904689670">‏قانون ترافیک ورودی Ecosia نسخه بتا برای امکان دادن به ترافیک mDNS.</translation>
<translation id="6583697665130212310">‏ببینید چرا Ecosia برخی‌از فایل‌ها را مسدود می‌کند، در برگه جدید باز می‌شود</translation>
<translation id="7011190694940573312">نصب انجام نشد زیرا این نسخه از سیستم‌عامل پشتیبانی نمی‌شود.</translation>
<translation id="7024536598735240744">خطای لغو فشرده‌سازی: <ph name="UNPACK_ERROR"/>.</translation>
<translation id="7025789849649390912">نصب متوقف شد.</translation>
<translation id="4032832945953542360">‏می‌توانید در اینجا بین نمایه‌های Ecosia جابه‌جا شوید</translation>
<translation id="931416298178634530">‏اگر می‌خواهید فقط یک‌بار از این حساب استفاده کنید، می‌توانید از <ph name="GUEST_LINK_BEGIN"/>حالت مهمان<ph name="GUEST_LINK_END"/> در مرورگر Ecosia استفاده کنید. اگر می‌خواهید برای شخص دیگری حساب اضافه کنید، به <ph name="DEVICE_TYPE"/> خود <ph name="LINK_BEGIN"/>شخص جدیدی اضافه کنید<ph name="LINK_END"/>.

اجازه‌هایی که قبلاً به وب‌سایت‌ها و برنامه‌ها داده‌اید ممکن است در این حساب اعمال شود. می‌توانید «حساب‌های Ecosia» خود را در بخش <ph name="SETTINGS_LINK_BEGIN"/>تنظیمات<ph name="SETTINGS_LINK_END"/> مدیریت کنید.</translation>
<translation id="7048502283602470098">کاوش هوش مصنوعی</translation>
<translation id="762525592078244189">‏Ecosia را برای خودتان اختصاصی کنید</translation>
<translation id="2379593823746842972">‏Ecosia به‌زودی داده‌های مرور را حذف می‌کند</translation>
<translation id="7085332316435785646">‏انتخاب کنید که آیا سابقه Chrome برای تجربه‌های شخصی‌شده‌تر در سرویس‌های Google لحاظ شود یا نه</translation>
<translation id="7088681679121566888">‏Chrome به‌روز است</translation>
<translation id="1318059253725731825">‏Ecosia درحال استفاده از میکروفون شما است.</translation>
<translation id="8933665254023068908">‏راه‌اندازی مجدد برای به‌روزرسانی EcosiaOS</translation>
<translation id="2394629668475473296">‏برای هم‌رسانی صفحه‌نمایش، «ضبط‌کن صفحه‌نمایش ویژه Ecosia» را در «اولویت‌های سیستم» مجاز کنید</translation>
<translation id="7311066525704006840">‏مدیر وظایف - Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد.}=1{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد. پنجره ناشناس بازگشایی نمی‌شود.}one{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد. # پنجره ناشناس بازگشایی نمی‌شود.}other{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد. # پنجره ناشناس بازگشایی نمی‌شود.}}</translation>
<translation id="7155997830309522122">‏در این صورت، لطفاً گذرواژه ذخیره‌شده در Chrome را ویرایش کنید تا با گذرواژه جدیدتان مطابقت داشته باشد.</translation>
<translation id="1027331268335328576">‏به Ecosia خوش آمدید</translation>
<translation id="675365189802108507">‏در تنظیمات Ecosia می‌توانید اطلاعات بیشتری درباره این ویژگی‌ها کسب کنید.</translation>
<translation id="5994043198751001258">‏اگر <ph name="TIMEOUT_DURATION"/> از Ecosia استفاده نشود، سازمانتان آن را می‌بندد.</translation>
<translation id="4239392394637574967">‏شما با حساب مدیریت‌شده وارد سیستم می‌شوید و به سرپرست آن اجازه کنترل بر نمایه Ecosia خود را می‌دهید. داده‌های Ecosia شما شامل برنامه‌ها، نشانک‌ها، سابقه، گذرواژه‌ها و سایر تنظیمات برای همیشه به <ph name="USER_NAME"/> مرتبط خواهد شد. می‌توانید این داده‌ها را از طریق داشبورد حساب‌های Ecosia حذف کنید اما نمی‌توانید این داده‌ها را به حساب دیگری مرتبط سازید. در صورت تمایل برای ذخیره داده‌های Ecosia موجود به صورت جداگانه می‌توانید نمایه جدیدی ایجاد کنید. <ph name="LEARN_MORE"/></translation>
<translation id="6994161374830839635">‏‫<ph name="MANAGER"/> ‏Ecosia را مدیریت می‌کند</translation>
<translation id="7295052994004373688">‏از این زبان برای نمایش واسط کاربر Google Chrome استفاده می‌شود</translation>
<translation id="7296210096911315575">اطلاعات مهم درباره استفاده و ایمنی</translation>
<translation id="7898621536417126731">‏برخی‌از داده‌های Ecosia هنوز در «حساب Ecosia» شما ذخیره نشده است. پیش‌از خروج از سیستم، چند دقیقه صبر کنید. اگر اکنون از سیستم خارج شوید، این داده‌ها حذف خواهد شد.</translation>
<translation id="5549921590305750618">‏Ecosia برای بارگیری فایل‌ها باید به حافظه دسترسی داشته باشد</translation>
<translation id="7339898014177206373">پنجرهٔ جدید</translation>
<translation id="680371069849762427">‏«مرور ایمن پیشرفته» قدرتمندترین محافظت آنلاین Ecosia را برای حفظ ایمنی شما هنگام مرور کردن ارائه می‌دهد</translation>
<translation id="7394745511930161845">مضمون خودتان را با هوش مصنوعی ایجاد کنید تا ظاهری منحصربه‌فرد به مرورگرتان بدهید</translation>
<translation id="2412381038247037703">‏شما بعنوان <ph name="USER_EMAIL_ADDRESS"/> وارد سیستم Ecosia شدید. لطفاً برای ورود به سیستم مجدد از همان حساب استفاده کنید.</translation>
<translation id="1224748120031661633">‏روی منوی Ecosia کلیک کنید</translation>
<translation id="7655708678113012665">{NUM_DEVICES,plural, =0{‏یک یا چند افزونه Ecosia به یک دستگاه USB دسترسی داشتند}=1{‏یک یا چند افزونه Ecosia به یک دستگاه USB دسترسی دارند}one{‏یک یا چند افزونه Ecosia به # دستگاه USB دسترسی دارند}other{‏یک یا چند افزونه Ecosia به # دستگاه USB دسترسی دارند}}</translation>
<translation id="3307959934543585795">‏Ecosia ممکن است درست کار نکند زیرا این توزیع Linux دیگر از آن پشتیبانی نمی‌کند.</translation>
<translation id="2421263730139898714">‏خروج از سیستم Ecosia</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{‏اگر به‌مدت یک دقیقه از Ecosia استفاده نشود، سازمانتان آن را به‌طور خودکار می‌بندد.}one{‏اگر به‌مدت # دقیقه از Ecosia استفاده نشود، سازمانتان آن را به‌طور خودکار می‌بندد.}other{‏اگر به‌مدت # دقیقه از Ecosia استفاده نشود، سازمانتان آن را به‌طور خودکار می‌بندد.}}</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{‏اگر به‌مدت یک دقیقه از Ecosia استفاده نشود، سازمانتان داده‌های مرور را به‌طور خودکار حذف می‌کند. این داده‌ها می‌تواند شامل سابقه، تکمیل خودکار، و بارگیری‌ها شود. برگه‌هایتان باز خواهد ماند.}one{‏اگر به‌مدت # دقیقه از Ecosia استفاده نشود، سازمانتان داده‌های مرور را به‌طور خودکار حذف می‌کند. این داده‌ها می‌تواند شامل سابقه، تکمیل خودکار، و بارگیری‌ها شود. برگه‌هایتان باز خواهد ماند.}other{‏اگر به‌مدت # دقیقه از Ecosia استفاده نشود، سازمانتان داده‌های مرور را به‌طور خودکار حذف می‌کند. این داده‌ها می‌تواند شامل سابقه، تکمیل خودکار، و بارگیری‌ها شود. برگه‌هایتان باز خواهد ماند.}}</translation>
<translation id="7477130805345743099">‏Chrome قبل‌از اینکه هر سایتی را ازطریق اتصال ناامن بار کند به شما هشدار می‌دهد</translation>
<translation id="12795904718916112">‏دریافت قوی‌ترین امنیت Ecosia</translation>
<translation id="4427878468534147875">‏اکنون که به سیستم وارد شده‌اید، می‌توانید از گذرواژه‌ها و موارد دیگر «حساب Ecosia» خود در Ecosia استفاده کنید. ‫<ph name="SHORTCUT"/> می‌تواند تنظیمات سرویس‌های Ecosia را تغییر دهد.</translation>
<translation id="932641430818191661">‏Ecosia نسخه Dev</translation>
<translation id="7877883466657693294">‏خاموش • Ecosia نمی‌تواند منبع این افزونه را تأیید کند</translation>
<translation id="7583399374488819119">نصب‌کننده <ph name="COMPANY_NAME"/></translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="1027331268335328576">‏به Ecosia خوش آمدید</translation>
<translation id="8411844745163855310">‏<ph name="MANAGER"/> لازم می‌داند که شما «شرایط خدمات» زیر را قبل‌از استفاده از دستگاه بخوانید و بپذیرید. این شرایط بسط داده نمی‌شود، اصلاح نمی‌شود، یا «شرایط EcosiaOS» را محدود نمی‌کند.</translation>
<translation id="1263466865695943046">‏Ecosia می‌تواند، اگر گذرواژه‌هایتان در معرض خطر باشد، مطلعتان کند</translation>
<translation id="7158975242722498086">‏سرپرست سیستم برای باز شدن <ph name="ALTERNATIVE_BROWSER_NAME"/> جهت دسترسی به <ph name="TARGET_URL_HOSTNAME"/>، Ecosia را پیکربندی کرده است.</translation>
<translation id="7649070708921625228">راهنما</translation>
<translation id="93440396576488794">‏نشان‌واره Ecosia Enterprise</translation>
<translation id="361644486359722423">‏‫Ecosia این بارگیری را مسدود کرد زیرا «مرور ایمن» خاموش است و نمی‌توان فایل را تأیید کرد</translation>
<translation id="7655455401911432608">‏سابقه مرور شما، سابقه سایت‌هایی که بااستفاده از Chrome در این دستگاه از آن‌ها بازدید کرده‌اید.</translation>
<translation id="8196791276481156937">‏حذف حساب از Ecosia</translation>
<translation id="7661924425853052955">‏اخیراً بازدیدی نداشته‌اید. ‫Chrome ‏<ph name="PERMISSION_1"/>،‏ <ph name="PERMISSION_2"/>،‏ و <ph name="COUNT"/> مورد دیگر را برداشت</translation>
<translation id="7668816516367091728">کارهایی مثل ترجمه، محاسبه، و غیره را مستقیماً از نوار نشانی انجام دهید</translation>
<translation id="3376578942612115781">‏حساب Ecosia به اصالت‌سنجی مجدد نیاز دارد</translation>
<translation id="769538538642757151">‏اگر موردی نیاز به بررسی داشته باشد، Chrome به شما اطلاع می‌دهد</translation>
<translation id="7747138024166251722">نصب‌کننده نتوانست دایرکتوری موقت ایجاد کند. لطفاً فضای خالی دیسک و اجازه نصب نرم‌افزار را بررسی کنید.</translation>
<translation id="4871843754042758264">‏برای باز کردن Ecosia و شروع به مرور، روی نامتان کلیک کنید.</translation>
<translation id="7763983146198734674">گذرواژه‌هایتان را ذخیره کنید و درحین حرکت به آن‌ها دسترسی داشته باشید</translation>
<translation id="2046160555506209000">‏اگر تصویری توضیح مفیدی نداشته باشد، Ecosia توضیحی برای شما ارائه خواهد کرد. برای ایجاد توضیحات، تصاویر به Ecosia ارسال می‌شود. هروقت خواستید می‌توانید این گزینه را در تنظیمات خاموش کنید.</translation>
<translation id="5661123757512626239">‏Ecosia برای این سایت به اجازه مکان نیاز دارد</translation>
<translation id="5288148671319098666">‏‫Ecosia به‌گونه‌ای طراحی شده است تا در همه دستگاه‌هایتان (از تلفن تا رایانه) سریع و ایمن باشد.</translation>
<translation id="7722016758804384514">‏ظاهراً نمایه توسط فرآیند Ecosia دیگری (<ph name="PROCESS_ID"/>) در رایانه‌ای دیگر (<ph name="HOST_NAME"/>) در حال استفاده است. Ecosia نمایه را قفل کرده است تا خراب نشود. اگر مطمئنید فرآیندهای دیگری از این نمایه استفاده نمی‌کنند، می‌توانید قفل نمایه را باز کنید و Ecosia را مجدداً راه‌اندازی نمایید.</translation>
<translation id="1047556320128249268">‏Ecosia می‌خواهد گذرواژه‌ها را کپی کند. برای اینکه اجازه دهید این کار انجام شود، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="4685983030787735093">‏‫Ecosia جدیدترین فناوری را برای مرور بهتر دراختیارتان قرار می‌دهد</translation>
<translation id="4199684616787081033">‏حذف از Ecosia...</translation>
<translation id="2402290209407843024">‏بدلیل خطای نامشخص، نصب ناموفق بود. لطفاً دوباره Ecosia را بارگیری کنید.</translation>
<translation id="7836610565365456468">ظاهر مرورگرتان را با زمینه‌های زنده‌ای که از هنرمندان، طبیعت، و موارد دیگر الهام گرفته‌اند تغییر دهید</translation>
<translation id="7845233973568007926">بابت نصب از شما سپاس‌گزاریم. قبل‌از استفاده از <ph name="BUNDLE_NAME"/>، باید رایانه را بازراه‌اندازی کنید.</translation>
<translation id="937989526647879266">‏هوش مصنوعی در Ecosia به افزایش سرعت، ایمنی، و دسترس‌پذیری وب کمک می‌کند</translation>
<translation id="7872446069773932638">درحال بارگیری… <ph name="SECONDS"/> ثانیه باقی مانده است</translation>
<translation id="2381210243314074423">‏به Ecosia خوش آمدید، <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">‏اگر رایانه‌ای را به صورت مشترک استفاده می‌کنید، دوستان و خانواده می‌توانند به صورت جداگانه مرور کنند و Ecosia را به صورتی که مایلند تنظیم کنند.</translation>
<translation id="4727435569202742773">‏شخصی قبلاً به‌عنوان <ph name="ACCOUNT_EMAIL_LAST"/> به سیستم Ecosia در این رایانه وارد شده است. برای اینکه اطلاعاتتان جدا حفظ شود، لطفاً کاربر Ecosia جدیدی ایجاد کنید.</translation>
<translation id="7917876797003313048">‏می‌توانید «حساب‌های Google» خودتان را که به سیستم آن‌ها وارد شده‌اید مدیریت کنید. از «حساب‌های Google» شما در مرورگر Chrome، «فروشگاه Play»، ‏Gmail، و محصولات دیگر استفاده می‌شود. اگر می‌خواهید حساب فرد دیگری را اضافه کنید (مثلاً یکی از اعضای خانواده)، به‌جای این کار، شخص جدیدی را به <ph name="DEVICE_TYPE"/> خود اضافه کنید. <ph name="LINK_BEGIN"/>بیشتر بدانید<ph name="LINK_END"/></translation>
<translation id="7112125772061727648">‏‫Ecosia این بارگیری را مسدود کرد زیرا این فایل فریب‌دهنده است و ممکن است تغییرات غیرمنتظره‌ای در دستگاهتان ایجاد کند</translation>
<translation id="7947083960301164556">مشاهده ویژگی‌های جدید</translation>
<translation id="4278262067490419012">‏برای اعمال به‌روزرسانی، EcosiaOS Flex باید بازراه‌اندازی شود.</translation>
<translation id="3140530394740845618">‏مدیریت نمایه‌های Ecosia</translation>
<translation id="7962368738413920945">‏سایت‌ها احتمالاً عملکردی مطابق انتظار شما خواهند داشت اما بعداز بسته شدن همه پنجره‌های Chrome، شما را به‌یاد نخواهند داشت</translation>
<translation id="5781596646235827063">‏این رایانه دیگر به‌روزرسانی‌های Ecosia را دریافت نمی‌کند زیرا Windows XP و Windows Vista دیگر پشتیبانی نمی‌شوند</translation>
<translation id="7783708361278795460">‏به «مدیر گذرواژه Ecosia» در این دستگاه</translation>
<translation id="6984747211123632080">‏نصب مجدد Ecosia</translation>
<translation id="7787479292144635608">‏استفاده از Ecosia بدون حساب</translation>
<translation id="2838372953389311551">‏اگر تصویری توضیح مفیدی نداشته باشد، Ecosia توضیحی برای شما ارائه خواهد کرد. برای ایجاد توضیحات، تصاویر به Ecosia ارسال می‌شود.</translation>
<translation id="8863497461138396324">‏این افزونه توسط توسعه‌دهنده آن لغو انتشار شده است و ممکن است ناامن باشد. آن را از Ecosia حذف کنید تا دیگر نتواند داده‌های شما (ازجمله اطلاعات شخصی) را در سایت‌هایی که بازدید می‌کنید ببیند و تغییر دهد.</translation>
<translation id="4882579364090762302">‏یکی از افزونه‌ها از شما می‌خواهد به سیستم Ecosia وارد شوید</translation>
<translation id="80471789339884597">بابت نصب از شما سپاس‌گزاریم. قبل‌از استفاده از <ph name="BUNDLE_NAME"/>، باید همه مرورگرها را بازراه‌اندازی کنید.</translation>
<translation id="8347473600923066837">‏می‌توانید نشانک‌ها، حالت مطالعه، و موارد دیگر را از منوِ Ecosia در بالا سمت چپ باز کنید</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="5251710252516682805">‏دیگر نمایه‌های Ecosia</translation>
<translation id="8086881907087796310">نصب انجام نشد زیرا رایانه شما با حداقل شرایط سخت‌افزاری مطابقت ندارد.</translation>
<translation id="2200308425865645682">‏قبل‌از اینکه بتوان برخی‌از داده‌ها را در «حساب Ecosia» شما ذخیره کرد و در همه دستگاه‌هایتان استفاده کرد، Ecosia باید هویت شما را تأیید کند. اگر از سیستم خارج شوید، این داده‌ها در این دستگاه باقی خواهد ماند.</translation>
<translation id="7221868538334633215">‏درباره &amp;Ecosia</translation>
<translation id="813913629614996137">درحال مقداردهی اولیه…</translation>
<translation id="5612740201368556834">‏استفاده از Ecosia بدون حساب</translation>
<translation id="4061472199368124600">‏Ecosia درحال استفاده از دوربین و میکروفون شما است.</translation>
<translation id="8296229475165428335">‏می‌توانید نشانک‌ها، حالت مطالعه، و موارد دیگر را از منوِ Ecosia باز کنید</translation>
<translation id="8267953129876836456">‏Chrome چند توصیه ایمنی برای بررسی پیدا کرد</translation>
<translation id="8270775718612349140">‏گواهینامه‌های تحت‌مدیریت Chrome</translation>
<translation id="3966234175958887595">‏Ecosia در حال تلاش برای نشان دادن گذرواژه‌هاست. برای اجازه به این کار، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="3216284932113164802">‏اوه! Ecosia با اشکال مواجه شده است. دوباره راه‌اندازی شود؟</translation>
<translation id="9943971783680417">‏میان‌بری به «مدیر گذرواژه Ecosia» اضافه کنید</translation>
<translation id="8336463659890584292">‏وقتی سایتی برای پیش‌بارگیری خصوصی پیوندها در صفحه خود درخواست می‌کند، Chrome از سرورهای Google استفاده می‌کند. با این کار هویتتان از سایت پیش‌بارگیری‌شده پنهان می‌شود، اما Google متوجه می‌شود که چه سایت‌هایی پیش‌بارگیری شده‌اند.</translation>
<translation id="6491651957026506753">‏این فایل خطرناک است، بنابراین Ecosia آن را مسدود کرده است.</translation>
<translation id="1851101453239911251">‏<ph name="BEGIN_BOLD"/>نحوه استفاده ما از این داده‌ها:<ph name="END_BOLD"/> سایت‌ها می‌توانند بااستفاده از Ecosia اطلاعاتی درباره علایقتان ذخیره کنند. برای مثال، اگر برای خرید کفش مخصوص ماراتون از سایتی بازدید کنید، ممکن است آن سایت علاقه شما را به‌صورت دونده ماراتون مشخص کند. بعداً، اگر برای ثبت‌نام در مسابقه‌ای به سایتی دیگر مراجعه کردید، آن سایت می‌تواند براساس علایقتان آگهی‌ای برای کفش مخصوص دویدن به شما نشان دهد.</translation>
<translation id="8355171755788522183">‏حق نشر <ph name="YEAR"/> Ecosia.‎ کلیه حقوق محفوظ است.</translation>
<translation id="5610400309434105339">‏<ph name="BEGIN_BOLD"/>نحوه استفاده ما از این داده‌ها:<ph name="END_BOLD"/> Ecosia می‌تواند علایق شما را برآورد کند. بعداً، سایتی که از آن بازدید می‌کنید می‌تواند برای شخصی کردن آگهی‌هایی که به شما نشان می‌دهد از Ecosia بخواهد علایق شما را ببیند.</translation>
<translation id="5883025779824839861">‏ادامه استفاده از Ecosia</translation>
<translation id="8394720698884623075">‏نشانی‌های وب را با فهرست سایت‌های ناامنی که در Chrome ذخیره شده است مقایسه می‌کند</translation>
<translation id="7578952608547569314">‏نشان‌واره Ecosia درون صفحه‌نمایش رایانه.</translation>
<translation id="5902103164685487225">‏درباره شخصی‌سازی آگهی در Ecosia بیشتر بدانید</translation>
<translation id="592990842052138727">‏EcosiaOS نتوانست داده‌هایتان را همگام‌سازی کند، چون جزئیات ورود به حساب شما به‌روز نیست.</translation>
<translation id="842386925677997438">‏ابزارهای ایمنی Chrome</translation>
<translation id="8428213095426709021">تنظیمات</translation>
<translation id="665177868576952817">‏برای ارسال شماره از اینجا به تلفن Android خود، در هر دو دستگاه به سیستم Ecosia وارد شوید.</translation>
<translation id="4070480171055648632">‏<ph name="MANAGER_NAME"/> حساب شما را مدیریت می‌کند. سرپرست شما می‌تواند این نمایه مرورگر Ecosia و داده‌های آن را (مانند نشانک‌ها، سابقه، و گذرواژه‌ها) ببیند و ویرایش کند.</translation>
<translation id="6910262464589177435">‏مدیر گذرواژه Ecosia</translation>
<translation id="1025044809499013222">‏لحظاتی پیش به‌روزرسانی امنیتی ویژه‌ای برای Ecosia اعمال شد. هم‌اکنون بازراه‌اندازی کنید و ما برگه‌هایتان را بازیابی خواهیم کرد.</translation>
<translation id="3816260943154642689">‏علایق شما به‌طوری‌که Ecosia برآورد کرده است</translation>
<translation id="8023973672752791660">‏قانون ترافیک ورودی Ecosia نسخه Dev برای امکان دادن به ترافیک mDNS.</translation>
<translation id="8550334526674375523">این نمایه کاری کاملاً مجزا از نمایه شخصی‌تان است.</translation>
<translation id="8555465886620020932">خطای سرویس: <ph name="SERVICE_ERROR"/>.</translation>
<translation id="5622136942112821750">‏با نمایه‌های Ecosia می‌توانید همه‌چیزتان را در Ecosia جدا کنید. با این کار، راحت‌تر می‌توان کار و سرگرمی را ازهم جدا کرد.</translation>
<translation id="18064594488616674">‏Ecosia پاسخ نمی‌دهد. مجدداً راه‌اندازی شود؟</translation>
<translation id="6896860023874996542">‏Ecosia برای دسترسی به دوربین به اجازه نیاز دارد تا بتواند نقشه سه‌بعدی محیط شما را ایجاد کند</translation>
<translation id="7558678848273505235">{0,plural, =1{‏Ecosia ‏۱ دقیقه دیگر راه‌اندازی مجدد می‌شود}one{‏Ecosia ‏# دقیقه دیگر راه‌اندازی مجدد می‌شود}other{‏Ecosia ‏# دقیقه دیگر راه‌اندازی مجدد می‌شود}}</translation>
<translation id="8641606876632989680">‏وقتی با گذرواژه‌ای لورفته به سیستم وارد شوید، Chrome به شما اطلاع می‌دهد</translation>
<translation id="8649026945479135076">‏امری عادی است که سایت‌هایی که بازدید می‌کنید برای شخصی کردن تجربه‌تان، علایق شما را به‌خاطر آورند. به‌علاوه، سایت‌ها می‌توانند بااستفاده از Chrome اطلاعاتی درباره علایقتان ذخیره کنند.</translation>
<translation id="9090890391337853620">‏راهنمای Ecosia</translation>
<translation id="524314285625975879">‏این برنامه همچنین صفحه‌ای را که هنگام راه‌اندازی Ecosia نشان داده می‌شود، کنترل می‌کند.</translation>
<translation id="4170280082681554565">‏با نمایه‌های Ecosia می‌توانید همه چیزتان را در Ecosia جدا کنید. برای دوستان و اعضای خانواده‌تان نمایه ایجاد کنید، یا کار و سرگرمی را ازهم جدا کنید.</translation>
<translation id="8712767363896337380">‏تقریباً به‌روزرسانی شده است! برای تکمیل به‌روزرسانی، Chrome را راه‌اندازی مجدد کنید.</translation>
<translation id="2672632089507560181">‏ثبت خروج از Ecosia</translation>
<translation id="873133009373065397">‏Google Chrome نمی‌تواند مرورگر پیش‌فرض را تعیین یا تنظیم کند</translation>
<translation id="8765470054473112089">‏وقتی در نوار نشانی یا چارگوش جستجو تایپ می‌کنید، Chrome آنچه تایپ می‌کنید را به موتور جستجوی پیش‌فرض شما ارسال می‌کند تا پیشنهادهای بهتری دریافت کند. این ویژگی در «حالت ناشناس» خاموش است.</translation>
<translation id="8781673607513845160">‏برای استفاده از دوربین، در <ph name="BEGIN_LINK"/>تنظیمات سیستم<ph name="END_LINK"/> به Chrome دسترسی دهید</translation>
<translation id="878572486461146056">خطای نصب: سرپرست شبکه شما «خط‌مشی گروهی» اعمال کرده است که از نصب جلوگیری می‌کند: <ph name="INSTALL_ERROR"/></translation>
<translation id="6632508343667825745">‏‫Ecosia این بارگیری را مسدود کرد زیرا این فایل می‌تواند به حساب‌های شخصی و شبکه‌های اجتماعی شما ازجمله <ph name="USER_EMAIL"/> آسیب برساند</translation>
<translation id="8797423385604279835">برگه‌هایتان را با کمک هوش مصنوعی سازمان‌دهی کنید</translation>
<translation id="905744008702074577">‏V8 موتور WebAssembly و جاوا اسکریپت Ecosia است که از آن برای بهبود عملکرد سایت استفاده می‌شود</translation>
<translation id="1975037445584526511">‏برای دریافت به‌روزرسانی‌های آتی Ecosia، باید Windows 10 یا بالاتر داشته باشید. این رایانه از Windows 7 استفاده می‌کند.</translation>
<translation id="2695952268686253864">‏نسخه Ecosia قدیمی است</translation>
<translation id="8825634023950448068">‏برای محافظت از حریم خصوصی شما، علایقی را که قدیمی‌تر از ۴ هفته باشند به‌طور خودکار حذف می‌کنیم. وقتی به مرور کردن ادامه می‌دهید، ممکن است علاقه‌ای مجدداً به فهرست اضافه شود. و اگر Chrome به‌اشتباه علاقه‌ای را اضافه کند یا شما نخواهید آگهی‌های مشخصی را ببینید، می‌توانید آن علاقه را بردارید.</translation>
<translation id="5066194399237265772">‏Ecosia می‌خواهد گذرواژه‌ها را ویرایش کند. برای اینکه اجازه دهید این کار انجام شود، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="1152277553870553858">‏‫Ecosia به‌طور مرتب ویژگی‌های جدیدی برای کمک به شما در انجام کارها اضافه می‌کند</translation>
<translation id="4534680278117737254">{NUM_EXTENSIONS,plural, =1{‏Ecosia توصیه می‌کند آن را بردارید}one{‏Ecosia توصیه می‌کند آن را بردارید}other{‏Ecosia توصیه می‌کند آن‌ها را بردارید}}</translation>
<translation id="8862326446509486874">شما حقوق لازم برای نصب در سطح سیستم را ندارید. دوباره به‌عنوان سرپرست نصب‌کننده را اجرا کنید.</translation>
<translation id="8908277254462331033">مشاهده ویژگی‌های ایمنی</translation>
<translation id="8282620071565190081">‏راه‌اندازی مجدد Ecosia</translation>
<translation id="7849498640944199147">‏برای ارسال شماره از <ph name="ORIGIN"/> به تلفن Android خود، در هر دو دستگاه به سیستم Ecosia وارد شوید.</translation>
<translation id="576192547306902465">‏این افزونه روش‌های اعمال حریم خصوصی، مثل نحوه جمع‌آوری و استفاده از داده‌ها را منتشر نکرده است. ‫Ecosia توصیه می‌کند آن را حذف کنید.</translation>
<translation id="8986207147630327271">با این کار، نمایه کاری را به این مرورگر اضافه می‌کنید و فقط کنترل نمایه کاری را دراختیار سرپرست قرار می‌دهید.</translation>
<translation id="8989968390305463310">‏سابقه مرور شما بر آگهی‌هایی که می‌بینید و علایقتان که در زیر برآورد شده است تأثیر می‌گذارد. برای محافظت از حریم خصوصی شما، Chrome علایقتان را هر ماه به‌طور خودکار و چرخشی حذف می‌کند. ممکن است علایق بازآوری شود، مگر اینکه آن‌ها را بردارید.</translation>
<translation id="8999117580775242387">‏وقتی HTTPS دردسترس نباشد، Chrome بدون دادن هشدار به شما از اتصال ناامن استفاده می‌کند</translation>
<translation id="7348818664647668234">{0,plural, =0{‏به‌روزرسانی Ecosia دردسترس است}=1{‏به‌روزرسانی Ecosia دردسترس است}one{‏به‌روزرسانی Ecosia از # روز پیش دردسترس است}other{‏به‌روزرسانی Ecosia از # روز پیش دردسترس است}}</translation>
<translation id="4817309082638621362">‏چندین سازمان Ecosia را مدیریت می‌کنند</translation>
<translation id="4638085384909702681">‏تنظیم Ecosia به‌عنوان مرورگر پیش‌فرض</translation>
<translation id="9047384314208087523">‏سیستم EcosiaOS Flex</translation>
<translation id="350189837353493413">‏ببینید چرا Ecosia برخی‌از فایل‌ها را مسدود می‌کند</translation>
<translation id="911206726377975832">داده‌های مرور شما نیز حذف شود؟</translation>
<translation id="9138603949443464873">‏برای اعمال تغییراتتان، Chrome را راه‌اندازی مجدد کنید</translation>
<translation id="9195993889682885387">‏Chrome می‌توانند علایقتان را براساس سابقه مرور چند هفته گذشته برآورد کند. این اطلاعات از دستگاهتان خارج نمی‌شود.</translation>
<translation id="5704599732514791330">‏به‌روزرسانی Ecosia برای شروع همگام‌سازی</translation>
<translation id="838842459108103907">‏سفارشی‌سازی Ecosia</translation>
<translation id="92460355979482493">‏وقتی روشن باشد، Chrome صفحه‌ها را پیش‌بارگیری می‌کند تا مرور و جستجو سریع‌تر شود.</translation>
<translation id="3070276123152913305">‏بازراه‌اندازی EcosiaOS Flex</translation>
<translation id="4512092435423703529">‏برای دسترسی به چیزهای Ecosia در همه دستگاه‌هایتان، به سیستم وارد شوید، سپس همگام‌سازی را روشن کنید.</translation>
<translation id="7972668220031382654">‏Ecosia توصیه می‌کند این فایل را اسکن کنید زیرا ممکن است خطرناک باشد.</translation>
<translation id="963650557422347554">‏وقتی روشن باشد، Chrome با محدود کردن فعالیت پس‌زمینه و جلوه‌های بصری، مثل پیمایش روان و نرخ فریم ویدیو، در مصرف باتری صرفه‌جویی می‌کند.</translation>
<translation id="983803489796659991">نصب انجام نشد چون سرور به‌روزرسانی هیچ‌گونه داده درهمی برای برنامه ندارد.</translation>
