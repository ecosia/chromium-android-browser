<translation id="6273793429163604305">سر جای خود…</translation>
<translation id="675229436434399924">‏برنامه‌های Ecosia نسخه Dev</translation>
<translation id="4870057811531036437">‏Ecosia از قبل برای همه کاربران این رایانه نصب شده است.</translation>
<translation id="330264384086604869">‏حذف از Ecosia</translation>
<translation id="6327105987658262776">به‌روزرسانی دردسترس نیست.</translation>
<translation id="6412673304250309937">‏نشانی‌های وب را با فهرست سایت‌های ناامنی که در Chrome ذخیره شده است مقایسه می‌کند. اگر سایتی تلاش کند گذرواژه شما را به‌سرقت ببرد، یا وقتی فایل مخربی بارگیری می‌کنید، Chrome ممکن است نشانی‌های وب را نیز به همراه بخش‌های کوچکی از محتوای صفحه، به «مرور ایمن» ارسال کند.</translation>
<translation id="4781882243268600858">‏به نمایه Ecosia موجود می‌روید؟</translation>
<translation id="2537426042760364251">‏Ecosia برای ایجاد نقشه سه‌بعدی از محیط اطرافتان به اجازه دوربین نیاز دارد</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia Dev</translation>
<translation id="5357908757303442841">‏در «مدیر گذرواژه Ecosia» در این دستگاه</translation>
<translation id="8859253218356192164">‏ارائه EcosiaOS Flex به‌کمک <ph name="BEGIN_LINK_CROS_OSS"/>نرم‌افزارهای متن‌باز<ph name="END_LINK_CROS_OSS"/> تکمیلی ممکن شده است.</translation>
<translation id="6676384891291319759">دسترسی به اینترنت</translation>
<translation id="4586967042094107073">‏اجازه به Ecosia برای اجرا در پس‌زمینه</translation>
<translation id="2173571365716863400">‏Ecosia برای این سایت به اجازه میکروفون نیاز دارد</translation>
<translation id="6161025257729272170">‏سرعت Ecosia را افزایش دهید</translation>
<translation id="9165312115453649251">‏سیستم EcosiaOS Flex</translation>
<translation id="8685318202174822382">‏در نمایه جدیدی از Ecosia ادامه می‌دهید؟</translation>
<translation id="6750954913813541382">‏Chrome برای رفع غلط‌های املایی، نوشتاری را که در مرورگر تایپ می‌کنید به Google ارسال می‌کند</translation>
<translation id="88039520238670574">‏درهرصورت از Ecosia خارج می‌شوید؟</translation>
<translation id="8583650869792032882">‏قانون ترافیک ورودی برای Ecosia Canary به منظور اجازه به ترافیک mDNS .</translation>
<translation id="6881299373831449287">‏درحال به‌روزرسانی Chrome</translation>
<translation id="6800892712521842441">‏برنامه‌های Ecosia نسخه بتا</translation>
<translation id="5267683457871579197">‏سیستم EcosiaOS</translation>
<translation id="8963533629322868062">‏برای دریافت به‌روزرسانی‌های آتی Ecosia، باید Windows 10 یا بالاتر داشته باشید. این رایانه از Windows 8.1 استفاده می‌کند.</translation>
<translation id="2128110540135015661">‏داده‌های محصول مرور این فرد از این دستگاه حذف می‌شود. برای بازیابی داده‌ها، با نام <ph name="USER_EMAIL"/> به سیستم Ecosia وارد شوید.</translation>
<translation id="2434044214904689670">‏قانون ترافیک ورودی Ecosia نسخه بتا برای امکان دادن به ترافیک mDNS.</translation>
<translation id="7482156490649194631">‏Ecosia به روز شده است اما حداقل ۳۰ روز از آن استفاده نکرده‌اید.</translation>
<translation id="7025789849649390912">نصب متوقف شد.</translation>
<translation id="4032832945953542360">‏می‌توانید در اینجا بین نمایه‌های Ecosia جابه‌جا شوید</translation>
<translation id="931416298178634530">‏اگر می‌خواهید فقط یک‌بار از این حساب استفاده کنید، می‌توانید از <ph name="GUEST_LINK_BEGIN"/>حالت مهمان<ph name="GUEST_LINK_END"/> در مرورگر Ecosia استفاده کنید. اگر می‌خواهید برای شخص دیگری حساب اضافه کنید، به <ph name="DEVICE_TYPE"/> خود <ph name="LINK_BEGIN"/>شخص جدیدی اضافه کنید<ph name="LINK_END"/>.

اجازه‌هایی که قبلاً به وب‌سایت‌ها و برنامه‌ها داده‌اید ممکن است در این حساب اعمال شود. می‌توانید «حساب‌های Ecosia» خود را در بخش <ph name="SETTINGS_LINK_BEGIN"/>تنظیمات<ph name="SETTINGS_LINK_END"/> مدیریت کنید.</translation>
<translation id="4281355161119203663">‏ولی‌تان «اجازه‌های مربوط به سایت‌ها، برنامه‌ها، و افزونه‌ها» را برای Ecosia خاموش کرده است. افزودن این <ph name="EXTENSION_TYPE_PARAMETER"/> مجاز نیست.</translation>
<translation id="7085332316435785646">‏انتخاب کنید که آیا سابقه Chrome برای تجربه‌های شخصی‌شده‌تر در سرویس‌های Google لحاظ شود یا نه</translation>
<translation id="7088681679121566888">‏Chrome به‌روز است</translation>
<translation id="1318059253725731825">‏Ecosia درحال استفاده از میکروفون شما است.</translation>
<translation id="8933665254023068908">‏راه‌اندازی مجدد برای به‌روزرسانی EcosiaOS</translation>
<translation id="7311066525704006840">‏مدیر وظایف - Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد.}=1{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد. پنجره ناشناس بازگشایی نمی‌شود.}one{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد. # پنجره ناشناس بازگشایی نمی‌شود.}other{‏به‌روزرسانی جدیدی برای Ecosia در دسترس است و به‌محض راه‌اندازی مجدد اعمال خواهد شد. # پنجره ناشناس بازگشایی نمی‌شود.}}</translation>
<translation id="7155997830309522122">‏در این صورت، لطفاً گذرواژه ذخیره‌شده در Chrome را ویرایش کنید تا با گذرواژه جدیدتان مطابقت داشته باشد.</translation>
<translation id="1027331268335328576">‏به Ecosia خوش آمدید</translation>
<translation id="675365189802108507">‏در تنظیمات Ecosia می‌توانید اطلاعات بیشتری درباره این ویژگی‌ها کسب کنید.</translation>
<translation id="4239392394637574967">‏شما با حساب مدیریت‌شده وارد سیستم می‌شوید و به سرپرست آن اجازه کنترل بر نمایه Ecosia خود را می‌دهید. داده‌های Ecosia شما شامل برنامه‌ها، نشانک‌ها، سابقه، گذرواژه‌ها و سایر تنظیمات برای همیشه به <ph name="USER_NAME"/> مرتبط خواهد شد. می‌توانید این داده‌ها را از طریق داشبورد حساب‌های Ecosia حذف کنید اما نمی‌توانید این داده‌ها را به حساب دیگری مرتبط سازید. در صورت تمایل برای ذخیره داده‌های Ecosia موجود به صورت جداگانه می‌توانید نمایه جدیدی ایجاد کنید. <ph name="LEARN_MORE"/></translation>
<translation id="7295052994004373688">‏از این زبان برای نمایش واسط کاربر Google Chrome استفاده می‌شود</translation>
<translation id="7296210096911315575">اطلاعات مهم درباره استفاده و ایمنی</translation>
<translation id="5549921590305750618">‏Ecosia برای بارگیری فایل‌ها باید به حافظه دسترسی داشته باشد</translation>
<translation id="7339898014177206373">پنجرهٔ جدید</translation>
<translation id="5337919616446681032">‏اگر می‌خواهید فقط یک‌بار از این حساب استفاده کنید، می‌توانید از «حالت مهمان» در مرورگر Ecosia استفاده کنید. اگر می‌خواهید برای شخص دیگری حساب اضافه کنید، به <ph name="DEVICE_TYPE"/> خود <ph name="LINK_BEGIN"/>شخص جدیدی اضافه کنید<ph name="LINK_END"/>.

اجازه‌هایی که قبلاً به وب‌سایت‌ها و برنامه‌ها داده‌اید ممکن است در این حساب اعمال شود. می‌توانید «حساب‌های Ecosia» خود را در بخش <ph name="SETTINGS_LINK_BEGIN"/>تنظیمات<ph name="SETTINGS_LINK_END"/> مدیریت کنید.</translation>
<translation id="2412381038247037703">‏شما بعنوان <ph name="USER_EMAIL_ADDRESS"/> وارد سیستم Ecosia شدید. لطفاً برای ورود به سیستم مجدد از همان حساب استفاده کنید.</translation>
