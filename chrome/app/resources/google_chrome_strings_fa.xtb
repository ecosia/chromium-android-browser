<translation id="1027331268335328576">‏به Ecosia خوش آمدید</translation>
<translation id="8411844745163855310">‏<ph name="MANAGER"/> لازم می‌داند که شما «شرایط خدمات» زیر را قبل‌از استفاده از دستگاه بخوانید و بپذیرید. این شرایط بسط داده نمی‌شود، اصلاح نمی‌شود، یا «شرایط EcosiaOS» را محدود نمی‌کند.</translation>
<translation id="1263466865695943046">‏Ecosia می‌تواند، اگر گذرواژه‌هایتان در معرض خطر باشد، مطلعتان کند</translation>
<translation id="7158975242722498086">‏سرپرست سیستم برای باز شدن <ph name="ALTERNATIVE_BROWSER_NAME"/> جهت دسترسی به <ph name="TARGET_URL_HOSTNAME"/>، Ecosia را پیکربندی کرده است.</translation>
<translation id="7649070708921625228">راهنما</translation>
<translation id="93440396576488794">‏نشان‌واره Ecosia Enterprise</translation>
<translation id="7655455401911432608">‏سابقه مرور شما، سابقه سایت‌هایی که بااستفاده از Chrome در این دستگاه از آن‌ها بازدید کرده‌اید.</translation>
<translation id="7747138024166251722">نصب‌کننده نتوانست دایرکتوری موقت ایجاد کند. لطفاً فضای خالی دیسک و اجازه نصب نرم‌افزار را بررسی کنید.</translation>
<translation id="4871843754042758264">‏برای باز کردن Ecosia و شروع به مرور، روی نامتان کلیک کنید.</translation>
<translation id="2046160555506209000">‏اگر تصویری توضیح مفیدی نداشته باشد، Ecosia توضیحی برای شما ارائه خواهد کرد. برای ایجاد توضیحات، تصاویر به Ecosia ارسال می‌شود. هروقت خواستید می‌توانید این گزینه را در تنظیمات خاموش کنید.</translation>
<translation id="8447746441670667471">‏نسخه جدیدی از Ecosia موجود است.</translation>
<translation id="5661123757512626239">‏Ecosia برای این سایت به اجازه مکان نیاز دارد</translation>
<translation id="7722016758804384514">‏ظاهراً نمایه توسط فرآیند Ecosia دیگری (<ph name="PROCESS_ID"/>) در رایانه‌ای دیگر (<ph name="HOST_NAME"/>) در حال استفاده است. Ecosia نمایه را قفل کرده است تا خراب نشود. اگر مطمئنید فرآیندهای دیگری از این نمایه استفاده نمی‌کنند، می‌توانید قفل نمایه را باز کنید و Ecosia را مجدداً راه‌اندازی نمایید.</translation>
<translation id="1047556320128249268">‏Ecosia می‌خواهد گذرواژه‌ها را کپی کند. برای اینکه اجازه دهید این کار انجام شود، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="4199684616787081033">‏حذف از Ecosia...</translation>
<translation id="2402290209407843024">‏بدلیل خطای نامشخص، نصب ناموفق بود. لطفاً دوباره Ecosia را بارگیری کنید.</translation>
<translation id="7845233973568007926">بابت نصب از شما سپاس‌گزاریم. قبل‌از استفاده از <ph name="BUNDLE_NAME"/>، باید رایانه را بازراه‌اندازی کنید.</translation>
<translation id="7872446069773932638">درحال بارگیری… <ph name="SECONDS"/> ثانیه باقی مانده است</translation>
<translation id="2381210243314074423">‏به Ecosia خوش آمدید، <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">‏اگر رایانه‌ای را به صورت مشترک استفاده می‌کنید، دوستان و خانواده می‌توانند به صورت جداگانه مرور کنند و Ecosia را به صورتی که مایلند تنظیم کنند.</translation>
<translation id="4727435569202742773">‏شخصی قبلاً به‌عنوان <ph name="ACCOUNT_EMAIL_LAST"/> به سیستم Ecosia در این رایانه وارد شده است. برای اینکه اطلاعاتتان جدا حفظ شود، لطفاً کاربر Ecosia جدیدی ایجاد کنید.</translation>
<translation id="7917876797003313048">‏می‌توانید «حساب‌های Google» خودتان را که به سیستم آن‌ها وارد شده‌اید مدیریت کنید. از «حساب‌های Google» شما در مرورگر Chrome، «فروشگاه Play»، ‏Gmail، و محصولات دیگر استفاده می‌شود. اگر می‌خواهید حساب فرد دیگری را اضافه کنید (مثلاً یکی از اعضای خانواده)، به‌جای این کار، شخص جدیدی را به <ph name="DEVICE_TYPE"/> خود اضافه کنید. <ph name="LINK_BEGIN"/>بیشتر بدانید<ph name="LINK_END"/></translation>
<translation id="8633885040939757689">‏Ecosia می‌خواهد گذرواژه‌ها را کپی کند.</translation>
<translation id="4278262067490419012">‏برای اعمال به‌روزرسانی، EcosiaOS Flex باید بازراه‌اندازی شود.</translation>
<translation id="7962368738413920945">‏سایت‌ها احتمالاً عملکردی مطابق انتظار شما خواهند داشت اما بعداز بسته شدن همه پنجره‌های Chrome، شما را به‌یاد نخواهند داشت</translation>
<translation id="5781596646235827063">‏این رایانه دیگر به‌روزرسانی‌های Ecosia را دریافت نمی‌کند زیرا Windows XP و Windows Vista دیگر پشتیبانی نمی‌شوند</translation>
<translation id="7783708361278795460">‏به «مدیر گذرواژه Ecosia» در این دستگاه</translation>
<translation id="6984747211123632080">‏نصب مجدد Ecosia</translation>
<translation id="2838372953389311551">‏اگر تصویری توضیح مفیدی نداشته باشد، Ecosia توضیحی برای شما ارائه خواهد کرد. برای ایجاد توضیحات، تصاویر به Ecosia ارسال می‌شود.</translation>
<translation id="80471789339884597">بابت نصب از شما سپاس‌گزاریم. قبل‌از استفاده از <ph name="BUNDLE_NAME"/>، باید همه مرورگرها را بازراه‌اندازی کنید.</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="7221868538334633215">‏درباره &amp;Ecosia</translation>
<translation id="813913629614996137">درحال مقداردهی اولیه…</translation>
<translation id="4061472199368124600">‏Ecosia درحال استفاده از دوربین و میکروفون شما است.</translation>
<translation id="8270775718612349140">‏گواهینامه‌های تحت‌مدیریت Chrome</translation>
<translation id="3966234175958887595">‏Ecosia در حال تلاش برای نشان دادن گذرواژه‌هاست. برای اجازه به این کار، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="2290912123073552463">‏ولی‌تان «اجازه‌های مربوط به سایت‌ها، برنامه‌ها، و افزونه‌ها» را برای Ecosia خاموش کرده است. فعال کردن این <ph name="EXTENSION_TYPE_PARAMETER"/> مجاز نیست.</translation>
<translation id="3216284932113164802">‏اوه! Ecosia با اشکال مواجه شده است. دوباره راه‌اندازی شود؟</translation>
<translation id="8341646175450781745">‏وقتی روشن باشد، Chrome حافظه را از برگه‌های غیرفعال آزاد می‌کند. با این کار، منابع بیشتری در رایانه به برگه‌ها و سایر برنامه‌ها اختصاص داده می‌شود و سرعت Chrome حفظ می‌شود. هرزمان به برگه‌های غیرفعال برگردید، به‌طور خودکار دوباره فعال می‌شوند. <ph name="BEGIN_LINK"/>بیشتر بدانید<ph name="END_LINK"/> یا <ph name="BEGIN_LINK_2"/>بازخورد ارسال کنید<ph name="END_LINK_2"/></translation>
<translation id="6491651957026506753">‏این فایل خطرناک است، بنابراین Ecosia آن را مسدود کرده است.</translation>
<translation id="1851101453239911251">‏<ph name="BEGIN_BOLD"/>نحوه استفاده ما از این داده‌ها:<ph name="END_BOLD"/> سایت‌ها می‌توانند بااستفاده از Ecosia اطلاعاتی درباره علایقتان ذخیره کنند. برای مثال، اگر برای خرید کفش مخصوص ماراتون از سایتی بازدید کنید، ممکن است آن سایت علاقه شما را به‌صورت دونده ماراتون مشخص کند. بعداً، اگر برای ثبت‌نام در مسابقه‌ای به سایتی دیگر مراجعه کردید، آن سایت می‌تواند براساس علایقتان آگهی‌ای برای کفش مخصوص دویدن به شما نشان دهد.</translation>
<translation id="8355171755788522183">‏حق نشر <ph name="YEAR"/> Ecosia.‎ کلیه حقوق محفوظ است.</translation>
<translation id="5610400309434105339">‏<ph name="BEGIN_BOLD"/>نحوه استفاده ما از این داده‌ها:<ph name="END_BOLD"/> Ecosia می‌تواند علایق شما را برآورد کند. بعداً، سایتی که از آن بازدید می‌کنید می‌تواند برای شخصی کردن آگهی‌هایی که به شما نشان می‌دهد از Ecosia بخواهد علایق شما را ببیند.</translation>
<translation id="5883025779824839861">‏ادامه استفاده از Ecosia</translation>
<translation id="8394720698884623075">‏نشانی‌های وب را با فهرست سایت‌های ناامنی که در Chrome ذخیره شده است مقایسه می‌کند</translation>
<translation id="4409756430498035341">‏Ecosia می‌خواهد گذرواژه‌های شما را صادر کند.</translation>
<translation id="5902103164685487225">‏درباره شخصی‌سازی آگهی در Ecosia بیشتر بدانید</translation>
<translation id="592990842052138727">‏EcosiaOS نتوانست داده‌هایتان را همگام‌سازی کند، چون جزئیات ورود به حساب شما به‌روز نیست.</translation>
<translation id="665177868576952817">‏برای ارسال شماره از اینجا به تلفن Android خود، در هر دو دستگاه به سیستم Ecosia وارد شوید.</translation>
<translation id="4070480171055648632">‏<ph name="MANAGER_NAME"/> حساب شما را مدیریت می‌کند. سرپرست شما می‌تواند این نمایه مرورگر Ecosia و داده‌های آن را (مانند نشانک‌ها، سابقه، و گذرواژه‌ها) ببیند و ویرایش کند.</translation>
<translation id="1025044809499013222">‏لحظاتی پیش به‌روزرسانی امنیتی ویژه‌ای برای Ecosia اعمال شد. هم‌اکنون بازراه‌اندازی کنید و ما برگه‌هایتان را بازیابی خواهیم کرد.</translation>
<translation id="7864624828358709494">‏Ecosia این فایل را مسدود کرد زیرا حاوی بدافزار است</translation>
<translation id="3816260943154642689">‏علایق شما به‌طوری‌که Ecosia برآورد کرده است</translation>
<translation id="8023973672752791660">‏قانون ترافیک ورودی Ecosia نسخه Dev برای امکان دادن به ترافیک mDNS.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="8550334526674375523">این نمایه کاری کاملاً مجزا از نمایه شخصی‌تان است.</translation>
<translation id="7185777478310554774">‏نسخه جدیدی از Ecosia وجود دارد که سریعتر از همیشه است.</translation>
<translation id="5622136942112821750">‏با نمایه‌های Ecosia می‌توانید همه‌چیزتان را در Ecosia جدا کنید. با این کار، راحت‌تر می‌توان کار و سرگرمی را ازهم جدا کرد.</translation>
<translation id="18064594488616674">‏Ecosia پاسخ نمی‌دهد. مجدداً راه‌اندازی شود؟</translation>
<translation id="6896860023874996542">‏Ecosia برای دسترسی به دوربین به اجازه نیاز دارد تا بتواند نقشه سه‌بعدی محیط شما را ایجاد کند</translation>
<translation id="7558678848273505235">{0,plural, =1{‏Ecosia ‏۱ دقیقه دیگر راه‌اندازی مجدد می‌شود}one{‏Ecosia ‏# دقیقه دیگر راه‌اندازی مجدد می‌شود}other{‏Ecosia ‏# دقیقه دیگر راه‌اندازی مجدد می‌شود}}</translation>
<translation id="8641606876632989680">‏وقتی با گذرواژه‌ای لورفته به سیستم وارد شوید، Chrome به شما اطلاع می‌دهد</translation>
<translation id="8649026945479135076">‏امری عادی است که سایت‌هایی که بازدید می‌کنید برای شخصی کردن تجربه‌تان، علایق شما را به‌خاطر آورند. به‌علاوه، سایت‌ها می‌توانند بااستفاده از Chrome اطلاعاتی درباره علایقتان ذخیره کنند.</translation>
<translation id="9090890391337853620">‏راهنمای Ecosia</translation>
<translation id="524314285625975879">‏این برنامه همچنین صفحه‌ای را که هنگام راه‌اندازی Ecosia نشان داده می‌شود، کنترل می‌کند.</translation>
<translation id="4997668724897475215">‏Ecosia توصیه می‌کند این فایل را اسکن کنید زیرا ممکن است خطرناک باشد</translation>
<translation id="4170280082681554565">‏با نمایه‌های Ecosia می‌توانید همه چیزتان را در Ecosia جدا کنید. برای دوستان و اعضای خانواده‌تان نمایه ایجاد کنید، یا کار و سرگرمی را ازهم جدا کنید.</translation>
<translation id="8712767363896337380">‏تقریباً به‌روزرسانی شده است! برای تکمیل به‌روزرسانی، Chrome را راه‌اندازی مجدد کنید.</translation>
<translation id="873133009373065397">‏Google Chrome نمی‌تواند مرورگر پیش‌فرض را تعیین یا تنظیم کند</translation>
<translation id="1975037445584526511">‏برای دریافت به‌روزرسانی‌های آتی Ecosia، باید Windows 10 یا بالاتر داشته باشید. این رایانه از Windows 7 استفاده می‌کند.</translation>
<translation id="2695952268686253864">‏نسخه Ecosia قدیمی است</translation>
<translation id="8825634023950448068">‏برای محافظت از حریم خصوصی شما، علایقی را که قدیمی‌تر از ۴ هفته باشند به‌طور خودکار حذف می‌کنیم. وقتی به مرور کردن ادامه می‌دهید، ممکن است علاقه‌ای مجدداً به فهرست اضافه شود. و اگر Chrome به‌اشتباه علاقه‌ای را اضافه کند یا شما نخواهید آگهی‌های مشخصی را ببینید، می‌توانید آن علاقه را بردارید.</translation>
<translation id="5066194399237265772">‏Ecosia می‌خواهد گذرواژه‌ها را ویرایش کند. برای اینکه اجازه دهید این کار انجام شود، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="6078545897140861225">‏این برنامه همچنین صفحه‌ای را که هنگام راه‌اندازی Ecosia یا کلیک کردن روی دکمه صفحه اصلی نشان داده می‌شود، کنترل می‌کند.</translation>
<translation id="1401515072108809622">‏Ecosia غیرفعال است</translation>
<translation id="8862326446509486874">شما حقوق لازم برای نصب در سطح سیستم را ندارید. دوباره به‌عنوان سرپرست نصب‌کننده را اجرا کنید.</translation>
<translation id="8282620071565190081">‏راه‌اندازی مجدد Ecosia</translation>
<translation id="7849498640944199147">‏برای ارسال شماره از <ph name="ORIGIN"/> به تلفن Android خود، در هر دو دستگاه به سیستم Ecosia وارد شوید.</translation>
<translation id="7910693244647744044">‏«مرور ایمن پیشرفته» را در حسابتان روشن کرده‌اید. اکنون آن را برای Ecosia دریافت کنید.</translation>
<translation id="8986207147630327271">با این کار، نمایه کاری را به این مرورگر اضافه می‌کنید و فقط کنترل نمایه کاری را دراختیار سرپرست قرار می‌دهید.</translation>
<translation id="8989968390305463310">‏سابقه مرور شما بر آگهی‌هایی که می‌بینید و علایقتان که در زیر برآورد شده است تأثیر می‌گذارد. برای محافظت از حریم خصوصی شما، Chrome علایقتان را هر ماه به‌طور خودکار و چرخشی حذف می‌کند. ممکن است علایق بازآوری شود، مگر اینکه آن‌ها را بردارید.</translation>
<translation id="7348818664647668234">{0,plural, =0{‏به‌روزرسانی Ecosia دردسترس است}=1{‏به‌روزرسانی Ecosia دردسترس است}one{‏به‌روزرسانی Ecosia از # روز پیش دردسترس است}other{‏به‌روزرسانی Ecosia از # روز پیش دردسترس است}}</translation>
<translation id="9003498785844995646">‏وقتی روشن باشد، Chrome با محدود کردن فعالیت پس‌زمینه و جلوه‌های بصری، مثل پیمایش روان و نرخ فریم ویدیو، در مصرف باتری صرفه‌جویی می‌کند. <ph name="BEGIN_LINK"/>اطلاعات بیشتری کسب کنید<ph name="END_LINK"/> یا <ph name="BEGIN_LINK_2"/>بازخورد ارسال کنید<ph name="END_LINK_2"/></translation>
<translation id="9047384314208087523">‏سیستم EcosiaOS Flex</translation>
<translation id="5675757883980078189">‏Ecosia به Windows 7 یا بالاتر نیاز دارد.</translation>
<translation id="911206726377975832">داده‌های مرور شما نیز حذف شود؟</translation>
<translation id="9138603949443464873">‏برای اعمال تغییراتتان، Chrome را راه‌اندازی مجدد کنید</translation>
<translation id="9195993889682885387">‏Chrome می‌توانند علایقتان را براساس سابقه مرور چند هفته گذشته برآورد کند. این اطلاعات از دستگاهتان خارج نمی‌شود.</translation>
<translation id="5704599732514791330">‏به‌روزرسانی Ecosia برای شروع همگام‌سازی</translation>
<translation id="838842459108103907">‏سفارشی کردن Ecosia</translation>
<translation id="3070276123152913305">‏بازراه‌اندازی EcosiaOS Flex</translation>
<translation id="4512092435423703529">‏برای دسترسی به چیزهای Ecosia در همه دستگاه‌هایتان، به سیستم وارد شوید، سپس همگام‌سازی را روشن کنید.</translation>
<translation id="7972668220031382654">‏Ecosia توصیه می‌کند این فایل را اسکن کنید زیرا ممکن است خطرناک باشد.</translation>
<translation id="989369509083708165">‏Google Chrome مرورگر پیش‌فرضتان است</translation>
<translation id="4614106433017753369">‏با <ph name="SHORTCUT"/> می‌توانید بین نمایه‌های Ecosia جابه‌جا شوید</translation>
</translationbundle>
