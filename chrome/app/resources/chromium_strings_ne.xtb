<!DOCTYPE translationbundle>
<translationbundle lang="ne">
<translation id="1026101648481255140">इन्स्टल गर्ने प्रक्रिया सुचारु गर्नुहोस्</translation>
<translation id="8933665254023068908">&amp;EcosiaOS अपडेट गर्न यसलाई रिलन्च गर्नुहोस्</translation>
<translation id="6566258574866003581">Ecosia तपाईंलाई यो एक्स्टेन्सनको समीक्षा गर्न सिफारिस गर्छ</translation>
<translation id="1042552502243217427">कुनै साइटले आफ्नो पेजमा भएका लिंकहरू गोप्य तरिकाले प्रिलोड गर्न लगाएका खण्डमा Chromium ले Google का सर्भरहरू प्रयोग गर्छ। यसो गर्दा प्रिलोड गरिएको साइटमा भएको तपाईंको पहिचान खुलाउने जानकारी लुकाइन्छ तर Google ले कुन कुन साइट प्रिलोड गरिन्छन् भन्ने कुरा सिक्छ।</translation>
<translation id="1065672644894730302">तपाइँका प्राथमिकातहरू पढ्न सकिदैन।

केही सुविधाहरू अनुपलब्ध हुन सक्छन् र प्राथमिकताहरूमा परिवर्तनहरू बचत हुने छैनन्।</translation>
<translation id="8561406087076314604">तपाईंका अभिभावकले Ecosia का हकमा "साइट, एप तथा एक्सटेन्सनसम्बन्धी अनुमति" अफ गर्नुभएको छ</translation>
<translation id="1098170124587656448">Chromium ले तपाईंलाई डेटा चोरीका घटना, हानिकारक एक्स्टेन्सन र थप समस्याहरूबाट सुरक्षित रहन मद्दत गर्न सक्छ</translation>
<translation id="3632544319066562282">Ecosia तपाईंका पासवर्डहरू निर्यात गर्न चाहन्छ। यसो गर्ने अनुमति दिन Windows को आफ्नो पासवर्ड टाइप गर्नुहोस्‌।</translation>
<translation id="113122355610423240">Chromium तपाईंको डिफल्ट ब्राउजर हो</translation>
<translation id="1131805035311359397">तपाईंका पासवर्डहरू कतै खुलासा भएका छन् कि छैनन् तथा सुरक्षासम्बन्धी अन्य समस्याबाट सुरक्षित छन् कि छैनन् भन्ने कुरा जाँच्न <ph name="BEGIN_LINK"/>Chromium मा साइन इन गर्नुहोस्<ph name="END_LINK"/>।</translation>
<translation id="1224748120031661633">Ecosia मेनुमा क्लिक गर्नुहोस्</translation>
<translation id="1184145431117212167">तपाईंको डिभाइसमा भएको Windows को संस्करणमा नचल्ने भएकाले इन्स्टल गर्न सकिएन।</translation>
<translation id="1185134272377778587">Chromium का बारेमा</translation>
<translation id="1330085168384841023">आफ्नो विन्डो सेयर गर्न सिस्टमका प्राथमिकताहरूमा गई Ecosia लाई स्क्रिन रेकर्ड गर्ने अनुमति दिनुहोस्।</translation>
<translation id="1203500561924088507">इन्स्टल गर्नुभएकोमा धन्यवाद। <ph name="BUNDLE_NAME"/> प्रयोग गर्नुअघि तपाईंले अनिवार्य रूपमा आफ्नो ब्राउजर रिस्टार्ट गर्नु पर्छ।</translation>
<translation id="7455175614937447568">यो ट्याब निष्क्रिय हुँदा Ecosia छिटो चल्ने बनाइराख्न मेमोरी खाली गरिएको थियो। तपाईं यो साइटलाई जुनसुकै बेला सक्रिय राखिराख्ने विकल्प छनौट गर्न सक्नुहुन्छ।</translation>
<translation id="9068280473864300215">यो फाइल खतरनाक भएकाले Ecosia ले यो फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="126567311906253476"><ph name="USER_EMAIL"/> मार्फत Google का Gmail वा YouTube लगायतका सेवाहरूमा साइन इन गर्दा तपाईं उही खातामार्फत Chromium मा स्वतः साइन इन गर्न सक्नुहुन्छ</translation>
<translation id="1290883685122687410">सेटअप गर्ने क्रममा निम्न त्रुटि भयो: <ph name="METAINSTALLER_EXIT_CODE"/>। <ph name="WINDOWS_ERROR"/></translation>
<translation id="319566061277127356">Ecosia मा आफ्नो नयाँ प्रोफाइल सेटअप गर्नुहोस्</translation>
<translation id="4019094010333463261">Ecosia सँग ब्लुटुथ डिभाइसहरू खोज्नका निम्ति 
 ब्लुटुथको एक्सेस हुनु पर्छ। <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="5405885279794834338">यो जानकारी Ecosia बाट पनि मेटाउनुहोस् (<ph name="URL"/>)</translation>
<translation id="727568860157522676">तपाइँ Ecosia मा साइन इन</translation>
<translation id="1478370723027452770">Chrome for Testing का सम्बन्धमा मद्दत प्राप्त गर्नुहोस्</translation>
<translation id="1497802159252041924">इन्स्टल गर्ने क्रममा त्रुटि भयो: <ph name="INSTALL_ERROR"/></translation>
<translation id="1861504561909287316">Ecosia को ट्याब सेयर गर्नुहोस्</translation>
<translation id="6896860023874996542">Ecosia लाई तपाईं वरपरको ठाउँको 3D नक्सा बनाउन तपाईंको क्यामेरा प्रयोग गर्ने अनुमति चाहिन्छ</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{यो एक्स्टेन्सन अब प्रयोग गर्न मिल्दैन। Ecosia ले तपाईंलाई यो एक्स्टेन्सन हटाउन सिफारिस गर्छ।}other{यी एक्स्टेन्सनहरू अब प्रयोग गर्न मिल्दैनन्। Ecosia ले तपाईंलाई यी एक्स्टेन्सनहरू हटाउन सिफारिस गर्छ।}}</translation>
<translation id="1574377791422810894">Chromium का सुरक्षासम्बन्धी टुलहरू</translation>
<translation id="2200308425865645682">Ecosia ले तपाईंको पहिचान पुष्टि गरेपछि मात्र तपाईं आफ्नो Ecosia खातामा कुनै डेटा सेभ गर्न र उक्त डेटा आफ्ना सबै डिभाइसहरूमा प्रयोग गर्न सक्नुहुन्छ। तपाईंले साइन आउट गर्नुभयो भने उक्त डेटा यो डिभाइसमा रहिरहने छ।</translation>
<translation id="7304240387834227637">Ecosia तपाईंको पासवर्ड म्यानेजरमा भएको जानकारी मेटाउन चाहन्छ। यसो गर्ने अनुमति दिन Windows को पासवर्ड टाइप गर्नुहोस्।</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न Ecosia पुनः सुरु गर्नु पर्ने हुन्छ}=1{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न Ecosia पुनः सुरु गर्नु पर्ने हुन्छ। तपाईंको इन्कोग्निटो विन्डो पुनः खुल्ने छैन।}other{तपाईंका व्यवस्थापकका अनुसार तपाईंले यो अद्यावधिक लागू गर्न Ecosia पुनः सुरु गर्नु पर्ने हुन्छ। तपाईंका # वटा इन्कोग्निटो विन्डो पुनः खुल्ने छैनन्।}}</translation>
<translation id="1625909126243026060">Chromium मा भएका गोपनीयता र सुरक्षासम्बन्धी मुख्य नियन्त्रण सुविधाहरूको समीक्षा गर्नुहोस्</translation>
<translation id="931416298178634530">तपाईं यो खाता एक पटक मात्र प्रयोग गर्न चाहनुहुन्छ भने तपाईं Ecosia ब्राउजरमार्फत <ph name="GUEST_LINK_BEGIN"/>गेस्ट मोड<ph name="GUEST_LINK_END"/> प्रयोग गर्न सक्नुहुन्छ। तपाईं अरू कसैको खाता लिंक गर्न चाहनुहुन्छ भने उहाँलाई <ph name="LINK_BEGIN"/>नयाँ व्यक्तिका रूपमा<ph name="LINK_END"/> आफ्नो <ph name="DEVICE_TYPE"/> मा सामेल गराउनुहोस्।

तपाईंले वेबसाइट तथा एपहरूलाई दिइसक्नुभएका अनुमति यो खाताका हकमा पनि लागू हुन सक्छ। तपाईं <ph name="SETTINGS_LINK_BEGIN"/>सेटिङ<ph name="SETTINGS_LINK_END"/>मा गई आफ्ना Ecosia खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ।</translation>
<translation id="1640672724030957280">डाउनलोड गरिँदै छ...</translation>
<translation id="1715127912119967311">यी सुविधाहरूको गुणस्तर सुधार्ने प्रयोजनका लागि Chromium ले तपाईंले यी सुविधासँग गरेका अन्तर्क्रियासम्बन्धी जानकारी Google लाई पठाउँछ। समीक्षकहरू यो जानकारी पढ्न, प्रोसेस गर्न र एनोटेट गर्न सक्छन्।</translation>
<translation id="1722488837206509557">तपाईंले यो अनुमति दिनुभयो भने तपाईं उपलब्ध डिभाइसहरूमध्येबाट कुनै डिभाइस चयन गर्न र उक्त डिभाइसमा सामग्री देखाउन सक्नु हुने छ।</translation>
<translation id="1118786556671181978">तपाईं वेबसाइटहरूले तपाईंलाई विज्ञापन देखाउन प्रयोग गर्ने रुचिका विषयहरू हेर्न तथा हटाउन सक्नुहुन्छ। Ecosia ले तपाईंको हालसालैको ब्राउजिङ इतिहासका आधारमा तपाईंलाई रुचि लाग्न सक्ने विषयहरू पत्ता लगाउँछ।</translation>
<translation id="2379593823746842972">Ecosia ले चाँडै नै ब्राउजिङ डेटा मेटाउने छ</translation>
<translation id="1736443181683099871">Chromium ले वेबपेजहरू लोड गर्न HTTPS प्रयोग गर्ने प्रयास गर्ने छ</translation>
<translation id="5490755016715767023">Ecosia <ph name="REMAINING_TIME"/> पछि रिस्टार्ट हुने छ</translation>
<translation id="1749104137266986751">HTTPS उपलब्ध नहुँदा Chromium ले तपाईंलाई चेतावनी नदिइकनै असुरक्षित कनेक्सन प्रयोग गर्ने छ</translation>
<translation id="8454595950895325762">क्रोमियम पृष्ठभूमिमा चलाउछन्</translation>
<translation id="9125443060066914183">Ecosia लाई अझ सुरक्षित बनाउनको लागि, हामीले <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> मा सूचीकृत नगरिएका केही एक्स्टेन्सनहरूलाई अक्षम बनाएका छौँ र तपाईंलाई थाहा दिए बिना थपिएको हुन सक्छ।</translation>
<translation id="6984747211123632080">Ecosia पुनर्स्थापित गर्नुहोस्</translation>
<translation id="1251415775728969647">Ecosia <ph name="AUTHENTICATION_PURPOSE"/> प्रयास गर्दै छ</translation>
<translation id="1761584959558744002">तपाईंको Ecosia खातामा ब्राउजिङ डेटा यथावत् राखी यो डिभाइसबाट मात्र ब्राउजिङ डेटा मेटाउन <ph name="BEGIN_LINK"/>Ecosia बाट साइन आउट गर्नुहोस्<ph name="END_LINK"/>।</translation>
<translation id="185970820835152459">तपाईं साइन इन गरिएका आफ्ना Google खाताहरू व्यवस्थापन गर्न सक्नुहुन्छ। तपाईंका Google खाताहरू Chromium ब्राउजर, Play स्टोर, Gmail र अन्य एपहरूमा प्रयोग गरिन्छन्। तपाईं परिवारका सदस्य जस्ता अरू कसैको खाता थप्न चाहनुहुन्छ भने उहाँको खाता थप्नुको साटो उहाँलाई नयाँ व्यक्तिका रूपमा आफ्नो <ph name="DEVICE_TYPE"/> मा सामेल गराउनुहोस्। <ph name="LINK_BEGIN"/>थप जान्नुहोस्<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">साइटहरूले Chromium मा तपाईंका रुचिसम्बन्धी जानकारी भण्डारण गर्न सक्छन्। उदाहरणका लागि, तपाईंले कुनै साइटमा गएर म्याराथनमा दौडिँदा लगाइने जुत्ता किन्नुभयो भने उक्त साइटले तपाईं म्याराथन दौडमा रुचि राख्नुहुन्छ भन्ने कुरा बुझ्न सक्छ। पछि तपाईं दौड प्रतियोगितामा आफ्नो नाम लेखाउन अर्कै साइटमा जानुभयो भने उक्त साइटले तपाईंको रुचिका आधारमा तपाईंलाई दौडिँदा लगाइने जुत्ताको विज्ञापन देखाउन सक्छ।</translation>
<translation id="4239392394637574967">तपाईंले व्यवस्थित खातासँगै साइन इन गरि यसको व्यवस्थापकलाई तपाईंको क्रोमियम प्रोफाइल माथि नियन्त्रण दिइरहनुभएको छ। तपाईंको क्रोमियम डाटा, जस्तै तपाईंका एप्स, बुकमार्कहरू, इतिहास, पासवर्डहरू, र अन्य सेटिङहरू <ph name="USER_NAME"/> मा स्थायी रूपमा बाँधिनेछन्। तपाईं यस डाटालाई गूगल खाता ड्यासबोर्ड मार्फत मेटाउन सक्षम हुनुहुनेछ, तर तपाईं यस खातालाई अर्को खातामा संलग्न गर्न सक्षम हुनुहुनेछैन। तपाईंले आफ्नो विद्यमान क्रोमियम डाटालाई अलग राख्न वैकल्पिक रूपमा नयाँ प्रोफाइल सिर्जना गर्न सक्नुहुन्छ। <ph name="LEARN_MORE"/></translation>
<translation id="1906696617298807388">तपाईंले एड्रेस बार वा खोज बाकसमा टाइप गर्दा तपाईंलाई सामग्रीसम्बन्धी सुझावहरू देखाउन सकियोस् भन्नाका लागि Chromium ले तपाईंले टाइप गर्ने कुरा Google Drive मा पठाउँछ। इन्कोग्निटो मोडमा यो सुविधा अफ हुन्छ।</translation>
<translation id="1911763535808217981">यसलाई निष्क्रिय पारेर, तपाईं Chromium मा साइन इन नगरिकनै Gmail जस्ता Google का साइटहरूमा साइन इन गर्न सक्नुहुन्छ</translation>
<translation id="18064594488616674">Ecosia ले कुनै प्रतिक्रिया जनाइरहेको छैन। अहिले नै पुन: लन्च गर्ने?</translation>
<translation id="8047394653992042491">यो अपडेट लागू गर्न EcosiaOS रिस्टार्ट गर्नु पर्ने हुन्छ।</translation>
<translation id="4988569127367972482">यस प्रकारको फाइल सामान्यतया डाउनलोड नगरिने र खतरनाक हुन सक्ने भएकाले Ecosia ले उक्त प्रकारको फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="1953553007165777902">डाउनलोड गरिँदै छ... <ph name="MINUTE"/> मिनेट बाँकी छ</translation>
<translation id="1966382378801805537">Chromium ले डिफल्ट ब्राउजर निर्धारण वा सेट गर्न सक्दैन</translation>
<translation id="6583697665130212310">Ecosia ले केही फाइलहरू ब्लक गर्नुको कारण जान्नुहोस् (नयाँ ट्याबमा खुल्छ)</translation>
<translation id="2008474315282236005">यसले यो डिभाइसको १ वस्तु मेट्नेछ। पछि आफ्नो डेटा प्राप्त गर्न Chromium मा <ph name="USER_EMAIL"/> को रूपमा साइन इन गर्नुहोस्।</translation>
<translation id="2018879682492276940">इन्स्टल गर्न सकिएन। कृपया फेरि प्रयास गर्नुहोस्।</translation>
<translation id="2020032459870799438">तपाईंका अन्य पासवर्डहरू कतै खुलासा भएका छन् कि छैनन् तथा सुरक्षासम्बन्धी अन्य समस्याबाट सुरक्षित छन् कि छैनन् भन्ने कुरा जाँच्न <ph name="BEGIN_LINK"/>Chromium मा साइन इन गर्नुहोस्<ph name="END_LINK"/>।</translation>
<translation id="2049376729098081731">Google का सेवाहरूमा आफ्नो आवश्यकताअनुसारका सुविधाहरू पाउन Chromium को ब्राउजिङ इतिहास समावेश गर्ने कि नगर्ने भन्ने कुरा छनौट गर्नुहोस्</translation>
<translation id="7112125772061727648">यो फाइल भ्रामक भएको र यसले तपाईंको डिभाइसमा अनपेक्षित परिवर्तन गर्न सक्ने भएकाले Ecosia ले यो फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="2088953378266246249">Chromium ले आफ्ना मूल प्रमाणपत्र कसरी व्यवस्थापन गर्छ भन्ने कुरासम्बन्धी जानकारी</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{Ecosia १ मिनेटसम्म प्रयोग नगरिएका खण्डमा तपाईंको सङ्गठनले ब्राउजिङ डेटा स्वतः मेटाउँछ। यसअन्तर्गत हिस्ट्री, अटोफिल तथा डाउनलोड समावेश हुन सक्छन्। तपाईंका ट्याबहरू खुलै रहने छन्।}other{Ecosia # मिनेटसम्म प्रयोग नगरिएका खण्डमा तपाईंको सङ्गठनले ब्राउजिङ डेटा स्वतः मेटाउँछ। यसअन्तर्गत हिस्ट्री, अटोफिल तथा डाउनलोड समावेश हुन सक्छन्। तपाईंका ट्याबहरू खुलै रहने छन्।}}</translation>
<translation id="2126108037660393668">डाउनलोड गरिएको फाइल पुष्टि गर्न सकिएन।</translation>
