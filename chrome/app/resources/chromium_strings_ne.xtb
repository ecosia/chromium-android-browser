<translation id="5055330219314726197">Ecosia लाई यो साइटका लागि तपाईंको क्यामेरामाथि पहुँच राख्ने अनुमति चाहिन्छ</translation>
<translation id="7458892263350425044">माइक्रोफोन प्रयोग गर्न <ph name="BEGIN_LINK"/>सिस्टम सेटिङ<ph name="END_LINK"/>मा गई Chrome लाई माइक्रोफोनको एक्सेस दिनुहोस्</translation>
<translation id="1975037445584526511">तपाईंको कम्प्युटरमा Windows १० वा सोभन्दा नयाँ संस्करण छ भने मात्र तपाईं भविष्यमा Ecosia का अपडेट प्राप्त गर्नुहुन्छ। यो कम्प्युटरमा Windows ७ प्रयोग भइरहेको छ।</translation>
<translation id="7467949745582939695">Chromium बन्द गरेर फेरि खोल्ने हो?</translation>
<translation id="80155189677487610">हाल चलिरहेको समान क्रोमियम संस्करण स्थापना गर्न सकिंदैन। कृपया क्रोमियमलाई बन्द गरि पुन: प्रयास गर्नुहोस्।</translation>
<translation id="751935028865900641">साइटहरूले अपेक्षित रूपमा काम गर्ने छन्। तपाईंले Chromium का सबै विन्डो बन्द गर्नुभयो भने तपाईंलाई अधिकांश साइटहरूबाट साइन आउट गरिने छ तर तपाईं Chromium मा साइन इन अवस्थामा हुनुहुन्छ भने तपाईंलाई तपाईंको Google खाताबाट भने साइन आउट गरिने छैन।</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia १ मिनेटमा पुनः सुरु हुने छ}other{Ecosia # मिनेटमा पुनः सुरु हुने छ}}</translation>
<translation id="8228132389897276908">आफ्नो विन्डो सेयर गर्न सिस्टमका प्राथमिकताहरूमा गई Ecosia लाई स्क्रिन रेकर्ड गर्ने अनुमति दिनुहोस्</translation>
<translation id="7582945390259497898">Chromium ले तपाईंका रुचिहरू अनुमान ‌गर्न सक्छ। तपाईंले यसपछि खोल्ने साइटले Chromium सँग तपाईंलाई देखाइने विज्ञापनहरू पर्सनलाइज गर्ने प्रयोजनका लागि तपाईंका रुचिहरू हेर्ने अनुमति माग्न सक्छ।</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME"/> इन्स्टलर</translation>
<translation id="7585391435984513350">तपाईंले हालसालै कुनै पनि साइट खोल्नुभएको छैन। Chromium ले <ph name="PERMISSION"/> रद्द गरेको छ</translation>
<translation id="4061472199368124600">Ecosia ले तपइँको क्यामेरा र माइक्रोफोन प्रयोग गर्दैछ।</translation>
<translation id="170259281605734125">Ecosia भर्खरै झन राम्रो भयो</translation>
<translation id="7649070708921625228">मद्दत</translation>
<translation id="675365189802108507">तपाईं Ecosia का सेटिङमा गई यी सुविधाहरूका बारेमा थप जान्न सक्नुहुन्छ।</translation>
<translation id="1508200558303644420">Ecosia तपाईंको डिफल्ट ब्राउजर होइन</translation>
<translation id="7174674455569790401">आफ्ना यन्त्रहरूभरि Ecosia लाई सिंक तथा वैयक्तीकृत गर्नुहोस्</translation>
<translation id="7699779824407626136">Chromium अपडेट</translation>
<translation id="7745317241717453663">यसले यो डिभाइसको तपाईंको ब्राउजिङ सम्बन्धी डेटा मेट्नेछ। पछि आफ्नो डेटा प्राप्त गर्न Chromium मा <ph name="USER_EMAIL"/> को रूपमा साइन इन गर्नुहोस्।</translation>
<translation id="7747138024166251722">स्थापनाकर्ताले एक अस्थायी डाइरेक्टरी सिर्जना गर्न सकेन। कृपया खाली डिस्क स्थान र सफ्टवेयर स्थापना गर्न अनुमति जाँच गर्नुहोस् ।</translation>
<translation id="6161025257729272170">Ecosia लाई अझ छिटो काम गर्ने बनाउनुहोस्</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia Canary</translation>
<translation id="7803986347287457849">तपाईंको इन्टरनेट ट्राफिक प्रयोग गर्न सक्ने मान्छेहरूलाई तपाईं कुन कुन वेबसाइटहरूमा जानुहुन्छ भन्ने कुरा हेर्न अझ कठिन बनाइदिनुहोस्। Chromium ले DNS (डोमेन नेम सिस्टम) मा कुनै वेबसाइटको IP एड्रेस हेर्न सुरक्षित कनेक्सन प्रयोग गर्छ।</translation>
<translation id="8301840715671593762">यस यन्त्रमा यो खाता प्रयोग गरेर Ecosia प्रोफाइल बनाइसकिएको छ</translation>
<translation id="7845233973568007926">इन्स्टल गर्नुभएकोमा धन्यवाद। <ph name="BUNDLE_NAME"/> प्रयोग गर्नुअघि तपाईंले अनिवार्य रूपमा आफ्नो कम्प्युटर रिस्टार्ट गर्नु पर्छ।</translation>
<translation id="7859018312476869945">तपाईंले एड्रेस बार वा खोज बाकसमा टाइप गर्दा तपाईंलाई अझ राम्रा सुझावहरू देखाउन सकियोस् भन्नाका लागि Chromium ले तपाईंले टाइप गर्ने कुरा तपाईंको डिफल्ट सर्च इन्जिनमा पठाउँछ। इन्कोग्निटो मोडमा यो सुविधा अफ हुन्छ।</translation>
<translation id="3268039966078382323">Ecosia लाई नवीनतम संस्करणमा अद्यावधिक गर्न सकिएन, जसका कारण तपाईं नयाँ सुविधाहरू तथा सुरक्षासम्बन्धी समाधानहरू चलाउनबाट वञ्चित भइराख्नुभएको छ।</translation>
<translation id="7872446069773932638">डाउनलोड गरिँदै छ... <ph name="SECONDS"/> सेकेन्ड बाँकी छ</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>तपाईं आफ्नो जानकारी कसरी व्यवस्थापन गर्न सक्नुहुन्छ:<ph name="END_BOLD"/> तपाईंको गोपनीयताको सुरक्षार्थ हामी ४ हप्ताभन्दा पुराना तपाईंका रुचिहरू स्वतः मेटाउँछौँ। तपाईंले विभिन्न साइटहरू ब्राउज गरिराख्ने क्रममा कुनै रुचि यो सूचीमा फेरि देखिन सक्छ। अथवा तपाईं Ecosia ले कुनै रुचिसँग सम्बन्धित सामग्री नदेखाओस् भन्ने चाहनुहुन्छ भने तपाईं उक्त रुचि हटाउन सक्नुहुन्छ।</translation>
<translation id="4638085384909702681">Ecosia लाई डिफल्ट ब्राउजर बनाउनुहोस्</translation>
<translation id="7934340546140346950">Chromium ले सम्भव भएसम्म असुरक्षित कनेक्सनहरू स्वतः अपग्रेड गरी तिनलाई HTTPS मा रूपान्तरण गर्छ</translation>
<translation id="2412381038247037703">तपाईंलाई Ecosia मा <ph name="USER_EMAIL_ADDRESS"/> को रूपमा साइन इन गरिएको थियो। कृपया फेरि साइन इन गर्न यही खाता प्रयोग गर्नुहोस्।</translation>
<translation id="7975919845073681630">यो Chromium को एउटा सहायक स्थापना हो र यसलाई तपाईँको डिफल्ट ब्राउजर बनाउन सकिँदैन।</translation>
<translation id="851583113375911087">अज्ञात स्रोतबाट डाउनलोड गरिएका एक्स्टेन्सन, एप र थिमहरूले तपाईंको डिभाइसमा हानि पुर्‍याउन सक्छन्। Ecosia त्यस्ता कुराहरू<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> बाट मात्र इन्स्टल गर्न सिफारिस गर्छ</translation>
<translation id="488806616089631539">Ecosia ले पहुँच प्राप्त गरेपछि, वेबसाइटहरू तपाईंसँग पहुँच माग्न सक्ने छन्।</translation>
<translation id="80471789339884597">इन्स्टल गर्नुभएकोमा धन्यवाद। <ph name="BUNDLE_NAME"/> प्रयोग गर्नुअघि तपाईंले अनिवार्य रूपमा आफ्ना सबै ब्राउजर रिस्टार्ट गर्नु पर्छ।</translation>
<translation id="8086881907087796310">तपाईंको कम्प्युटरले हार्डवेयरसम्बन्धी न्यूनतम मापदण्डहरू पूरा नगर्ने भएकाले इन्स्टल गर्ने प्रक्रिया पूरा हुन सकेन।</translation>
