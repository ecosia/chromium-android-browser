<!DOCTYPE translationbundle>
<translationbundle lang="hi">
<translation id="4033006861724039519">इंस्‍टॉलर संग्रह खराब या अमान्‍य है. कृपया Ecosia फिर से डाउनलोड करें.</translation>
<translation id="1026101648481255140">इंस्टॉल करने की प्रोसेस को दोबारा चालू करें</translation>
<translation id="8296565077892323223">Ecosia को पसंद के मुताबिक बनाएं और कंट्रोल करें. अपडेट उपलब्ध है.</translation>
<translation id="1761584959558744002">ब्राउज़िंग डेटा को सिर्फ़ इस डिवाइस से मिटाने और अपने Ecosia खाते में सेव रखने के लिए, <ph name="BEGIN_LINK"/>Ecosia से साइन आउट करें<ph name="END_LINK"/>.</translation>
<translation id="3271929752667225813">Ecosia में साइन इन करने के डायलॉग बॉक्स को बंद करने के लिए क्लिक करें</translation>
<translation id="2056307067005384438">इस एक्सटेंशन को <ph name="USER_EMAIL_ADDRESS"/> के तौर पर इस्तेमाल करने के लिए, Ecosia में साइन इन करें.</translation>
<translation id="1065672644894730302">आपकी प्राथमिकताओं को पढ़ा नहीं जा सकता| \\n\\nकुछ विशेषताएं अनुपलब्ध हो सकती हैं और प्राथमिकताओं में किए गए परिवर्तनों को सहेजा नहीं जाएगा.</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> पहले Ecosia का उपयोग कर रहा था</translation>
<translation id="2000339487270823788">यह आपका Ecosia है</translation>
<translation id="8078678931242443254">Ecosia को कौन इस्तेमाल कर रहा है?</translation>
<translation id="6346154190168496057">Ecosia को अपडेट नहीं किया जा सकता</translation>
<translation id="5312730628132049495">Ecosia में साइन इन करें. अगर आपको किसी खाते में सिर्फ़ एक बार साइन इन करना है, तो <ph name="GUEST_LINK_BEGIN"/>डिवाइस का इस्तेमाल मेहमान के तौर पर करें<ph name="GUEST_LINK_END"/>.</translation>
<translation id="1152920704813762236">ChromeOS के बारे में जानकारी</translation>
<translation id="7303930050538184306">Ecosia में &amp;खोलें</translation>
<translation id="1184145431117212167">इंस्टॉल नहीं किया जा सका, क्योंकि Windows के आपके वर्शन पर यह काम नहीं करता.</translation>
<translation id="4988569127367972482">Ecosia ने इस डाउनलोड को ब्लॉक किया है, क्योंकि इस तरह की फ़ाइल आम तौर पर डाउनलोड नहीं की जाती और यह खतरनाक हो सकती है</translation>
<translation id="1203500561924088507">इंस्टॉल करने के लिए धन्यवाद. <ph name="BUNDLE_NAME"/> का इस्तेमाल करने से पहले, ब्राउज़र को रीस्टार्ट करना ज़रूरी है.</translation>
<translation id="4517165228415697265">Ecosia का सुझाव है कि आप Ecosia को डिफ़ॉल्ट ब्राउज़र के तौर पर सेट करें</translation>
<translation id="1265739287306757398">तरीका जानें</translation>
<translation id="1523806373970723624">&amp;Ecosia को अपडेट करने के लिए फिर से लॉन्च करें</translation>
<translation id="1290883685122687410">सेटअप करने में गड़बड़ी हुई: <ph name="METAINSTALLER_EXIT_CODE"/>. <ph name="WINDOWS_ERROR"/></translation>
<translation id="5279514147510747661">कृपया Ecosia के द्वारा नवीनतम सिस्टम अपडेट इंस्टॉल करने के दौरान इंतज़ार करें.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> के मुताबिक, यह ज़रूरी है कि इस डिवाइस का इस्तेमाल करने से पहले आप सेवा की इन शर्तों को पढ़ें और स्वीकार करें. इन शर्तों से, EcosiaOS Flex की शर्तों में कोई नई शर्त नहीं जुड़ती, न ही उनमें कोई बदलाव होता है, और न ही उन्हें सीमित किया जाता है.</translation>
<translation id="3592624492063123732">पासवर्ड देखने के लिए, Ecosia की किसी दूसरी प्रोफ़ाइल पर स्विच करें</translation>
<translation id="8067423333018528301">साइन इन करने के दौरान हुई किसी गड़बड़ी की वजह से, EcosiaOS आपके डेटा को सिंक नहीं कर सका.</translation>
<translation id="2926455547526018397">Ecosia बीटा</translation>
<translation id="2995860351618948435">इस कंप्यूटर में Ecosia का ज़्यादा नवीन वर्शन पहले से मौजूद है. अगर सॉफ्टवेयर काम नहीं कर रहा है, तो कृपया Ecosia अनइंस्‍टॉल करें और फिर से प्रयास करें.</translation>
<translation id="824192326282906244">Ecosia की सेटिंग में जाकर, इसमें कभी भी बदलाव किया जा सकता है. आपको ये बदलाव तुरंत नहीं दिखेंगे. ऐसा इसलिए होता है, क्योंकि आपकी दिलचस्पी के मुताबिक विज्ञापन दिखाने के ट्रायल के दौरान भी, विज्ञापन दिखाने के पुराने तरीके को पूरी तरह से नहीं बदला जाता है.</translation>
<translation id="3621704124701415791">Ecosia में Ecosia Translate की सुविधा पहले से ही मौजूद होती है. इससे ज़रूरत पड़ने पर कभी भी अनुवाद किया जा सकता है</translation>
<translation id="5043324171996581320">{COUNT,plural, =0{Ecosia अपडेट हो गया है. फिर से लॉन्च करके, नए वर्शन का इस्तेमाल किया जा सकता है. इसके बाद, आपके मौजूदा टैब फिर से खुल जाएंगे.}=1{Ecosia अपडेट हो गया है. फिर से लॉन्च करके, नए वर्शन का इस्तेमाल किया जा सकता है. इसके बाद, आपके मौजूदा टैब फिर से खुल जाएंगे. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{Ecosia अपडेट हो गया है. फिर से लॉन्च करके, नए वर्शन का इस्तेमाल किया जा सकता है. इसके बाद, आपके मौजूदा टैब फिर से खुल जाएंगे. आपकी # गुप्त विंडो फिर से नहीं खुलेगी.}other{Ecosia अपडेट हो गया है. फिर से लॉन्च करके, नए वर्शन का इस्तेमाल किया जा सकता है. इसके बाद, आपके मौजूदा टैब फिर से खुल जाएंगे. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="4696685525015809740">Ecosia Canary ऐप्स </translation>
<translation id="7045045549868370797">क्या आपको Ecosia में साइन इन करना है?</translation>
<translation id="1691902349688685912">Ecosia का अपडेट पूरा करने के लिए फिर से लॉन्च करें</translation>
<translation id="1497802159252041924">इंस्टॉल करने में गड़बड़ी: <ph name="INSTALL_ERROR"/></translation>
<translation id="3697186779259384993">अपनी नई Ecosia प्रोफ़ाइल को पसंद के मुताबिक बनाएं</translation>
<translation id="2441303983090031276">EcosiaOS को अतिरिक्त <ph name="BEGIN_LINK_CROS_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_CROS_OSS"/> की मदद से बनाया गया है.</translation>
<translation id="5598074261782651109">Ecosia अपडेट करें</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> इस Ecosia प्रोफ़ाइल में पहले से साइन इन हैं. इससे <ph name="USER_EMAIL_ADDRESS"/> के लिए एक नई Ecosia प्रोफ़ाइल बन जाएगी</translation>
<translation id="4943938785458240142">Ecosia आपके कैमरे का उपयोग कर रहा है.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> खरतरनाक है, इसलिए Ecosia ने उसे अवरोधित कर दिया है.</translation>
<translation id="1597911401261118146">डेटा के गलत इस्तेमाल और सुरक्षा की अन्य समस्याओं से आपके पासवर्ड सुरक्षित हैं या नहीं, इसकी जांच करने के लिए, <ph name="BEGIN_LINK"/>Chrome में साइन इन करें<ph name="END_LINK"/>.</translation>
<translation id="1597547208646178091">Ecosia को ज़्यादा सुरक्षित बनाने के लिए, हमने निम्न एक्सटेंशन को अक्षम कर दिया है जो <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> में सूचीबद्ध नहीं है और आपकी जानकारी के बिना जोड़ा गया हो सकता है.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>अपना डेटा कैसे मैनेज करें:<ph name="END_BOLD"/> आपकी निजता को सुरक्षित रखने के लिए, हम आपकी पसंद के उन विषयों को ऑटोमैटिकली मिटा देते हैं जिनका अनुमान चार हफ़्ते पहले लगाया गया था. ब्राउज़ करते रहने पर, आपकी पसंद का कोई विषय, सूची में फिर से शामिल किया जा सकता है. इसके अलावा, आपके पास उन विषयों को हटाने का भी विकल्प होता है जिन्हें आपको Ecosia की सूची में शामिल नहीं करवाना है.</translation>
<translation id="1628000112320670027">Chrome में सहायता पाएं</translation>
<translation id="1640672724030957280">डाउनलोड हो रहा है...</translation>
<translation id="1662146548738125461">ChromeOS Flex के बारे में जानकारी</translation>
<translation id="5500958820122281144">Ecosia गु&amp;प्त विंडो में लिंक खोलें</translation>
<translation id="7602423871874451395">Ecosia अपनी डेटा निर्देशिका को पढ़ और उस पर लिख नहीं सकता :\n\n<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="2020747823154282691">Ecosia, ब्राउज़िंग के आपके अनुभव को बेहतर बनाने और तेज़ी से काम पूरे करने के लिए, इस टैब को बंद कर सकता है.</translation>
<translation id="3939060118711873999">Ecosia एक ऐसा वेब ब्राउज़र है, जो वेब पेज और ऐप्स  को बिजली की गति से चलाता है. यह तेज़, स्थिर, और उपयोग में आसान है. Ecosia में अंतर्निहित मैलवेयर और फ़िशिंग सुरक्षा के साथ ज़्यादा सुरक्षित रूप से वेब ब्राउज़ करें.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia एक घंटे में फिर से लॉन्च होगा}one{Ecosia # घंटे में फिर से लॉन्च होगा}other{Ecosia # घंटे में फिर से लॉन्च होगा}}</translation>
<translation id="1722488837206509557">इससे, आपको इन डिवाइसों में से किसी एक को चुनने और उस पर कॉन्टेंट दिखाने का विकल्प मिलेगा.</translation>
<translation id="4021894801595982809">Ecosia इस पासवर्ड को आपके Ecosia खाते में सेव कर लेगा. आपको इसे याद रखने की ज़रूरत नहीं है.</translation>
<translation id="2346323077583431428">पक्का करें कि आपने <ph name="TARGET_DEVICE_NAME"/> पर Ecosia में साइन इन किया है. इसके बाद, फिर से भेजने की कोशिश करें.</translation>
<translation id="788366290112401490">शॉर्टकट, Ecosia में खुलते हैं</translation>
<translation id="6180968682827452331">इस एक्सटेंशन का इस्तेमाल अब नहीं किया जा सकता. Ecosia का सुझाव है कि आप इसे अनइंस्टाॅल कर दें.</translation>
<translation id="1812689907177901597">इसे बंद करके, Chrome में साइन इन किए बिना Gmail जैसी Google साइटों में साइन इन किया जा सकता है</translation>
<translation id="5055330219314726197">Ecosia को इस साइट के लिए आपका कैमरा एक्सेस करने की अनुमति चाहिए</translation>
<translation id="1508200558303644420">Ecosia आपका डिफ़ॉल्ट ब्राउज़र नहीं है</translation>
<translation id="8135642897811755229">Ecosia बीटा (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia पुराना हो गया है</translation>
<translation id="8228132389897276908">विंडो शेयर करने के लिए, 'सिस्टम की सेटिंग' में जाकर Ecosia के लिए स्क्रीन रिकॉर्ड करने की अनुमति दें</translation>
<translation id="1919130412786645364">Chrome में साइन-इन करने दें</translation>
<translation id="1953553007165777902">डाउनलोड हो रहा है... <ph name="MINUTE"/> मिनट बचे हैं</translation>
<translation id="8116259102110666562">Ecosia हर डिवाइस पर काम करता है, ताकि आपको एक जैसा अनुभव मिले</translation>
<translation id="2001586581944147178">आपके इंटरनेट ट्रैफ़िक का ऐक्सेस रखने वाले लोगों के लिए, यह देखना मुश्किल बनाएं कि आपने किन साइटों पर विज़िट किया है. Chrome, डीएनएस (डोमेन नेम सिस्टम) में किसी साइट का आईपी पता खोजने के लिए, सुरक्षित कनेक्शन का इस्तेमाल करता है.</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{इस एक्सटेंशन का इस्तेमाल अब नहीं किया जा सकता. Ecosia का सुझाव है कि आप इसे हटा दें.}one{इस एक्सटेंशन का इस्तेमाल अब नहीं किया जा सकता. Ecosia का सुझाव है कि आप इसे हटा दें.}other{इन एक्सटेंशन का इस्तेमाल अब नहीं किया जा सकता. Ecosia का सुझाव है कि आप इन्हें हटा दें.}}</translation>
<translation id="8608092457636055141">हर प्रोफ़ाइल के पास उसके अपने Ecosia से जुड़ी जानकारी होती है, जैसे कि बुकमार्क, इतिहास, पासवर्ड, और अन्य जानकारी</translation>
<translation id="2018879682492276940">इंस्टॉल नहीं हो सका. कृपया फिर से कोशिश करें.</translation>
<translation id="686474599126256998">खाते का ऐक्सेस सेट अप करने के दौरान भी Ecosia का इस्तेमाल किया जा सकता है. सेटअप पूरा होने तक, हो सकता है कि आप कुछ संसाधनों को ऐक्सेस न कर पाएं.</translation>
<translation id="2034233344106846793">जब भी मुमकिन होता है, तब Chrome, असुरक्षित कनेक्शन को एचटीटीपीएस पर अपने-आप अपग्रेड कर देता है</translation>
<translation id="207902854391093810">ट्रायल के दौरान, विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, आपकी देखी गई साइटों को अनुमति देता है कि वे Chrome से आपकी जानकारी पाने का अनुरोध कर सकें. इस जानकारी से, साइट पर दिखाए जाने वाले विज्ञापनों की परफ़ॉर्मेंस का पता लगाने में मदद मिलती है. विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, क्रॉस-साइट ट्रैकिंग को रोकता है. इसके लिए एपीआई, साइटों को आपस में कम से कम जानकारी शेयर करने देता है.</translation>
<translation id="8655983536493871574">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में Windows 10 या उसके बाद वाला वर्शन होना चाहिए. इस कंप्यूटर में Windows 8 का इस्तेमाल किया जा रहा है.</translation>
<translation id="3590393640971125498">EcosiaOS Flex की शर्तें</translation>
<translation id="864244542982029641">फिर भी Ecosia छोड़ें?</translation>
<translation id="3791194915692553395">EcosiaOS Flex को <ph name="BEGIN_LINK_LINUX_OSS"/>Linux डेवलपमेंट एनवायरमेंट<ph name="END_LINK_LINUX_OSS"/> की तरह, अतिरिक्त <ph name="BEGIN_LINK_CROS_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_CROS_OSS"/> की मदद से बनाया गया है.</translation>
<translation id="2120620239521071941">ऐसा करने से इस डिवाइस से <ph name="ITEMS_COUNT"/> आइटम मिट जाएंगे. बाद में अपना डेटा पाने के लिए, Chrome में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="2159716220295742156">&amp;Ecosia को अपडेट करने के लिए फिर से लॉन्च करें</translation>
<translation id="2123055963409958220"><ph name="BEGIN_LINK"/>अभी वाली सेटिंग<ph name="END_LINK"/> की रिपोर्ट करके Chrome को बेहतर बनाने में सहायता करें</translation>
<translation id="2126108037660393668">डाउनलोड की गई फ़ाइल की पुष्टि नहीं हो पाई.</translation>
<translation id="2985399486579137606">Ecosia की प्रोफ़ाइलें मैनेज करें</translation>
<translation id="2131230230468101642">आपकी निजता को सुरक्षित रखने के लिए, हम आपकी पसंद के उन विषयों को ऑटोमैटिकली मिटा देते हैं जिनका अनुमान चार हफ़्ते पहले लगाया गया था. ब्राउज़ करते रहने पर, आपकी पसंद का कोई विषय, सूची में फिर से शामिल किया जा सकता है. इसके अलावा, आपके पास उन विषयों को हटाने का भी विकल्प होता है जिन्हें आपको Chrome की सूची में शामिल नहीं करवाना है.</translation>
<translation id="5404489723475681578">EcosiaOS को रीस्टार्ट करें</translation>
<translation id="5982672133249369264">कृपया Ecosia को अभी रीस्टार्ट करें</translation>
<translation id="2174917724755363426">इंस्टॉल करने की प्रोसेस पूरी नहीं हुई. क्या आपको वाकई इसे रद्द करना है?</translation>
<translation id="2190166659037789668">अपडेट जांच में यह गड़बड़ी है: <ph name="UPDATE_CHECK_ERROR"/>.</translation>
<translation id="2199691482078155239">Chrome, आपको विज्ञापन देखने पर ज़्यादा कंट्रोल देता है. साथ ही, यह तय करता है कि साइटें, आपको आपकी दिलचस्पी के मुताबिक विज्ञापन दिखाने के लिए आपके बारे में क्या जानकारी सेव कर सकती हैं.</translation>
<translation id="7347725536241560534">Ecosia से अपना Ecosia खाता हटाने के लिए, साइन आउट करें</translation>
<translation id="223889379102603431">इस बारे में जानकारी कि Chrome अपने रूट सर्टिफ़िकेट कैसे मैनेज करता है</translation>
<translation id="4337034173783952373">अपने सभी डिवाइसों पर, Ecosia ब्राउज़र से जुड़ी सुविधाएं ऐक्सेस करने के लिए, साइन इन करें. इसके बाद, सिंक करने की सुविधा चालू करें</translation>
<translation id="4735588186234302898">Ecosia API (एपीआई) कुंजियां मौजूद नहीं हैं. Ecosia के कुछ फ़ंक्शन बंद कर दिए जाएंगे.</translation>
<translation id="7908111389403807005">क्या आप वाकई Ecosia को विस्थापित करना चाहते हैं?</translation>
<translation id="2309047409763057870">यह Google Chrome का द्वितीयक इंस्टॉलेशन है और इसे आपका डिफ़ॉल्ट ब्राउज़र नहीं बनाया जा सकता.</translation>
<translation id="7613817989637275906">Ecosia को पता चला है कि इन आइटम में मैलवेयर है:</translation>
<translation id="7273750863406285983">Ecosia को इस साइट के लिए आपका कैमरा और माइक्रोफ़ोन एक्सेस करने की अनुमति चाहिए</translation>
<translation id="234869673307233423">Chrome आपके पासवर्ड की जांच नहीं कर सकता. बाद में कोशिश करें.</translation>
<translation id="5707346538075088068">इस प्रोफ़ाइल का इस्तेमाल करने के दौरान Ecosia में जनरेट किए गए किसी भी तरह के डेटा (जैसे कि बुकमार्क बनाना, इतिहास, पासवर्ड, और दूसरी सेटिंग) को वर्क प्रोफ़ाइल का एडमिन हटा सकता है. <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">जारी रखें</translation>
<translation id="2390624519615263404">सुरक्षा से जुड़ी सुविधाएं देखें</translation>
<translation id="3959732324458144441">EcosiaOS सिस्टम</translation>
<translation id="2526043366208696235">{NUM_DEVICES,plural, =0{एक या उससे ज़्यादा Ecosia एक्सटेंशन, 1 एचआईडी डिवाइस को ऐक्सेस कर रहे थे}=1{एक या उससे ज़्यादा Ecosia एक्सटेंशन, 1 एचआईडी डिवाइस को ऐक्सेस कर रहे हैं}one{एक या उससे ज़्यादा Ecosia एक्सटेंशन, # एचआईडी डिवाइस को ऐक्सेस कर रहे हैं}other{एक या उससे ज़्यादा Ecosia एक्सटेंशन, # एचआईडी डिवाइसों को ऐक्सेस कर रहे हैं}}</translation>
<translation id="8172133981892685841">यह एक्सटेंशन, Ecosia Web Store की नीति का उल्लंघन करता है और यह खतरनाक हो सकता है. इसे Ecosia से हटाएं, ताकि यह उन साइटों का डेटा न देख सके और न उसमें बदलाव कर सके जिन पर विज़िट किया जाता है. इस डेटा में आपकी निजी जानकारी भी शामिल है.</translation>
<translation id="3632544319066562282">Ecosia आपके पासवर्ड निर्यात करना चाहता है. इसकी मंज़ूरी देने के लिए अपना Windows पासवर्ड लिखें.</translation>
<translation id="3077076541395306362">इस एक्सटेंशन में मैलवेयर है और यह खतरनाक है. इसे Ecosia से हटाएं, ताकि यह उन साइटों का डेटा न देख सके और न उसमें बदलाव कर सके जिन पर विज़िट किया जाता है. इस डेटा में आपकी निजी जानकारी भी शामिल है.</translation>
<translation id="2485422356828889247">विस्थापित करें</translation>
<translation id="2513154137948333830">सिस्टम फिर से चालू करना होगा: <ph name="INSTALL_SUCCESS"/></translation>
<translation id="2534365042754120737">आपके डेटा की सुरक्षा के लिए, Chrome को उन साइटों को मिली हुई अनुमतियां हटाने दें जिन पर आपने हाल ही में विज़िट नहीं किया है. इससे सूचनाएं पाने की सुविधा बंद नहीं होती.</translation>
<translation id="2280934980919215876"><ph name="TIMEOUT_DURATION"/> तक Ecosia का इस्तेमाल न करने पर, आपका संगठन इसे बंद कर देता है. ब्राउज़िंग डेटा मिटाया गया. इसमें ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं.</translation>
<translation id="2559253115192232574">Chrome जब आपकी पसंद का अनुमान लगा लेता है, तब आपके किसी दूसरी साइट पर जाने पर, वह साइट Chrome से आपकी पसंद जानने की अनुमति मांग सकती है. साइट यह अनुमति इसलिए मांगती है, ताकि वह आपको आपकी पसंद के हिसाब से विज्ञापन दिखा सके. Chrome आपकी पसंद के ज़्यादा से ज़्यादा तीन विषयों की जानकारी शेयर कर सकता है.</translation>
<translation id="2563121210305478421">Chrome को फिर से लॉन्च करें?</translation>
<translation id="2569974318947988067">Chrome, नेविगेशन को एचटीटीपीएस पर अपग्रेड करने की कोशिश करेगा</translation>
<translation id="7527831132809333552">आपका संगठन Ecosia को मैनेज करता है</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> इस Ecosia प्रोफ़ाइल में पहले से साइन इन है. आपकी निजी ब्राउज़िंग के लिए, Ecosia आपकी खुद की प्रोफ़ाइल बना सकता है.</translation>
<translation id="80155189677487610">Ecosia के उस वर्शन के समान वर्शन को इंस्‍टॉल नहीं कर सकता, जो वर्तमान में चल रहा है. कृपया Ecosia बंद करें और फिर से प्रयास करें.</translation>
<translation id="2586406160782125153">ऐसा करने से इस डिवाइस से आपका ब्राउज़िंग डेटा मिट जाएगा. बाद में अपना डेटा पाने के लिए, Chrome में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="6391863622742187823">Ecosia ब्राउज़र से जुड़ी सुविधाओं को <ph name="ACCOUNT_EMAIL"/> से ऐक्सेस करें</translation>
<translation id="259935314519650377">डाउनलोड किए गए इंस्टॉलर को कैश मेमोरी में सेव नहीं किया जा सका. गड़बड़ी: <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="2622559029861875898">Chrome, अपडेट की जांच नहीं कर सकता. अपने इंटरनेट कनेक्शन की जांच करें.</translation>
<translation id="5656828929762509280">Ecosia के लिए उपलब्ध एक्सटेंशन की मदद से ज़्यादा काम करें</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="2649768380733403658">Chrome, समय-समय पर जांच करके यह पक्का करता है कि आपके ब्राउज़र की सेटिंग सबसे सुरक्षित हैं. अगर किसी चीज़ की समीक्षा ज़रूरी होगी, तो हम आपको इसकी सूचना देंगे.</translation>
<translation id="7774247008790177839">नए Ecosia &amp;टैब में लिंक खोलें</translation>
<translation id="9178613517891824246">Ecosia को क्रैश रिपोर्ट और <ph name="UMA_LINK"/> भेजकर Ecosia को बेहतर बनाने में मदद करें</translation>
<translation id="6154325450733409298"><ph name="URL"/> को Ecosia के नए टैब में खोलें.</translation>
<translation id="2738871930057338499">इंटरनेट से कनेक्ट नहीं किया जा सका. एचटीटीपी 403 फॉरबिडन रिस्पॉन्स दिख रहा है. कृपया अपने प्रॉक्सी कॉन्फ़िगरेशन की जांच करें.</translation>
<translation id="1676748966275099244">चेतावनी: Ecosia, एक्सटेंशन को आपका ब्राउज़िंग इतिहास रिकॉर्ड करने से नहीं रोक सकता. गुप्त मोड में इस एक्सटेंशन को बंद करने के लिए, इस विकल्प से चुने हुए का निशान हटाएं.</translation>
<translation id="1831192335802727557">Ecosia को इस साइट के लिए आपका माइक्रोफ़ोन एक्सेस करने की अनुमति चाहिए</translation>
<translation id="2770231113462710648">डिफ़ॉल्ट ब्राउज़र को इसमें बदलें:</translation>
<translation id="2775140325783767197">Chrome आपके पासवर्ड की जांच नहीं कर सकता. अपने इंटरनेट कनेक्शन की जांच करें.</translation>
<translation id="2797864378188255696">Gmail या YouTube जैसी Google की सेवाओं में <ph name="USER_EMAIL"/> से साइन इन करने पर, Chrome में इसी खाते से अपने-आप साइन इन किया जा सकता है</translation>
<translation id="2799223571221894425">फिर से लॉन्‍च करें</translation>
<translation id="2825024317344269723">खतरनाक साइट. Chrome ने सूचनाएं पाने की अनुमति हटा दी है.</translation>
<translation id="2846251086934905009">इंस्टॉल करने में गड़बड़ी हुई: इंस्टॉल करने की प्रोसेस पूरी नहीं हो सकी. इंस्टॉल करने की प्रोसेस रद्द की गई.</translation>
<translation id="2847461019998147611">Google Chrome इस भाषा में दिखाएं</translation>
<translation id="2853415089995957805">Chrome उन पेजों को पहले से लोड कर देता है जिन पर आपके जाने की संभावना हो. ऐसा इसलिए है, ताकि जब आप उन पर जाएं, तो वे ज़्यादा तेज़ी से लोड हो जाएं</translation>
<translation id="8109744984354428711">Ecosia लॉन्च हो रहा है...</translation>
<translation id="812798451698099271">इस खाते के साथ एक Ecosia प्रोफ़ाइल पहले से मौजूद है</translation>
<translation id="3035352359183300151">जानें कि Ecosia कुछ फ़ाइलों को डाउनलोड होने से क्यों रोकता है</translation>
<translation id="2861074815332034794">Chrome को अपडेट किया जा रहा है (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="727568860157522676">आप Ecosia में प्रवेश हैं.</translation>
<translation id="2876628302275096482"><ph name="BEGIN_LINK"/>Chrome आपके डेटा को निजी कैसे रखता है<ph name="END_LINK"/>, इसके बारे में ज़्यादा जानें</translation>
<translation id="2885378588091291677">काम का मैनेजर</translation>
<translation id="2888126860611144412">Chrome के बारे में</translation>
<translation id="29082080693925013">अपने टैब व्यवस्थित रखने के लिए, अक्सर विज़िट की जाने वाली साइटों को पिन करें और टैब को ग्रुप में व्यवस्थित करें</translation>
<translation id="2915996080311180594">बाद में रीस्टार्ट करें</translation>
<translation id="2926676257163822632">कमज़ोर पासवर्ड का अंदाज़ा लगाना आसान होता है. Chrome को <ph name="BEGIN_LINK"/>आपके लिए मज़बूत पासवर्ड बनाने और उन्हें याद रखने की अनुमति दें<ph name="END_LINK"/>.</translation>
<translation id="219546601381787154">Ecosia को इस साइट के लिए, कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="2928420929544864228">इंस्टॉल हो गया.</translation>
<translation id="2929907241665500097">किसी गड़बड़ी की वजह से Chrome अपडेट नहीं हुआ. <ph name="BEGIN_LINK"/>Chrome को अपडेट करने से जुड़ी समस्याएं और नहीं हो पाने वाले अपडेट ठीक करें.<ph name="END_LINK"/></translation>
<translation id="2945997411976714835">इंस्टॉल करने में गड़बड़ी हुई: इंस्टॉल करने की प्रोसेस शुरू नहीं हो सकी.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - नेटवर्क में Ecosia से साइन-इन करें</translation>
<translation id="8696852719113991652">Ecosia से अपना Ecosia खाता हटाने के लिए, सेटिंग पेज में जाकर Ecosia से साइन आउट करें</translation>
<translation id="5405885279794834338">Ecosia से भी डेटा मिटाएं (<ph name="URL"/>)</translation>
<translation id="5622643576877267490">&amp;EcosiaOS Flex को अपडेट करने के लिए, इसे फिर से लॉन्च करें</translation>
<translation id="2234042158691635795">Ecosia पृष्ठभूमि मोड में है.</translation>
<translation id="3038232873781883849">इंस्टॉल करने की प्रोसेस, कुछ देर में शुरू होगी...</translation>
<translation id="3059710691562604940">सुरक्षित ब्राउज़िंग की सुविधा बंद है. Chrome इसे चालू करने का सुझाव देता है.</translation>
<translation id="780008372122710391">Ecosia Password Manager को फटाफट ऐक्सेस करने के लिए, शॉर्टकट का इस्तेमाल करें. आपके पास, अपने शॉर्टकट को कंप्यूटर की होम स्क्रीन पर या ऐप्लिकेशन लॉन्चर पर ले जाने का विकल्प है.</translation>
<translation id="385080958066798123">Ecosia टैब</translation>
<translation id="3080151273017101988">Google Chrome के बंद होने पर बैकग्राउंड में चल रहे ऐप्लिकेशन काम करते रहें</translation>
<translation id="3100998948628680988">अपनी Chrome प्रोफ़ाइल को नाम दें</translation>
<translation id="7051119589302096163">Ecosia ने इस डाउनलोड को ब्लॉक कर दिया है, क्योंकि यह फ़ाइल आम तौर पर डाउनलोड नहीं की जाती और यह खतरनाक हो सकती है</translation>
<translation id="3114643501466072395">डेटा के गलत इस्तेमाल और सुरक्षा की अन्य समस्याओं से आपके दूसरे पासवर्ड सुरक्षित हैं या नहीं, इसकी जांच करने के लिए, <ph name="BEGIN_LINK"/>Chrome में साइन इन करें<ph name="END_LINK"/>.</translation>
<translation id="231621248561775155">Ecosia ने इस डाउनलोड को ब्लॉक किया है, क्योंकि संग्रहित फ़ाइल में अन्य फ़ाइलें भी शामिल होती हैं. इन फ़ाइलों में मैलवेयर हो सकता है</translation>
<translation id="1722634673917783018">अगली बार जब आप Ecosia फिर से लॉन्‍च करेंगे तो आपके बदलाव लागू होंगे.</translation>
<translation id="2636091632287013185">Ecosia ऐप्स</translation>
<translation id="7580831958727159171">ट्रायल के दौरान, आपके पास पसंद के उन विषयों को देखने और हटाने का विकल्प होता है जिनका इस्तेमाल करके साइटें आपको विज्ञापन दिखाती हैं. Ecosia उन विषयों का अनुमान लगाता है जो आपको दिलचस्प लग सकते हैं. यह अनुमान आपके हाल के ब्राउज़िंग इतिहास के आधार पर लगाया जाता है.</translation>
<translation id="9068280473864300215">Ecosia ने इस डाउनलोड को ब्लॉक कर दिया है, क्योंकि यह फ़ाइल खतरनाक है</translation>
<translation id="3226612997184048185">अगर आपने बुकमार्क Google खाते में भी सेव किए हैं, तो आपको Chrome में प्रॉडक्ट की कीमतें ट्रैक करने का विकल्प मिलेगा. साथ ही, प्रॉडक्ट की कीमत में गिरावट आने पर आपको सूचना दी जाएगी</translation>
<translation id="3234642784688107085">थीम बनाने, लिखने में मदद पाने, और टैब व्यवस्थित करने के लिए, एआई की नई सुविधाएं आज़माएं</translation>
<translation id="3245429137663807393">अगर Chrome के इस्तेमाल से जुड़ी जानकारी देने वाली रिपोर्ट भी शेयर की जाती हैं, तो याद रखें कि आपके देखे गए पेजों के यूआरएल उनमें शामिल होते हैं</translation>
<translation id="3261565993776444564">अपने ब्राउज़र को पसंद के मुताबिक बनाने के लिए, नए रंग वाली थीम आज़माकर देखें</translation>
<translation id="2388751143175762498">Ecosia में साइन इन करें</translation>
<translation id="3286538390144397061">अभी फिर से प्रारंभ करें</translation>
<translation id="8268239447047453615">इसके बाद, आपको Ecosia को रीस्टार्ट करना होगा.</translation>
<translation id="9090890391337853620">Ecosia सहायक</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia अभी फिर से लॉन्च होगा}=1{Ecosia 1 सेकंड में फिर से लॉन्च होगा}one{Ecosia # सेकंड में फिर से लॉन्च होगा}other{Ecosia # सेकंड में फिर से लॉन्च होगा}}</translation>
<translation id="7280797724682955539">स्थापित करने के दौरान ऑपरेटिंग सिस्टम में गड़बड़ी आई. कृपया Ecosia फिर से डाउनलोड करें.</translation>
<translation id="3428747202529429621">अगर आप Chrome में साइन इन हैं, तो यह सुविधा आपको सुरक्षित रखती है. साथ ही, अन्य Google ऐप्लिकेशन में इसका इस्तेमाल सुरक्षा को बेहतर बनाने में भी हो सकता है</translation>
<translation id="3434246496373299699">आप जब अपने Google खाते से साइन इन करते हैं, तब Chrome आपके पासवर्ड की जांच कर सकता है</translation>
<translation id="6094573000614590044">अपने सभी डिवाइसों से पासवर्ड वगैरह ऐक्सेस करने के लिए, Ecosia में साइन इन करें</translation>
<translation id="5032126307005935789">यह फ़ाइल खतरनाक हो सकती है<ph name="LINE_BREAK"/>पासवर्ड देने पर, Ecosia आपके लिए इस डाउनलोड की जांच कर सकता है. फ़ाइल की जानकारी, Ecosia सुरक्षित ब्राउज़िंग को भेजी जाती है. हालांकि, फ़ाइल का कॉन्टेंट और पासवर्ड आपके डिवाइस पर ही रहता है.</translation>
<translation id="1762318218111418450">Ecosia में जोड़ा जा रहा है...</translation>
<translation id="6761747850241550887">स्वयं को Ecosia में जोड़ें</translation>
<translation id="2149148292984034533">EcosiaOS शर्तें</translation>
<translation id="6558895515431832002">इस साइट से आपकी जगह की जानकारी शेयर करने के लिए Ecosia को आपकी जगह की जानकारी का एक्सेस चाहिए</translation>
<translation id="3533694711092285624">सेव किया हुआ कोई भी पासवर्ड नहीं है. Chrome आपके पासवर्ड की जांच तब कर सकता है, जब आप उन्हें सेव करें.</translation>
<translation id="3541482654983822893">Chrome आपके पासवर्ड की जांच नहीं कर सकता. 24 घंटे बाद कोशिश करें.</translation>
<translation id="7881897052591031502">Ecosia में साइन इन करने पर, बुकमार्क, पासवर्ड वगैरह सेव किए जा सकते हैं और फ़ोन पर इस्तेमाल किए जा सकते हैं</translation>
<translation id="8901409988302458368">आपके सिस्टम एडमिन ने Ecosia को इस तरह कॉन्फ़िगर किया है कि वह <ph name="TARGET_URL_HOSTNAME"/> को ऐक्सेस करने के लिए कोई दूसरा ब्राउज़र खोले.</translation>
<translation id="7174674455569790401">Ecosia को अपने सभी डिवाइस पर सिंक करें और मनमुताबिक बनाएं</translation>
<translation id="8403827649521531901">आपने पहले से ही Ecosia की किसी दूसरी प्रोफ़ाइल में, <ph name="USER_EMAIL_ADDRESS"/> के तौर पर साइन इन किया हुआ है</translation>
<translation id="3260765223735049374">क्या आपको Ecosia में नई प्रोफ़ाइल बनाकर साइन इन करना है?</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें}=1{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}other{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="3597003331831379823">खास सुविधाओं का ऐक्सेस होने के बाद भी, सेटअप नहीं किया जा सका. <ph name="METAINSTALLER_ERROR"/></translation>
<translation id="3609788354808247807">आपने हाल ही में वेबसाइट का इस्तेमाल नहीं किया है. Chrome ने <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/>, और <ph name="PERMISSION_3"/> की अनुमति हटा दी है</translation>
<translation id="464306605599005355">अब अपने Ecosia खाते के साथ और शेयर किए गए कंप्यूटर पर Ecosia का उपयोग करना आसान हो गया है.</translation>
<translation id="3635073343384702370">पासवर्ड सेव करने पर ही, Chrome आपके पासवर्ड की जांच कर सकता है</translation>
<translation id="3667616615096815454">इंस्टॉल नहीं किया जा सका, सर्वर के पास ऐप्लिकेशन की जानकारी उपलब्ध नहीं है.</translation>
<translation id="1490060441084292633">Ecosia को पता चला है कि "<ph name="EXTENSION_NAME"/>" में मैलवेयर है</translation>
<translation id="3695446226812920698">तरीका जानें</translation>
<translation id="6967821869905227561">Ecosia की अन्य प्रोफ़ाइलें</translation>
<translation id="5311911269004680646"><ph name="BEGIN_LINK_LINUX_OSS"/>Linux डेवलपमेंट एनवायरमेंट<ph name="END_LINK_LINUX_OSS"/> की तरह, EcosiaOS को भी अतिरिक्त <ph name="BEGIN_LINK_CROS_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_CROS_OSS"/> की मदद से बनाया गया है.</translation>
<translation id="3716540481907974026">ChromeOS Flex का वर्शन</translation>
<translation id="3718181793972440140">ऐसा करने से इस डिवाइस से 1 आइटम मिट जाएगा. बाद में अपना डेटा पाने के लिए, Chrome में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Ecosia का सुझाव है कि आप यह एक्सटेंशन हटा दें. <ph name="BEGIN_LINK"/>Ecosia पर इस्तेमाल किए जा सकने वाले एक्सटेंशन के बारे में ज़्यादा जानें<ph name="END_LINK"/>}one{Ecosia का सुझाव है कि आप यह एक्सटेंशन हटा दें. <ph name="BEGIN_LINK"/>Ecosia पर इस्तेमाल किए जा सकने वाले एक्सटेंशन के बारे में ज़्यादा जानें<ph name="END_LINK"/>}other{Ecosia का सुझाव है कि आप ये एक्सटेंशन हटा दें. <ph name="BEGIN_LINK"/>Ecosia पर इस्तेमाल किए जा सकने वाले एक्सटेंशन के बारे में ज़्यादा जानें<ph name="END_LINK"/>}}</translation>
<translation id="3744202345691150878">ChromeOS से जुड़ी सहायता पाएं</translation>
<translation id="4600924482853773728">Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="4969069484658032230">EcosiaOS Flex आपके डेटा को सिंक नहीं कर सका, क्योंकि साइन इन करने के दौरान कोई गड़बड़ी हुई है.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="2829233304432701500">Ecosia के लिए, आपके डिवाइस में Windows 10 या उसके बाद का वर्शन होना चाहिए.</translation>
<translation id="3952510753191144456">इससे <ph name="USER_EMAIL_ADDRESS"/> के लिए एक नई Ecosia प्रोफ़ाइल बन जाएगी</translation>
<translation id="4019094010333463261">Ecosia को ब्लूटूथ का ऐक्सेस चाहिए, ताकि वह ब्लूटूथ डिवाइस ढूंढ पाए. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="8534308095039131078">कृपया सभी Ecosia विंडो बंद करें और फिर से प्रयास करें.</translation>
<translation id="3865754807470779944">Chrome वर्शन <ph name="PRODUCT_VERSION"/> इंस्टॉल है</translation>
<translation id="8283315171506895091">Ecosia गु&amp;प्त विंडो में लिंक खोलें</translation>
<translation id="6496553866814956056">Ecosia को विस्थापित करें</translation>
<translation id="3941890832296813527">इंस्टॉल करने में गड़बड़ी हुई: इंस्टॉलर की फ़ाइल का नाम अमान्य है या इस नाम का इस्तेमाल नहीं किया जा सकता.</translation>
<translation id="4459596553899864514">Ecosia, आपके Ecosia Password Manager के डेटा को मिटाना चाहता है. इसकी अनुमति देने के लिए, Windows का पासवर्ड डालें.</translation>
<translation id="8846463365332065180">परफ़ॉर्मेंस को बेहतर बनाने वाली सुविधाओं की मदद से Ecosia तेज़ी से काम करता है</translation>
<translation id="1118786556671181978">आपके पास अपनी पसंद के उन विषयों को देखने और हटाने का विकल्प होता है जिनका इस्तेमाल करके, साइटें आपको विज्ञापन दिखाती हैं. Ecosia आपके हाल के ब्राउज़िंग इतिहास के आधार पर, आपकी पसंद के विषयों का अनुमान लगाता है.</translation>
<translation id="8047394653992042491">अपडेट लागू करने के लिए, EcosiaOS को रीस्टार्ट करना होगा.</translation>
<translation id="4050175100176540509">महत्‍वपूर्ण सुरक्षा सुधार और नई सुविधाएं नवीनतम वर्शन में उपलब्‍ध हैं.</translation>
<translation id="4817913198787198451">Ecosia को पसंद के मुताबिक बनाएं और कंट्रोल करें</translation>
<translation id="4395802781633621239">अपने सभी डिवाइसों से पासवर्ड वगैरह ऐक्सेस करने के लिए, Ecosia में साइन इन करें. इसके बाद, यह पासवर्ड आपके Ecosia खाते में सेव हो जाएगा.</translation>
<translation id="1330085168384841023">विंडो शेयर करने के लिए, 'सिस्टम की सेटिंग' में जाकर Ecosia के लिए स्क्रीन रिकॉर्ड करने की अनुमति दें.</translation>
<translation id="3708834841667355707">Ecosia नई सुविधाओं पर काम कर रहा है. इनकी मदद से साइटें, आपकी निजी जानकारी का कम से कम इस्तेमाल करने के बावजूद, आपको ब्राउज़िंग का पहले जैसा अनुभव दे पाएंगी</translation>
<translation id="319566061277127356">Ecosia पर अपनी नई प्रोफ़ाइल सेट अप करें</translation>
<translation id="7433581196371819898">Ecosia, इस एक्सटेंशन के सोर्स की पुष्टि नहीं कर सका. यह खतरनाक भी हो सकता है. इसे Ecosia से हटाएं, ताकि यह उन साइटों का डेटा न देख सके और न उसमें कोई बदलाव कर सके जिन पर विज़िट किया जाता है. इस डेटा में निजी जानकारी भी शामिल है.</translation>
<translation id="2198589091447191935">Ecosia तेज़ी से काम करता है और JavaScript का इस्तेमाल करने वाली सुविधाएं डिज़ाइन के मुताबिक काम करनी चाहिए (हम इसका सुझाव देते हैं)</translation>
<translation id="7105712012505419722">आप प्रबंधित खाते से साइन इन कर रहे हैं और उसके एडमिन को अपनी Ecosia प्रोफ़ाइल पर नियंत्रण दे रहे हैं. आपका Ecosia डेटा, जैसे आपके ऐप्लिकेशन, बुकमार्क, इतिहास, पासवर्ड, और दूसरे सेटिंग <ph name="USER_NAME"/> से स्थायी रूप से जुड़ जाएंगे. आप Ecosia खाता डैशबोर्ड से इस डेटा को मिटा सकेंगे, लेकिन आप किसी दूसरे खाते से इस डेटा को जोड़ नहीं सकेंगे. <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">इंस्‍टॉल हो रहा है...</translation>
<translation id="7691143774653486474">इंस्टॉलर, संग्रह को विस्तारित करने में विफल हुआ. कृपया Ecosia फिर से डाउनलोड करें.</translation>
<translation id="2446603005062458629">Ecosia जल्द ही बंद हो जाएगा और डेटा को मिटा देगा</translation>
<translation id="4173512894976930765">ऐसा हो सकता है कि साइटें उम्मीद के मुताबिक काम करें. Chrome की सभी विंडो बंद करने पर, आपको ज़्यादातर साइटों से साइन आउट कर दिया जाएगा. हालांकि, अगर आपने Chrome में साइन इन किया हुआ है, तो आपको Google खाते से साइन आउट नहीं किया जाएगा.</translation>
<translation id="2745180350547322293">Ecosia ने इस डाउनलोड को ब्लॉक कर दिया है, क्योंकि यह साइट सुरक्षित कनेक्शन का इस्तेमाल नहीं कर रही है और हो सकता है कि फ़ाइल के साथ छेड़छाड़ की गई हो</translation>
<translation id="6826163993811146231">{0,plural, =1{एक दिन के अंदर Ecosia को फिर से लॉन्च करें}one{# दिनों के अंदर Ecosia को फिर से लॉन्च करें}other{# दिनों के अंदर Ecosia को फिर से लॉन्च करें}}</translation>
<translation id="4205939740494406371">Chrome आपके पासवर्ड की जांच नहीं कर सकता. 24 घंटे बाद कोशिश करें या <ph name="BEGIN_LINK"/>अपने Google खाते के पासवर्ड की जांच करें<ph name="END_LINK"/>.</translation>
<translation id="4222932583846282852">रद्द किया जा रहा है...</translation>
<translation id="4224210481850767180">इंस्टॉल करने की प्रोसेस रद्द कर दी गई है.</translation>
<translation id="3554373328288278512">Ecosia को इस साइट के लिए, माइक्रोफ़ोन और कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="424864128008805179">Chrome से साइन आउट करें?</translation>
<translation id="8384922154025337808">आपके Ecosia डेटा को इस खाते से लिंक करें?</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>किस डेटा का इस्तेमाल किया जाता है:<ph name="END_BOLD"/> आपका ब्राउज़िंग इतिहास, जिसमें इस डिवाइस पर Ecosia का इस्तेमाल करके देखी गई साइटों का रिकॉर्ड होता है.</translation>
<translation id="4281844954008187215">सेवा की शर्तें</translation>
<translation id="4293420128516039005">Chrome को अपने सभी डिवाइस पर सिंक करने और मनमुताबिक बनाने के लिए साइन इन करें</translation>
<translation id="6419542773162312746">Ecosia टूलबार में ऐक्सेस के अनुरोध दिखाने के लिए, एक्सटेंशन को अनुमति दें</translation>
<translation id="8864449561723972619">Ecosia डेवलपर (mDNS-In)</translation>
<translation id="4329315893554541805">मनमुताबिक अनुभव और अन्य सुविधाएं पाने के लिए, Chrome को 'वेब और ऐप्लिकेशन गतिविधि' सेटिंग और लिंक की गई Google की सेवाओं में शामिल करें</translation>
<translation id="4334294535648607276">डाउनलोड पूर्ण.</translation>
<translation id="4335235004908507846">Chrome आपको डेटा के गलत इस्तेमाल से बचाता है. साथ ही, यह नुकसान पहुंचाने वाले एक्सटेंशन जैसी कई चीज़ाें से भी आपकी सुरक्षा करता है</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> को Ecosia में जोड़ दिया गया है</translation>
<translation id="4348548358339558429">मनमुताबिक अनुभव पाने के लिए, 'वेब और ऐप्लिकेशन गतिविधि' सेटिंग में Chrome को शामिल करें</translation>
<translation id="197803137365953132">Ecosia ने इस डाउनलोड को ब्लॉक किया है, क्योंकि यह फ़ाइल आपके निजी और सोशल नेटवर्क खातों को नुकसान पहुंचा सकती है</translation>
<translation id="4384570495110188418">Chrome आपके पासवर्ड की जांच नहीं कर सकता, क्योंकि आपने साइन इन नहीं किया है</translation>
<translation id="4389991535395284064">गुप्त मोड में ब्राउज़ करते समय, असुरक्षित कनेक्शन का इस्तेमाल करके किसी भी साइट को लोड करने से पहले, Chrome आपको चेतावनी देगा</translation>
<translation id="4427306783828095590">बेहतर सुरक्षा की मदद से फ़िशिंग और मैलवेयर को बेहतर तरीके से ब्लॉक किया जाता है</translation>
<translation id="4434353761996769206">इंस्टॉलर से जुड़ी गड़बड़ी: <ph name="INSTALLER_ERROR"/></translation>
<translation id="2297526912548649074">Ecosia में <ph name="USER_EMAIL"/> से साइन इन करें</translation>
<translation id="9035946286843935549">Ecosia - नेटवर्क में साइन इन करें - <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">Ecosia पर कोई और क्रिया चल रही है. कृपया बाद में फिर से कोशिश करें.</translation>
<translation id="4459234553906210702">विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, आपकी देखी गई साइटों को अनुमति देता है कि वे Chrome से आपकी जानकारी पाने का अनुरोध कर सकें. इस जानकारी से, साइट पर दिखाए जाने वाले विज्ञापनों की परफ़ॉर्मेंस का पता लगाने में मदद मिलती है. विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, क्रॉस-साइट ट्रैकिंग को रोकता है. इसके लिए एपीआई, साइटों को आपस में कम से कम जानकारी शेयर करने देता है.</translation>
<translation id="4501471624619070934">इंस्टॉल नहीं हो पाया, क्योंकि इस देश में ऐक्सेस करने की अनुमति नहीं है.</translation>
<translation id="4567424176335768812">आपने <ph name="USER_EMAIL_ADDRESS"/> के रूप में साइन इन किया हुआ है. अब आप अपने सभी साइन इन किए हुए डिवाइस पर अपने बुकमार्क, इतिहास, और दूसरी सेटिंग को एक्सेस कर सकते हैं.</translation>
<translation id="6533266716128249922">Ecosia की सूचना सेटिंग पर जाएं</translation>
<translation id="7562371913339616107">Ecosia आपके ब्राउज़िंग अनुभव को बेहतर बनाने और संसाधनों को कम करने के लिए, इन टैब को बंद कर सकता है.</translation>
<translation id="488806616089631539">Ecosia को ऐक्सेस मिलने के बाद, वेबसाइटें आपसे ऐक्सेस मांग सकेंगी.</translation>
<translation id="3268039966078382323">Ecosia सबसे नए वर्शन में अपडेट नहीं कर सका, इसलिए आपको नई सुविधाएं और सुरक्षा सुधार नहीं मिल रहे हैं.</translation>
<translation id="4624065194742029982">Chrome का गुप्त मोड</translation>
<translation id="4690206707618474800">वैकल्पिक: EcosiaOS Flex को बेहतर बनाने में हमारी मदद करने के लिए, Ecosia को इसके इस्तेमाल से जुड़ा डेटा और इसकी परफ़ॉर्मेंस की जानकारी अपने-आप भेजने की सुविधा चालू करें.</translation>
<translation id="9125443060066914183">Ecosia को ज़्यादा सुरक्षित बनाने के लिए, हमने ऐसे कुछ एक्सटेंशन अक्षम कर दिए हैं जो <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> में सूचीबद्ध नहीं हैं और आपकी जानकारी के बिना जोड़े गए हो सकते हैं.</translation>
<translation id="4680828127924988555">इंस्टॉल करना रद्द करें</translation>
<translation id="8236553889322631924">नामालूम स्रोत से डाउनलोड किए गए एक्सटेंशन, ऐप्लिकेशन, और थीम से आपके डिवाइस को नुकसान पहुंच सकता है. हमारा सुझाव है कि आप इन्हें सिर्फ़ Ecosia वेब स्टोर से इंस्टॉल करें</translation>
<translation id="4710245680469034439">प्रकृति, कलाकारों के कलेक्शन वगैरह से जुड़ी थीम सेट करके, अपने ब्राउज़र को अपनी पसंद के मुताबिक बनाएं</translation>
<translation id="4724676981607797757">काम नहीं करने वाले प्रोटोकॉल की गड़बड़ी की वजह से इंस्टॉल नहीं हो सका.</translation>
<translation id="3305517118160815955">अनिर्दिष्ट कारण से स्थापना विफल हुई. अगर Ecosia अभी खुला हुआ है, तो कृपया उसे बंद करें और फिर से प्रयास करें.</translation>
<translation id="4747730611090640388">Chrome आपकी पसंद के विषयों का अनुमान लगा सकता है.  Chrome जब आपकी पसंद का अनुमान लगा लेता है, तब आपके किसी दूसरी साइट पर जाने पर, वह साइट Chrome से आपकी पसंद जानने की अनुमति मांग सकती है. साइट यह अनुमति इसलिए मांगती है, ताकि वह आपको आपकी पसंद के हिसाब से विज्ञापन दिखा सके.</translation>
<translation id="827222962844006655">Ecosia Canary (mDNS-In)</translation>
<translation id="3543284013834505767">इसमें स्पेलिंग जाँचने वाली उसी सुविधा का इस्तेमाल होता है जिसका इस्तेमाल 'Ecosia सर्च' में किया जाता है. आप ब्राउज़र में जो भी लेख लिखते हैं उसे Ecosia को भेजा जाता है. आप 'सेटिंग' में जाकर इसे कभी भी बदल सकते हैं.</translation>
<translation id="4793679854893018356">जानें कि Chrome आपको इंटरनेट पर कैसे सुरक्षित रखता है</translation>
<translation id="8957938953005153147">Ecosia, मौजूदा पासवर्ड बदलने की कोशिश कर रहा है. इसकी अनुमति देने के लिए, Windows का पासवर्ड डालें.</translation>
<translation id="8144706290339578682">EcosiaOS Flex आपके डेटा को सिंक नहीं कर सका, क्योंकि आपके डोमेन पर सिंक करने की सुविधा उपलब्ध नहीं है.</translation>
<translation id="7984841734836997333"><ph name="EXISTING_USER"/> ने पहले से साइन इन किया हुआ है. अलग ब्राउज़र का इस्तेमाल करने के लिए, Ecosia में अपनी प्रोफ़ाइल में <ph name="USER_EMAIL_ADDRESS"/> से साइन इन करें.</translation>
<translation id="4264506519284061030">आपका संगठन, आपकी वर्क प्रोफ़ाइल में मौजूद ब्राउज़िंग डेटा देख सकता है और उसे मैनेज कर सकता है. जैसे, आपके बुकमार्क, ब्राउज़िंग इतिहास, और पासवर्ड. हालांकि, वह Ecosia पर बनाई गई निजी प्रोफ़ाइलों से जुड़ा ब्राउज़िंग डेटा नहीं देख सकता.</translation>
<translation id="8701027951719712428">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में macOS 11 या इसके बाद का वर्शन इंस्टॉल होना चाहिए. फ़िलहाल, इस कंप्यूटर में macOS 10.15 का इस्तेमाल किया जा रहा है.</translation>
<translation id="4873783916118289636">Chrome के निजता और सुरक्षा से जुड़े मुख्य कंट्रोल देखें</translation>
<translation id="8454595950895325762">Ecosia को पृष्ठभूमि में चलने दें</translation>
<translation id="489671036945006830">नए Ecosia &amp;टैब में लिंक खोलें</translation>
<translation id="6566258574866003581">Ecosia आपको इस एक्सटेंशन की जांच करने का सुझाव देता है</translation>
<translation id="4951177103388687412">टैब ग्रुप की मदद से, अपने काम के टैब व्यवस्थित करें और अपने काम पर फ़ोकस करें</translation>
<translation id="5581150090232500900">Ecosia को अपने डिफ़ॉल्ट ब्राउज़र के रूप में सेट करना</translation>
<translation id="6495878830719404098">Ecosia में</translation>
<translation id="6113625922434842626">EcosiaOS Flex आपके डेटा को सिंक नहीं कर सका, क्योंकि आपके खाते में साइन इन करने से जुड़ी जानकारी पुरानी हो चुकी है.</translation>
<translation id="4410570812343670816">Ecosia प्रोफ़ाइलों में आपका स्वागत है</translation>
<translation id="4970880042055371251">ChromeOS वर्शन</translation>
<translation id="8570641140903702642">Ecosia कैनरी</translation>
<translation id="6735145163744656874">Ecosia आपके ब्राउज़िंग अनुभव को बेहतर बनाने और चीज़ों को आसान बनाए रखने के लिए, इन टैब को बंद कर सकता है.</translation>
<translation id="2569934116750022163">“Ecosia Password Manager” पर क्लिक करें</translation>
<translation id="5120334927898581447">Google की अन्य सेवाओं में साइन इन करते समय, Chrome में साइन इन करें</translation>
<translation id="5126049312684316860">Chrome ऐसे कई और पेजों को पहले से लोड करके रखता है जिन पर आपके जाने की संभावना होती है, ताकि जब आप उन पर जाएं, तो वे ज़्यादा तेज़ी से लोड हो जाएं</translation>
<translation id="7782767522222146179">Ecosia के लिए बेहतरीन ऐप्स ,गेम, एक्सटेंशन और थीम खोजें.</translation>
<translation id="6416551953415159186">अपनी Ecosia प्रोफ़ाइल को पसंद के मुताबिक बनाएं</translation>
<translation id="719484593754925816">Ecosia, ब्राउज़िंग के आपके अनुभव को बेहतर बनाने और संसाधनों को कम करने के लिए, इस टैब को बंद कर सकता है.</translation>
<translation id="1859120614572957305">Ecosia में आपका स्वागत है; नई ब्राउज़र विंडो खोली गई</translation>
<translation id="6648664289472946060">आपकी प्रोफ़ाइल का उपयोग नहीं किया जा सकता क्‍योंकि यह Ecosia के किसी नए वर्शन से है.

कुछ विशेषताएं अनुपलब्‍ध हो सकती हैं. कृपया कोई भिन्‍न प्रोफ़ाइल निर्देशिका बताएं या Ecosia के किसी नए वर्शन का उपयोग करें.</translation>
<translation id="5201744974236816379">Chrome अपडेट</translation>
<translation id="6960183526681645011">अगर आप कोई डिवाइस शेयर करते हैं, तो आपके दोस्त और परिवार के लोग अलग-अलग ब्राउज़ कर सकते हैं. साथ ही, Ecosia को अपने हिसाब से सेट कर सकते हैं</translation>
<translation id="3784023996375784431">मैसेज, दस्तावेज़ों, और अन्य ऐप्लिकेशन में मिले लिंक पर क्लिक करके, किसी भी समय Ecosia का इस्तेमाल करें</translation>
<translation id="1869027055332251164">अतिथि कोई पदचिह्न छोड़े बिना Ecosia का उपयोग कर सकते हैं.</translation>
<translation id="5320351714793324716">कुकी को अनुमति देने पर, Chrome उनका इस्तेमाल पेजों को पहले से लोड करते समय कर सकता है</translation>
<translation id="143614250230771428">EcosiaOS आपके डेटा को सिंक नहीं कर सका, क्योंकि आपके डोमेन पर सिंक करने की सुविधा उपलब्ध नहीं है.</translation>
<translation id="1809194740315140401">फ़ाइलें डाउनलोड करने के लिए, Ecosia को डिवाइस का स्टोरेज ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="8975930032513941502">आप चाहें, तो EcosiaOS को यह अनुमति दें कि वह गड़बड़ी की जानकारी और इस्तेमाल से जुड़ा डेटा Ecosia को अपने-आप भेज सके. आपके ऐसा करने से, EcosiaOS की सुविधाओं और परफ़ॉर्मेंस को बेहतर बनाने में मदद मिलेगी.</translation>
<translation id="5357889879764279201">ChromeOS Flex से जुड़ी समस्याओं के लिए मदद पाएं</translation>
<translation id="5368118228313795342">अतिरिक्त कोड: <ph name="EXTRA_CODE"/>.</translation>
<translation id="6665128960039431910">इससे यह भी नियंत्रित होता है कि जब आप Ecosia को चालू करते हैं या ऑम्निबॉक्स से खोजते हैं तब कौन सा पेज दिखाया जाए.</translation>
<translation id="1861504561909287316">Ecosia का टैब शेयर करें</translation>
<translation id="5412485296464121825">साइटें, Chrome पर आपकी पसंद के विषयों की जानकारी सेव कर सकती हैं. उदाहरण के लिए, अगर आपने किसी साइट पर मैराथन दौड़ के लिए जूते खोजे हैं, तो साइट, मैराथन दौड़ को आपकी पसंद के विषय के तौर पर सेव कर सकती है. बाद में, अगर आपने किसी दूसरी साइट पर जाकर दौड़ के लिए रजिस्ट्रेशन करवाया है, तो वह साइट आपकी पसंद के आधार पर दौड़ वाले जूते का विज्ञापन आपको दिखा सकती है.</translation>
<translation id="6673288084648462613">आपकी पसंदीदा फ़ाइल खराब या अमान्‍य है.

Ecosia आपकी सेटिंग बहाल नहीं कर सकता.</translation>
<translation id="5468572406162360320">इन सुविधाओं को बेहतर बनाने में मदद करने के लिए, Chrome उनके साथ होने वाले आपके इंटरैक्शन Google को भेजता है. इस डेटा को समीक्षा करने वाले व्यक्ति पढ़ सकते हैं, प्रोसेस कर सकते हैं, और इसकी व्याख्या कर सकते हैं.</translation>
<translation id="5524761631371622910">ट्रायल के दौरान, अगर Chrome ने आपको किसी मौजूदा ट्रायल में अपने-आप शामिल कर लिया है, तो आपके ब्राउज़िंग इतिहास का इस बात पर असर पड़ता है कि आपको कौनसे विज्ञापन दिखेंगे. साथ ही, यहां दिए गए आपकी पसंद के विषयों के अनुमान पर भी इसका असर पड़ता है. आपकी निजता को सुरक्षित रखने के लिए, Chrome हर महीने आपकी पसंद के विषयों को मिटा देता है.</translation>
<translation id="2905159584855395810">Ecosia को ज़्यादा तेज़ बनाएं</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="5167067155585861308">Ecosia का सुझाव है कि आप यह एक्सटेंशन हटा दें. <ph name="BEGIN_LINK"/>Ecosia पर इस्तेमाल किए जा सकने वाले एक्सटेंशन के बारे में ज़्यादा जानें<ph name="END_LINK"/></translation>
<translation id="7005470355724599337">आपको वेब पर सुरक्षित रखने के लिए, Ecosia और भी कई काम करता है</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/> खरतरनाक हो सकता है, इसलिए Ecosia ने उसे अवरोधित कर दिया है.</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें}=1{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}other{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए Ecosia को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="8544776492099331022">Ecosia को पसंद के मुताबिक बनाएं और कंट्रोल करें. यहां कुछ है जिस पर आपको ध्यान देने की ज़रूरत है - ब्यौरे/अधिक जानकारी के लिए क्लिक करें.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="569897634095159764">इंटरनेट से कनेक्ट नहीं किया जा सका. प्रॉक्सी सर्वर की पुष्टि करना ज़रूरी है.</translation>
<translation id="570005089986962444">इस सेटिंग के चालू होने पर Chrome, इस्तेमाल नहीं किए जा रहे टैब से मेमोरी खाली करता है. इससे इस्तेमाल किए जा रहे टैब और अन्य ऐप्लिकेशन को ज़्यादा कंप्यूटर रिसॉर्स मिलते हैं. साथ ही, Chrome तेज़ी से काम करता है. जब इस्तेमाल नहीं किए जा रहे टैब पर कोई वापस जाता है, तो वे अपने-आप फिर से चालू हो जाते हैं.</translation>
<translation id="5581150090232500900">Ecosia को अपने डिफ़ॉल्ट ब्राउज़र के तौर पर सेट करें</translation>
<translation id="5727531838415286053">अगर Chrome ने आपको किसी मौजूदा ट्रायल में अपने-आप शामिल कर लिया है, तो आपके ब्राउज़िंग इतिहास से इस बात पर असर पड़ता है कि आपको कौनसे विज्ञापन दिखेंगे. साथ ही, यहां दिए गए आपकी पसंद के विषयों के अनुमान पर भी इसका असर पड़ता है. आपकी निजता को सुरक्षित रखने के लिए, Chrome हर महीने आपकी पसंद के विषयों को मिटा देता है. पसंद के विषय तब तक रीफ़्रेश किए जाते हैं, जब तक उन्हें मिटाया नहीं जाता.</translation>
<translation id="5736850870166430177">अगर कोई साइट आपका पासवर्ड चुराने की कोशिश करती है या नुकसान पहुंचाने वाली कोई फ़ाइल डाउनलोड होने पर Chrome, सुरक्षित ब्राउज़िंग की सेवा को उनके यूआरएल भेज सकता है. यूआरएल के साथ-साथ पेज का कुछ कॉन्टेंट भी भेजा जाता है</translation>
<translation id="8301840715671593762">इस खाते से बनाई गई एक Ecosia प्रोफ़ाइल इस डिवाइस पर पहले से मौजूद है</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia कैनरी</translation>
<translation id="2542649989941327712">Ecosia लॉन्च नहीं किया जा सका. फिर से कोशिश करें.</translation>
<translation id="5809516625706423866">इंटरनेट से कनेक्ट नहीं किया जा सका. एचटीटीपी 401 अनऑथराइज़्ड कोड दिख रहा है. कृपया अपने प्रॉक्सी कॉन्फ़िगरेशन की जांच करें.</translation>
<translation id="9091453616111683919">Ecosia से <ph name="EXTENSION_NAME"/> हटाएं</translation>
<translation id="1773882594264682232">आपके साइन इन होने के दौरान, आपके पास Ecosia में अपने Ecosia खाते से पासवर्ड और अन्य चीज़ों का इस्तेमाल करने का विकल्प होता है. सेटिंग में जाकर इन्हें कभी भी बदला जा सकता है.</translation>
<translation id="5513857521842828996">Ecosia की सभी विंडो बंद करने पर, आपको ज़्यादातर साइटों से साइन आउट कर दिया जाएगा. हालांकि, अगर आपने Ecosia में साइन इन किया हुआ है, तो आपको Ecosia खाते से साइन आउट नहीं किया जाएगा. <ph name="SETTINGS_LINK"/>, ताकि साइटें आपके ब्राउज़िंग सेशन की जानकारी याद रखें.</translation>
<translation id="586971344380992563">असुरक्षित साइटों और डाउनलोड की गई फ़ाइलों के बारे में, <ph name="BEGIN_LINK"/>Chrome आपको चेतावनी देता है<ph name="END_LINK"/></translation>
<translation id="5895138241574237353">फिर से प्रारंभ करें</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - नेटवर्क में साइन इन करें</translation>
<translation id="5924017743176219022">इंटरनेट से कनेक्ट हो रहा है…</translation>
<translation id="5932997892801542621">Chrome, पता बार या खोज बॉक्स में आपके टाइप किए गए टेक्स्ट को Google Drive को भेजता है, ताकि आइटम के सुझाव पाए जा सकें. यह सुविधा गुप्त मोड में काम नहीं करती.</translation>
<translation id="4960252760049500399">आपके वेब, बुकमार्क और अन्य Ecosia सामग्री यहां मौजूद रहती है.</translation>
<translation id="5941711191222866238">छोटा करें</translation>
<translation id="4662363689050405237">Ecosia को सामान्य ब्राउज़र बनाएं</translation>
<translation id="1284343625991453987">Ecosia का शॉर्टकट</translation>
<translation id="5953954252731207958">आपने हाल ही में वेबसाइट का इस्तेमाल नहीं किया है. Chrome ने <ph name="PERMISSION"/> की अनुमति हटा दी है</translation>
<translation id="6003112304606738118">डाउनलोड हो रहा है... <ph name="HOURS"/> घंटे बचे हैं</translation>
<translation id="6014316319780893079"><ph name="BEGIN_LINK"/>Chrome के टूल<ph name="END_LINK"/> की मदद से, सुरक्षित तरीके से ब्राउज़िंग की जा सकती है. साथ ही, अपना डेटा भी कंट्रोल किया जा सकता है</translation>
<translation id="4767994371234572952">Ecosia को अपने मुताबिक बनाएं</translation>
<translation id="5490755016715767023">Ecosia <ph name="REMAINING_TIME"/> में रीस्टार्ट होगा</translation>
<translation id="6040143037577758943">बंद करें</translation>
<translation id="6070348360322141662">ज़्यादा सुरक्षा के लिए, Google Chrome आपका डेटा एनक्रिप्ट करेगा</translation>
<translation id="608006075545470555">इस ब्राउज़र में वर्क प्रोफ़ाइल जोड़ें</translation>
<translation id="6097822892606850415">एआई की मदद से पूरे आत्मविश्वास के साथ लिखें</translation>
<translation id="170259281605734125">Ecosia पहले से बेहतर हो गया है</translation>
<translation id="6134085236017727171">माइक्रोफ़ोन इस्तेमाल करने के लिए, <ph name="BEGIN_LINK"/>सिस्टम सेटिंग<ph name="END_LINK"/> में जाकर Chrome को इसे ऐक्सेस करने की अनुमति दें</translation>
<translation id="4618410489751241263">ये टैब ज़्यादा संसाधनों का इस्तेमाल कर रहे हैं. परफ़ॉर्मेंस को बेहतर बनाने के लिए, Ecosia को इन्हें बंद करने की अनुमति दें.</translation>
<translation id="6145313976051292476">Chrome में पीडीएफ़ खोलें</translation>
<translation id="5137471865755621561"><ph name="TIMEOUT_DURATION"/> तक Ecosia का इस्तेमाल न करने पर, आपका संगठन इसका डेटा मिटा देता है. इसमें ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं.</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - Ecosia</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia बीटा</translation>
<translation id="51576365410323372">यह टैब अतिरिक्त संसाधनों का इस्तेमाल कर रहा है. परफ़ॉर्मेंस को बेहतर बनाने के लिए, Ecosia को इसे बंद करने की अनुमति दें.</translation>
<translation id="6182736845697986886">अपडेट सर्वर में कोई गड़बड़ी होने की वजह से इंस्टॉल नहीं हो सका.</translation>
<translation id="6200139057479872438">आपने हाल ही में वेबसाइट का इस्तेमाल नहीं किया है. Chrome ने <ph name="PERMISSION_1"/> और <ph name="PERMISSION_2"/> की अनुमति हटा दी है</translation>
<translation id="7845247414826995986">स्क्रीन शेयर करने के लिए, 'सिस्टम की सेटिंग' में जाकर Ecosia के लिए स्क्रीन रिकॉर्ड करने की अनुमति दें.</translation>
<translation id="4154538917942874814">mDNS ट्रैफ़िक की अनुमति देने के लिए Ecosia के लिए इनबाउंड नियम.</translation>
<translation id="5736558630107498475">Ecosia जल्द ही बंद हो जाएगा</translation>
<translation id="8542320769345885402">Ecosia Password Manager</translation>
<translation id="6251759518630934363">यह सुविधा स्टैंडर्ड सुरक्षा मोड की तुलना में ज़्यादा डेटा का विश्लेषण करके, आपको ऐसी खतरनाक साइटों के बारे में चेतावनी देती है जिनके बारे में Google को पहले से नहीं पता था. Chrome की चेतावनियों को अनदेखा किया जा सकता है.</translation>
<translation id="8561406087076314604">आपके माता-पिता ने Ecosia के लिए, "साइटों, ऐप्लिकेशन, और एक्सटेंशन के लिए अनुमतियां" बंद कर दी हैं</translation>
<translation id="1818520302923047971">Ecosia को कंट्रोल करें और पसंद के मुताबिक बनाएं. Ecosia को अपने डिफ़ॉल्ट ब्राउज़र के तौर पर सेट करें.</translation>
<translation id="6669755086687029198">ऑनलाइन कोई काम करने, कुछ नया बनाने, और किसी विषय के बारे में बेहतर जानकारी खोजने के लिए, Ecosia को डिफ़ॉल्ट ब्राउज़र के तौर पर सेट करें</translation>
<translation id="675229436434399924">Ecosia डेवलपर ऐप्लिकेशन</translation>
<translation id="4870057811531036437">Ecosia आपके कंप्यूटर पर मौजूद सभी उपयोगकर्ताओं के लिए पहले से इंंस्टॉल है.</translation>
<translation id="378302976931789177">Ecosia को आपके आस-पास की जगहों को मैप करने और आपके हाथों को ट्रैक करने की अनुमति चाहिए</translation>
<translation id="790624108224468719">"<ph name="EXTENSION_NAME"/>" एक्सटेंशन का इस्तेमाल करने के लिए, आपको Ecosia में साइन इन करना होगा</translation>
<translation id="330264384086604869">Ecosia से हटाएं</translation>
<translation id="6327105987658262776">कोई अपडेट उपलब्ध नहीं है.</translation>
<translation id="7455175614937447568">टैब के इनऐक्टिव होने पर, मेमोरी खाली की गई थी, ताकि Ecosia को तेज़ी से ऐक्सेस किया जा सके. इस साइट को हमेशा ऐक्टिव रखने का विकल्प चुना जा सकता है.</translation>
<translation id="6412673304250309937">यह सेवा, Chrome में पहले से सेव असुरक्षित साइटों के साथ यूआरएल की जांच करती है. अगर कोई साइट आपका पासवर्ड चुराने की कोशिश करती है या कोई नुकसान पहुंचाने वाली फ़ाइल डाउनलोड की जाती है, तो Chrome सुरक्षित ब्राउज़िंग की सेवा को उनका यूआरएल भेजता है. यूआरएल के साथ-साथ उन पेजों का कुछ कॉन्टेंट भी भेजा जाता है.</translation>
<translation id="7757263274906217411">{COUNT,plural, =1{Ecosia का 1 मिनट तक इस्तेमाल न करने पर, आपका संगठन इसे अपने-आप बंद कर देता है. ब्राउज़िंग डेटा मिटा दिया जाता है. इसमें, ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं.}one{Ecosia का # मिनट तक इस्तेमाल न करने पर, आपका संगठन इसे अपने-आप बंद कर देता है. ब्राउज़िंग डेटा मिटा दिया जाता है. इसमें, ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं.}other{Ecosia का # मिनट तक इस्तेमाल न करने पर, आपका संगठन इसे अपने-आप बंद कर देता है. ब्राउज़िंग डेटा मिटा दिया जाता है. इसमें, ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं.}}</translation>
<translation id="4781882243268600858">क्या आप मौजूदा Ecosia प्रोफ़ाइल में स्विच करना चाहते हैं?</translation>
<translation id="6473905796280459355">'Chrome के बारे में जानकारी' पेज पर जाएं</translation>
<translation id="2455767468864733533">Ecosia Web Store पर जाएं</translation>
<translation id="6481963882741794338">मनमुताबिक अनुभव और अन्य सुविधाएं पाने के लिए, Chrome को Google की अन्य सेवाओं के साथ लिंक करें</translation>
<translation id="648319183876919572">बेहतर सुरक्षित ब्राउज़िंग की सुविधा, आपको नुकसान पहुंचाने वाली वेबसाइटों और डाउनलोड से बचाती है</translation>
<translation id="8419312540998601274">चालू है • Ecosia इस एक्सटेंशन के सोर्स की पुष्टि नहीं कर सकता</translation>
<translation id="1251415775728969647">Ecosia, <ph name="AUTHENTICATION_PURPOSE"/> की कोशिश कर रहा है</translation>
<translation id="5061261337583604526">Ecosia अपने-आप बंद हो गया था</translation>
<translation id="2537426042760364251">आपके आस-पास की जगहों का 3D मैप बनाने के लिए, Ecosia को कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia डेवलपर</translation>
<translation id="6520670145826811516">जगह की जानकारी इस्तेमाल करने के लिए, <ph name="BEGIN_LINK"/>सिस्टम सेटिंग<ph name="END_LINK"/> में जाकर Chrome को इसे ऐक्सेस करने की अनुमति दें</translation>
<translation id="5357908757303442841">इस डिवाइस पर Ecosia पासवर्ड मैनेजर में</translation>
<translation id="8859253218356192164">EcosiaOS Flex को अतिरिक्त <ph name="BEGIN_LINK_CROS_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_CROS_OSS"/> की मदद से बनाया गया है.</translation>
<translation id="1485302026917450654">क्या आपको Ecosia में साइन इन करना है?</translation>
<translation id="6676384891291319759">इंटरनेट एक्सेस करें</translation>
<translation id="4586967042094107073">Ecosia को बैकग्राउंड में चलने दें</translation>
<translation id="2173571365716863400">Ecosia को इस साइट के लिए, माइक्रोफ़ोन ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="6712881677154121168">डाउनलोड करने में गड़बड़ी: <ph name="DOWNLOAD_ERROR"/>.</translation>
<translation id="6161025257729272170">Ecosia को ज़्यादा तेज़ बनाएं</translation>
<translation id="9165312115453649251">EcosiaOS Flex सिस्टम</translation>
<translation id="8685318202174822382">क्या आप नई Ecosia प्रोफ़ाइल में ब्राउज़िंग जारी रखना चाहते हैं?</translation>
<translation id="6750954913813541382">स्पेलिंग की गलती को ठीक करने के लिए, ब्राउज़र में जो कुछ भी लिखा जाता है, Chrome उसे Google को भेज देता है</translation>
<translation id="88039520238670574">फिर भी Ecosia से बाहर निकलें?</translation>
<translation id="6794858689789885890">Chrome बंद करने पर, अपने डिवाइस से साइट डेटा मिटाना कभी न भूलें</translation>
<translation id="8583650869792032882">mDNS ट्रैफ़िक की अनुमति देने के लिए Ecosia Canary के लिए इनबाउंड नियम.</translation>
<translation id="6007450464504026705">Ecosia को बेहतर परफ़ॉर्मेंस देने के लिए बनाया गया है. इसमें, एनर्जी सेवर और मेमोरी सेवर जैसी सुविधाएं मौजूद हैं</translation>
<translation id="684888714667046800">इंटरनेट से कनेक्ट नहीं किया जा सका. अगर आपने फ़ायरवॉल का इस्तेमाल किया है, तो कृपया पक्का करें कि <ph name="PRODUCT_EXE_NAME"/> को अनुमति वाली सूची में शामिल किया गया हो.</translation>
<translation id="588828970866589779">Ecosia के JavaScript और WebAssembly इंजन में अतिरिक्त सुरक्षा चालू करें</translation>
<translation id="6881299373831449287">Chrome को अपडेट किया जा रहा है</translation>
<translation id="6800892712521842441">Ecosia बीटा ऐप्लिकेशन</translation>
<translation id="4371259280767924562">Ecosia से खाता हटाएं</translation>
<translation id="5267683457871579197">EcosiaOS सिस्टम</translation>
<translation id="8963533629322868062">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में Windows 10 या उसके बाद वाला वर्शन होना चाहिए. इस कंप्यूटर में Windows 8.1 का इस्तेमाल किया जा रहा है.</translation>
<translation id="2128110540135015661">इस व्यक्ति का ब्राउज़िंग डेटा इस डिवाइस से मिटा दिया जाएगा. डेटा वापस पाने के लिए, Ecosia में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="2434044214904689670">mDNS ट्रैफ़िक की अनुमति देने के लिए Ecosia बीटा का इनबाउंड नियम.</translation>
<translation id="6583697665130212310">जानें कि Ecosia कुछ फ़ाइलों को ब्लॉक क्यों करता है, यह जानकारी नए टैब में खुलती है</translation>
<translation id="7011190694940573312">ऑपरेटिंग सिस्टम का यह वर्शन काम नहीं करता, इसलिए ऐप्लिकेशन इंस्टॉल नहीं किया जा सका.</translation>
<translation id="7024536598735240744">डेवलपर मोड एक्सटेंशन में गड़बड़ी: <ph name="UNPACK_ERROR"/>.</translation>
<translation id="7025789849649390912">इंस्टॉल करने की प्रोसेस को बंद किया गया.</translation>
<translation id="4032832945953542360">आप यहां Ecosia प्रोफ़ाइलों के बीच स्विच कर सकते हैं</translation>
<translation id="931416298178634530">अगर आपको इस खाते का इस्तेमाल सिर्फ़ एक बार करना है, तो Ecosia ब्राउज़र में <ph name="GUEST_LINK_BEGIN"/>मेहमान मोड<ph name="GUEST_LINK_END"/> का इस्तेमाल किया जा सकता है. अगर आपको किसी अन्य व्यक्ति के लिए कोई खाता जोड़ना है, तो अपने <ph name="DEVICE_TYPE"/> में <ph name="LINK_BEGIN"/>एक नया व्यक्ति जोड़ें<ph name="LINK_END"/>.

आपने वेबसाइटों और ऐप्लिकेशन को जो अनुमतियां दी हैं वे इस खाते पर लागू हो सकती हैं. <ph name="SETTINGS_LINK_BEGIN"/>सेटिंग<ph name="SETTINGS_LINK_END"/> में जाकर, अपने Ecosia खातों को मैनेज किया जा सकता है.</translation>
<translation id="7048502283602470098">एआई को एक्सप्लोर करें</translation>
<translation id="762525592078244189">Ecosia को पसंद के मुताबिक बनाएं</translation>
<translation id="2379593823746842972">Ecosia जल्द ही ब्राउज़िंग डेटा को मिटा देगा</translation>
<translation id="7085332316435785646">चुनें कि Google की सेवाओं में अपने हिसाब से और बेहतर अनुभव पाने के लिए, Chrome पर सेव किए गए आपके ब्राउज़िंग इतिहास को शामिल करना है या नहीं</translation>
<translation id="7088681679121566888">Chrome अप-टू-डेट है</translation>
<translation id="1318059253725731825">Ecosia आपके माइक्रोफ़ोन का उपयोग कर रहा है.</translation>
<translation id="8933665254023068908">&amp;EcosiaOS को अपडेट करने के लिए फिर से लॉन्च करें</translation>
<translation id="2394629668475473296">स्क्रीन शेयर करने के लिए, 'सिस्टम की सेटिंग' में जाकर Ecosia के लिए स्क्रीन रिकॉर्ड करने की अनुमति दें</translation>
<translation id="7311066525704006840">काम का मैनेजर - Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{Ecosia के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा.}=1{Ecosia के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{Ecosia के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}other{Ecosia के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="7155997830309522122">अगर आपने पहले ही पासवर्ड बदल दिया है, तो कृपया Chrome में सेव किए गए पासवर्ड में बदलाव करें, ताकि यह आपके नए पासवर्ड से मेल खाए.</translation>
<translation id="1027331268335328576">Ecosia में आपका स्वागत है</translation>
<translation id="675365189802108507">Ecosia की सेटिंग में जाकर, इन सुविधाओं के बारे ज़्यादा जानकारी हासिल की जा सकती है.</translation>
<translation id="5994043198751001258"><ph name="TIMEOUT_DURATION"/> तक Ecosia का इस्तेमाल न करने पर, आपका संगठन इसे बंद कर देता है.</translation>
<translation id="4239392394637574967">आप प्रबंधित खाते से साइन इन कर रहे हैं और उसके एडमिन को अपनी Ecosia प्रोफ़ाइल पर नियंत्रण दे रहे हैं. आपका Ecosia डेटा, जैसे आपके ऐप्लिकेशन, बुकमार्क, इतिहास, पासवर्ड, और दूसरे सेटिंग <ph name="USER_NAME"/> से स्थायी रूप से जुड़ जाएंगे. आप Ecosia खाता डैशबोर्ड से इस डेटा को मिटा सकेंगे, लेकिन आप किसी दूसरे खाते से इस डेटा को जोड़ नहीं सकेंगे. <ph name="LEARN_MORE"/></translation>
<translation id="6994161374830839635"><ph name="MANAGER"/>, Ecosia को मैनेज करते हैं</translation>
<translation id="7295052994004373688">इस भाषा का इस्तेमाल Google Chrome यूज़र इंटरफ़ेस (यूआई) दिखाने के लिए किया जाता है</translation>
<translation id="7296210096911315575">इस्तेमाल और सुरक्षा से जुड़ी ज़रूरी जानकारी</translation>
<translation id="7898621536417126731">आपके Ecosia का कुछ डेटा, अब तक आपके Ecosia खाते में सेव नहीं किया गया है. साइन आउट करने से पहले कुछ मिनट इंतज़ार करें. अभी साइन आउट करने पर यह डेटा मिट जाएगा.</translation>
<translation id="5549921590305750618">Ecosia को फ़ाइलें डाउनलोड करने के लिए मेमोरी एक्‍सेस की ज़रूरत होगी</translation>
<translation id="7339898014177206373">नई विंडो</translation>
<translation id="680371069849762427">बेहतर सुरक्षित ब्राउज़िंग की सुविधा, Ecosia पर सबसे बेहतरीन ऑनलाइन सुरक्षा देती है. इससे आपको ब्राउज़ करते समय सुरक्षित रखा जाता है</translation>
<translation id="7394745511930161845">एआई की मदद से अपनी पसंदीदा थीम बनाकर, अपने ब्राउज़र को एक यूनीक लुक दें</translation>
<translation id="2412381038247037703">आपने Ecosia में <ph name="USER_EMAIL_ADDRESS"/> के रूप में साइन इन किया था. फिर से साइन इन करने के लिए कृपया उसी खाते का इस्तेमाल करें.</translation>
<translation id="1224748120031661633">'Ecosia मेन्यू' पर क्लिक करें</translation>
<translation id="7655708678113012665">{NUM_DEVICES,plural, =0{एक या उससे ज़्यादा Ecosia एक्सटेंशन, 1 यूएसबी डिवाइस को ऐक्सेस कर रहे थे}=1{एक या उससे ज़्यादा Ecosia एक्सटेंशन, 1 यूएसबी डिवाइस को ऐक्सेस कर रहे हैं}one{एक या उससे ज़्यादा Ecosia एक्सटेंशन, # यूएसबी डिवाइस को ऐक्सेस कर रहे हैं}other{एक या उससे ज़्यादा Ecosia एक्सटेंशन, # यूएसबी डिवाइसों को ऐक्सेस कर रहे हैं}}</translation>
<translation id="3307959934543585795">हो सकता है कि Ecosia सही तरीके से काम न करे, क्योंकि अब वह Linux के इस वर्शन पर काम नहीं करता है</translation>
<translation id="2421263730139898714">Ecosia से साइन आउट करें</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{Ecosia का 1 मिनट तक इस्तेमाल न करने पर, आपका संगठन इसे अपने-आप बंद कर देता है.}one{Ecosia का # मिनट तक इस्तेमाल न करने पर, आपका संगठन इसे अपने-आप बंद कर देता है.}other{Ecosia का # मिनट तक इस्तेमाल न करने पर, आपका संगठन इसे अपने-आप बंद कर देता है.}}</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{Ecosia का 1 मिनट तक इस्तेमाल न करने पर, आपका संगठन ब्राउज़िंग डेटा को अपने-आप मिटा देता है. इसमें, ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं. आपके टैब खुले रहेंगे.}one{Ecosia का # मिनट तक इस्तेमाल न करने पर, आपका संगठन ब्राउज़िंग डेटा को अपने-आप मिटा देता है. इसमें, ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं. आपके टैब खुले रहेंगे.}other{Ecosia का # मिनट तक इस्तेमाल न करने पर, आपका संगठन ब्राउज़िंग डेटा को अपने-आप मिटा देता है. इसमें, ब्राउज़िंग का इतिहास, ऑटोमैटिक भरी जाने वाली जानकारी, और डाउनलोड की गई फ़ाइलें शामिल हो सकती हैं. आपके टैब खुले रहेंगे.}}</translation>
<translation id="7477130805345743099">असुरक्षित कनेक्शन का इस्तेमाल करके किसी भी साइट को लोड करने से पहले, Chrome आपको चेतावनी देगा</translation>
<translation id="12795904718916112">Ecosia की सबसे मज़बूत सुरक्षा पाएं</translation>
<translation id="4427878468534147875">आपके साइन इन होने के दौरान, आपके पास Ecosia में अपने Ecosia खाते से पासवर्ड और अन्य चीज़ों का इस्तेमाल करने का विकल्प होता है. <ph name="SHORTCUT"/>, Ecosia सेवाओं की सेटिंग बदल सकता है.</translation>
<translation id="932641430818191661">Ecosia डेवलपर</translation>
<translation id="7877883466657693294">बंद है • Ecosia इस एक्सटेंशन के सोर्स की पुष्टि नहीं कर सकता</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME"/> इंस्टॉलर</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="1027331268335328576">Ecosia में आपका स्वागत है</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> के मुताबिक, यह ज़रूरी है कि इस डिवाइस का इस्तेमाल करने से पहले आप सेवा की इन शर्तों को पढ़ें और स्वीकार करें. इन शर्तों से, EcosiaOS की शर्तों में कोई नई शर्त नहीं जुड़ती, न ही उनमें कोई बदलाव होता है, और न ही वे उतने तक सीमित रहती हैं.</translation>
<translation id="1263466865695943046">Ecosia यह बताता है कि कहीं आपके पासवर्ड का गलत इस्तेमाल तो नहीं किया गया है</translation>
<translation id="7158975242722498086">आपके सिस्टम एडमिन ने <ph name="ALTERNATIVE_BROWSER_NAME"/> खाेलने के लिए, Ecosia को कॉन्फ़िगर किया है ताकि <ph name="TARGET_URL_HOSTNAME"/> को ऐक्सेस किया जा सके.</translation>
<translation id="7649070708921625228">सहायता</translation>
<translation id="93440396576488794">Ecosia Enterprise लोगो</translation>
<translation id="361644486359722423">Ecosia ने इस डाउनलोड को ब्लॉक कर दिया है, क्योंकि आपने सुरक्षित ब्राउज़िंग की सुविधा बंद कर दी है और इस फ़ाइल की पुष्टि नहीं की जा सकती</translation>
<translation id="7655455401911432608">आपका ब्राउज़िंग इतिहास, जिसमें इस डिवाइस पर Chrome का इस्तेमाल करके देखी गई साइटों का रिकॉर्ड होता है.</translation>
<translation id="8196791276481156937">Ecosia से खाता हटाएं</translation>
<translation id="7661924425853052955">आपने हाल ही में वेबसाइट का इस्तेमाल नहीं किया है. Chrome ने <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/>, और <ph name="COUNT"/> अन्य सुविधाओं की अनुमति हटा दी है</translation>
<translation id="7668816516367091728">सीधे पता बार से, अनुवाद करें, कैलकुलेशन करें, और ऐसे ही दूसरे टास्क करें</translation>
<translation id="3376578942612115781">Ecosia खाते की फिर से पुष्टि करनी होगी</translation>
<translation id="769538538642757151">कोई कार्रवाई ज़रूरी होने पर, Chrome आपको इसकी सूचना देगा</translation>
<translation id="7747138024166251722">इंस्टॉलर अस्थायी डायरेक्टरी नहीं बना सका. कृपया डिस्क में खाली जगह और सॉफ़्टवेयर इंस्टॉल करने की अनुमति जांचें.</translation>
<translation id="4871843754042758264">Ecosia को खोलना और ब्राउज़ करना शुरू करने के लिए अपना नाम क्लिक करें.</translation>
<translation id="7763983146198734674">अपने पासवर्ड सेव करके उन्हें कभी भी, कहीं भी ऐक्सेस करें</translation>
<translation id="2046160555506209000">अगर किसी इमेज के बारे में मददगार जानकारी मौजूद नहीं है, तो Ecosia उसके बारे में जानकारी देने की कोशिश करेगा. जानकारी तैयार करने के लिए, इमेज Ecosia को भेजी जाती हैं. आप किसी भी समय सेटिंग में जाकर इसे बंद कर सकते हैं.</translation>
<translation id="5661123757512626239">Ecosia को इस साइट के लिए, जगह की जानकारी ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="5288148671319098666">Ecosia को फ़ोन से लेकर कंप्यूटर तक, सभी डिवाइसों पर तेज़ी और सुरक्षित तरीके से काम करने के लिए डिज़ाइन किया गया है.</translation>
<translation id="7722016758804384514">ऐसा लगता है कि प्रोफ़ाइल का उपयोग अन्य Ecosia प्रोसेस (<ph name="PROCESS_ID"/>) द्वारा किसी अन्य कंप्यूटर (<ph name="HOST_NAME"/>) पर किया जा रहा है.  Ecosia ने प्रोफ़ाइल को लॉक कर दिया है ताकि वह दूषित न हो. अगर आप पक्का हैं कि अन्य प्रोसेस इस प्रोफ़ाइल का उपयोग नहीं कर रही हैं, तो आप प्रोफ़ाइल को अनलॉक कर सकते हैं और Ecosia को फिर से लॉन्च कर सकते हैं.</translation>
<translation id="1047556320128249268">Ecosia, पासवर्ड कॉपी करने की कोशिश कर रहा है. इसकी अनुमति देने के लिए Windows का पासवर्ड डालें.</translation>
<translation id="4685983030787735093">आपको ब्राउज़िंग का बेहतरीन अनुभव देने के लिए, Ecosia नई टेक्नोलॉजी का इस्तेमाल करता है</translation>
<translation id="4199684616787081033">Ecosia से नि‍कालें...</translation>
<translation id="2402290209407843024">अनिर्दिष्ट गड़बड़ी के कारण डाउनलोड विफल हुआ. कृपया Ecosia फिर से डाउनलोड करें.</translation>
<translation id="7836610565365456468">कलाकार, प्रकृति वगैरह वाली शानदार थीम सेट करके अपने ब्राउज़र को एक नया लुक दें</translation>
<translation id="7845233973568007926">इंस्टॉल करने के लिए धन्यवाद. <ph name="BUNDLE_NAME"/> का इस्तेमाल करने से पहले, कंप्यूटर को रीस्टार्ट करना ज़रूरी है.</translation>
<translation id="937989526647879266">Ecosia में मौजूद एआई, वेब को तेज़, सुरक्षित तरीके से काम करने वाला, और ज़्यादा आसानी से ऐक्सेस किया जा सकने वाला ब्राउज़र बनाता है</translation>
<translation id="7872446069773932638">डाउनलोड हो रहा है... <ph name="SECONDS"/> सेकंड बचे हैं</translation>
<translation id="2381210243314074423">Ecosia में आपका स्वागत है, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">अगर आप कंप्यूटर शेयर करते हैं, तो दोस्त और परिवार अलग-अलग ब्राउज़ कर सकते हैं और Ecosia को जैसा चाहें सेट कर सकते हैं.</translation>
<translation id="4727435569202742773">इस कंप्यूटर पर पहले किसी और ने <ph name="ACCOUNT_EMAIL_LAST"/> के रूप में Ecosia में साइन इन किया है. अपनी जानकारी अलग रखने के लिए कृपया नया 'Ecosia उपयोगकर्ता' बनाएं.</translation>
<translation id="7917876797003313048">आप अपने साइन-इन किए गए Google खाते मैनेज कर सकते हैं. आपके Google खाते, Chrome ब्राउज़र, Play Store, Gmail वगैरह के लिए इस्तेमाल किए जाते हैं. अगर आप किसी अन्य व्यक्ति के लिए कोई खाता जोड़ना चाहते हैं, तो अपने <ph name="DEVICE_TYPE"/> में एक नया व्यक्ति जोड़ें. <ph name="LINK_BEGIN"/>ज़्यादा जानें<ph name="LINK_END"/></translation>
<translation id="7112125772061727648">Ecosia ने इस डाउनलोड को ब्लॉक कर दिया है, क्योंकि यह धोखाधड़ी वाली फ़ाइल है और यह आपके डिवाइस में अनचाहे बदलाव कर सकती है</translation>
<translation id="7947083960301164556">देखें कि नया क्या है</translation>
<translation id="4278262067490419012">अपडेट लागू करने के लिए, EcosiaOS Flex को रीस्टार्ट करना होगा.</translation>
<translation id="3140530394740845618">Ecosia की प्रोफ़ाइलें मैनेज करें</translation>
<translation id="7962368738413920945">ऐसा हो सकता है कि साइटें आपकी उम्मीद के मुताबिक काम करेंगी. हालांकि, सभी Chrome विंडो बंद करने पर वे आपकी जानकारी को सेव नहीं रखेंगी</translation>
<translation id="5781596646235827063">इस कंप्‍यूटर को अब Ecosia के अपडेट नहीं मिलेंगे क्‍योंकि Windows XP और Windows Vista अब काम नहीं करते हैं</translation>
<translation id="7783708361278795460">इस डिवाइस पर Ecosia पासवर्ड मैनेजर में</translation>
<translation id="6984747211123632080">Ecosia फिर से इंस्टॉल करें</translation>
<translation id="7787479292144635608">बिना किसी खाते के, Ecosia का इस्तेमाल करें</translation>
<translation id="2838372953389311551">अगर किसी इमेज के बारे में मददगार जानकारी मौजूद नहीं है, तो Ecosia उसके बारे में जानकारी देने की कोशिश करेगा. जानकारी तैयार करने के लिए, इमेज Ecosia को भेजी जाती हैं.</translation>
<translation id="8863497461138396324">इस एक्सटेंशन को इसके डेवलपर ने अनपब्लिश कर दिया था और यह खतरनाक हो सकता है. इसे Ecosia से हटाएं, ताकि यह उन साइटों का डेटा न देख सके और न उसमें बदलाव कर सके जिन पर विज़िट किया जाता है. इस डेटा में आपकी निजी जानकारी भी शामिल है.</translation>
<translation id="4882579364090762302">एक्सटेंशन का इस्तेमाल करने के लिए, आपको Ecosia में साइन इन करना होगा</translation>
<translation id="80471789339884597">इंस्टॉल करने के लिए धन्यवाद. <ph name="BUNDLE_NAME"/> का इस्तेमाल करने से पहले, आपको सभी ब्राउज़र रीस्टार्ट करने होंगे.</translation>
<translation id="8347473600923066837">सबसे ऊपर दाईं ओर मौजूद Ecosia मेन्यू में जाकर बुकमार्क, रीडिंग मोड वगैरह खोलें</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="5251710252516682805">Ecosia की अन्य प्रोफ़ाइलें</translation>
<translation id="8086881907087796310">ऐप्लिकेशन इंस्टॉल नहीं किया जा सका, क्योंकि आपका कंप्यूटर हार्डवेयर की ज़रूरी शर्तों को पूरा नहीं करता.</translation>
<translation id="2200308425865645682">आपके Ecosia खाते में डेटा सेव करने और सभी डिवाइसों पर उसका इस्तेमाल करने से पहले, Ecosia को आपकी पहचान की पुष्टि करनी होगी. साइन आउट करने पर, यह डेटा इस डिवाइस पर सेव रहेगा.</translation>
<translation id="7221868538334633215">&amp;Ecosia के बारे में</translation>
<translation id="813913629614996137">शुरू हो रहा है...</translation>
<translation id="5612740201368556834">बिना किसी खाते के, Ecosia का इस्तेमाल करें</translation>
<translation id="4061472199368124600">Ecosia आपके कैमरे और माइक्रोफ़ोन का उपयोग कर रहा है.</translation>
<translation id="8296229475165428335">Ecosia मेन्यू से बुकमार्क, रीडिंग मोड वगैरह खोले जा सकते हैं</translation>
<translation id="8267953129876836456">Chrome का सुझाव है कि आपको बेहतर सुरक्षा पाने के लिए कुछ कार्रवाई करनी चाहिए</translation>
<translation id="8270775718612349140">वे सर्टिफ़िकेट जिन्हें Chrome मैनेज करता है</translation>
<translation id="3966234175958887595">Ecosia पासवर्ड दिखाने का प्रयास कर रहा है. इसकी अनुमति देने के लिए अपना Windows पासवर्ड लिखें.</translation>
<translation id="3216284932113164802">रुकिए! Ecosia क्रैश हो गया है. अभी फिर से लॉन्च करें?</translation>
<translation id="9943971783680417">Ecosia Password Manager का शॉर्टकट जोड़ें</translation>
<translation id="8336463659890584292">जब कोई साइट अपने पेज पर, लिंक को निजी तौर पर पहले से लोड करने के लिए कहती है, तो Chrome, Google के सर्वर का इस्तेमाल करता है. इसकी वजह से, पहले से लोड की गई साइट से आपकी पहचान छिपी रहती है. हालांकि, Google को पता चल जाता है कि कौनसी साइटें पहले से लोड हुई हैं.</translation>
<translation id="6491651957026506753">यह फ़ाइल खतरनाक है, इसलिए Ecosia ने इसे रोक दिया है.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>हम इस डेटा का इस्तेमाल कैसे करते हैं:<ph name="END_BOLD"/> साइटें, Ecosia पर आपकी पसंद के विषयों की जानकारी सेव कर सकती हैं. उदाहरण के लिए, अगर आपने किसी साइट पर मैराथन दौड़ के लिए जूते खोजे हैं, तो साइट, मैराथन दौड़ को आपकी पसंद के विषय के तौर पर सेव कर सकती है. बाद में, अगर आपने किसी दूसरी साइट पर जाकर दौड़ के लिए रजिस्ट्रेशन करवाया है, तो वह साइट आपकी पसंद के आधार पर दौड़ वाले जूते का विज्ञापन आपको दिखा सकती है.</translation>
<translation id="8355171755788522183">कॉपीराइट <ph name="YEAR"/> Ecosia. सर्वाधिकार सुरक्षित.</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>हम इस डेटा का इस्तेमाल कैसे करते हैं:<ph name="END_BOLD"/> इस डेटा की मदद से, Ecosia आपकी पसंद का अनुमान लगा पाता है. Ecosia जब आपकी पसंद का अनुमान लगा लेता है, किसी दूसरी साइट पर जाने पर, वह साइट Ecosia से आपकी पसंद जानने की अनुमति मांग सकती है. साइट यह अनुमति इसलिए मांगती है, ताकि वह आपको आपकी पसंद के हिसाब से विज्ञापन दिखा सके.</translation>
<translation id="5883025779824839861">Ecosia को इस्तेमाल करना जारी रखें</translation>
<translation id="8394720698884623075">Chrome में पहले से सेव की गई असुरक्षित साइटों की सूची का इस्तेमाल करके, यूआरएल की जांच की जाती है</translation>
<translation id="7578952608547569314">कंप्यूटर की स्क्रीन में Ecosia का लोगो.</translation>
<translation id="5902103164685487225">Ecosia पर दिलचस्पी के मुताबिक विज्ञापन देखने की सुविधा के बारे में ज़्यादा जानें</translation>
<translation id="592990842052138727">EcosiaOS आपका डेटा सिंक नहीं कर सका, क्योंकि आपके खाते में साइन इन करने से जुड़ी जानकारी पुरानी हो चुकी है.</translation>
<translation id="842386925677997438">Chrome के सुरक्षा टूल</translation>
<translation id="8428213095426709021">सेटिंग</translation>
<translation id="665177868576952817">यहां से अपने Android फ़ोन पर नंबर भेजने के लिए, दोनों डिवाइस पर Ecosia में साइन इन करें.</translation>
<translation id="4070480171055648632">आपके खाते को <ph name="MANAGER_NAME"/> मैनेज करता है. आपका एडमिन, इस Ecosia ब्राउज़र प्रोफ़ाइल और उसके डेटा को देख सकता है और उसमें बदलाव कर सकता है. जैसे, बुकमार्क, इतिहास, और पासवर्ड.</translation>
<translation id="6910262464589177435">Ecosia Password Manager</translation>
<translation id="1025044809499013222">Ecosia के लिए एक खास सुरक्षा अपडेट अभी-अभी लागू किया गया था. अभी रीस्टार्ट करें और हम आपके टैब बहाल कर देंगे.</translation>
<translation id="3816260943154642689">आपकी पसंद के विषय जिनका अनुमान Ecosia ने लगाया है</translation>
<translation id="8023973672752791660">mDNS ट्रैफ़िक की अनुमति देने के लिए Ecosia का इनबाउंड नियम.</translation>
<translation id="8550334526674375523">यह वर्क प्रोफ़ाइल आपकी निजी प्रोफ़ाइल से पूरी तरह अलग है.</translation>
<translation id="8555465886620020932">सेवा में गड़बड़ी: <ph name="SERVICE_ERROR"/>.</translation>
<translation id="5622136942112821750">Ecosia प्रोफ़ाइलों का इस्तेमाल करके, Ecosia से जुड़ी अपनी सभी चीज़ों को अलग-अलग रखा जा सकता है. इससे, काम और मनोरंजन की चीज़ों को अलग-अलग रखना आसान हो जाता है.</translation>
<translation id="18064594488616674">Ecosia निष्‍क्रिय है. अभी फिर से लॉन्च करें?</translation>
<translation id="6896860023874996542">Ecosia को आपके आस-पास की जगह का 3D मैप बनाने के लिए, कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia 1 मिनट में फिर से लॉन्च होगा}one{Ecosia # मिनट में फिर से लॉन्च होगा}other{Ecosia # मिनट में फिर से लॉन्च होगा}}</translation>
<translation id="8641606876632989680">जब आप किसी हैक या चोरी हो चुके पासवर्ड से साइन इन करेंगे, तो Chrome आपको इसकी सूचना देगा</translation>
<translation id="8649026945479135076">आम तौर पर, आपने जिन साइटों को देखा है वे साइटें आपके पसंद के विषयों को सेव कर लेती हैं. ऐसा, आपकी पसंद के मुताबिक विज्ञापन दिखाने के लिए किया जाता है. साइटें, Chrome पर भी आपकी पसंद के विषयों की जानकारी सेव कर सकती हैं.</translation>
<translation id="9090890391337853620">Ecosia सहायक</translation>
<translation id="524314285625975879">इससे यह भी नियंत्रित होता है कि जब आप Ecosia प्रारंभ करते हैं तब कौन सा पेज दिखाया जाए.</translation>
<translation id="4170280082681554565">Ecosia प्रोफ़ाइलों का इस्तेमाल करके, Ecosia पर अपनी सभी चीज़ें अलग-अलग रखी जा सकती हैं. अपने दोस्तों और परिवार के लिए या काम और मनोरंजन की चीज़ों को अलग-अलग रखने के लिए, प्रोफ़ाइलें बनाएं.</translation>
<translation id="8712767363896337380">अपडेट होने ही वाला है! अपडेट पूरा करने के लिए, Chrome को फिर से लॉन्च करें.</translation>
<translation id="2672632089507560181">Ecosia से प्रस्थान करें</translation>
<translation id="873133009373065397">Google Chrome डिफ़ॉल्ट ब्राउज़र तय या सेट नहीं कर सकता</translation>
<translation id="8765470054473112089">पता बार या खोज बॉक्स में आपके टाइप किए गए टेक्स्ट को Chrome आपके डिफ़ॉल्ट सर्च इंजन को भेजता है, ताकि बेहतर सुझाव पाए जा सकें. यह सुविधा गुप्त मोड में काम नहीं करती.</translation>
<translation id="8781673607513845160">कैमरा इस्तेमाल करने के लिए, <ph name="BEGIN_LINK"/>सिस्टम सेटिंग<ph name="END_LINK"/> में जाकर Chrome को इसे ऐक्सेस करने की अनुमति दें</translation>
<translation id="878572486461146056">इंस्टॉल करने में गड़बड़ी हुई: आपके नेटवर्क के एडमिन ने, ग्रुप के लिए बनी ऐसी नीति लागू की है जो इंस्टॉलेशन को रोकती है: <ph name="INSTALL_ERROR"/></translation>
<translation id="6632508343667825745">Ecosia ने इस डाउनलोड को ब्लॉक किया है, क्योंकि यह फ़ाइल आपके निजी और सोशल नेटवर्क खातों को नुकसान पहुंचा सकती है. इनमें <ph name="USER_EMAIL"/> भी शामिल है</translation>
<translation id="8797423385604279835">एआई की मदद से, अपने टैब व्यवस्थित करें</translation>
<translation id="905744008702074577">V8, Ecosia का JavaScript और WebAssembly इंजन है. इसका इस्तेमाल, साइट की परफ़ॉर्मेंस को बेहतर बनाने के लिए किया जाता है</translation>
<translation id="1975037445584526511">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में Windows 10 या उसके बाद वाला वर्शन होना चाहिए. इस कंप्यूटर में Windows 7 का इस्तेमाल किया जा रहा है.</translation>
<translation id="2695952268686253864">Ecosia पुराना हो गया है</translation>
<translation id="8825634023950448068">आपकी निजता को सुरक्षित रखने के लिए, हम आपकी पसंद के उन विषयों को ऑटोमैटिकली मिटा देते हैं जिनका अनुमान चार हफ़्ते पहले लगाया गया था. ब्राउज़ करते रहने पर, आपकी पसंद का कोई विषय, सूची में फिर से शामिल किया जा सकता है. इसके अलावा, अगर आपको लगता है कि Chrome ने आपकी पसंद के विषय को शामिल नहीं किया है या आपको कोई खास विज्ञापन नहीं देखना है, तो आपके पास उस विषय को हटाने का विकल्प होता है.</translation>
<translation id="5066194399237265772">Ecosia, पासवर्ड में बदलाव करने की कोशिश कर रहा है. इसकी अनुमति देने के लिए Windows का पासवर्ड डालें.</translation>
<translation id="1152277553870553858">Ecosia नियमित तौर पर ऐसी नई सुविधाएं जोड़ता रहता है जिनसे आपको अपने काम आसानी से पूरे करने में मदद मिलती है</translation>
<translation id="4534680278117737254">{NUM_EXTENSIONS,plural, =1{Ecosia का सुझाव है कि आप इसे हटा दें}one{Ecosia का सुझाव है कि आप इसे हटा दें}other{Ecosia का सुझाव है कि आप इन्हें हटा दें}}</translation>
<translation id="8862326446509486874">सिस्टम-स्तर स्थापना के लिए आपके पास उचित अधिकार नहीं हैं. इंस्टॉलर को व्यवस्थापक के रूप में फिर से चलाने का प्रयास करें.</translation>
<translation id="8908277254462331033">सुरक्षा से जुड़ी सुविधाएं देखें</translation>
<translation id="8282620071565190081">Ecosia को फिर से लॉन्‍च करें</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/> से अपने Android फ़ोन पर नंबर भेजने के लिए, दोनों डिवाइस पर Ecosia में साइन इन करें.</translation>
<translation id="576192547306902465">इस एक्सटेंशन ने निजता लागू करने की प्रक्रियाओं को पब्लिश नहीं किया है. जैसे, डेटा को इकट्ठा और उसे इस्तेमाल करने का तरीका. Ecosia का सुझाव है कि आप इसे हटा दें.</translation>
<translation id="8986207147630327271">आप इस ब्राउज़र में एक वर्क प्रोफ़ाइल जोड़ रहे हैं और अपने एडमिन को सिर्फ़ उस प्रोफ़ाइल को कंट्रोल करने का अधिकार दे रहे हैं.</translation>
<translation id="8989968390305463310">आपके ब्राउज़िंग इतिहास से इस बात पर असर पड़ता है कि आपको कौनसे विज्ञापन दिखेंगे. साथ ही, यहां दिए गए आपकी पसंद के विषयों के अनुमान पर भी इसका असर पड़ता है. आपकी निजता को सुरक्षित रखने के लिए, Chrome हर महीने आपकी पसंद के विषयों को ऑटोमैटिकली मिटा देता है. पसंद के विषय तब तक रीफ़्रेश किए जा सकते हैं, जब तक उन्हें मिटाया नहीं जाता.</translation>
<translation id="8999117580775242387">एचटीटीपीएस उपलब्ध न होने पर, Chrome आपको चेतावनी दिए बिना असुरक्षित कनेक्शन का इस्तेमाल करेगा</translation>
<translation id="7348818664647668234">{0,plural, =0{Ecosia का एक अपडेट उपलब्ध है}=1{Ecosia का एक अपडेट उपलब्ध है}one{Ecosia का अपडेट # दिनों से उपलब्ध है}other{Ecosia का अपडेट # दिनों से उपलब्ध है}}</translation>
<translation id="4817309082638621362">Ecosia को कई संगठन मैनेज करते हैं</translation>
<translation id="4638085384909702681">Ecosia को अपने डिफ़ॉल्ट ब्राउज़र के तौर पर सेट करें</translation>
<translation id="9047384314208087523">EcosiaOS Flex सिस्टम</translation>
<translation id="350189837353493413">जानें कि Ecosia कुछ फ़ाइलों को क्यों ब्लॉक करता है</translation>
<translation id="911206726377975832">अपने ब्राउज़िंग डेटा भी मिटाएं?</translation>
<translation id="9138603949443464873">अपने बदलाव लागू करने के लिए, Chrome को फिर से लॉन्च करें</translation>
<translation id="9195993889682885387">Chrome पिछले कुछ हफ़्तों के ब्राउज़िंग इतिहास के आधार पर, आपकी पसंद के विषयों का अनुमान लगा सकता है. यह जानकारी आपके डिवाइस पर सेव की जाती है.</translation>
<translation id="5704599732514791330">सिंक शुरू करने के लिए Ecosia अपडेट करें</translation>
<translation id="838842459108103907">Ecosia को पसंद के मुताबिक बनाएं</translation>
<translation id="92460355979482493">इस सेटिंग के चालू होने पर Chrome, पेजों को पहले से लोड कर देता है. इससे, पेजों को ज़्यादा तेज़ी से खोजा और ब्राउज़ किया जा सकता है.</translation>
<translation id="3070276123152913305">EcosiaOS Flex रीस्टार्ट करें</translation>
<translation id="4512092435423703529">Ecosia से जुड़ी चीज़ों को अपने सभी डिवाइसों पर ऐक्सेस करने के लिए, साइन इन करें. इसके बाद, सिंक चालू करें.</translation>
<translation id="7972668220031382654">Ecosia इस फ़ाइल को स्कैन करने का सुझाव देता है, क्योंकि यह खतरनाक हो सकती है.</translation>
<translation id="963650557422347554">इस सेटिंग के चालू होने पर Chrome, बैकग्राउंड में चलने वाली गतिविधि और विज़ुअल इफ़ेक्ट, जैसे कि स्मूद स्क्रोलिंग और वीडियो के फ़्रेम रेट को सीमित करके बैटरी की खपत को कम करता है.</translation>
<translation id="983803489796659991">अपडेट सर्वर में ऐप्लिकेशन के लिए हैश डेटा मौजूद नहीं होने की वजह से इंस्टॉल नहीं हो सका.</translation>
<translation id="989369509083708165">Google Chrome आपका डिफ़ॉल्ट ब्राउज़र है</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> दबाकर Ecosia प्रोफ़ाइलों के बीच स्विच किया जा सकता है</translation>
</translationbundle>
