<translation id="6145313976051292476">Otvaranje PDF-ova u Chromeu</translation>
<translation id="6039735020616040749">Štednja memorije učinila je Ecosia bržim</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - Ecosia</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> – Ecosia Beta</translation>
<translation id="4154538917942874814">Ulazno pravilo kako bi Ecosia dopustio mDNS promet.</translation>
<translation id="8542320769345885402">Ecosia upravitelj zaporki</translation>
<translation id="6273793429163604305">Priprema...</translation>
<translation id="675229436434399924">Aplikacije preglednika Ecosia Dev</translation>
<translation id="4870057811531036437">Ecosia već je instaliran za sve korisnike na računalu.</translation>
<translation id="330264384086604869">Ukloni iz programa Ecosia</translation>
<translation id="6327105987658262776">Ažuriranja nisu dostupna.</translation>
<translation id="6412673304250309937">Provjerava URL-ove s popisom nesigurnih web-lokacija pohranjenih u Chromeu. Ako neka web-lokacija pokuša ukrasti vašu zaporku ili ako preuzmete štetnu datoteku, Chrome također može poslati URL-ove, uključujući dijelove sadržaja web-stranice, Sigurnom pregledavanju.</translation>
<translation id="4781882243268600858">Želite li prijeći na postojeći profil u Ecosiau?</translation>
<translation id="2537426042760364251">Ecosia treba dopuštenje za fotoaparat kako bi mogao izraditi 3D kartu vašeg okruženja</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> – Ecosia Dev</translation>
<translation id="5357908757303442841">Na Ecosia upravitelju zaporki na ovom uređaju</translation>
<translation id="8859253218356192164">EcosiaOS Flex omogućuje dodatni <ph name="BEGIN_LINK_CROS_OSS"/>softver otvorenog izvornog koda<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="6676384891291319759">Pristup Internetu</translation>
<translation id="4586967042094107073">Neka Ecosia radi u pozadini</translation>
<translation id="2173571365716863400">Ecosia treba dopuštenje za mikrofon za ovu web-lokaciju</translation>
<translation id="6161025257729272170">Ubrzajte Ecosia</translation>
<translation id="9165312115453649251">Sustav EcosiaOS Flex</translation>
<translation id="8685318202174822382">Želite li nastaviti na novom profilu u Ecosiau?</translation>
<translation id="6750954913813541382">Chrome šalje Googleu tekst koji utipkate u preglednik radi ispravljanja pravopisnih pogrešaka</translation>
<translation id="88039520238670574">Želite li ipak zatvoriti Ecosia?</translation>
<translation id="8583650869792032882">Ulazno pravilo kako bi Ecosia Canary dopustio mDNS promet.</translation>
<translation id="6881299373831449287">Ažuriranje Chromea</translation>
<translation id="6800892712521842441">Aplikacije preglednika Ecosia Beta</translation>
<translation id="5267683457871579197">Sustav Ecosia OS</translation>
<translation id="8963533629322868062">Da biste primali buduća ažuriranja Ecosiaa, trebat će vam Windows 10 ili novija verzija. Na ovom se računalu upotrebljava Windows 8.1.</translation>
<translation id="2128110540135015661">Podaci o pregledavanju za tu osobu izbrisat će se s ovog uređaja. Da biste vratili te podatke, prijavite se na Ecosia kao <ph name="USER_EMAIL"/>.</translation>
<translation id="2434044214904689670">Ulazno pravilo kako bi Ecosia Beta dopustio mDNS promet.</translation>
<translation id="7482156490649194631">Ecosia ažuriran je, ali vi ga niste upotrebljavali barem 30 dana.</translation>
<translation id="7025789849649390912">Instaliranje je zaustavljeno.</translation>
<translation id="4032832945953542360">Ovdje se možete prebacivati između profila u Ecosiau</translation>
<translation id="931416298178634530">Ako ovaj račun želite upotrijebiti samo jednom, možete upotrijebiti <ph name="GUEST_LINK_BEGIN"/>način rada za goste<ph name="GUEST_LINK_END"/> u pregledniku Ecosia. Ako želite dodati račun za nekog drugog, <ph name="LINK_BEGIN"/>dodajte novu osobu<ph name="LINK_END"/> na svoj <ph name="DEVICE_TYPE"/>.

Dopuštenja koja ste već dali web-lokacijama i aplikacijama mogu se primijeniti na ovaj račun. Svojim Ecosia računima možete upravljati u <ph name="SETTINGS_LINK_BEGIN"/>postavkama<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="4281355161119203663">Tvoj je roditelj isključio "Dopuštenja za web-lokacije, aplikacije i proširenja" za Ecosia. Nije dopušteno dodati <ph name="EXTENSION_TYPE_PARAMETER"/>.</translation>
<translation id="7085332316435785646">Odaberite želite li uključiti povijest na Chromeu za prilagođenije doživljaje na Googleovim uslugama</translation>
<translation id="7088681679121566888">Chrome je ažuriran</translation>
<translation id="1318059253725731825">Ecosia upotrebljava vaš mikrofon.</translation>
<translation id="8933665254023068908">Ponovo pokrenite da biste ažurirali &amp;Ecosia OS</translation>
<translation id="7311066525704006840">Upravitelj zadacima - Ecosia:</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{Dostupno je novo ažuriranje za Ecosia koje će se primijeniti nakon ponovnog pokretanja.}=1{Dostupno je novo ažuriranje za Ecosia koje će se primijeniti nakon ponovnog pokretanja. Anonimni se prozor neće ponovno otvoriti.}one{Dostupno je novo ažuriranje za Ecosia koje će se primijeniti nakon ponovnog pokretanja. Vaš # anonimni prozor neće se ponovno otvoriti.}few{Dostupno je novo ažuriranje za Ecosia koje će se primijeniti nakon ponovnog pokretanja. Vaša # anonimna prozora neće se ponovno otvoriti.}other{Dostupno je novo ažuriranje za Ecosia koje će se primijeniti nakon ponovnog pokretanja. Vaših # anonimnih prozora neće se ponovno otvoriti.}}</translation>
<translation id="7155997830309522122">Ako jeste, uredite zaporku spremljenu u Chromeu kako bi odgovarala vašoj novoj zaporki.</translation>
<translation id="1027331268335328576">Dobro došli u Ecosia</translation>
<translation id="675365189802108507">Više informacija o tim značajkama dostupno je u postavkama Ecosiaa.</translation>
<translation id="4239392394637574967">Prijavljujete se upravljanim računom i dajete administratoru kontrolu nad svojim profilom u sustavu Ecosia. Vaši podaci u sustavu Ecosia, primjerice, aplikacije, oznake, povijest, zaporke i ostale postavke, trajno će se povezati s korisnikom <ph name="USER_NAME"/>. Moći ćete izbrisati te podatke putem Nadzorne ploče Ecosia računa, ali ih nećete moći povezati s nekim drugim računom. Ako želite, možete izraditi novi profil kako biste zadržali postojeće podatke u sustavu Ecosia zasebno. <ph name="LEARN_MORE"/></translation>
<translation id="7295052994004373688">Taj se jezik koristi za prikaz korisničkog sučelja Google Chromea</translation>
<translation id="7296210096911315575">Važne informacije o upotrebi i sigurnosti</translation>
<translation id="5549921590305750618">Ecosia treba pristup pohrani radi preuzimanja datoteka</translation>
<translation id="7339898014177206373">Novi prozor</translation>
<translation id="5337919616446681032">Ako ovaj račun želite upotrijebiti samo jednom, možete upotrijebiti način rada za goste u pregledniku Ecosia. Ako želite dodati račun za nekog drugog, <ph name="LINK_BEGIN"/>dodajte novu osobu<ph name="LINK_END"/> na svoj <ph name="DEVICE_TYPE"/>.

Dopuštenja koja ste već dali web-lokacijama i aplikacijama mogu se primijeniti na ovaj račun. Svojim Ecosia računima možete upravljati u <ph name="SETTINGS_LINK_BEGIN"/>postavkama<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="2412381038247037703">Bili ste prijavljeni na Ecosia kao <ph name="USER_EMAIL_ADDRESS"/>. Prijavite se ponovo istim računom.</translation>
<translation id="5669097765101132299">Ecosia je blokirao tu datoteku jer je opasna</translation>
<translation id="3307959934543585795">Ecosia možda neće ispravno raditi jer više nije podržan na toj distribuciji Linuxa</translation>
<translation id="12795904718916112">Odaberite najsnažniju Ecosiaovu zaštitu sigurnosti</translation>
<translation id="7486227612705979895">Chrome će pristupati vašem Disku radi prikazivanja prijedloga u adresnoj traci</translation>
<translation id="932641430818191661">Ecosia Dev</translation>
<translation id="7583399374488819119">Program za instalaciju <ph name="COMPANY_NAME"/></translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="1027331268335328576">Dobro došli u Ecosia</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> zahtijeva da pročitate i prihvatite sljedeće uvjete pružanja usluge prije upotrebe ovog uređaja. Ti uvjeti ne predstavljaju proširenje, izmjenu ni ograničenje uvjeta Ecosia OS-a.</translation>
<translation id="1263466865695943046">Ecosia će vas obavijestiti ako vaše zaporke budu ugrožene</translation>
<translation id="7158975242722498086">Vaš administrator sustava konfigurirao je Ecosia da otvara <ph name="ALTERNATIVE_BROWSER_NAME"/> za pristup URL-u <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="7649070708921625228">Pomoć</translation>
<translation id="93440396576488794">Logotip Ecosia Enterprise</translation>
<translation id="7655455401911432608">Vaša povijest pregledavanja, zapisnik web-lokacija koje ste posjetili u Chromeu na ovom uređaju.</translation>
<translation id="7747138024166251722">Program za instalaciju nije izradio privremeni direktorij. Provjerite ima li slobodnog prostora na disku i postoji li dopuštenje za instalaciju softvera.</translation>
<translation id="4871843754042758264">Kliknite svoje ime da biste otvorili Ecosia i počeli s pregledavanjem.</translation>
<translation id="2046160555506209000">Ako slika nema koristan opis, Ecosia će ga pokušati pružiti. Da bi se izradili opisi, slike se šalju Ecosiau. To možete isključiti u bilo kojem trenutku u postavkama.</translation>
<translation id="8447746441670667471">Dostupna je nova verzija preglednika Ecosia.</translation>
<translation id="5661123757512626239">Ecosia treba dopuštenje za lokaciju za ovu web-lokaciju</translation>
<translation id="7722016758804384514">Izgleda da neki drugi proces preglednika Ecosia (<ph name="PROCESS_ID"/>) na nekom drugom računalu (<ph name="HOST_NAME"/>) upotrebljava taj profil. Ecosia je zaključao profil da se profil ne bi promijenio. Ako ste sigurni da nijedan drugi proces ne upotrebljava taj profil, možete ga otključati i ponovo pokrenuti Ecosia.</translation>
<translation id="1047556320128249268">Ecosia pokušava kopirati zaporke. Upišite svoju zaporku za Windows da biste to dopustili.</translation>
<translation id="4199684616787081033">Ukloni iz Ecosiaa...</translation>
<translation id="2402290209407843024">Instalacija nije uspjela zbog neodređene pogreške. Ponovo preuzmite Ecosia.</translation>
<translation id="7845233973568007926">Zahvaljujemo što ste izvršili instaliranje. Da biste mogli koristiti <ph name="BUNDLE_NAME"/>, morate ponovno pokrenuti računalo.</translation>
<translation id="7872446069773932638">Preuzimanje... Još <ph name="SECONDS"/> s</translation>
<translation id="2381210243314074423">Dobro došli u Ecosia, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">Ako dijelite računalo, prijatelji i članovi obitelji mogu zasebno pregledavati i postaviti Ecosia prema svojim željama.</translation>
<translation id="4727435569202742773">Netko se prethodno prijavio u Ecosia na ovom računalu kao <ph name="ACCOUNT_EMAIL_LAST"/>. Izradite novog korisnika Ecosiaa kako bi vaši podaci bili odvojeni.</translation>
<translation id="7917876797003313048">Možete upravljati Google računima na koje ste prijavljeni. Vaši Google računi koriste se za preglednik Chrome, Trgovinu Play, Gmail i brojne druge usluge. Ako želite dodati račun za nekog drugog, na primjer člana obitelji, dodajte novu osobu na uređaj <ph name="DEVICE_TYPE"/>. <ph name="LINK_BEGIN"/>Saznajte više<ph name="LINK_END"/></translation>
<translation id="8633885040939757689">Ecosia pokušava kopirati zaporke.</translation>
<translation id="4278262067490419012">Potrebno je ponovo pokrenuti EcosiaOS Flex kako bi se ažuriranje primijenilo.</translation>
<translation id="7962368738413920945">Web-lokacije će vjerojatno funkcionirati kao što očekujete, ali vas neće zapamtiti nakon što zatvorite sve prozore Chromea</translation>
<translation id="5781596646235827063">Ovo računalo više neće primati ažuriranja za Ecosia jer sustavi Windows XP i Windows Vista više nisu podržani</translation>
<translation id="7783708361278795460">Na Ecosia upravitelj zaporki na ovom uređaju</translation>
<translation id="6984747211123632080">Ponovo instaliraj Ecosia</translation>
<translation id="2838372953389311551">Ako slika nema koristan opis, Ecosia će ga pokušati pružiti. Da bi se izradili opisi, slike se šalju Ecosiau.</translation>
<translation id="80471789339884597">Zahvaljujemo što ste izvršili instaliranje. Da biste mogli koristiti <ph name="BUNDLE_NAME"/>, morate ponovno pokrenuti sve preglednike.</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="7221868538334633215">O programu Ecosia</translation>
<translation id="813913629614996137">Pokretanje...</translation>
<translation id="4061472199368124600">Ecosia upotrebljava vašu kameru i mikrofon.</translation>
<translation id="8270775718612349140">Certifikati kojima upravlja Chrome</translation>
<translation id="3966234175958887595">Ecosia pokušava prikazati zaporke. Upišite svoju zaporku za Windows da biste to dopustili.</translation>
<translation id="2290912123073552463">Tvoj je roditelj isključio "Dopuštenja za web-lokacije, aplikacije i proširenja" za Ecosia. Nije dopušteno omogućiti <ph name="EXTENSION_TYPE_PARAMETER"/>.</translation>
<translation id="3216284932113164802">Opa! Ecosia je pao. Ponovo pokrenuti sada?</translation>
<translation id="8341646175450781745">Kad je to uključeno, Chrome oslobađa memoriju neaktivnih kartica. Time se aktivnim karticama i drugim aplikacijama daje više računalnih resursa, a Chrome ostaje brz. Neaktivne kartice automatski će se ponovo aktivirati kada se vratite na njih. <ph name="BEGIN_LINK"/>Saznajte više<ph name="END_LINK"/> ili <ph name="BEGIN_LINK_2"/>pošaljite povratne informacije<ph name="END_LINK_2"/></translation>
<translation id="6491651957026506753">Datoteka je opasna i Ecosia ju je blokirao.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>Kako upotrebljavamo te podatke<ph name="END_BOLD"/>: web-lokacije mogu pohraniti informacije o vašim interesima u Ecosia. Na primjer, ako posjetite neku web-lokaciju da biste kupili tenisice za maraton, ta web-lokacija može definirati vaš interes kao trčanje maratona. Ako poslije posjetite neku drugu web-lokaciju da biste se registrirali za utrku, ta vam web-lokacija može prikazati oglas za tenisice za trčanje na temelju vaših interesa.</translation>
<translation id="8355171755788522183">Autorska prava <ph name="YEAR"/>. Ecosia. Sva prava pridržana.</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>Kako upotrebljavamo te podatke<ph name="END_BOLD"/>: Ecosia može procijeniti vaše interese. Web-lokacija koju posjetite nakon toga može od Ecosiaa tražiti podatke o vašim interesima kako bi prilagodila oglase koji će vam se prikazivati.</translation>
<translation id="5883025779824839861">Nastavi upotrebljavati Ecosia</translation>
<translation id="8394720698884623075">Provjerava nalaze li se URL-ovi na popisu nesigurnih web-lokacija pohranjenom u Chromeu</translation>
<translation id="4409756430498035341">Ecosia želi izvesti vaše zaporke.</translation>
<translation id="5902103164685487225">Saznajte više o prilagodbi oglasa u Ecosiau</translation>
<translation id="592990842052138727">Ecosia OS nije mogao sinkronizirati vaše podatke jer su vaši podaci za prijavu na račun zastarjeli.</translation>
<translation id="665177868576952817">Da biste poslali broj s ovog uređaja na svoj Android telefon, prijavite se na Ecosia na oba uređaja.</translation>
<translation id="4070480171055648632">Vašim računom upravlja <ph name="MANAGER_NAME"/>. Vaš administrator može pregledavati i uređivati profil ovog preglednika Ecosia i njegove podatke, kao što su oznake, povijest i zaporke.</translation>
<translation id="1025044809499013222">Upravo je primijenjeno posebno sigurnosno ažuriranje za Ecosia. Ponovo pokrenite sustav i vratit ćemo vaše kartice.</translation>
<translation id="7864624828358709494">Ecosia je blokirao ovu datoteku jer sadrži zlonamjerni softver</translation>
<translation id="3816260943154642689">Vaši interesi prema Ecosiaovoj procjeni</translation>
<translation id="8023973672752791660">Ulazno pravilo kako bi Ecosia Dev dopustio mDNS promet.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="8550334526674375523">Ovaj poslovni profil potpuno je zaseban od vašeg osobnog profila.</translation>
<translation id="7185777478310554774">Dostupna je nova verzija preglednika Ecosia, brža no ikad.</translation>
<translation id="5622136942112821750">Ecosiaovi profili omogućuju vam da razdvojite sve svoje sadržaje u Ecosiau. To olakšava odvajanje posla i zabave.</translation>
<translation id="18064594488616674">Ecosia ne reagira. Ponovo pokrenuti sada?</translation>
<translation id="6896860023874996542">Ecosia treba dopuštenje za pristup kameri radi izrade 3D karte vašeg okruženja</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia će se ponovo pokrenuti za jednu minutu}one{Ecosia će se ponovo pokrenuti za # min}few{Ecosia će se ponovo pokrenuti za # min}other{Ecosia će se ponovo pokrenuti za # min}}</translation>
<translation id="8641606876632989680">Chrome će vas obavijestiti kada se prijavite ugroženom zaporkom</translation>
<translation id="8649026945479135076">Uobičajeno je da web-lokacije koje posjećujete pamte vaše interese radi prilagodbe vašeg doživljaja. Web-lokacije mogu i pohraniti podatke o vašim interesima u Chrome.</translation>
<translation id="9090890391337853620">Ecosia Helper</translation>
<translation id="524314285625975879">Upravlja i time koja se stranica prikazuje prilikom pokretanja Ecosiaa.</translation>
<translation id="4997668724897475215">Ecosia preporučuje skeniranje datoteke jer je možda opasna</translation>
<translation id="4170280082681554565">Ecosiaovi profili omogućuju vam da razdvojite sve svoje sadržaje u Ecosiau. Izradite profile za prijatelje i obitelj ili odvojite posao i zabavu.</translation>
<translation id="8712767363896337380">Ažuriranje je skoro gotovo! Ponovo pokrenite Chrome da biste završili ažuriranje.</translation>
<translation id="873133009373065397">Google Chrome ne može utvrditi niti postaviti zadani preglednik</translation>
<translation id="1975037445584526511">Da biste primali buduća ažuriranja Ecosiaa, trebat će vam Windows 10 ili novija verzija. Na ovom se računalu upotrebljava Windows 7.</translation>
<translation id="2695952268686253864">Ecosia je zastario</translation>
<translation id="8825634023950448068">Da bismo zaštitili vašu privatnost, automatski brišemo vaše interese starije od četiri tjedna. Tijekom vašeg daljnjeg pregledavanja neki se interes može ponovo pojaviti na popisu. A ako Chrome pogriješi ili ne želite vidjeti određene oglase, možete ukloniti interes.</translation>
<translation id="5066194399237265772">Ecosia pokušava urediti zaporke. Upišite svoju zaporku za Windows da biste to dopustili.</translation>
<translation id="6078545897140861225">Upravlja i time koja se stranica prikazuje prilikom pokretanja Ecosiaa ili kada se klikne gumb Početna.</translation>
<translation id="1401515072108809622">Ecosia je neaktivan</translation>
<translation id="8862326446509486874">Nemate odgovarajuća prava za instaliranje na razini sustava. Pokušajte ponovno pokrenuti program za instalaciju kao administrator.</translation>
<translation id="8282620071565190081">Ponovo pokrenite Ecosia</translation>
<translation id="7849498640944199147">Da biste poslali broj s uređaja <ph name="ORIGIN"/> na svoj Android telefon, prijavite se na Ecosia na oba uređaja.</translation>
<translation id="7910693244647744044">Uključili ste poboljšano sigurno pregledavanje na svom računu. Sada ga preuzmite za Ecosia.</translation>
<translation id="8986207147630327271">Dodat ćete poslovni profil u ovaj preglednik i dati administratoru kontrolu samo nad poslovnim profilom.</translation>
<translation id="8989968390305463310">Vaša povijest pregledavanja utječe na oglase koji vam se prikazuju i interese procijenjene u nastavku. Da bi zaštitio vašu privatnost, Chrome automatski kontinuirano briše vaše interese svakog mjeseca. Interesi se mogu osvježiti ako ih ne uklonite.</translation>
<translation id="7348818664647668234">{0,plural, =0{Dostupno je ažuriranje Ecosiaa}=1{Dostupno je ažuriranje Ecosiaa}one{Ažuriranje Ecosiaa dostupno je # dana}few{Ažuriranje Ecosiaa dostupno je # dana}other{Ažuriranje Ecosiaa dostupno je # dana}}</translation>
<translation id="9003498785844995646">Kad je to uključeno, Chrome štedi bateriju ograničavajući pozadinsku aktivnost i vizualne efekte, kao što je glatko pomicanje i broj sličica u sekundi videozapisa. <ph name="BEGIN_LINK"/>Saznajte više<ph name="END_LINK"/> ili <ph name="BEGIN_LINK_2"/>pošaljite povratne informacije<ph name="END_LINK_2"/></translation>
<translation id="9047384314208087523">Sustav EcosiaOS Flex</translation>
<translation id="5675757883980078189">Ecosia zahtijeva Windows 7 ili noviju verziju.</translation>
<translation id="911206726377975832">Izbrisati i podatke o pregledavanju?</translation>
<translation id="9138603949443464873">Da bi se vaše promjene primijenile, ponovo pokrenite Chrome</translation>
<translation id="9195993889682885387">Chrome može procijeniti vaše interese na temelju vaše povijesti pregledavanja iz posljednjih nekoliko tjedana. Te informacije ostaju na vašem uređaju.</translation>
<translation id="5704599732514791330">Ažurirajte Ecosia da bi se pokrenula sinkronizacija</translation>
<translation id="838842459108103907">Prilagodi Ecosia</translation>
<translation id="3070276123152913305">Ponovo pokretanje EcosiaOS Flexa</translation>
<translation id="4512092435423703529">Da biste mogli pristupiti svojim sadržajima u Ecosiau na svim svojim uređajima, prijavite se i zatim uključite sinkronizaciju.</translation>
<translation id="7972668220031382654">Ecosia preporučuje skeniranje datoteke jer je možda opasna.</translation>
<translation id="989369509083708165">Google Chrome vaš je zadani preglednik</translation>
<translation id="4614106433017753369">Pomoću prečaca <ph name="SHORTCUT"/> možete se prebacivati između profila u Ecosiau</translation>
</translationbundle>
