<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Mae Ecosia yn argymell eich bod yn ei dynnu. <ph name="BEGIN_LINK"/>Dysgu rhagor am estyniadau a gefnogir<ph name="END_LINK"/>}zero{Mae Ecosia yn argymell eich bod yn eu tynnu. <ph name="BEGIN_LINK"/>Dysgu rhagor am estyniadau a gefnogir<ph name="END_LINK"/>}two{Mae Ecosia yn argymell eich bod yn eu tynnu. <ph name="BEGIN_LINK"/>Dysgu rhagor am estyniadau a gefnogir<ph name="END_LINK"/>}few{Mae Ecosia yn argymell eich bod yn eu tynnu. <ph name="BEGIN_LINK"/>Dysgu rhagor am estyniadau a gefnogir<ph name="END_LINK"/>}many{Mae Ecosia yn argymell eich bod yn eu tynnu. <ph name="BEGIN_LINK"/>Dysgu rhagor am estyniadau a gefnogir<ph name="END_LINK"/>}other{Mae Ecosia yn argymell eich bod yn eu tynnu. <ph name="BEGIN_LINK"/>Dysgu rhagor am estyniadau a gefnogir<ph name="END_LINK"/>}}</translation>
