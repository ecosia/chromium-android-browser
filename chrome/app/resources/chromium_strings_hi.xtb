<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="hi">
<translation id="1026101648481255140">इंस्टॉल करने की प्रोसेस को दोबारा चालू करें</translation>
<translation id="8933665254023068908">&amp;EcosiaOS को अपडेट करने के लिए, उसे फिर से लॉन्च करें</translation>
<translation id="1065672644894730302">आपकी प्राथमिकताओं को पढ़ा नहीं जा सकता| \\n\\nकुछ विशेषताएं अनुपलब्ध हो सकती हैं और प्राथमिकताओं में किए गए परिवर्तनों को सहेजा नहीं जाएगा.</translation>
<translation id="1098170124587656448">क्रोमियम, आपको डेटा के गलत इस्तेमाल से बचाता है. साथ ही, इससे आप नुकसान पहुंचाने वाले एक्सटेंशन जैसी कई चीज़ाें से सुरक्षित रह पाएंगे</translation>
<translation id="3632544319066562282">क्रोमियम आपके पासवर्ड निर्यात करना चाहता है. इसकी मंज़ूरी देने के लिए अपना Windows पासवर्ड लिखें.</translation>
<translation id="113122355610423240">क्रोमियम आपका डिफ़ॉल्ट ब्राउज़र है</translation>
<translation id="1131805035311359397">डेटा के गलत इस्तेमाल और सुरक्षा की अन्य समस्याओं से आपके पासवर्ड सुरक्षित हैं या नहीं, इसकी जांच करने के लिए, <ph name="BEGIN_LINK"/>क्रोमियम में साइन इन करें<ph name="END_LINK"/>.</translation>
<translation id="1185134272377778587">क्रोमियम के बारे में</translation>
<translation id="1203500561924088507">इंस्टॉल करने के लिए धन्यवाद. <ph name="BUNDLE_NAME"/> का इस्तेमाल करने से पहले, ब्राउज़र को रीस्टार्ट करना ज़रूरी है.</translation>
<translation id="1231839967188101156">इस सेटिंग के चालू रहने पर Chromium, इस्तेमाल नहीं किए जा रहे टैब से मेमोरी खाली करता है. इससे इस्तेमाल किए जा रहे टैब और अन्य ऐप्लिकेशन को, ज़्यादा कंप्यूटर रिसॉर्स मिलते हैं. साथ ही, Chromium तेज़ी से काम करता है. जब इस्तेमाल नहीं किए जा रहे टैब पर कोई वापस जाता है, तो वे अपने-आप फिर से चालू हो जाते हैं. <ph name="BEGIN_LINK"/>ज़्यादा जानें<ph name="END_LINK"/></translation>
<translation id="2298752889004612764">मेमोरी सेवर ने Ecosia को और तेज़ बना दिया</translation>
<translation id="319566061277127356">क्रोमियम पर अपनी नई प्रोफ़ाइल सेट अप करें</translation>
<translation id="2549591663512786020">क्रोमियम पासवर्ड दिखाने का प्रयास कर रहा है.</translation>
<translation id="727568860157522676">आप क्रोमियम में प्रवेश हैं!</translation>
<translation id="6650631555168164414">Ecosia की सुविधाओं का ज़्यादा से ज़्यादा फ़ायदा लिया जा सकता है</translation>
<translation id="1861504561909287316">क्रोमियम का टैब शेयर करें</translation>
<translation id="6896860023874996542">क्रोमियम को आपके आस-पास की जगह का 3D मैप बनाने के लिए, कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें}=1{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}other{आपका एडमिन चाहता है कि आप अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="1625909126243026060">Chromium के निजता और सुरक्षा से जुड़े मुख्य कंट्रोल देखें</translation>
<translation id="931416298178634530">अगर आपको इस खाते का इस्तेमाल सिर्फ़ एक बार करना है, तो Ecosia ब्राउज़र में <ph name="GUEST_LINK_BEGIN"/>मेहमान मोड<ph name="GUEST_LINK_END"/> का इस्तेमाल किया जा सकता है. अगर आपको किसी अन्य व्यक्ति के लिए कोई खाता जोड़ना है, तो अपने <ph name="DEVICE_TYPE"/> में <ph name="LINK_BEGIN"/>एक नया व्यक्ति जोड़ें<ph name="LINK_END"/>.

आपने वेबसाइटों और ऐप्लिकेशन को जो अनुमतियां दी हैं वे इस खाते पर लागू हो सकती हैं. <ph name="SETTINGS_LINK_BEGIN"/>सेटिंग<ph name="SETTINGS_LINK_END"/> में जाकर, अपने Ecosia खातों को मैनेज किया जा सकता है.</translation>
<translation id="1640672724030957280">डाउनलोड हो रहा है...</translation>
<translation id="6876820794875877783">क्रोमियम का एक नया और सुरक्षित वर्शन उपलब्ध है.</translation>
<translation id="1118786556671181978">आपके पास अपनी पसंद के उन विषयों को देखने और हटाने का विकल्प होता है जिनका इस्तेमाल करके, साइटें आपको विज्ञापन दिखाती हैं. Ecosia आपके हाल के ब्राउज़िंग इतिहास के आधार पर, आपकी पसंद के विषयों का अनुमान लगाता है.</translation>
<translation id="8454595950895325762">क्रोमियम को पृष्ठभूमि में चलने दें</translation>
<translation id="9125443060066914183">Ecosia को ज़्यादा सुरक्षित बनाने के लिए, हमने ऐसे कुछ एक्सटेंशन अक्षम कर दिए हैं जो <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> में सूचीबद्ध नहीं हैं और आपकी जानकारी के बिना जोड़े गए हो सकते हैं.</translation>
<translation id="6984747211123632080">क्रोमियम को फिर से इंस्टॉल करें</translation>
<translation id="185970820835152459">आप अपने साइन-इन किए गए Google खाते मैनेज कर सकते हैं. आपके Google खाते, Chromium ब्राउज़र, Play Store, Gmail वगैरह के लिए इस्तेमाल किए जाते हैं. अगर आप किसी अन्य व्यक्ति के लिए कोई खाता जोड़ना चाहते हैं, तो अपने <ph name="DEVICE_TYPE"/> में एक नया व्यक्ति जोड़ें. <ph name="LINK_BEGIN"/>ज़्यादा जानें<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">साइटें, Chromium में आपकी पसंद के विषयों की जानकारी सेव कर सकती हैं. उदाहरण के लिए, अगर आपने किसी साइट पर मैराथन दौड़ के लिए जूते खोजे हैं, तो साइट, मैराथन दौड़ को आपकी पसंद के विषय के तौर पर सेव कर सकती है. बाद में, अगर आपने किसी दूसरी साइट पर जाकर दौड़ के लिए रजिस्ट्रेशन करवाया है, तो वह साइट आपकी पसंद के आधार पर दौड़ वाले जूते का विज्ञापन आपको दिखा सकती है.</translation>
<translation id="4239392394637574967">आप प्रबंधित खाते से साइन इन कर रहे हैं और उसके एडमिन को अपनी क्रोमियम प्रोफ़ाइल पर नियंत्रण दे रहे हैं. आपका क्रोमियम डेटा, जैसे आपके ऐप्लिकेशन, बुकमार्क, इतिहास, पासवर्ड, और दूसरे सेटिंग स्थायी रूप से <ph name="USER_NAME"/> से जुड़ जाएंगे. आप Ecosia खाता डैशबोर्ड के ज़रिए इस डेटा को मिटा सकेंगे, लेकिन दूसरे किसी खाते से इस डेटा को जोड़ नहीं सकेंगे. आप अपने मौजूदा क्रोमियम डेटा को अलग रखने के लिए वैकल्पिक रूप से एक नई प्रोफ़ाइल बना सकते हैं. <ph name="LEARN_MORE"/></translation>
<translation id="1911763535808217981">इसे बंद करके, आप क्रोमियम में साइन इन किए बिना Gmail जैसी Google साइटों में साइन इन कर सकते हैं</translation>
<translation id="18064594488616674">क्रोमियम अनुत्तरदायी है. अभी रीलॉन्‍च करें?</translation>
<translation id="8047394653992042491">अपडेट को लागू करने के लिए, EcosiaOS को रीस्टार्ट करने की ज़रूरत होती है.</translation>
<translation id="5337919616446681032">अगर आपको इस खाते का इस्तेमाल सिर्फ़ एक बार करना है, तो Ecosia ब्राउज़र में मेहमान मोड का इस्तेमाल किया जा सकता है. अगर आपको किसी अन्य व्यक्ति के लिए कोई खाता जोड़ना है, तो अपने <ph name="DEVICE_TYPE"/> में <ph name="LINK_BEGIN"/>एक नया व्यक्ति जोड़ें<ph name="LINK_END"/>.

आपने वेबसाइटों और ऐप्लिकेशन को जो अनुमतियां दी हैं वे इस खाते पर लागू हो सकती हैं. <ph name="SETTINGS_LINK_BEGIN"/>सेटिंग<ph name="SETTINGS_LINK_END"/> में जाकर, अपने Ecosia खातों को मैनेज किया जा सकता है.</translation>
<translation id="1953553007165777902">डाउनलोड हो रहा है... <ph name="MINUTE"/> मिनट बचे हैं</translation>
<translation id="1966382378801805537">क्रोमियम, डिफ़ॉल्ट ब्राउज़र को तय या सेट नहीं कर सकता</translation>
<translation id="2008474315282236005">ऐसा करने से इस डिवाइस से 1 आइटम मिट जाएगा. बाद में अपना डेटा पाने के लिए, Chromium में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="2018879682492276940">इंस्टॉल नहीं हो सका. कृपया फिर से कोशिश करें.</translation>
<translation id="2020032459870799438">डेटा के गलत इस्तेमाल और सुरक्षा की अन्य समस्याओं से आपके दूसरे पासवर्ड सुरक्षित हैं या नहीं, इसकी जांच करने के लिए, <ph name="BEGIN_LINK"/>क्रोमियम में साइन इन करें<ph name="END_LINK"/>.</translation>
<translation id="2049376729098081731">चुनें कि Google की सेवाओं में अपने हिसाब से और बेहतर अनुभव पाने के लिए, Chromium पर सेव किए गए आपके ब्राउज़िंग इतिहास को शामिल करना है या नहीं</translation>
<translation id="2088953378266246249">इस बारे में जानकारी कि Chromium अपने रूट सर्टिफ़िकेट कैसे मैनेज करता है</translation>
<translation id="838842459108103907">Ecosia को पसंद के मुताबिक बनाएं</translation>
<translation id="2174917724755363426">इंस्टॉल करने की प्रोसेस पूरी नहीं हुई. क्या आपको वाकई इसे रद्द करना है?</translation>
<translation id="9035946286843935549">क्रोमियम - नेटवर्क में साइन इन करें - <ph name="PAGE_TITLE"/></translation>
<translation id="6111519389633335269">अगर आप किसी कंप्यूटर को शेयर करते हैं, तो दोस्त और परिवार अलग-अलग ब्राउज़ कर सकते हैं और क्रोमियम को जैसा चाहें सेट कर सकते हैं.</translation>
<translation id="2313870531055795960">Chromium में पहले से सेव असुरक्षित साइटों की सूची का इस्तेमाल करके, यूआरएल की जांच करता है. अगर कोई साइट आपका पासवर्ड चुराने की कोशिश करती है या नुकसान पहुंचाने वाली कोई फ़ाइल डाउनलोड होने पर Chromium, सुरक्षित ब्राउज़िंग की सेवा को उनका यूआरएल भेजता है. यूआरएल के साथ-साथ पेज का कुछ कॉन्टेंट भी भेजा जाता है.</translation>
<translation id="665177868576952817">यहां से अपने Android फ़ोन पर नंबर भेजने के लिए, दोनों डिवाइस पर क्रोमियम में साइन इन करें.</translation>
<translation id="815199437159352723">इस एक्सटेंशन ने यह बदल दिया है कि जब आप क्रोमियम प्रारंभ करते हैं तब कौन सा पृष्‍ठ दिखाया जाए.</translation>
<translation id="2359808026110333948">जारी रखें</translation>
<translation id="592990842052138727">EcosiaOS आपका डेटा सिंक नहीं कर सका, क्योंकि आपके खाते में साइन इन करने से जुड़ी जानकारी पुरानी हो चुकी है.</translation>
<translation id="9032120646440147804">एक्सटेंशन "<ph name="EXTENSION_NAME"/>" ने यह बदल दिया है कि जब आप क्रोमियम प्रारंभ करते हैं तब कौन सा पृष्‍ठ दिखाया जाए.</translation>
<translation id="3554373328288278512">Ecosia को इस साइट के लिए, माइक्रोफ़ोन और कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="6495878830719404098">क्रोमियम में</translation>
<translation id="2485422356828889247">विस्थापित करें</translation>
<translation id="5549921590305750618">फ़ाइलें डाउनलोड करने के लिए क्रोमियम को मेमोरी एक्‍सेस की ज़रूरत होगी</translation>
<translation id="9090890391337853620">क्रोमियम सहायक</translation>
<translation id="5707346538075088068">इस प्रोफ़ाइल का इस्तेमाल करने के दौरान Ecosia में जनरेट हुए किसी भी तरह के डेटा को वर्क प्रोफ़ाइल का एडमिन हटा सकता है. डेटा में, बुकमार्क, इतिहास, पासवर्ड, और दूसरी सेटिंग शामिल हैं. <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosia को इस्तेमाल करना जारी रखें</translation>
<translation id="7280797724682955539">इंस्‍टॉलेशन के दौरान ऑपरेटिंग सिस्‍टम गड़बड़ी हुई. कृपया क्रोमियम फिर से डाउनलोड करें.</translation>
<translation id="6960183526681645011">अगर आप कोई डिवाइस शेयर करते हैं, तो आपके दोस्त और परिवार के लोग अलग-अलग ब्राउज़ कर सकते हैं. साथ ही, Ecosia को अपने हिसाब से सेट कर सकते हैं</translation>
<translation id="5591151834004774364">Ecosia ने इस आर्काइव फ़ाइल को ब्लॉक कर दिया है, क्योंकि इसमें मैलवेयर हो सकता है</translation>
<translation id="2381210243314074423"><ph name="ACCOUNT_FIRST_NAME"/>, Ecosia में आपका स्वागत है</translation>
<translation id="385080958066798123">क्रोमियम टैब</translation>
<translation id="2718390899429598676">ज़्यादा सुरक्षा के लिए, क्रोमियम आपके डेटा को सुरक्षित करेगा.</translation>
<translation id="2770231113462710648">डिफ़ॉल्ट ब्राउज़र को इसमें बदलें:</translation>
<translation id="2799223571221894425">फिर से लॉन्‍च करें</translation>
<translation id="3952510753191144456">इससे <ph name="USER_EMAIL_ADDRESS"/> के लिए एक नई Ecosia प्रोफ़ाइल बन जाएगी</translation>
<translation id="4199684616787081033">क्रोमियम से निकालें...</translation>
<translation id="2850691299438350830">अगर आप साइन इन हैं, तो यह सुविधा Chromium पर आपको सुरक्षित रखती है. साथ ही, इसका इस्तेमाल करके Google के अन्य ऐप्लिकेशन में सुरक्षा को बेहतर बनाया जा सकता है</translation>
<translation id="2885378588091291677">काम का मैनेजर</translation>
<translation id="7221868538334633215">&amp;क्रोमियम के बारे में</translation>
<translation id="2915996080311180594">बाद में रीस्टार्ट करें</translation>
<translation id="2928420929544864228">इंस्टॉल हो गया.</translation>
<translation id="2977470724722393594">क्रोमियम अप टू डेट है</translation>
<translation id="2977506796191543575">अगर कोई साइट आपका पासवर्ड चुराने की कोशिश करती है या नुकसान पहुंचाने वाली कोई फ़ाइल डाउनलोड होने पर Chromium, सुरक्षित ब्राउज़िंग की सेवा को उनके यूआरएल भेज सकता है. यूआरएल के साथ-साथ पेज का कुछ कॉन्टेंट भी भेजा जाता है</translation>
<translation id="6338684070520405381">क्रोमियम, पासवर्ड में बदलाव करने की कोशिश कर रहा है.</translation>
<translation id="2899530016847324742">{NUM_DEVICES,plural, =1{Ecosia को किसी एचआईडी डिवाइस से कनेक्ट किया गया है}one{Ecosia को किसी एचआईडी डिवाइस से कनेक्ट किया गया है}other{Ecosia को एचआईडी डिवाइसों से कनेक्ट किया गया है}}</translation>
<translation id="3032706164202344641">क्रोमियम आपके पासवर्ड की जांच नहीं कर सकता. बाद में कोशिश करें.</translation>
<translation id="1762318218111418450">क्रोमियम में जोड़ रहा है...</translation>
<translation id="3038232873781883849">इंस्टॉल करने की प्रोसेस, कुछ देर में शुरू होगी...</translation>
<translation id="9178613517891824246">Ecosia को क्रैश रिपोर्ट और <ph name="UMA_LINK"/> भेजकर क्रोमियम को बेहतर बनाने में मदद करें</translation>
<translation id="3101560983689755071">आपके ब्राउज़िंग इतिहास से इस बात पर असर पड़ता है कि आपको कौनसे विज्ञापन दिखेंगे. साथ ही, यहां दिए गए आपकी पसंद के विषयों के अनुमान पर भी इसका असर पड़ता है. आपकी निजता को सुरक्षित रखने के लिए, Chromium हर महीने आपकी पसंद के विषयों को ऑटोमैटिकली मिटा देता है. पसंद के विषय तब तक रीफ़्रेश किए जा सकते हैं, जब तक उन्हें मिटाया नहीं जाता.</translation>
<translation id="7691143774653486474">इंस्‍टॉलर संगह को असंकुचित करने में विफल हुआ. कृपया क्रोमियम फिर से डाउनलोड करें.</translation>
<translation id="1318059253725731825">Ecosia आपके माइक्रोफ़ोन का उपयोग कर रहा है.</translation>
<translation id="8282620071565190081">क्रोमियम फिर से लॉन्च करें</translation>
<translation id="5500958820122281144">क्रोमियम गु&amp;प्त विंडो में लिंक खोलें</translation>
<translation id="3697186779259384993">अपनी नई Ecosia प्रोफ़ाइल को पसंद के मुताबिक बनाएं</translation>
<translation id="3216284932113164802">ओह! क्रोमियम क्रैश हुआ. अभी फिर से लॉन्‍च करें?</translation>
<translation id="4409756430498035341">क्रोमियम आपके पासवर्ड निर्यात करना चाहता है.</translation>
<translation id="7602423871874451395">क्रोमियम इसकी डेटा निर्देशिका में पढ़ या लिख नहीं सकता:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="3283186697780795848">क्रोमियम वर्शन <ph name="PRODUCT_VERSION"/> इंस्टॉल है</translation>
<translation id="3286538390144397061">अभी फिर से प्रारंभ करें</translation>
<translation id="4735588186234302898">Ecosia API (एपीआई) कुंजियां मौजूद नहीं हैं. क्रोमियम के कुछ फ़ंक्शन बंद कर दिए जाएंगे.</translation>
<translation id="3296368748942286671">जब क्रोमियम बंद हो तब पृष्ठभूमि ऐप्‍लिकेशन चलाना जारी रखें</translation>
<translation id="812798451698099271">इस खाते के साथ एक Ecosia प्रोफ़ाइल पहले से मौजूद है</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="4781882243268600858">क्या आप मौजूदा Ecosia प्रोफ़ाइल में स्विच करना चाहते हैं?</translation>
<translation id="3412460710772753638">इस डिवाइस पर, Password Manager में अपडेट करें</translation>
<translation id="1914619467562029368">{COUNT,plural, =1{Ecosia को 1 मिनट से ज़्यादा समय तक इस्तेमाल न करने पर, वह अपने-आप बंद हो जाएगा. यह टाइम आउट, आपके एडमिन ने कॉन्फ़िगर किया है.}one{Ecosia को # मिनट से ज़्यादा समय तक इस्तेमाल न करने पर, वह अपने-आप बंद हो जाएगा. यह टाइम आउट, आपके एडमिन ने कॉन्फ़िगर किया है.}other{Ecosia को # मिनट से ज़्यादा समय तक इस्तेमाल न करने पर, वह अपने-आप बंद हो जाएगा. यह टाइम आउट, आपके एडमिन ने कॉन्फ़िगर किया है.}}</translation>
<translation id="4170280082681554565">Ecosia प्रोफ़ाइलों का इस्तेमाल करके, आप Ecosia पर अपनी सभी चीज़ों को अलग-अलग रख सकते हैं. अपने दोस्तों और परिवार के लिए या काम और मनोरंजन की चीज़ों को अलग-अलग रखने के लिए, प्रोफ़ाइलें बनाएं.</translation>
<translation id="347328004046849135">जब आप किसी हैक या चोरी हो चुके पासवर्ड से साइन इन करेंगे, तब क्रोमियम आपको इसकी सूचना देगा</translation>
<translation id="3474745554856756813">ऐसा करने से इस डिवाइस से <ph name="ITEMS_COUNT"/> आइटम मिट जाएंगे. बाद में अपना डेटा पाने के लिए, Chromium में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> दबाकर Ecosia प्रोफ़ाइलों के बीच स्विच किया जा सकता है</translation>
<translation id="8534308095039131078">कृपया सभी क्रोमियम विंडो बंद करें और फिर से प्रयास करें.</translation>
<translation id="3533435340678213462">आपकी निजता को सुरक्षित रखने के लिए, हम आपकी पसंद के उन विषयों को ऑटोमैटिकली मिटा देते हैं जिनका अनुमान चार हफ़्ते पहले लगाया गया था. ब्राउज़ करते रहने पर, आपकी पसंद का कोई विषय, सूची में फिर से शामिल किया जा सकता है. इसके अलावा, आपके पास उन विषयों को हटाने का भी विकल्प होता है जिन्हें आपको Chromium की सूची में शामिल नहीं करवाना है.</translation>
<translation id="3567254597502212821">आपका ब्राउज़िंग इतिहास, जिसमें इस डिवाइस पर Chromium का इस्तेमाल करके देखी गई साइटों का रिकॉर्ड होता है.</translation>
<translation id="2804130178228362015">आपके कंप्यूटर पर नुकसान पहुंचाने वाला सॉफ़्टवेयर है. क्रोमियम उसे हटा सकता है, आपकी सेटिंग को बहाल कर सकता है, और एक्सटेंशन को बंद कर सकता है, ताकि आपका ब्राउज़र फिर सामान्य रूप से काम करने लगे.</translation>
<translation id="7375011918167125899">आपने पहले से ही किसी दूसरे खाते में साइन इन किया हुआ है. आपकी ब्राउज़िंग को निजी रखने के लिए, Ecosia आपकी प्रोफ़ाइल बना सकता है.</translation>
<translation id="2128110540135015661">इस व्यक्ति का ब्राउज़िंग डेटा इस डिवाइस से मिटा दिया जाएगा. डेटा वापस पाने के लिए, क्रोमियम में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="1323499021727766710">{COUNT,plural, =0{क्रोमियम के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा.}=1{क्रोमियम के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{क्रोमियम के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}other{क्रोमियम के लिए एक नया अपडेट उपलब्ध है और जैसे ही आप फिर से लॉन्च करेंगे, अपडेट लागू कर दिया जाएगा. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/> से अपने Android फ़ोन पर नंबर भेजने के लिए, दोनों डिवाइस पर क्रोमियम में साइन इन करें.</translation>
<translation id="3685209450716071127">क्रोमियम आपके पासवर्ड की जांच नहीं कर सकता. अपने इंटरनेट कनेक्शन की जांच करें.</translation>
<translation id="5902103164685487225">Ecosia पर दिलचस्पी के मुताबिक विज्ञापन देखने की सुविधा के बारे में ज़्यादा जानें</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें}=1{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें. आपकी गुप्त विंडो फिर से नहीं खुलेगी.}one{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}other{आपके एडमिन का कहना है कि आप यह अपडेट लागू करने के लिए क्रोमियम को फिर से लॉन्च करें. आपकी # गुप्त विंडो फिर से नहीं खुलेंगी.}}</translation>
<translation id="489671036945006830">नए क्रोमियम &amp;टैब में लिंक खोलें</translation>
<translation id="3728336900324680424">पता बार में सुझाव देने के लिए क्रोमियम आपका 'डिस्क' ऐक्सेस करेगा</translation>
<translation id="6107290018380796650">'क्रोमियम' आपको वेब पर फ़ोन नंबर क्लिक करने और उसके ज़रिए Skype से कॉल करने की सुविधा देता है!</translation>
<translation id="3959732324458144441">EcosiaOS सिस्टम</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - क्रोमियम</translation>
<translation id="386822487697155367">ChromiumOS के लिए सहायता पाएं</translation>
<translation id="6391863622742187823">Ecosia ब्राउज़र से जुड़ी सुविधाओं को <ph name="ACCOUNT_EMAIL"/> से ऐक्सेस करें</translation>
<translation id="8544776492099331022">क्रोमियम को पसंद के मुताबिक बनाएं और नियंत्रित करें. कुछ है जिस पर आपको ध्यान देने की ज़रूरत है - विवरण के लिए क्लिक करें.</translation>
<translation id="4871843754042758264">क्रोमियम को खोलना और ब्राउज़ करना शुरू करने के लिए अपना नाम क्लिक करें.</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> इस Ecosia प्रोफ़ाइल में पहले से साइन इन है. आपकी निजी ब्राउज़िंग के लिए, Ecosia आपकी खुद की प्रोफ़ाइल बना सकता है.</translation>
<translation id="4070480171055648632">आपके खाते को <ph name="MANAGER_NAME"/> मैनेज करता है. आपका एडमिन, इस Ecosia ब्राउज़र पर प्रोफ़ाइल और उसके डेटा, जैसे कि बुकमार्क, इतिहास, और पासवर्ड को देख सकता है और उसमें बदलाव कर सकता है.</translation>
<translation id="1047556320128249268">क्रोमियम, पासवर्ड कॉपी करने की कोशिश कर रहा है. इसकी अनुमति देने के लिए Windows का पासवर्ड डालें.</translation>
<translation id="4997668724897475215">Ecosia इस फ़ाइल को स्कैन करने का सुझाव देता है, क्योंकि यह खतरनाक हो सकती है</translation>
<translation id="3997429360543082038">ChromiumOS के बारे में जानकारी</translation>
<translation id="5311911269004680646"><ph name="BEGIN_LINK_LINUX_OSS"/>Linux डेवलपमेंट एनवायरमेंट<ph name="END_LINK_LINUX_OSS"/> की तरह, EcosiaOS को भी अतिरिक्त <ph name="BEGIN_LINK_CROS_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_CROS_OSS"/> की मदद से बनाया गया है.</translation>
<translation id="4036079820698952681"><ph name="BEGIN_LINK"/>अभी वाली सेटिंग<ph name="END_LINK"/> की रिपोर्ट करके क्रोमियम को बेहतर बनाने में सहायता करें</translation>
<translation id="4050175100176540509">महत्‍वपूर्ण सुरक्षा सुधार और नई सुविधाएं नवीनतम वर्शन में उपलब्‍ध हैं.</translation>
<translation id="4148957013307229264">इंस्‍टॉल हो रहा है...</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - नेटवर्क में साइन इन करें - क्रोमियम</translation>
<translation id="7782767522222146179">क्रोमियम के लिए शानदार ऐप्‍स, गेम, एक्‍सटेंशन और थीम खोजें.</translation>
<translation id="4216212958613226427">इस भाषा का इस्तेमाल क्रोमियम यूज़र इंटरफ़ेस (यूआई) की सामग्री दिखाने के लिए किया जाता है</translation>
<translation id="4222932583846282852">रद्द किया जा रहा है...</translation>
<translation id="8384922154025337808">आपके क्रोमियम डेटा को इस खाते से लिंक करें?</translation>
<translation id="4271805377592243930">क्रोमियम के लिए सहायता पाएं</translation>
<translation id="3305517118160815955">अनिर्दिष्ट कारण से इंस्‍टॉलेशन विफल हुआ. अगर Ecosia अभी खुला हुआ है, तो कृपया उसे बंद करें और फिर से प्रयास करें.</translation>
<translation id="4304713468139749426">Password Manager</translation>
<translation id="4334294535648607276">डाउनलोड पूर्ण.</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> के मुताबिक, यह ज़रूरी है कि इस डिवाइस का इस्तेमाल करने से पहले आप सेवा की इन शर्तों को पढ़ें और स्वीकार करें. इन शर्तों से, EcosiaOS की शर्तों में कोई नई शर्त नहीं जुड़ती, न ही उनमें कोई बदलाव होता है, और न ही वे उतने तक सीमित रहती हैं.</translation>
<translation id="88039520238670574">फिर भी क्रोमियम से बाहर निकलें?</translation>
<translation id="4586967042094107073">क्रोमियम को बैकग्राउंड में चलने दें</translation>
<translation id="4817913198787198451">क्रोमियम को पसंद के मुताबिक बनाएं और नियंत्रित करें</translation>
<translation id="4427306783828095590">बेहतर सुरक्षा की मदद से फ़िशिंग और मैलवेयर को बेहतर तरीके से ब्लॉक किया जाता है</translation>
<translation id="1859120614572957305">Ecosia में आपका स्वागत है; नई ब्राउज़र विंडो खोली गई</translation>
<translation id="4544142686420020088">किसी गड़बड़ी की वजह से क्रोमियम अपडेट नहीं हुआ. <ph name="BEGIN_LINK"/>क्रोमियम को अपडेट करने से जुड़ी समस्याएं और नहीं हो पाने वाले अपडेट ठीक करें.<ph name="END_LINK"/></translation>
<translation id="8685318202174822382">क्या आप नए Ecosia प्रोफ़ाइल में ब्राउज़िंग जारी रखना चाहते हैं?</translation>
<translation id="4567424176335768812">आपने <ph name="USER_EMAIL_ADDRESS"/> के रूप में साइन इन किया हुआ है. अब आप अपने सभी साइन इन किए हुए डिवाइस पर अपने बुकमार्क, इतिहास, और दूसरी सेटिंग को एक्सेस कर सकते हैं.</translation>
<translation id="4594305310729380060">इस डिवाइस पर, Password Manager में सेव करें</translation>
<translation id="2636091632287013185">क्रोमियम ऐप्स</translation>
<translation id="4613863813562375431">ChromiumOS वर्शन</translation>
<translation id="4621240073146040695">करीब अप टू डेट हो गया है! अपडेट करना पूरा करने के लिए क्रोमियम फिर से लॉन्च करें.</translation>
<translation id="1676748966275099244">चेतावनी: Ecosia, एक्सटेंशन को आपका ब्राउज़िंग इतिहास रिकॉर्ड करने से नहीं रोक सकता. गुप्त मोड में इस एक्सटेंशन को बंद करने के लिए, इस विकल्प से चुने हुए का निशान हटाएं.</translation>
<translation id="4673151026126227699">अगर Chromium के इस्तेमाल से जुड़ी जानकारी देने वाली रिपोर्ट शेयर की जाती हैं, तो आपके देखे गए पेजों के यूआरएल उनमें शामिल होते हैं</translation>
<translation id="1384607180773886645">ऐसा लगता है कि प्रोफ़ाइल का उपयोग अन्य क्रोमियम प्रोसेस (<ph name="PROCESS_ID"/>) द्वारा किसी अन्य कंप्यूटर (<ph name="HOST_NAME"/>) पर किया जा रहा है. क्रोमियम ने प्रोफ़ाइल को लॉक कर दिया है ताकि वह दूषित न हो. अगर आप पक्का हैं कि कोई अन्य प्रोसेस इस प्रोफ़ाइल का उपयोग नहीं कर रही हैं, तो आप प्रोफ़ाइल को अनलॉक कर सकते हैं और क्रोमियम को फिर से लॉन्च कर सकते हैं.</translation>
<translation id="4680828127924988555">इंस्टॉल करना रद्द करें</translation>
<translation id="4727435569202742773">इस कंप्यूटर पर पहले किसी अन्य व्यक्ति ने <ph name="ACCOUNT_EMAIL_LAST"/> के रूप में Ecosia में साइन इन किया. अपनी जानकारी अलग रखने के लिए कृपया नया Ecosia उपयोगकर्ता बनाएं.</translation>
<translation id="864244542982029641">फिर भी क्रोमियम छोड़ें?</translation>
<translation id="1025044809499013222">क्रोमियम के लिए एक खास सुरक्षा अपडेट अभी लागू किया गया था. अभी रीस्टार्ट करें और हम आपके टैब बहाल कर देंगे.</translation>
<translation id="824192326282906244">Ecosia की सेटिंग में जाकर, इसमें कभी भी बदलाव किया जा सकता है. आपको ये बदलाव तुरंत नहीं दिखेंगे. ऐसा इसलिए होता है, क्योंकि आपकी दिलचस्पी के मुताबिक विज्ञापन दिखाने के ट्रायल के दौरान भी, विज्ञापन दिखाने के पुराने तरीके को पूरी तरह से नहीं बदला जाता है.</translation>
<translation id="4788777615168560705">क्रोमियम आपके पासवर्ड की जांच नहीं कर सकता. 24 घंटे बाद कोशिश करें या <ph name="BEGIN_LINK"/>अपने Google खाते के पासवर्ड की जांच करें<ph name="END_LINK"/>.</translation>
<translation id="3543284013834505767">इसमें स्पेलिंग जाँचने वाली उसी सुविधा का इस्तेमाल होता है जिसका इस्तेमाल 'Ecosia सर्च' में किया जाता है. आप ब्राउज़र में जो भी लेख लिखते हैं उसे Ecosia को भेजा जाता है. आप 'सेटिंग' में जाकर इसे कभी भी बदल सकते हैं.</translation>
<translation id="4154538917942874814">mDNS ट्रैफ़िक की अनुमति देने के लिए क्रोमियम के लिए इनबाउंड नियम.</translation>
<translation id="2159716220295742156">&amp;Ecosia को अपडेट करने के लिए फिर से लॉन्च करें</translation>
<translation id="2234042158691635795">क्रोमियम पृष्ठभूमि मोड में है.</translation>
<translation id="1869027055332251164">अतिथि कुछ भी छोड़े बिना क्रोमियम का उपयोग कर सकते हैं.</translation>
<translation id="6761747850241550887">स्वयं को क्रोमियम में जोड़ें</translation>
<translation id="3708834841667355707">Ecosia पर नई सुविधाओं को एक्सप्लोर किया जा रहा है. इनकी मदद से साइटें, आपसे जुड़ी कम से कम जानकारी का इस्तेमाल करके, ब्राउज़िंग का पहले जैसा अनुभव दे पाएंगी</translation>
<translation id="5224391634244552924">कोई भी पासवर्ड सेव नहीं किया गया है. आप जब अपने पासवर्ड सेव करते हैं, तो क्रोमियम उनकी जांच कर सकता है.</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> इस Ecosia प्रोफ़ाइल में पहले से साइन इन हैं. इससे <ph name="USER_EMAIL_ADDRESS"/> के लिए एक नई Ecosia प्रोफ़ाइल बन जाएगी</translation>
<translation id="5277894862589591112">अपने बदलाव लागू करने के लिए, क्रोमियम को फिर से लॉन्च करें</translation>
<translation id="5296845517486664001">ट्रायल के दौरान, अगर Chromium ने आपको किसी मौजूदा ट्रायल में अपने-आप शामिल कर लिया है, तो आपके ब्राउज़िंग इतिहास से इस बात पर असर पड़ता है कि आपको कौनसे विज्ञापन दिखेंगे. साथ ही, यहां दिए गए आपकी पसंद के विषयों के अनुमान पर भी इसका असर पड़ता है. आपकी निजता को सुरक्षित रखने के लिए, Chromium हर महीने आपकी पसंद के विषयों को मिटा देता है.</translation>
<translation id="7105712012505419722">आप प्रबंधित खाते से साइन इन कर रहे हैं और उसके एडमिन को अपनी क्रोमियम प्रोफ़ाइल पर नियंत्रण दे रहे हैं. आपका क्रोमियम डेटा, जैसे आपके ऐप्लिकेशन, बुकमार्क, इतिहास, पासवर्ड, और दूसरे सेटिंग स्थायी रूप से <ph name="USER_NAME"/> से जुड़ जाएंगे. आप Ecosia खाता डैशबोर्ड के ज़रिए इस डेटा को मिटा सकेंगे, लेकिन आप किसी अन्य खाते से इस डेटा को जोड़ नहीं सकेंगे. <ph name="LEARN_MORE"/></translation>
<translation id="5386450000063123300">क्रोमियम अपडेट हो रहा है (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">क्रोमियम में साइन-इन करने दें</translation>
<translation id="8447746441670667471">क्रोमियम का एक नया वर्शन उपलब्ध है.</translation>
<translation id="330264384086604869">क्रोमियम से निकालें</translation>
<translation id="3138995062177413515">{0,plural, =0{अब Ecosia बंद हो जाएगा.}=1{Ecosia 1 सेकंड में बंद हो जाएगा.}one{Ecosia # सेकंड में बंद हो जाएगा.}other{Ecosia # सेकंड में बंद हो जाएगा.}}</translation>
<translation id="5581150090232500900">क्रोमियम को अपने डिफ़ॉल्ट ब्राउज़र के रूप में सेट करें</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - क्रोमियम बीटा</translation>
<translation id="3307959934543585795">हो सकता है कि Ecosia सही तरीके से काम न करे, क्योंकि अब वह Linux के इस वर्शन पर काम नहीं करता है</translation>
<translation id="6558895515431832002">इस साइट से आपकी जगह की जानकारी शेयर करने के लिए क्रोमियम को आपकी जगह की जानकारी का एक्सेस चाहिए</translation>
<translation id="5487574057737591516">आपकी निजता को सुरक्षित रखने के लिए, हम आपकी पसंद के उन विषयों को ऑटोमैटिकली मिटा देते हैं जिनका अनुमान चार हफ़्ते पहले लगाया गया था. ब्राउज़ करते रहने पर, आपकी पसंद का कोई विषय, सूची में फिर से शामिल किया जा सकता है. इसके अलावा, अगर आपको लगता है कि Chromium ने आपकी पसंद के विषय को शामिल नहीं किया है या आपको कोई खास विज्ञापन नहीं देखना है, तो आपके पास उस विषय को हटाने का विकल्प होता है.</translation>
<translation id="5279514147510747661">कृपया क्रोमियम द्वारा नवीनतम सिस्टम अपडेट इंस्टॉल करने के दौरान प्रतीक्षा करें.</translation>
<translation id="5066194399237265772">क्रोमियम, पासवर्ड कॉपी करने की कोशिश कर रहा है. इसकी अनुमति देने के लिए Windows का पासवर्ड डालें.</translation>
<translation id="5527463683072221100">Chromium में पीडीएफ़ खोलें</translation>
<translation id="5614091477838198795">इसके चालू होने पर, आपको Chromium से भी साइन आउट कर दिया जाएगा</translation>
<translation id="7348818664647668234">{0,plural, =0{क्रोमियम का एक अपडेट उपलब्ध है}=1{क्रोमियम का एक अपडेट उपलब्ध है}one{क्रोमियम का एक अपडेट # दिनों से उपलब्ध है}other{क्रोमियम का एक अपडेट # दिनों से उपलब्ध है}}</translation>
<translation id="5675757883980078189">क्रोमियम के लिए Windows 7 या उसके बाद के वर्शन की आवश्यकता होती है.</translation>
<translation id="5982672133249369264">कृपया 'क्रोमियम' को अभी रीस्टार्ट करें</translation>
<translation id="5698481217667032250">क्रोमियम को इस भाषा में दिखाएं</translation>
<translation id="1027331268335328576">क्रोमियम में आपका स्वागत है</translation>
<translation id="2942675027725878581">Ecosia को पता चला है कि इन आइटम में मैलवेयर है:</translation>
<translation id="5895138241574237353">फिर से प्रारंभ करें</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - नेटवर्क में साइन इन करें</translation>
<translation id="5924017743176219022">इंटरनेट से कनेक्ट हो रहा है…</translation>
<translation id="5941711191222866238">छोटा करें</translation>
<translation id="5972142260211327093">अगर Chromium ने आपको किसी मौजूदा ट्रायल में अपने-आप शामिल कर लिया है, तो आपके ब्राउज़िंग इतिहास से इस बात पर असर पड़ता है कि आपको कौनसे विज्ञापन दिखेंगे. साथ ही, यहां दिए गए आपकी पसंद के विषयों के अनुमान पर भी इसका असर पड़ता है. आपकी निजता को सुरक्षित रखने के लिए, Chromium हर महीने आपकी पसंद के विषयों को मिटा देता है. पसंद के विषय तब तक रीफ़्रेश किए जाते हैं, जब तक उन्हें मिटाया नहीं जाता.</translation>
<translation id="5704599732514791330">सिंक शुरू करने के लिए क्रोमियम अपडेट करें</translation>
<translation id="5988505247484123880">आम तौर पर, आपने जिन साइटों को देखा है वे साइटें आपके पसंद के विषयों को सेव कर लेती हैं. ऐसा, आपकी पसंद के मुताबिक विज्ञापन दिखाने के लिए किया जाता है. साइटें, Chromium पर भी आपकी पसंद के विषयों की जानकारी सेव कर सकती हैं.</translation>
<translation id="6003112304606738118">डाउनलोड हो रहा है... <ph name="HOURS"/> घंटे बचे हैं</translation>
<translation id="6040143037577758943">बंद करें</translation>
<translation id="7185777478310554774">क्रोमियम का एक नया वर्शन उपलब्ध है और यह पहले से ज़्यादा तेज़ है.</translation>
<translation id="7303930050538184306">&amp;क्रोमियम में खोलें</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> को क्रोमियम में जोड़ा गया</translation>
<translation id="2905159584855395810">Ecosia को ज़्यादा तेज़ बनाएं</translation>
<translation id="608006075545470555">इस ब्राउज़र में वर्क प्रोफ़ाइल जोड़ें</translation>
<translation id="8296565077892323223">क्रोमियम को पसंद के मुताबिक बनाएं और नियंत्रित करें. अपडेट उपलब्ध है.</translation>
<translation id="6419542773162312746">Ecosia टूलबार में ऐक्सेस के अनुरोध दिखाने के लिए, एक्सटेंशन को अनुमति दें</translation>
<translation id="4021894801595982809">क्रोमियम इस पासवर्ड को आपके Ecosia खाते में सेव कर लेगा. आपको इसे याद रखने की ज़रूरत नहीं है.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> खतरनाक है, इसलिए क्रोमियम ने उसे अवरोधित कर दिया है.</translation>
<translation id="6134968993075716475">सुरक्षित ब्राउज़िंग की सुविधा बंद है. 'क्रोमियम' इसे चालू करने का सुझाव देता है.</translation>
<translation id="4032832945953542360">आप यहां Ecosia प्रोफ़ाइलों के बीच स्विच कर सकते हैं</translation>
<translation id="2346323077583431428">पक्का करें कि आपने <ph name="TARGET_DEVICE_NAME"/> पर क्रोमियम में साइन इन किया है. इसके बाद, फिर से भेजने की कोशिश करें.</translation>
<translation id="2995860351618948435">इस कंप्‍यूटर में पहले से क्रोमियम का ज़्यादा नया वर्शन है. अगर सॉफ़्टवेयर काम नहीं कर रहा है, तो कृपया क्रोमियम अनइंस्‍टॉल करें और फिर से प्रयास करें.</translation>
<translation id="5690368185132749068">{0,plural, =0{क्रोमियम अभी फिर से लॉन्च होगा}=1{क्रोमियम 1 सेकंड में फिर से लॉन्च होगा}one{क्रोमियम # सेकंड में फिर से लॉन्च होगा}other{क्रोमियम # सेकंड में फिर से लॉन्च होगा}}</translation>
<translation id="1809194740315140401">फ़ाइलें डाउनलोड करने के लिए, Ecosia को डिवाइस का स्टोरेज ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="6245734527075554892">Chromium में पहले से सेव की गई असुरक्षित साइटों की सूची का इस्तेमाल करके, यूआरएल की जांच की जाती है</translation>
<translation id="4662363689050405237">क्रोमियम को डिफ़ॉल्ट ब्राउज़र बनाएं</translation>
<translation id="6266342355635466082">क्रोमियम आपके अपडेट की जांच नहीं कर सकता. अपने इंटरनेट कनेक्शन की जांच करें.</translation>
<translation id="6268381023930128611">क्रोमियम से प्रस्थान करें?</translation>
<translation id="6273793429163604305">तैयार हो जाएं...</translation>
<translation id="6416551953415159186">अपनी Ecosia प्रोफ़ाइल को पसंद के मुताबिक बनाएं</translation>
<translation id="6290827346642914212">अपने Chromium प्रोफ़ाइल को नाम दें</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/> खतरनाक हो सकता है, इसलिए क्रोमियम ने उसे अवरोधित कर दिया है.</translation>
<translation id="4943938785458240142">Ecosia आपके कैमरे का उपयोग कर रहा है.</translation>
<translation id="5669097765101132299">Ecosia ने इस फ़ाइल को ब्लॉक किया है, क्योंकि यह नुकसान पहुंचा सकती है</translation>
<translation id="6327105987658262776">कोई अपडेट उपलब्ध नहीं है.</translation>
<translation id="6450895420388847775">क्रोमियम पर एक अन्य क्रिया चल रही है. कृपया बाद में फिर से कोशिश करें.</translation>
<translation id="464306605599005355">अब अपने Ecosia खाते के साथ और शेयर किए गए कंप्यूटर पर क्रोमियम का उपयोग करना आसान हो गया है.</translation>
<translation id="7908111389403807005">क्या आप वाकई क्रोमियम को अनइंस्टाल करना चाहते हैं?</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>हम इस डेटा का इस्तेमाल कैसे करते हैं:<ph name="END_BOLD"/> इस डेटा की मदद से, Ecosia आपकी पसंद के विषयों का अनुमान लगा सकता है. Ecosia जब आपकी पसंद का अनुमान लगा लेता है, तब आपके किसी दूसरी साइट पर जाने पर, वह साइट Ecosia से आपकी पसंद जानने की अनुमति मांग सकती है. साइट यह अनुमति इसलिए मांगती है, ताकि वह आपको आपकी पसंद के हिसाब से विज्ञापन दिखा सके.</translation>
<translation id="3939060118711873999">क्रोमियम वेब ब्राउज़र है जो बहुत तेज़ी से वेबपेज और ऐप्‍लिकेशन चलाता है. यह तेज़, स्‍थिर, और उपयोग में आसान है. क्रोमियम में अंतर्निहित मैलवेयर और फ़ीशिंग सुरक्षा के साथ ज़्यादा आसानी से वेब ब्राउज़ करें.</translation>
<translation id="5404489723475681578">EcosiaOS को रीस्टार्ट करें</translation>
<translation id="4410570812343670816">Ecosia प्रोफ़ाइलों में आपका स्वागत है</translation>
<translation id="5789438819244101666">{SECONDS,plural, =1{क्रोमियम 1 सेकंड में रीस्टार्ट होगा}one{क्रोमियम # सेकंड में रीस्टार्ट होगा}other{क्रोमियम # सेकंड में रीस्टार्ट होगा}}</translation>
<translation id="524314285625975879">इससे यह भी नियंत्रित होता है कि जब आप क्रोमियम प्रारंभ करते हैं तब कौन सा पृष्‍ठ दिखाया जाए.</translation>
<translation id="6496553866814956056">क्रोमियम को अनइंस्टाल करें</translation>
<translation id="8608092457636055141">हर प्रोफ़ाइल के पास उसके अपने Ecosia की जानकारी होती है, जैसे कि बुकमार्क, इतिहास, पासवर्ड, और अन्य जानकारी</translation>
<translation id="6570579332384693436">स्पेलिंग की गड़बड़ियां ठीक करने के लिए, क्रोमियम लेख फ़ील्ड में आपके लिखे गए लेख को Google को भेजती है</translation>
<translation id="6533266716128249922">क्रोमियम की सूचना सेटिंग पर जाएं</translation>
<translation id="1722634673917783018">अगली बार जब आप क्रोमियम फिर से लॉन्‍च करेंगे तो आपके बदलाव लागू होंगे .</translation>
<translation id="2537426042760364251">आपके आस-पास की जगहों का 3D मैप बनाने के लिए, Ecosia को कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="6663852025006259149">ऐसा हो सकता है कि साइटें आपकी उम्मीद के मुताबिक काम करें. हालांकि, Chromium की सभी विंडो बंद करने के बाद, साइटें आपकी जानकारी सेव नहीं रखेंगी</translation>
<translation id="6676384891291319759">इंटरनेट एक्सेस करें</translation>
<translation id="8067423333018528301">साइन इन करने से जुड़ी गड़बड़ी की वजह से, EcosiaOS आपका डेटा सिंक नहीं कर सका.</translation>
<translation id="2173571365716863400">Ecosia को इस साइट के लिए, माइक्रोफ़ोन ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="6648664289472946060">आपकी प्रोफ़ाइल का उपयोग नहीं किया जा सकता क्‍योंकि यह क्रोमियम के नए वर्शन से है.

हो सकता है कुछ सुविधाएं अनुपलब्ध हों. कृपया अलग प्रोफाइल निर्देशिका दर्ज करें या क्रोमियम के नए वर्शन का उपयोग करें.</translation>
<translation id="6039735020616040749">मेमोरी सेवर ने Ecosia को और तेज़ बना दिया</translation>
<translation id="4870057811531036437">आपके कंप्यूटर पर मौजूद सभी उपयोगकर्ताओं के लिए क्रोमियम पहले से इंस्टॉल है.</translation>
<translation id="4512092435423703529">Ecosia से जुड़ी सुविधाओं को अपने सभी डिवाइसों पर ऐक्सेस करने के लिए, साइन इन करें. इसके बाद, सिंक चालू करें.</translation>
<translation id="7972668220031382654">Ecosia इस फ़ाइल को स्कैन करने का सुझाव देता है, क्योंकि यह खतरनाक हो सकती है.</translation>
<translation id="2290912123073552463">आपके अभिभावक ने क्रोमियम के लिए, "साइट, ऐप्लिकेशन, और एक्सटेंशन के लिए अनुमतियां" को बंद कर दिया है. इस <ph name="EXTENSION_TYPE_PARAMETER"/> को चालू करने की अनुमति नहीं है.</translation>
<translation id="2441303983090031276">EcosiaOS को अतिरिक्त <ph name="BEGIN_LINK_CROS_OSS"/>ओपन सोर्स सॉफ़्टवेयर<ph name="END_LINK_CROS_OSS"/> की मदद से बनाया गया है.</translation>
<translation id="1263466865695943046">'क्रोमियम' यह बताता है कि कहीं आपके पासवर्ड का गलत इस्तेमाल तो नहीं किया गया है</translation>
<translation id="7864624828358709494">Ecosia ने इस फ़ाइल को ब्लॉक कर दिया है, क्योंकि इसमें मैलवेयर है</translation>
<translation id="4600924482853773728">क्रोमियम - <ph name="PAGE_TITLE"/></translation>
<translation id="6863361426438995919">Google Pay (क्रोमियम पर कॉपी किया गया)</translation>
<translation id="1490060441084292633">Ecosia को पता चला है कि "<ph name="EXTENSION_NAME"/>" में मैलवेयर है</translation>
<translation id="7482156490649194631">क्रोमियम को अपडेट किया गया है लेकिन आपने इसे कम से कम 30 दिनों से उपयोग नहीं किया है.</translation>
<translation id="4062366803229254216">दूसरे डिवाइस से जोड़े रखने के लिए, Ecosia को ब्लूटूथ का ऐक्सेस 
 चाहिए. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="6929417474050522668">ट्रायल के दौरान, विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, आपकी देखी गई साइटों को अनुमति देता है कि वे Chromium से आपकी जानकारी पाने का अनुरोध कर सकें. इस जानकारी से, साइट पर दिखाए जाने वाले विज्ञापनों की परफ़ॉर्मेंस का पता लगाने में मदद मिलती है. विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, क्रॉस-साइट ट्रैकिंग को रोकता है. इसके लिए एपीआई, साइटों को आपस में कम से कम जानकारी शेयर करने देता है.</translation>
<translation id="6940431691900807093">Chromium जब आपकी पसंद का अनुमान लगा लेता है, तब आपके किसी दूसरी साइट पर जाने पर, वह साइट Chromium से आपकी पसंद जानने की अनुमति मांग सकती है. साइट यह अनुमति इसलिए मांगती है, ताकि वह आपको आपकी पसंद के हिसाब से विज्ञापन दिखा सके. Chromium आपकी पसंद के ज़्यादा से ज़्यादा तीन विषयों की जानकारी शेयर कर सकता है.</translation>
<translation id="8283315171506895091">क्रोमियम गु&amp;प्त विंडो में लिंक खोलें</translation>
<translation id="6978145336957848883">कमज़ोर पासवर्ड का अंदाज़ा लगाना आसान होता है. क्रोमियम को <ph name="BEGIN_LINK"/>आपके लिए मज़बूत पासवर्ड बनाने और उन्हें याद रखने की अनुमति दें<ph name="END_LINK"/>.</translation>
<translation id="1401515072108809622">Ecosia कुछ समय से इस्तेमाल में नहीं है</translation>
<translation id="2149148292984034533">EcosiaOS की शर्तें</translation>
<translation id="1831192335802727557">क्रोमियम को इस साइट के लिए आपका माइक्रोफ़ोन एक्सेस करने की अनुमति चाहिए</translation>
<translation id="7025789849649390912">इंस्टॉल करने की प्रोसेस को बंद किया गया.</translation>
<translation id="5598074261782651109">क्रोमियम अपडेट करें</translation>
<translation id="2838372953389311551">अगर किसी इमेज के बारे में मददगार जानकारी मौजूद नहीं है, तो 'क्रोमियम' उसके बारे में जानकारी देने की कोशिश करेगा. जानकारी तैयार करने के लिए, इमेज Ecosia को भेजी जाती हैं.</translation>
<translation id="219546601381787154">Ecosia को इस साइट के लिए, कैमरा ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="2542649989941327712">Ecosia लॉन्च नहीं किया जा सका. फिर से कोशिश करें.</translation>
<translation id="7197677400338048821">क्रोमियम आपके पासवर्ड की जांच नहीं कर सकता. 24 घंटे बाद कोशिश करें.</translation>
<translation id="7311066525704006840">काम का मैनेजर - क्रोमियम</translation>
<translation id="3816260943154642689">आपकी पसंद के विषय जिनका अनुमान Ecosia ने लगाया है</translation>
<translation id="7309928523159922338">विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, आपकी देखी गई साइटों को अनुमति देता है कि वे Chromium से आपकी जानकारी पाने का अनुरोध कर सकें. इस जानकारी से, साइट पर दिखाए जाने वाले विज्ञापनों की परफ़ॉर्मेंस का पता लगाने में मदद मिलती है. विज्ञापनों की परफ़ॉर्मेंस का पता लगाने वाला एपीआई, क्रॉस-साइट ट्रैकिंग को रोकता है. इसके लिए एपीआई, साइटों को आपस में कम से कम जानकारी शेयर करने देता है.</translation>
<translation id="731795002583552498">क्रोमियम अपडेट हो रहा है</translation>
<translation id="6673288084648462613">आपकी पसंदीदा फ़ाइल खराब या अमान्‍य है.

क्रोमियम आपकी सेटिंग बहाल नहीं कर सकता.</translation>
<translation id="4811228173434336381">क्रोमियम</translation>
<translation id="7339898014177206373">नई विंडो</translation>
<translation id="4960252760049500399">आपके वेब, बुकमार्क, और अन्य क्रोमियम सामग्री यहां मौजूद रहती है.</translation>
<translation id="7158975242722498086">आपके सिस्टम एडमिन ने <ph name="ALTERNATIVE_BROWSER_NAME"/> खाेलने के लिए, क्रोमियम को कॉन्फ़िगर किया है ताकि <ph name="TARGET_URL_HOSTNAME"/> काे ऐक्सेस किया जा सके.</translation>
<translation id="5622136942112821750">Ecosia प्रोफ़ाइलों का इस्तेमाल करके, Ecosia से जुड़ी अपनी सभी चीज़ों को अलग-अलग रखा जा सकता है. इससे, काम और मनोरंजन की चीज़ों को अलग-अलग रखना आसान हो जाता है.</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - क्रोमियम डेवपलर</translation>
<translation id="5055330219314726197">क्रोमियम को इस साइट के लिए आपका कैमरा एक्सेस करने की अनुमति चाहिए</translation>
<translation id="1975037445584526511">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में Windows 10 या उसके बाद वाला वर्शन होना चाहिए. इस कंप्यूटर में Windows 7 का इस्तेमाल किया जा रहा है.</translation>
<translation id="7467949745582939695">Chromium को फिर से लॉन्च करें?</translation>
<translation id="80155189677487610">वर्तमान में चल रहे समान क्रोमियम वर्शन को इंस्‍टॉल नहीं कर सकते. कृपया क्रोमियम बंद करें और फिर से प्रयास करें.</translation>
<translation id="7558678848273505235">{0,plural, =1{क्रोमियम 1 मिनट में फिर से लॉन्च होगा}one{क्रोमियम # मिनट में फिर से लॉन्च होगा}other{क्रोमियम # मिनट में फिर से लॉन्च होगा}}</translation>
<translation id="3674955518940155608">साथ ही, क्रोमियम (<ph name="URL"/>) का डेटा साफ़ करें</translation>
<translation id="7582945390259497898">Chromium आपकी पसंद के विषयों का अनुमान लगा सकता है. Chromium जब आपकी पसंद का अनुमान लगा लेता है, तब आपके किसी दूसरी साइट पर जाने पर, वह साइट Chromium से आपकी पसंद जानने की अनुमति मांग सकती है. साइट यह अनुमति इसलिए मांगती है, ताकि वह आपको आपकी पसंद के हिसाब से विज्ञापन दिखा सके.</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME"/> इंस्टॉलर</translation>
<translation id="7910693244647744044">आपके खाते में, बेहतर सुरक्षित ब्राउज़िंग की सुविधा चालू है. अब यह सुविधा Ecosia में पाएं.</translation>
<translation id="4061472199368124600">Ecosia आपके कैमरे और माइक्रोफ़ोन का उपयोग कर रहा है.</translation>
<translation id="170259281605734125">क्रोमियम पहले से बेहतर हो गया है</translation>
<translation id="7649070708921625228">सहायता</translation>
<translation id="675365189802108507">Ecosia की सेटिंग में जाकर, इन सुविधाओं के बारे ज़्यादा जानकारी हासिल की जा सकती है.</translation>
<translation id="7682601070171973634">Chromium पर ऐसी नई सुविधाएं एक्सप्लोर की जा रही हैं जिनसे साइटें, उपयोगकर्ता का कम डेटा इस्तेमाल करके उन्हें पहले जैसा अनुभव दे सकती हैं</translation>
<translation id="1508200558303644420">क्रोमियम आपका डिफ़ॉल्ट ब्राउज़र नहीं है</translation>
<translation id="7174674455569790401">क्रोमियम को अपने सभी डिवाइस पर सिंक करें और मनमुताबिक बनाएं</translation>
<translation id="7745317241717453663">ऐसा करने से इस डिवाइस से आपका ब्राउज़िंग डेटा मिट जाएगा. बाद में अपना डेटा पाने के लिए, Chromium में <ph name="USER_EMAIL"/> के रूप में साइन इन करें.</translation>
<translation id="7747138024166251722">इंस्टॉलर अस्थायी डायरेक्टरी नहीं बना सका. कृपया डिस्क में खाली जगह और सॉफ़्टवेयर इंस्टॉल करने की अनुमति जांचें.</translation>
<translation id="6161025257729272170">Ecosia को ज़्यादा तेज़ बनाएं</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - क्रोमियम कैनरी</translation>
<translation id="8301840715671593762">इस खाते से बनाई गई एक Ecosia प्रोफ़ाइल इस डिवाइस पर पहले से मौजूद है</translation>
<translation id="7845233973568007926">इंस्टॉल करने के लिए धन्यवाद. <ph name="BUNDLE_NAME"/> का इस्तेमाल करने से पहले, कंप्यूटर को रीस्टार्ट करना ज़रूरी है.</translation>
<translation id="3268039966078382323">क्रोमियम सबसे नए वर्शन में अपडेट नहीं कर सका, इसलिए आपको नई सुविधाएं और सुरक्षा सुधार नहीं मिल रहे हैं.</translation>
<translation id="7872446069773932638">डाउनलोड हो रहा है... <ph name="SECONDS"/> सेकंड बचे हैं</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>अपना डेटा कैसे मैनेज करें:<ph name="END_BOLD"/> आपकी निजता को सुरक्षित रखने के लिए, हम आपकी पसंद के उन विषयों को ऑटोमैटिकली मिटा देते हैं जिनका अनुमान चार हफ़्ते पहले लगाया गया था. ब्राउज़ करते रहने पर, आपकी पसंद का कोई विषय, सूची में फिर से शामिल किया जा सकता है. इसके अलावा, आपके पास उन विषयों को हटाने का भी विकल्प होता है जिन्हें आपको Ecosia की सूची में शामिल नहीं करवाना है.</translation>
<translation id="2412381038247037703">आपने क्रोमियम में <ph name="USER_EMAIL_ADDRESS"/> के रूप में साइन इन किया था. फिर से साइन इन करने के लिए कृपया उसी खाते का इस्तेमाल करें.</translation>
<translation id="7975919845073681630">यह क्रोमियम का द्वितीयक इंस्टॉलेशन है और इसे आपका डिफ़ॉल्ट ब्राउज़र नहीं बनाया जा सकता.</translation>
<translation id="851583113375911087">नामालूम स्रोत से डाउनलोड किए गए एक्सटेंशन, ऐप्लिकेशन, और थीम से आपके डिवाइस को नुकसान पहुंच सकता है. हमारा सुझाव है कि आप इन्हें सिर्फ़ <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> से इंस्टॉल करें</translation>
<translation id="488806616089631539">क्रोमियम को ऐक्सेस मिलने के बाद, वेबसाइटें आपसे ऐक्सेस मांग सकेंगी.</translation>
<translation id="80471789339884597">इंस्टॉल करने के लिए धन्यवाद. <ph name="BUNDLE_NAME"/> का इस्तेमाल करने से पहले, आपको सभी ब्राउज़र रीस्टार्ट करने होंगे.</translation>
<translation id="5661123757512626239">Ecosia को इस साइट के लिए, जगह की जानकारी ऐक्सेस करने की अनुमति चाहिए</translation>
<translation id="143614250230771428">EcosiaOS आपका डेटा सिंक नहीं कर सका, क्योंकि आपके डोमेन के लिए सिंक करने की सुविधा उपलब्ध नहीं है.</translation>
<translation id="813913629614996137">शुरू हो रहा है...</translation>
<translation id="6491651957026506753">यह फ़ाइल खतरनाक है, इसलिए क्रोमियम ने इसे रोक दिया है.</translation>
<translation id="796435732739009892">Ecosia ने इस फ़ाइल को ब्लॉक कर दिया है, क्योंकि इस तरह की फ़ाइल खतरनाक हो सकती है</translation>
<translation id="2046160555506209000">अगर किसी इमेज के बारे में मददगार जानकारी मौजूद नहीं है, तो 'क्रोमियम' उसके बारे में जानकारी देने की कोशिश करेगा. जानकारी तैयार करने के लिए, इमेज Ecosia को भेजी जाती हैं. आप किसी भी समय सेटिंग में जाकर इसे बंद कर सकते हैं.</translation>
<translation id="8266560134891435528">क्रोमियम आपके पासवर्ड की जांच नहीं कर सकता, क्योंकि आपने साइन इन नहीं किया है</translation>
<translation id="8633885040939757689">क्रोमियम, पासवर्ड कॉपी करने की कोशिश कर रहा है.</translation>
<translation id="2243562167758283214">यह फ़ाइल खतरनाक हो सकती है, इसलिए क्रोमियम ने इसे ब्लॉक कर दिया है.</translation>
<translation id="8330519371938183845">Chrome को अपने सभी डिवाइस पर सिंक करने और मनमुताबिक बनाने के लिए साइन इन करें</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> पहले क्रोमियम का उपयोग कर रहा था</translation>
<translation id="4337034173783952373">अपने सभी डिवाइसों पर, Ecosia ब्राउज़र से जुड़ी सुविधाएं ऐक्सेस करने के लिए, साइन इन करें. इसके बाद, सिंक करने की सुविधा चालू करें</translation>
<translation id="8655983536493871574">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में Windows 10 या उसके बाद वाला वर्शन होना चाहिए. इस कंप्यूटर में Windows 8 का इस्तेमाल किया जा रहा है.</translation>
<translation id="6826163993811146231">{0,plural, =1{एक दिन के अंदर क्रोमियम को फिर से लॉन्च करें}one{# दिनों के अंदर क्रोमियम को फिर से लॉन्च करें}other{# दिनों के अंदर क्रोमियम को फिर से लॉन्च करें}}</translation>
<translation id="4033006861724039519">इंस्‍टॉलर संग्रह खराब या अमान्‍य है. कृपया क्रोमियम फिर से डाउनलोड करें.</translation>
<translation id="8975930032513941502">आप चाहें, तो EcosiaOS को यह अनुमति दें कि वह गड़बड़ी की जानकारी और इस्तेमाल से जुड़ा डेटा Ecosia को अपने-आप भेज सके. आपके ऐसा करने से, EcosiaOS की सुविधाओं और परफ़ॉर्मेंस को बेहतर बनाने में मदद मिलेगी.</translation>
<translation id="2695952268686253864">क्रोमियम पुराना हो गया है</translation>
<translation id="8550334526674375523">यह वर्क प्रोफ़ाइल आपकी निजी प्रोफ़ाइल से पूरी तरह अलग है.</translation>
<translation id="4281355161119203663">आपके अभिभावक ने क्रोमियम के लिए, "साइट, ऐप्लिकेशन, और एक्सटेंशन के लिए अनुमतियां" को बंद कर दिया है. इस <ph name="EXTENSION_TYPE_PARAMETER"/> को जोड़ने की अनुमति नहीं है.</translation>
<translation id="6235917057647038042">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में macOS 10.13 या इसके बाद का वर्शन होना चाहिए. इस कंप्यूटर में macOS 10.12 का इस्तेमाल किया जा रहा है.</translation>
<translation id="8568283329061645092">आप जब अपने Google खाते से साइन इन करते हैं, तब क्रोमियम आपके पासवर्ड की जांच कर सकता है</translation>
<translation id="8574036838419011058">इस सेटिंग के चालू होने पर Chromium, बैकग्राउंड गतिविधि और विज़ुअल इफ़ेक्ट, जैसे कि स्मूद स्क्रोलिंग और वीडियो के फ़्रेम रेट को सीमित करके बैटरी की खपत कम करता है. <ph name="BEGIN_LINK"/>ज़्यादा जानें<ph name="END_LINK"/></translation>
<translation id="7129808598331559748">कॉपीराइट <ph name="YEAR"/> The Ecosia Authors. सर्वाधिकार सुरक्षित.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>हम इस डेटा का इस्तेमाल कैसे करते हैं:<ph name="END_BOLD"/> साइटें, Ecosia पर आपकी पसंद के विषयों की जानकारी सेव कर सकती हैं. उदाहरण के लिए, अगर आपने किसी साइट पर मैराथन दौड़ के लिए जूते खोजे हैं, तो साइट, मैराथन दौड़ को आपकी पसंद के विषय के तौर पर सेव कर सकती है. बाद में, अगर आपने किसी दूसरी साइट पर जाकर दौड़ के लिए रजिस्ट्रेशन करवाया है, तो वह साइट आपकी पसंद के आधार पर दौड़ वाले जूते का विज्ञापन आपको दिखा सकती है.</translation>
<translation id="8109744984354428711">क्रोमियम लॉन्च हो रहा है...</translation>
<translation id="2402290209407843024">अनिर्दिष्ट कारणों से इंस्‍टॉलेशन विफल हुआ. कृपया क्रोमियम फिर से डाउनलोड करें.</translation>
<translation id="6665128960039431910">इससे यह भी नियंत्रित होता है कि जब आप क्रोमियम शुरू करते हैं या ऑम्निबॉक्स से खोजते हैं तब कौन सा पेज दिखाया जाए.</translation>
<translation id="2000339487270823788">यह आपका क्रोमियम है</translation>
<translation id="7273750863406285983">क्रोमियम को इस साइट के लिए आपका कैमरा और माइक्रोफ़ोन एक्सेस करने की अनुमति चाहिए</translation>
<translation id="5267683457871579197">EcosiaOS सिस्टम</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>किस डेटा का इस्तेमाल किया जाता है:<ph name="END_BOLD"/> आपका ब्राउज़िंग इतिहास, जिसमें इस डिवाइस पर Ecosia का इस्तेमाल करके देखी गई साइटों का रिकॉर्ड होता है.</translation>
<translation id="8862326446509486874">सिस्टम-स्तर स्थापना के लिए आपके पास उचित अधिकार नहीं हैं. इंस्टॉलर को व्यवस्थापक के रूप में फिर से चलाने का प्रयास करें.</translation>
<translation id="8880203542552872219">अगर आपने पहले ही पासवर्ड बदल दिया है, तो कृपया क्रोमियम में सेव किए गए पासवर्ड में बदलाव करें, ताकि यह आपके नए पासवर्ड से मेल खाए.</translation>
<translation id="6078545897140861225">इससे यह भी नियंत्रित होता है कि जब आप क्रोमियम शुरू करते हैं या होम बटन क्लिक करते हैं तब कौन सा पेज दिखाया जाए.</translation>
<translation id="3966234175958887595">Ecosia पासवर्ड दिखाने का प्रयास कर रहा है. इसे अनुमति देने के लिए अपना Windows पासवर्ड लिखें.</translation>
<translation id="8931379085695076764">Chromium पिछले कुछ हफ़्तों के ब्राउज़िंग इतिहास के आधार पर, आपकी पसंद के विषयों का अनुमान लगा सकता है. यह जानकारी आपके डिवाइस पर सेव की जाती है.</translation>
<translation id="6346154190168496057">क्रोमियम को अपडेट नहीं किया जा सकता</translation>
<translation id="93440396576488794">Ecosia Enterprise का लोगो</translation>
<translation id="8986207147630327271">आप इस ब्राउज़र में एक वर्क प्रोफ़ाइल जोड़ रहे हैं और अपने एडमिन को सिर्फ़ उस प्रोफ़ाइल को कंट्रोल करने का अधिकार दे रहे हैं.</translation>
<translation id="1597547208646178091">क्रोमियम को ज़्यादा सुरक्षित बनाने के लिए, हमने निम्न एक्सटेंशन को अक्षम कर दिया है जो <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> में सूचीबद्ध नहीं है और आपकी जानकारी के बिना जोड़ा गया हो सकता है.</translation>
<translation id="2388751143175762498">क्रोमियम में साइन इन करें</translation>
<translation id="7268098999602465369">क्रोमियम पुराना हो गया है</translation>
<translation id="6022879254514691681">{0,plural, =1{क्रोमियम एक घंटे के अंदर फिर से लॉन्च होगा}one{क्रोमियम # घंटे के अंदर फिर से लॉन्च होगा}other{क्रोमियम # घंटे के अंदर फिर से लॉन्च होगा}}</translation>
<translation id="8963533629322868062">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में Windows 10 या उसके बाद वाला वर्शन होना चाहिए. इस कंप्यूटर में Windows 8.1 का इस्तेमाल किया जा रहा है.</translation>
<translation id="7774247008790177839">नए क्रोमियम &amp;टैब में लिंक खोलें</translation>
<translation id="911206726377975832">अपने ब्राउज़िंग डेटा भी मिटाएं?</translation>
<translation id="7580831958727159171">ट्रायल के दौरान, आपके पास पसंद के उन विषयों को देखने और हटाने का विकल्प होता है जिनका इस्तेमाल करके साइटें आपको विज्ञापन दिखाती हैं. Ecosia उन विषयों का अनुमान लगाता है जो आपको दिलचस्प लग सकते हैं. यह अनुमान आपके हाल के ब्राउज़िंग इतिहास के आधार पर लगाया जाता है.</translation>
<translation id="8901409988302458368">आपके सिस्टम एडमिन ने 'क्रोमियम' को इस तरह कॉन्फ़िगर किया है कि वह <ph name="TARGET_URL_HOSTNAME"/> को ऐक्सेस करने के लिए कोई दूसरा ब्राउज़र खोले.</translation>
<translation id="1523806373970723624">&amp;Ecosia को अपडेट करने के लिए फिर से लॉन्च करें</translation>
<translation id="2470806471563820591">क्रोमियम (mDNS-In)</translation>
<translation id="6933283849886243832">हो सकता है क्रोमियम सही तरीके से काम ना करें क्‍योंकि अब वह Windows XP या Windows Vista पर काम नहीं करता है</translation>
<translation id="942598560705308788">वे सर्टिफ़िकेट जिन्हें Chromium मैनेज करता है</translation>
<translation id="6718055545215052843">आगे भी Ecosia के अपडेट पाते रहने के लिए, आपके कंप्यूटर में macOS 10.13 या इसके बाद का वर्शन होना चाहिए. इस कंप्यूटर में OS X 10.11 का इस्तेमाल किया जा रहा है.</translation>
<translation id="8078678931242443254">क्रोमियम को कौन इस्तेमाल कर रहा है?</translation>
<translation id="12795904718916112">Ecosia की सबसे मज़बूत सुरक्षा पाएं</translation>
<translation id="9792300276217204">Chromium बंद करने के बाद, अपने डिवाइस से साइट डेटा मिटाना कभी न भूलें</translation>
<translation id="6235001546696543832">क्रोमियम लेखक</translation>
</translationbundle>
