<translation id="6712881677154121168">የማውረድ ስህተት፦ <ph name="DOWNLOAD_ERROR"/>.</translation>
<translation id="6648664289472946060">መገለጫዎ ከአዲስ የEcosia ስሪት ስለሆነ የመጣው ሥራ ላይ ሊውል አይችልም።

