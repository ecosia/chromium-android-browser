<translation id="8957938953005153147">Ecosia ነባር የይለፍ ቃላትን ለመተካት እየሞከረ ነው። ይህን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
<translation id="5549921590305750618">Ecosia ፋይሎችን ለማውረድ የማከማቻ መዳረሻ ያስፈልገዋል</translation>
<translation id="9090890391337853620">Ecosia አጋዥ</translation>
<translation id="6094573000614590044">የይለፍ ቃላትዎን እና ሌሎችንም በሁሉም መሣሪያዎችዎ ላይ ለማግኘት ወደ Ecosia ይግቡ</translation>
<translation id="5707346538075088068">ይህን መገለጫ በሚጠቀሙበት ጊዜ የመነጨ ማንኛውም የEcosia ውሂብ (እንደ የዕልባቶች፣ ታሪክ፣ የይለፍ ቃላት እና ሌሎች ቅንብሮች መፈጠር ያለ) በስራ መገለጫ አስተዳዳሪው ሊወገድ ይችላል። <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosiaን መጠቀምዎን ይቀጥሉ</translation>
<translation id="259935314519650377">የወረደውን ጫኝ መሸጎጥ አልተሳካም። ስህተት፦ <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="2198589091447191935">Ecosia ይበልጥ በፍጥነት ይሰራል እና ጃቫስክሪፕት የሚጠቀሙ ባህሪያት በተነደፉት መስራት አለባቸው (የሚመከር)</translation>
<translation id="7280797724682955539">በጭነት ጊዜ የስርዓተ ክወና ስህተት ተፈጥሯል። እባክዎ Ecosiaን እንደገና ያውርዱት።</translation>
<translation id="6960183526681645011">መሣሪያ የሚያጋሩ ከሆኑ ጓደኛዎች እና ቤተሰብ ተለይተው ሊያስሱ እና Ecosiaን በሚፈልጉበት መንገድ ማዋቀር ይችላሉ</translation>
<translation id="2381210243314074423">እንኳን ወደ Ecosia በደህና መጡ <ph name="ACCOUNT_FIRST_NAME"/></translation>
