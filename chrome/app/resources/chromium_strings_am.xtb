<translation id="143614250230771428">ማስመር ለጎራዎ ስለማይገኝ EcosiaOS ውሂብዎን ማስመር አይችልም።</translation>
<translation id="813913629614996137">በማስጀመር ላይ…</translation>
<translation id="6491651957026506753">ይህ ፋይል አደገኛ ስለሆነ Ecosia አግዶታል።</translation>
<translation id="796435732739009892">እንደዚህ አይነት ፋይል አደገኛ ስለሆነ Ecosia ይህን ፋይል አግዶታል።</translation>
<translation id="2046160555506209000">አንድ ምስል ጠቃሚ መግለጫ ከሌለው Ecosia ለእርስዎ አንድ ለማቅረብ ይሞክራል። ዝርዝር መግለጫዎችን ለመፍጠር፣ ምስሎች ወደ Ecosia ይላካሉ። ይህን በማንኛውም ጊዜ በቅንብሮች ውስጥ ሊያጠፉት ይችላሉ።</translation>
<translation id="8266560134891435528">እርስዎ በመለያ ስላልገቡ ስለሆኑ Chromium የይለፍ ቃላትዎን መፈተሽ አይችልም</translation>
<translation id="8633885040939757689">Ecosia የይለፍ ቃላትን ለመቅዳት እየሞከረ ነው።</translation>
<translation id="2243562167758283214">ይህ ፋይል አደገኛ ሊሆን ስለሚችል Ecosia አግዶታል።</translation>
<translation id="8330519371938183845">Chromiumን በመላ መሣሪያዎችዎ ላይ ለማሳመር እና ግላዊነት ለማላበስ</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> ከዚህ ቀደም Ecosiaን እየተጠቀመ ነበር</translation>
<translation id="4337034173783952373">በሁሉም መሣሪያዎችዎ ላይ የእርስዎን የEcosia አሳሽ ነገሮች ለመድረስ ይግቡ፣ ከዚያ ስምረትን ያብሩ</translation>
<translation id="8655983536493871574">የወደፊት የEcosia ዝማኔዎችን ለማግኘት Windows 10 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር Windows 8 እየተጠቀመ ነው።</translation>
<translation id="6826163993811146231">{0,plural, =1{በአንድ ቀን ውስጥ Ecosiaን ዳግም አስጀምር}one{በ# ቀኖች ውስጥ Ecosiaን ዳግም አስጀምር}other{በ# ቀኖች ውስጥ Ecosiaን ዳግም አስጀምር}}</translation>
<translation id="4033006861724039519">የጫኚው መዝገብ ተበላሽቷል ወይም ትክክል አይደለም። እባክዎ Ecosiaን እንደገና ያውርዱ።</translation>
<translation id="8975930032513941502">ከተፈለገ፦ የምርመራ እና የአጠቃቀም ውሂብ ወደ Ecosia በራስ-ሰር በመላክ የEcosiaOS ባህሪያትን እና አፈጻጸምን እንዲሻሻል ያግዙ።</translation>
<translation id="2695952268686253864">Ecosia ጊዜው አልፎበታል</translation>
<translation id="8550334526674375523">ይህ የስራ መገለጫ ከግል መገለጫዎ ሙሉ ለሙሉ የተለየ ነው።</translation>
<translation id="4281355161119203663">የእርስዎ ወላጅ ለEcosia «የጣቢያዎች፣ መተግበሪያዎች እና ቅጥያዎች ፈቃዶች»ን አጥፍተዋል። ይህን <ph name="EXTENSION_TYPE_PARAMETER"/> ማከል አይፈቀድም።</translation>
<translation id="6235917057647038042">የወደፊቱን የEcosia ዝመኔዎችን ለማግኘት፣ macOS 10.13 ወይም ከዚያ በኋላ ያለው ያስፈልግዎታል። ይህ ኮምፒተር macOS 10.12 እየተጠቀመ ነው።</translation>
<translation id="8568283329061645092">Chromium በእርስዎ የGoogle መለያ በሚገቡበት ጊዜ የእርስዎን የይለፍ ቃላትን ሊፈትሽ ይችላል</translation>
<translation id="8574036838419011058">ሲበራ፣ Chromium የዳራ እንቅስቃሴን እና እንደ ለስላሳ ሽብለላ እና የቪድዮ የክፈፍ ፍጥነቶች ያሉ ምስላዊ ተጽዕኖዎችን በመገደብ የባትሪ ኃይልን ይቆጥባል። <ph name="BEGIN_LINK"/>የበለጠ ለመረዳት<ph name="END_LINK"/></translation>
<translation id="7129808598331559748">የቅጂ መብት <ph name="YEAR"/> የEcosia ደራሲያን። ሁሉም መብቶች የተጠበቁ ናቸው።</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>ይህንን ውሂብ እንዴት እንደሚጠቀሙበት፦<ph name="END_BOLD"/> ጣቢያዎች ስለዝንባሌዎችዎ መረጃን በEcosia አማካኝነት ማከማቸት ይችላሉ። ለምሳሌ፣ ለማራቶን ጫማ ለመግዛት ጣቢያን ከጎበኙ ጣቢያው ዝንባሌዎን እንደ ማራቶን መሮጥ ሊገልጽ ይችላል። በኋላ ላይ ለሩጫ ለመመዝገብ ሌላ ጣቢያ ከጎበኙ ይህ ጣቢያ በዝንባሌዎችዎ ላይ ተመስርቶ የመሮጫ ጫማ ማስታወቂያ ሊያሳየዎት ይችላል።</translation>
<translation id="8109744984354428711">Ecosiaን በማስጀመር ላይ...</translation>
<translation id="2402290209407843024">ተለይቶ ባልታወቀ ስህተት ምክንያት ጭነት ከሽፏል። እባክዎ Ecosiaን እንደገና ያውርዱ።</translation>
<translation id="6665128960039431910">እንዲሁም Ecosiaን ሲጀምሩት ወይም ከኦምኒቦክሱ ሆነው ሲፈልጉ የሚታየውን ገጽ ይቆጣጠራል።</translation>
<translation id="2000339487270823788">ይሄ የእርስዎ Ecosia ነው</translation>
<translation id="7273750863406285983">Ecosia ለዚህ ጣቢያ የእርስዎን ካሜራ እና ማይክሮፎን ለመድረስ ፈቃድ ያስፈልገዋል</translation>
<translation id="5267683457871579197">የEcosiaOS ስርዓት</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>ምን ውሂብ ጥቅም ላይ እንደሚውል፦<ph name="END_BOLD"/> የአሰሳ ታሪክዎ፣ በዚህ መሣሪያ ላይ Ecosiaን ተጠቅመው የጎበኟቸው የጣቢያዎች መዝገብ።</translation>
<translation id="8862326446509486874">ለስርዓተ-ደረጃ ጭነት ተገቢ መብቶች የሉዎትም። ጫኚውን እንደ አስተዳዳሪ በማሄድ እንደገና ይሞክሩ።</translation>
<translation id="8880203542552872219">እንደዚያ ከሆነ፣ ከእርስዎ አዲሱ የይለፍ ቃል ጋር እንዲዛመድ የእርስዎን በChromium የተቀመጠ የይለፍ ቃል አርትዕ ያድርጉ።</translation>
<translation id="6078545897140861225">እንዲሁም Ecosiaን ሲጀምሩት ወይም የመነሻ አዝራሩን ጠቅ ሲያደርጉት የሚታየውን ገጽ ይቆጣጠራል።</translation>
<translation id="3966234175958887595">Ecosia የይለፍ ቃሎችን ለማሳየት እየሞከረ ነው። ይህንን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
<translation id="8931379085695076764">Chromium ካለፉት ጥቂት ሳምንታት የአሰሳ ታሪክዎ ላይ በመመስረት ዝንባሌዎችዎን ሊገምት ይችላል። ይህ መረጃ በመሣሪያዎ ላይ ይቆያል።</translation>
<translation id="6346154190168496057">Ecosiaን ማዘመን አልተቻለም</translation>
<translation id="93440396576488794">የEcosia Enterprise ዓርማ</translation>
<translation id="8986207147630327271">የስራ መገለጫን ወደዚህ አሳሽ እያከሉ እና ለአስተዳዳሪዎ በስራ መገለጫው ላይ ብቻ ቁጥጥር እየሰጡ ነው።</translation>
<translation id="1597547208646178091">Ecosiaን ይበልጥ ደህንነቱ የተጠበቀ እንዲሆን ለማድረግ፣ በ<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> ውስጥ ያልተዘረዘረውን የሚከተለውን ቅጥያ አሰናክለነዋል እና እርስዎ ሳያውቁት የታከለ ሊሆን ይችላል።</translation>
<translation id="2388751143175762498">Ecosia ውስጥ ይግቡ</translation>
<translation id="7268098999602465369">Ecosia ጊዜው አልፎበታል</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia በአንድ ሰዓት ውስጥ ዳግም ይጀምራል}one{Ecosia በ# ሰዓቶች ውስጥ ዳግም ይጀምራል}other{Ecosia በ# ሰዓቶች ውስጥ ዳግም ይጀምራል}}</translation>
<translation id="8963533629322868062">የወደፊት የEcosia ዝማኔዎችን ለማግኘት Windows 10 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር Windows 8.1ን እየተጠቀመ ነው።</translation>
<translation id="7774247008790177839">አገናኙን በEcosia አዲስ &amp;ትር ውስጥ ክፈት</translation>
<translation id="911206726377975832">የአሰሳ ውሂብዎም ይሰረዝ?</translation>
<translation id="7580831958727159171">በሙከራዎቹ ጊዜ ማስታወቂያዎችን ለእርስዎ ለማሳየት የሚጠቀሙባቸውን የዝንባሌ ጣቢያዎች ርዕሶች ማየት እና ማስወገድ ይችላሉ። Ecosia በቅርብ ጊዜ የአሰሳ ታሪክዎ ላይ ተመስርቶ የእርስዎን ፍላጎቶች ይገምታል።</translation>
<translation id="8901409988302458368">የእርስዎ የስርዓት አስተዳዳሪ <ph name="TARGET_URL_HOSTNAME"/>ን ለመድረስ Ecosia ተለዋጭ አሳሽን እንዲከፍት አዋቅረውታል።</translation>
