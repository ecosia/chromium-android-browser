<translation id="719484593754925816">Ecosia የአሰሳ ተሞክሮዎን ለማሻሻል እና ንብረቶችን ለማስለቀቅ ይህን ትር ሊያቦዝን ይችላል።</translation>
<translation id="5941711191222866238">አሳንስ</translation>
<translation id="5972142260211327093">Chromium በዘፈቀደ እርስዎን በገቢር ሙከራ ካስቀመጠ የአሰሳ ታሪክዎ በሚያዩዋቸው ማስታወቂያዎች እና ከታች በተገመተው ዝንባሌዎች ላይ ተጽዕኖ ይኖረዋል። የእርስዎን ግላዊነት ለመጠበቅ Chromium በየወሩ ዝንባሌዎችዎን ይሰርዛል። እርስዎ ካላስወገዷቸው በስተቀር ዝንባሌዎች ይታደሳሉ።</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{ድርጅትዎ Ecosia ለ1 ደቂቃ ጥቅም ላይ ሳይውል ሲቀር በራስ ሰር ይዘጋዋል።}one{ድርጅትዎ Ecosia ለ# ደቂቃ ጥቅም ላይ ሳይውል ሲቀር በራስ ሰር ይዘጋዋል።}other{ድርጅትዎ Ecosia ለ# ደቂቃዎች ጥቅም ላይ ሳይውል ሲቀር በራስ ሰር ይዘጋዋል።}}</translation>
<translation id="5704599732514791330">ስምረትን ለመጀመር Ecosiaን ያዘምኑ</translation>
<translation id="5988505247484123880">የሚጎበኟቸው ጣቢያዎች ልምድዎን ግላዊነት ማላበስ እንዲችሉ እርስዎ የሚፈልጓቸውን ነገሮች ማስታወስ የተለመደ ነው። እንዲሁም ጣቢያዎች ስለዝንባሌዎችዎ መረጃን በChromium አማካኝነት ማከማቸት ይችላሉ።</translation>
<translation id="6003112304606738118">በማውረድ ላይ... <ph name="HOURS"/> ሰዓት(ታት) ይቀራል(ሉ)</translation>
<translation id="8347473600923066837">ከላይ በስተቀኝ ካለው የEcosia ምናሌ ሆነው ዕልባቶችን፣ የንባብ ሁነታን እና ሌሎችንም መክፈት ይችላሉ</translation>
<translation id="6040143037577758943">ዝጋ</translation>
<translation id="6058380562449900225">ውሂብዎን ለመጠበቅ እርስዎ በቅርቡ ካልጎበኟቸው ጣቢያዎች Chromium ፈቃዶችን እንዲያስወግድ ይፍቀዱ። ማሳወቂያዎችን አያቆምም።</translation>
<translation id="7303930050538184306">በEcosia ውስጥ &amp;ክፈት</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> ወደ Ecosia ታክሏል።</translation>
<translation id="2905159584855395810">Ecosiaን የበለጠ ፈጣን ያድርጉት</translation>
<translation id="608006075545470555">የስራ መገለጫ ወደዚህ አሳሽ ያክሉ</translation>
<translation id="8296565077892323223">Ecosiaን ያብጁትና ይቆጣጠሩት። ዝማኔ ይገኛል።</translation>
<translation id="6102072151902574948">ሲበራ Chromium የዳራ እንቅስቃሴን እና እንደ ለስላሳ ሽብለላ እና የቪድዮ የክፈፍ ፍጥነቶች ያሉ ምስላዊ ተጽዕኖዎችን በመገደብ የባትሪ ኃይልን ይቆጥባል።</translation>
<translation id="8419312540998601274">በርቷል • Ecosia ይህ ቅጥያ ከየት እንደመጣ ማረጋገጥ አይችልም</translation>
<translation id="6419542773162312746">ቅጥያ በEcosia የመሣሪያ አሞሌ ውስጥ የመዳረሻ ጥያቄዎችን እንዲያሳይ ፍቀድ</translation>
<translation id="4021894801595982809">Ecosia ይህን የይለፍ ቃል በእርስዎ የEcosia መለያ ውስጥ ያስቀምጠዋል። ማስታወስ አይኖርብዎትም።</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> አደገኛ ነው፣ ስለዚህ Ecosia አግዶታል።</translation>
<translation id="2446603005062458629">Ecosia በቅርቡ ይዘጋል እና ውሂብ ይሰርዛል</translation>
<translation id="6134968993075716475">የጥንቃቄ አሰሳ ጠፍቷል። Chromium እንዲያበሩት ይመክራል።</translation>
<translation id="4032832945953542360">እዚህ በEcosia መገለጫዎች መካከል መቀያየር ይችላሉ</translation>
<translation id="615103374448673771">ኩኪዎችን ከፈቀዱ Chromium ቅድሚያ በመጫን ጊዜ ሊጠቀምባቸው ይችላል</translation>
<translation id="5032126307005935789">ይህ ፋይል አደገኛ ሊሆን ይችላል<ph name="LINE_BREAK"/>የይለፍ ቃሉን ካቀረቡ Ecosia ይህንን ውርድ ሊፈትሽልዎ ይችላል። የፋይሉ መረጃ ወደ የEcosia ጥንቃቄ አሰሳ ይላካል፣ ነገር ግን የፋይሉ ይዘት እና የይለፍ ቃል በመሣሪያዎ ላይ ይቆያሉ።</translation>
<translation id="6182736845697986886">በዝማኔ አገልጋይ የውስጥ ስህተት ምክንያት መጫኑ አልተሳካም።</translation>
<translation id="2346323077583431428">በእርስዎ <ph name="TARGET_DEVICE_NAME"/> ላይ በመለያ ወደ Ecosia መግባትዎን ያረጋግጡ እና እንደገና ለመላክ ይሞክሩ።</translation>
<translation id="2995860351618948435">ይህ ኮምፒውተር አስቀድሞ ይበልጥ አዲስ የሆነ የEcosia ስሪት አለው። ሶፍትዌሩ የማይሰራ ከሆነ እባክዎ Ecosiaን ያራግፉና እንደገና ይሞክሩ።</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia አሁን ዳግም ይጀመራል}=1{Ecosia በ1 ሰከንድ ውስጥ ዳግም ይጀመራል}one{Ecosia በ# ሰከንዶች ውስጥ ዳግም ይጀመራል}other{Ecosia በ# ሰከንዶች ውስጥ ዳግም ይጀመራል}}</translation>
<translation id="1809194740315140401">Ecosia ፋይሎችን ለማውረድ የማከማቻ መዳረሻ ፈቃድ ያስፈልገዋል</translation>
<translation id="6245734527075554892">በChromium ላይ በተከማቹ ደህንነታቸው ያልተጠበቁ ጣቢያዎች ዝርዝር ጋር ዩአርኤሎችን ይፈትሻል</translation>
<translation id="4662363689050405237">Ecosia ነባሪውን አሳሽ ያድርጉ።</translation>
<translation id="6266342355635466082">Chromium ዝማኔዎችን መፈተሽ አይችልም። የበይነመረብ ግንኙነትዎን ለመፈተሽ ይሞክሩ።</translation>
<translation id="6268381023930128611">ከChromium ተዘግቶ ይውጣ?</translation>
<translation id="4618410489751241263">እነዚህ ትሮች ተጨማሪ ንብረቶችን እየተጠቀሙ ነው። አፈፃፀምዎን ለማሻሻል Ecosia እንዲያቦዝናቸው ይፍቀዱ።</translation>
<translation id="6416551953415159186">የEcosia መገለጫዎን ያብጁ</translation>
<translation id="6290827346642914212">የChromium መገለጫዎን ይሰይሙ</translation>
<translation id="4882579364090762302">አንድ ቅጥያ ወደ Ecosia እንዲገቡ ይፈልጋል</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/> አደገኛ ሊሆን ስለሚችል Ecosia አግዶታል።</translation>
<translation id="4943938785458240142">Ecosia ካሜራዎን እየተጠቀመ ነው።</translation>
<translation id="6327105987658262776">ምንም ዝማኔ የለም።</translation>
<translation id="6450895420388847775">ሌላ ሥርዓተ ክወና በEcosia ላይ በሂደት ላይ ነው። እባክዎ ቆይተው እንደገና ይሞክሩ።</translation>
<translation id="464306605599005355">አሁን Ecosiaን ከEcosia መለያዎ ጋር እና በተጋሩ ኮምፒውተሮች ላይ መጠቀም ይበልጥ ቀላል ነው።</translation>
<translation id="6735145163744656874">Ecosia የአሰሳ ተሞክሮዎን ለማሻሻል እና ነገሮች ፍጥነት ኖሯቸው ለማቆየት እነዚህን ትሮች ሊያቦዝናቸው ይችላል።</translation>
<translation id="1284343625991453987">የEcosia አቋራጭ</translation>
<translation id="7051119589302096163">ፋይሉ በተለምዶ ስላማይወርድ እና አደገኛ ሊሆን ስለሚችል Ecosia ይህን ውርድ አግዷል</translation>
<translation id="7908111389403807005">እርግጠኛ ነዎት Ecosiaን ማራገፍ ይፈልጋሉ?</translation>
<translation id="6375219077595103062">ለየሚስጥር ቁልፍ አስተዳዳሪ አቋራጭ ያክሉ</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>ይህን ውሂብ እንዴት እንደምንጠቀምበት፦<ph name="END_BOLD"/> Ecosia የእርስዎን ዝንባሌዎች ሊገምት ይችላል። በኋላ ላይ እርስዎ የሚጎበኙት ጣቢያ እርስዎ የሚያዩዋቸውን ማስታወቂያዎች ግላዊነት ለማላበስ Ecosia ዝንባሌዎችዎን እንዲያይ ሊጠይቅ ይችላል።</translation>
<translation id="7578952608547569314">በኮምፒውተር ማያ ገፅ ውስጥ የEcosia ዓርማ።</translation>
<translation id="3939060118711873999">Ecosia ድረ-ገጾችን እና መተግበሪያዎችን እጅግ በጣም ፈጣን በሆነ ፍጥነት የሚያሄድ ድር አሳሽ ነው። ፈጣን፣ የረጋ እና ለመጠቀም ቀላል ነው። Ecosia ውስጥ አብሮ በተሰራላቸው የተንኮል-አዘል ሶፍትዌር እና የማስገሪያ መከላከያዎች አማካኝነት ደህንነትዎ ይበልጥ በተጠበቀ ሁኔታ ድሩን ያስሱ።</translation>
<translation id="5404489723475681578">EcosiaOSን ዳግም አስጀምር</translation>
<translation id="6443470774889161065">እርስዎ የመጎብኘት ዕድልዎ ከፍተኛ የሆኑባቸው ተጨማሪ ገጾች ሲጎበኟቸው ይበልጥ በፍጥነት እንዲጫኑ Chromium በቅድሚያ ይጭናቸዋል</translation>
<translation id="7877883466657693294">ጠፍቷል • Ecosia ይህ ቅጥያ ከየት እንደመጣ ማረጋገጥ አይችልም</translation>
<translation id="4410570812343670816">ወደ Ecosia መገለጫዎች እንኳን በደህና መጡ</translation>
<translation id="4371259280767924562">መለያን ከEcosia አስወግድ</translation>
<translation id="524314285625975879">እንዲሁም Ecosiaን ሲጀምሩት የሚታየውን ገፅ ይቆጣጠራል።</translation>
<translation id="648319183876919572">የተሻሻለ የደህንነት አሰሳ እርስዎን ከአደገኛ ድር ጣቢያዎች እና ውርዶች ለመጠበቅ ይበልጥ ያደርጋል</translation>
<translation id="6496553866814956056">Ecosiaን ያራግፉ</translation>
<translation id="788366290112401490">አቋራጮች በEcosia ውስጥ ይከፍታሉ</translation>
<translation id="1773882594264682232">በመለያ ገብተው ሳለ በEcosia ውስጥ ከEcosia መለያዎ የይለፍ ቃላትዎን እና ሌሎችንም መጠቀም ይችላሉ። ይህን በማንኛውም ጊዜ ቅንብሮች ውስጥ መለወጥ ይችላሉ።</translation>
<translation id="2280934980919215876">ድርጅትዎ Ecosia ለ<ph name="TIMEOUT_DURATION"/> ያህል ሥራ ላይ ሳይውል ይዘጋዋል። የአሰሳ ውሂብ ተሰርዟል። ይህ ታሪክን፣ ራስ-ሙላን እና ውርዶችን ሊያካትት ይችላል።</translation>
<translation id="8608092457636055141">እያንዳንዱ መገለጫ እንደ ዕልባቶች፣ ታሪክ፣ የይለፍ ቃላት እና ሌሎችም ያሉ የራሱ የEcosia መረጃዎችን ይይዛል</translation>
<translation id="6563921047760808519"><ph name="BEGIN_LINK"/>Chromium እንዴት የእርስዎን ውሂብ በግል እንደሚያስቀምጥ<ph name="END_LINK"/> የበለጠ ይወቁ</translation>
<translation id="3592624492063123732">ከሌላ የEcosia መገለጫ የይለፍ ቃላትን ለማየት መቀየር ይችላሉ</translation>
<translation id="6570579332384693436">የሥርዓተ ፊደል አጻጻፍ ስህተቶችን ለማስተካከል፣ Chromium እርስዎ በጽሁፍ መስኮች ውስጥ የሚተይቡትን ጽሁፍ ወደ Google ይልካል</translation>
<translation id="6533266716128249922">ወደ የEcosia ማሳወቂያ ቅንብሮች ይሂዱ</translation>
<translation id="1722634673917783018">ለውጦችዎ Ecosia በሚያስጀምሩበት ቀጣዩ ጊዜ ላይ ይተገበራሉ።</translation>
<translation id="2537426042760364251">Ecosia የዙሪያዎን የ3ል ካርታ ለመፍጠር የካሜራ ፈቃድ ያስፈልገዋል</translation>
<translation id="6663852025006259149">ጣቢያዎች እርስዎ እንደሚጠብቁት ሊሰሩ ይችላሉ ነገር ግን ሁሉንም የChromium መስኮቶች ከዘጉ በኋላ እርስዎን አያስታውሱዎትም</translation>
<translation id="6669284030132180248">እንዲሁም ዕልባቶችዎን በእርስዎ Google መለያ ውስጥ ካስቀመጡ Chromium ውስጥ የምርት ዋጋዎችን መከታተል እና ዋጋው ሲቀንስ ማሳወቂያ ማግኘት ይችላሉ</translation>
<translation id="6676384891291319759">በይነመረብን ተዳረስ</translation>
<translation id="8067423333018528301">በመለያ ሲገባ በነበረ ስህተት ምክንያት &amp;EcosiaOS ውሂብዎን ማስመር አልቻለም።</translation>
<translation id="6692797197837897398">Chrome በሚያዩዋቸው ማስታወቂያዎች ላይ የበለጠ ቁጥጥር ይሰጥዎታል እንዲሁም ግላዊነት የተላበሱ ማስታወቂያዎችን ሲያሳዩዎ ጣቢያዎች ስለእርስዎ ምን ማወቅ እንደሚችሉ ይገድባል።</translation>
