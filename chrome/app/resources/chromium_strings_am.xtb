<translation id="538767207339317086">የChromium በመለያ መግባትን ይፍቀዱ</translation>
<translation id="330264384086604869">ከEcosia አስወግድ</translation>
<translation id="5581150090232500900">Ecosia እንደ ነባሪ አሳሽዎ አድርገው ያዋቅሩት</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia ቅድመ-ይሁንታ</translation>
<translation id="3307959934543585795">በዚህ የLinux ስርጭት ላይ ከእንግዲህ ስለማይደገፍ Ecosia በአግባቡ ላይሰራ ይችላል።</translation>
<translation id="197803137365953132">ፋይሉ የእርስዎን የግል እና የማህበራዊ አውታረ መረብ መለያዎች ሊጎዳ ስለሚችል Ecosia ይህን ውርድ አግዶታል</translation>
<translation id="6558895515431832002">Ecosia አካባቢዎን ለዚህ ጣቢያ ለማጋራት የአካባቢዎ መዳረሻ ያስፈልገዋል</translation>
<translation id="5487574057737591516">የእርስዎን ግላዊነት ለመጠበቅ ከ4 ሳምንታት በላይ የቆዩ ዝንባሌዎችዎን በራስ-ሰር እንሰርዛለን። ማሰስዎን በሚቀጥሉበት ጊዜ ዝንባሌ እንደገና በዝርዝሩ ላይ ሊታይ ይችላል። እና Chromium ከተሳሳተ ወይም የተወሰኑ ማስታወቂያዎችን ማየት ካልፈለጉ ዝንባሌን ማስወገድ ይችላሉ።</translation>
<translation id="5279514147510747661">Ecosia የቅርብ ጊዜዎቹ የስርዓቱ ዝማኔዎችን እስኪጭን ድረስ እባክዎ ይጠብቁ።</translation>
<translation id="5066194399237265772">Ecosia የይለፍ ቃላትን ለማርትዕ እየሞከረ ነው። ይህንን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
