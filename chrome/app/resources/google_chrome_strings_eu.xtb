<translation id="5404489723475681578">Berrabiarazi Ecosia OS</translation>
<translation id="5982672133249369264">Berrabiarazi Ecosia</translation>
<translation id="2174917724755363426">Ez da osatu instalazioa. Ziur bertan behera utzi nahi duzula?</translation>
