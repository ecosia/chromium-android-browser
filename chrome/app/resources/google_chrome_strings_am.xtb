<translation id="2876628302275096482"><ph name="BEGIN_LINK"/>Chrome እንዴት የእርስዎን ውሂብ በግል እንደሚያስቀምጥ<ph name="END_LINK"/> የበለጠ ይወቁ</translation>
<translation id="2885378588091291677">ተግባር መሪ</translation>
<translation id="2888126860611144412">ስለChrome</translation>
<translation id="29082080693925013">እንደተደራጁ ለመቆየት በተደጋጋሚ የሚጎበኙ ጣቢያዎችን መሰካት እና ትሮችን በቡድን ማደራጀት ይችላሉ</translation>
<translation id="2915996080311180594">በኋላ ዳግም አስነሳ</translation>
<translation id="2926676257163822632">ደካማ የይለፍ ቃላት ለመገመት ቀላል ናቸው። Chrome <ph name="BEGIN_LINK"/> ለእርስዎ ጠንካራ የይለፍ ቃላትን እንዲፈጥር እና እንዲያስታውስ<ph name="END_LINK"/> ይፍቀዱ።</translation>
<translation id="219546601381787154">Ecosia ለዚህ ጣቢያ የካሜራ ፈቃድ ያስፈልገዋል</translation>
<translation id="2928420929544864228">ጭነት ተጠናቅቋል።</translation>
<translation id="2929907241665500097">Chrome አልተዘመነም፣ የሆነ ስክህተት ተከስቷል። <ph name="BEGIN_LINK"/>የChrome ዝማኔ ችግሮችን እና ያልተሳኩ ዝማኔዎችን ያስተካክሉ።<ph name="END_LINK"/></translation>
<translation id="2945997411976714835">የጭነት ስህተት፦ የጫኙ ሂደት መጀመር አልተሳካም።</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - በአውታረ መረብ ወደ መለያ መግባት - Ecosia</translation>
<translation id="8696852719113991652">የEcosia መለያዎን ከEcosia ለማስወገድ በቅንብሮች ገጽ ውስጥ ከEcosia ዘግተው ይውጡ</translation>
<translation id="5405885279794834338">እንዲሁም ከEcosia (<ph name="URL"/>) ውሂብ ይሰርዙ</translation>
<translation id="5622643576877267490">&amp;EcosiaOS Flexን ለማዘመን እንደገና ያስጀምሩ</translation>
