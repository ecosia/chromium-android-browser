<translation id="1975037445584526511">የወደፊት የEcosia ዝማኔዎችን ለማግኘት Windows 10 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር Windows 7ን እየተጠቀመ ነው።</translation>
<translation id="2695952268686253864">Ecosia ጊዜው አልፎበታል</translation>
<translation id="8825634023950448068">የእርስዎን ግላዊነት ለመጠበቅ ከ4 ሳምንታት በላይ የቆዩ ዝንባሌዎችዎን በራስ-ሰር እንሰርዛለን። ማሰስዎን በሚቀጥሉበት ጊዜ ዝንባሌ እንደገና በዝርዝሩ ላይ ሊታይ ይችላል። እና Chrome ከተሳሳተ ወይም የተወሰኑ ማስታወቂያዎችን ማየት ካልፈለጉ ዝንባሌን ማስወገድ ይችላሉ።</translation>
<translation id="5066194399237265772">Ecosia የይለፍ ቃላትን ለማርትዕ እየሞከረ ነው። ይህን ለመፍቀድ የእርስዎን Windows የይለፍ ቃል ይተይቡ።</translation>
<translation id="6078545897140861225">እንዲሁም Ecosiaን ሲጀምሩት ወይም የመነሻ አዝራሩን ጠቅ ሲያደርጉት የሚታየውን ገጽ ይቆጣጠራል።</translation>
<translation id="1401515072108809622">Ecosia ገቢር አይደለም</translation>
<translation id="8862326446509486874">ለስርዓተ-ደረጃ ጭነት ተገቢ መብቶች የሉዎትም። ጫኚውን እንደ አስተዳዳሪ በማሄድ እንደገና ይሞክሩ።</translation>
<translation id="8282620071565190081">Ecosiaን ዳግም አስጀምር</translation>
<translation id="7849498640944199147">አንድ ቁጥር ከ<ph name="ORIGIN"/> ወደ የእርስዎ Android ስልክ ለመላክ በሁለቱም መሣሪያዎች ላይ በመለያ ወደ Ecosia ይግቡ።</translation>
<translation id="7910693244647744044">የተሻሻለ የደህንነት አሰሳን በእርስዎ መለያ ውስጥ አብርተዋል። አሁን ለEcosia ያግኙት።</translation>
<translation id="8986207147630327271">የስራ መገለጫን ወደዚህ አሳሽ እያከሉ እና ለአስተዳዳሪዎ በስራ መገለጫው ላይ ብቻ ቁጥጥር እየሰጡ ነው።</translation>
<translation id="8989968390305463310">የአሰሳ ታሪክዎ ከታች እንደተገመተው እርስዎ በሚያዩዋቸው ማስታወቂያዎች እና ዝንባሌዎች ላይ ተጽዕኖ ያሳድራል። የእርስዎን ግላዊነት ለመጠበቅ Chrome በየወሩ ዝንባሌዎችዎን በራስ-ሰር ይሰርዛል። እርስዎ ካላስወገዷቸው በስተቀር ዝንባሌዎችን ማደስ ይችላሉ።</translation>
<translation id="7348818664647668234">{0,plural, =0{የEcosia ዝማኔ አለ}=1{የEcosia ዝማኔ አለ}one{አንድ የEcosia ዝማኔ ለ# ቀኖች ነበር}other{አንድ የEcosia ዝማኔ ለ# ቀኖች ነበር}}</translation>
<translation id="9003498785844995646">ሲበራ፣ Chrome የዳራ እንቅስቃሴን እና እንደ ለስላሳ ሽብለላ እና የቪድዮ የክፈፍ ፍጥነቶች ያሉ ምስላዊ ተጽዕኖዎችን በመገደብ የባትሪ ኃይልን ይቆጥባል። <ph name="BEGIN_LINK"/>የበለጠ ለመረዳት<ph name="END_LINK"/> ወይም <ph name="BEGIN_LINK_2"/>ግብረመልስ ይላኩ<ph name="END_LINK_2"/></translation>
<translation id="9047384314208087523">የEcosiaOS Flex ስርዓት</translation>
<translation id="5675757883980078189">Ecosia Windows 7 ወይም ከዚያ በላይ ያስፈልገዋል።</translation>
<translation id="911206726377975832">የአሰሳ ውሂብዎም ይሰረዝ?</translation>
<translation id="9138603949443464873">የእርስዎን ለውጦች ተፈጻሚ ለማድረግ፣ Chromeን ዳግም ያስጀምሩ</translation>
<translation id="9195993889682885387">Chrome ያለፉት ጥቂት ሳምንታት የአሰሳ ታሪክዎ ላይ ተመስርቶ ዝንባሌዎችዎን ሊገምት ይችላል። ይህ መረጃ በመሣሪያዎ ላይ ይቆያል።</translation>
<translation id="5704599732514791330">ስምረትን ለመጀመር Ecosiaን ያዘምኑ</translation>
<translation id="838842459108103907">Ecosiaን አብጅ</translation>
<translation id="3070276123152913305">EcosiaOS Flexን እንደገና ያስጀምሩ</translation>
<translation id="4512092435423703529">በሁሉም መሣሪያዎችዎ ላይ የእርስዎን Ecosia ነገሮች ለመድረስ ይግቡ፣ ከዚያ ስምረትን ያብሩ።</translation>
<translation id="7972668220031382654">Ecosia ይህ ፋይል አደገኛ ሊሆን ስለሚችል እንዲቃኙት ይመክራል።</translation>
<translation id="989369509083708165">Google Chrome ነባሪ አሳሽዎ ነው</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> በEcosia መገለጫዎች መካከል መቀያየር ይችላል</translation>
</translationbundle>
