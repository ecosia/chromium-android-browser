<translation id="3268039966078382323">Ecosia ወደ የቅርብ ጊዜው ስሪት ሊዘመን አልቻለም፣ ስለዚህ አዲስ ባህሪያት እና የደህንነት ማስተካከያዎች እያመለጠዎት ነው።</translation>
<translation id="4624065194742029982">Chrome ማንነት የማያሳውቅ</translation>
<translation id="4690206707618474800">ግዴታ አይደለም፦ የምርመራ እና የአጠቃቀም ውሂብን በራስ-ሰር ወደ Ecosia በመላክ የEcosiaOS Flex ባህሪያትን እና አፈጻጸምን እንዲሻሻል ያግዙ።</translation>
<translation id="9125443060066914183">Ecosia ይበልጥ ደህንነቱ የተጠበቀ እንዲሆን ለማድረግ፣ በ<ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> ውስጥ ያልተጠቀሱ እና እርስዎ ሳያውቋቸው የታከሉ ሊሆኑ የሚችሉ የተወሰኑ ዝርዝሮችን አሰናክለናል።</translation>
<translation id="4680828127924988555">መጫኑን ሰርዝ</translation>
<translation id="8236553889322631924">ካልታወቁ ምንጮች የመጡ ቅጥያዎች፣ መተግበሪያዎች እና ገጽታዎች መሣሪያዎን ሊጎዱ ይችላሉ። Ecosia እነሱን ከEcosia የድር መደብር ብቻ መጫንን ይመክራል</translation>
<translation id="4710245680469034439">በተፈጥሮ በተነሳሱ ገጽታዎች፣ የአርቲስቶች ስብስቦች እና ሌሎችም አሳሽዎን ግላዊነት ያላብሱት</translation>
<translation id="4724676981607797757">በማይደገፍ የፕሮቶኮል ስህተት ምክንያት መጫኑ አልተሳካም።</translation>
<translation id="3305517118160815955">ተለይቶ ባልታወቀ ስህተት ምክንያት ጭነት ከሽፏል። Ecosia አሁን እያሄደ ከሆነ ፣ እባክዎ ይዝጉትና እንደገና ይሞክሩ።</translation>
<translation id="4747730611090640388">Chrome የእርስዎን ዝንባሌዎች ሊገምት ይችላል።  በኋላ ላይ እርስዎ የሚጎበኙት ጣቢያ እርስዎ የሚያዩዋቸውን ማስታወቂያዎች ግላዊነት ለማላበስ Chrome ዝንባሌዎችዎን እንዲያይ ሊጠይቅ ይችላል።</translation>
<translation id="827222962844006655">Ecosia Canary (mDNS-In)</translation>
<translation id="3543284013834505767">ይህ በ Ecosia ፍለጋ ውስጥ ጥቅም ላይ ጋር ተመሳሳይ የፊደል አራሚ ይጠቀማል። በአሳሽ ውስጥ የሚተይቡት ጽሁፍ ወደ Ecosia ይላካል። ይህን ባህሪ ሁልጊዜ በቅንብሮች ውስጥ መለወጥ ይችላሉ።</translation>
<translation id="4793679854893018356">Chrome እንዴት ደህንነትዎን እንደሚጠብቅ ይወቁ</translation>
<translation id="8957938953005153147">Ecosia ነባር ይለፍ ቃሎችን ለመተካት እየሞከረ ነው። ይህን ለመፍቀድ የWindows የይለፍ ቃልዎን ይተይቡ።</translation>
<translation id="8144706290339578682">ስምረት ለጎራዎ ስለማይገኝ EcosiaOS Flex ውሂብዎን ማስመር አልቻለም።</translation>
<translation id="7984841734836997333"><ph name="EXISTING_USER"/> አስቀድመው ገብተዋል።  አሰሳዎን ለያይተው ለመጠቀም በራስዎ መገለጫ ውስጥ እንደ <ph name="USER_EMAIL_ADDRESS"/> ሆነው ወደ Ecosia ይግቡ።</translation>
<translation id="4264506519284061030">ድርጅትዎ እንደ እልባቶችዎ፣ ታሪክዎ እና የይለፍ ቃላትዎ ባሉ የስራ መገለጫዎ ውስጥ የአሰሳ ውሂብን ማየት እና ማስተዳደር ይችላል። በግል የEcosia መገለጫዎች ውስጥ የአሰሳ ውሂብን ማየት አይችልም።</translation>
<translation id="8701027951719712428">የወደፊት የEcosia ዝማኔዎችን ለማግኘት macOS 11 ወይም ከዚያ በላይ ያስፈልግዎታል። ይህ ኮምፒውተር macOS 10.15 እየተጠቀመ ነው።</translation>
<translation id="4873783916118289636">በChrome ውስጥ ቁልፍ የግላዊነት እና የደህንነት ቁጥጥሮችን ይገምግሙ</translation>
<translation id="8454595950895325762">Ecosia በጀርባ ውስጥ ይሂድ</translation>
<translation id="489671036945006830">አገናኝ በአዲስ የEcosia &amp;ትር ውስጥ ክፈት</translation>
<translation id="6566258574866003581">Ecosia ይህን ቅጥያ እንዲገመግሙ ይመክርዎታል</translation>
<translation id="4951177103388687412">በትር ቡድኖች እርዳታ እንደተደራጁ እና በትኩረት እንደቆዩ ይዝለቁ</translation>
<translation id="5581150090232500900">Ecosiaን እንደ ነባሪ አሳሽዎ አድርገው ያቀናብሩ</translation>
<translation id="6495878830719404098">በEcosia ውስጥ</translation>
<translation id="6113625922434842626">የመለያ መግቢያ ዝርዝሮችዎ ጊዜ ያለፈባቸው ስለሆኑ EcosiaOS Flex ውሂብዎን ማስመር አልቻለም።</translation>
<translation id="4410570812343670816">ወደ Ecosia መገለጫዎች እንኳን በደህና መጡ</translation>
<translation id="4970880042055371251">የChromeOS ስሪት</translation>
<translation id="8570641140903702642">Ecosia Canary</translation>
<translation id="6735145163744656874">Ecosia የአሰሳ ተሞክሮዎን ለማሻሻል እና ነገሮች ፍጥነት ኖሯቸው ለማቆየት እነዚህን ትሮች ሊያቦዝናቸው ይችላል።</translation>
<translation id="2569934116750022163">«Ecosia የይለፍ ቃል አስተዳዳሪ» ላይ ጠቅ ያድርጉ</translation>
<translation id="5120334927898581447">ወደ ሌሎች የGoogle አገልግሎቶች ሲገቡ ወደ Chrome ይግቡ</translation>
<translation id="5126049312684316860">እርስዎ የመጎብኘት ዕድልዎ ከፍተኛ የሆኑባቸው ተጨማሪ ገጾች ሲጎበኟቸው ይበልጥ በፍጥነት እንዲጫኑ Chrome በቅድሚያ ይጭናቸዋል</translation>
<translation id="7782767522222146179">ለEcosia ምርጥ መተግበሪያዎችን፣ ጨዋታዎችን፣ ቅጥያዎችን እና ገጽታዎችን ያግኙ።</translation>
<translation id="6416551953415159186">የEcosia መገለጫዎን ያብጁ</translation>
<translation id="719484593754925816">Ecosia የአሰሳ ተሞክሮዎን ለማሻሻል እና ንብረቶችን ለማስለቀቅ ይህን ትር ሊያቦዝነው ይችላል።</translation>
<translation id="1859120614572957305">እንኳን ወደ Ecosia በደህና መጡ፤ አዲስ የአሳሽ መስኮት ተከፍቷል።</translation>
<translation id="6648664289472946060">መገለጫዎ የአዲስ Ecosia ስሪት አካል ስለሆነ መጠቀም አይቻልም።

አንዳንድ ባሕሪያት ላይገኙ ይችላሉ። እባክዎ የተለየ የመገለጫ አቃፊ ይግለጹ ወይም አዲሱን የEcosia ስሪት ይጠቀሙ።</translation>
<translation id="5201744974236816379">Chrome ዝማኔ</translation>
<translation id="6960183526681645011">መሣሪያ የሚያጋሩ ከሆኑ ጓደኛዎች እና ቤተሰብ ተለይተው ሊያስሱ እና Ecosiaን በሚፈልጉበት መንገድ ማዋቀር ይችላሉ</translation>
<translation id="3784023996375784431">በመልዕክቶች፣ ሰነዶች እና ሌሎች መተግበሪያዎች ውስጥ አገናኞች ላይ ጠቅ በሚያደርጉበት ማንኛውም ጊዜ Ecosia ይጠቀሙ</translation>
<translation id="1869027055332251164">እንግዳዎች ምንም ነገር ሳይተዉ Ecosiaን መጠቀም ይችላሉ።</translation>
<translation id="5320351714793324716">ኩኪዎችን ከፈቀዱ Chrome ቅድሚያ በመጫን ጊዜ ሊጠቀምባቸው ይችላል</translation>
<translation id="143614250230771428">ማስመር ለጎራዎ ስለማይገኝ EcosiaOS ውሂብዎን ማስመር አልቻለም።</translation>
<translation id="1809194740315140401">Ecosia ፋይሎችን ለማውረድ የማከማቻ መዳረሻ ፈቃድ ያስፈልገዋል</translation>
<translation id="8975930032513941502">ከተፈለገ፦ የምርመራ እና የአጠቃቀም ውሂብ ወደ Ecosia በራስ-ሰር በመላክ የEcosiaOS ባህሪያትን እና አፈጻጸምን እንዲሻሻል ያግዙ።</translation>
<translation id="5357889879764279201">በChromeOS Flex ላይ እገዛን ያግኙ</translation>
<translation id="5368118228313795342">ተጨማሪ ኮድ፦ <ph name="EXTRA_CODE"/>።</translation>
<translation id="6665128960039431910">እንዲሁም Ecosiaን ሲጀምሩት ወይም ከኦምኒቦክሱ ሆነው ሲፈልጉ የሚታየውን ገፅ ይቆጣጠራል።</translation>
<translation id="1861504561909287316">አንድ የEcosia ትር ያጋሩ</translation>
<translation id="5412485296464121825">ጣቢያዎች በChrome አማካኝነት ስለዝንባሌዎችዎ መረጃን ማከማቸት ይችላሉ። ለምሳሌ፣ ለማራቶን ጫማ ለመግዛት ጣቢያን ከጎበኙ ጣቢያው ዝንባሌዎን እንደ ማራቶን መሮጥ ሊገልጽ ይችላል። በኋላ ላይ ለሩጫ ለመመዝገብ ሌላ ጣቢያ ከጎበኙ ይህ ጣቢያ በዝንባሌዎችዎ ላይ ተመስርቶ የመሮጫ ጫማ ማስታወቂያ ሊያሳየዎት ይችላል።</translation>
<translation id="6673288084648462613">የምርጫዎችዎ ፋይል ተበላሽቷል ወይም ልክ አይደለም ነው።

Ecosia ቅንጅቶችዎን ማስመለስ አልቻለም።</translation>
<translation id="5468572406162360320">እነዚህ ባህሪያት እንዲሻሻሉ ለማገዝ Chrome ከእነሱ ጋር ያሉዎትን መስተጋብሮች ወደ Google ይልካል። ይህ ውሂብ በሰው ገምጋሚዎች ሊነበብ፣ ሊሰናዳ እና ሊብራራ ይችላል።</translation>
