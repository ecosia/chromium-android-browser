<translation id="8542320769345885402">Ecosia የይለፍ ቃል አስተዳዳሪ</translation>
<translation id="6251759518630934363">ከመደበኛ ጥበቃ በላይ ተጨማሪ ውሂብ ከጣቢያዎች ትንታኔ በመስጠት Google እንኳን በፊት ስላላወቃቸው አደገኛ ጣቢያዎች ያስጠነቅቅዎታል። የChrome ማስጠንቀቂያዎችን ለመዝለል መምረጥ ይችላሉ።</translation>
<translation id="8561406087076314604">የእርስዎ ወላጅ ለEcosia «የጣቢያዎች፣ መተግበሪያዎች እና ቅጥያዎች ፈቃዶች» የሚለውን አጥፍተዋል።</translation>
<translation id="1818520302923047971">Ecosiaን ያብጁ እና ይቆጣጠሩ። Ecosiaን እንደ ነባሪ ያቀናብሩት።</translation>
<translation id="6669755086687029198">መስመር ላይ ደህንነቱ በተጠበቀ ሁኔታ ለመሥራት፣ ለመፍጠር እና ለማሰስ Ecosiaን እንደ ነባሪ ያቀናብሩት</translation>
<translation id="675229436434399924">Ecosia Dev መተግበሪያዎች</translation>
<translation id="4870057811531036437">Ecosia ቀደም ብሎ በእርስዎ ኮምፒውተር ላይ ላሉ ተጠቃሚዎች ተጭኗል።</translation>
<translation id="378302976931789177">Ecosia አካባቢዎን በካርታ ለመንደፍ እና የእጆችዎን እንቅስቃሴዎች ለመከታተል ፈቃድ ይፈልጋል</translation>
