<!DOCTYPE translationbundle>
<translationbundle lang="ur">
<translation id="1026101648481255140">انسٹالیشن دوبارہ شروع کریں</translation>
<translation id="8933665254023068908">‏EcosiaOS&amp; کو اپ ڈیٹ کرنے کیلئے بند کر کے دوبارہ چلائیں</translation>
<translation id="6566258574866003581">‏Ecosia تجویز کرتا ہے کہ آپ اس ایکسٹینشن کا جائزہ لیں</translation>
<translation id="1042552502243217427">‏جب کوئی سائٹ اپنے صفحے پر لنکس کو نجی طور پر پیشگی لوڈ کرنے کا مطالبہ کرتی ہے تو Chromium براؤزر ‏Google سرورز کا استعمال کرتا ہے۔ اس سے پیشگی لوڈ کردہ سائٹ سے آپ کی شناخت پوشیدہ ہو جاتی ہے، لیکن Google جانتا ہے کہ کونسی سائٹس پیشگی لوڈ ہوتی ہیں۔</translation>
<translation id="1065672644894730302">آپ کی ترجیحات کو نہیں پڑھا جا سکتا ہے۔

کچھ خصوصیات غیر دستیاب ہو سکتی ہیں اور ترجیحات میں تبدیلیاں محفوظ نہیں ہونگی۔</translation>
<translation id="8561406087076314604">‏آپ کے والدین نے "Ecosia کی خاطر سائٹس، ایپس اور ایکسٹینشنز کے لیے اجازتوں" کو آف کر دیا ہے</translation>
<translation id="1098170124587656448">‏Chromium آپ کو ڈیٹا کی خلاف ورزیوں، غلط ایکسٹینشنز اور بہت کچھ سے محفوظ رکھنے میں مدد کر سکتا ہے</translation>
<translation id="3632544319066562282">‏Ecosia آپ کے پاس ورڈز برآمد کرنا چاہتا ہے۔ اس کی اجازت دینے کیلئے، اپنا Windows پاس ورڈ ٹائپ کریں۔</translation>
<translation id="113122355610423240">‏Chromium آپ کا ڈیفالٹ براؤزر ہے</translation>
<translation id="1131805035311359397">‏یہ دیکھنے کے لئے کہ آیا آپ کے پاس ورڈز ڈیٹا کی خلاف ورزیوں اور دیگر سیکیورٹی مسائل سے محفوظ ہیں، <ph name="BEGIN_LINK"/>Chromium میں سائن ان کریں<ph name="END_LINK"/>۔</translation>
<translation id="1224748120031661633">‏Ecosia مینو پر کلک کریں</translation>
<translation id="1184145431117212167">‏انسٹالیشن ناکام ہوگئی کیونکہ Windows کا آپ کا ورژن تعاون یافتہ نہیں ہے۔</translation>
<translation id="1185134272377778587">‏Chromium کے بارے میں</translation>
<translation id="1330085168384841023">‏اپنی ونڈو کا اشتراک کرنے کے لیے، سسٹم کی ترجیحات میں Ecosia کے لیے اسکرین ریکارڈنگ کی اجازت دیں۔</translation>
<translation id="1203500561924088507">انسٹال کرنے کا شکریہ۔ آپ کو <ph name="BUNDLE_NAME"/> استعمال کرنے سے پہلے اپنا براؤزر لازمی طور سے ری اسٹارٹ کرنا چاہیے۔</translation>
<translation id="7455175614937447568">‏جب یہ ٹیب غیر فعال تھا تو Ecosia کو تیز رکھنے کے لیے میموری خالی کر دی گئی تھی۔ آپ اس سائٹ کو ہمیشہ غیر فعال ہونے سے خارج کرنے کا انتخاب کر سکتے ہیں۔</translation>
<translation id="9068280473864300215">‏Ecosia نے اس ڈاؤن لوڈ کو مسدود کر دیا کیونکہ فائل خطرناک ہے</translation>
<translation id="126567311906253476">‏<ph name="USER_EMAIL"/> کے ساتھ Gmail یا YouTube جیسی Google سروسز میں سائن ان کرتے وقت، آپ اسی اکاؤنٹ سے خودکار طور پر Chromium میں سائن ان کر سکتے ہیں</translation>
<translation id="1290883685122687410">سیٹ اپ میں خرابی: <ph name="METAINSTALLER_EXIT_CODE"/>. <ph name="WINDOWS_ERROR"/></translation>
<translation id="319566061277127356">‏اپنی نئی Ecosia پروفائل سیٹ اپ کریں</translation>
<translation id="4019094010333463261">‏‫Ecosia کو بلوٹوتھ آلات دریافت کرنے کے لیے بلوٹوتھ تک رسائی درکار ہے۔ <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="5405885279794834338">‏Ecosia (<ph name="URL"/>) سے ڈیٹا بھی حذف کریں</translation>
<translation id="727568860157522676">‏آپ Ecosia میں سائن ان ہیں!</translation>
<translation id="1478370723027452770">‏Chrome for Testing کے سلسلے میں مدد حاصل کریں</translation>
<translation id="1497802159252041924">انسٹال کی خرابی: <ph name="INSTALL_ERROR"/></translation>
<translation id="1861504561909287316">‏ایک Ecosia ٹیب کا اشتراک کریں</translation>
<translation id="6896860023874996542">‏پنے اطراف کا 3D نقشہ تخلیق کرنے کی خاطر Ecosia کو آپ کے کیمرے تک رسائی کی اجازت درکار ہے</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{‏یہ ایکسٹینشن اب مزید تعاون یافتہ نہیں ہے۔ ‫Ecosia تجویز کرتا ہے کہ آپ اسے ہٹا دیں}other{‏یہ ایکسٹینشنز اب مزید تعاون یافتہ نہیں ہیں۔ ‫Ecosia تجویز کرتا ہے کہ آپ انہیں ہٹا دیں۔}}</translation>
<translation id="1574377791422810894">‏Chromium کے سیفٹی ٹولز</translation>
<translation id="2200308425865645682">‏آپ کے Ecosia اکاؤنٹ میں کچھ ڈیٹا کو محفوظ کرنے اور آپ کے تمام آلات پر اس کا استعمال کرنے سے پہلے Ecosia کو اس بات کی توثیق کرنے کی ضرورت ہے کہ یہ آپ ہی ہیں۔ اگر آپ سائن آؤٹ کرتے ہیں تو یہ ڈیٹا اس آلے پر رہے گا۔</translation>
<translation id="7304240387834227637">‏‫Ecosia آپ کا پاس ورڈ مینیجر ڈیٹا حذف کرنا چاہتا ہے۔ اس کی اجازت دینے کے لیے اپنا Windows پاس ورڈ ٹائپ کریں۔</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{‏آپ کے منتظم کا مطالبہ ہے کہ آپ اپ ڈیٹ کو لاگو کرنے کیلئے Ecosia کو بند کر کے دوبارہ چلائیں}=1{‏آپ کے منتظم کا مطالبہ ہے کہ آپ اپ ڈیٹ کو لاگو کرنے کیلئے Ecosia کو بند کر کے دوبارہ چلائیں۔ آپ کی پوشیدگی ونڈو دوبارہ نہیں کھلے گی۔}other{‏آپ کے منتظم کا مطالبہ ہے کہ آپ اپ ڈیٹ کو لاگو کرنے کیلئے Ecosia کو بند کر کے دوبارہ چلائیں۔ آپ کی # پوشیدگی ونڈوز دوبارہ نہیں کھلیں گی۔}}</translation>
<translation id="1625909126243026060">‏Chromium میں کلیدی رازداری اور سیکیورٹی کنٹرولز کا جائزہ لیں</translation>
<translation id="931416298178634530">‏اگر آپ اس اکاؤنٹ کو صرف ایک بار استعمال کرنا چاہتے ہیں تو آپ Ecosia براؤزر میں <ph name="GUEST_LINK_BEGIN"/>مہمان وضع<ph name="GUEST_LINK_END"/> کا استعمال کر سکتے ہیں۔ اگر آپ کسی اور کے لیے کوئی اکاؤنٹ شامل کرنا چاہتے ہیں تو اپنے <ph name="DEVICE_TYPE"/> میں <ph name="LINK_BEGIN"/>ایک نیا شخص شامل کریں<ph name="LINK_END"/>۔

ویب سائٹس اور ایپس کو پہلے سے آپ کی دی گئی اجازتیں اس اکاؤنٹ پر لاگو ہو سکتی ہیں۔ آپ <ph name="SETTINGS_LINK_BEGIN"/>ترتیبات<ph name="SETTINGS_LINK_END"/> میں اپنے Ecosia اکاؤنٹس کا نظم کر سکتے ہیں۔</translation>
<translation id="1640672724030957280">ڈاؤن لوڈ ہو رہی ہے…</translation>
<translation id="1715127912119967311">‏ان خصوصیات کو بہتر بنانے میں مدد کے لیے، Chromium ان کے ساتھ آپ کے تعاملات Google کو بھیجتا ہے۔ اس ڈیٹا کو انسان جائزہ کار پڑھ سکتے ہیں، اس پر کارروائی کر سکتے ہیں اور تشریح کر سکتے ہیں۔</translation>
<translation id="1722488837206509557">یہ آپ کو دستیاب آلات میں سے انتخاب کرنے اور ان پر مواد ڈسپلے کرنے کی اجازت دے گا۔</translation>
<translation id="1118786556671181978">‏آپ دلچسپی کے ان موضوعات کو دیکھ اور ہٹا سکتے ہیں جنہیں سائٹس آپ کو اشتہارات دکھانے کے لیے استعمال کرتی ہیں۔ Ecosia آپ کی حالیہ براؤزنگ کی سرگزشت کی بنیاد پر آپ کی دلچسپیوں کا تخمینہ لگاتا ہے۔</translation>
<translation id="2379593823746842972">‏Ecosia جلد ہی براؤزنگ ڈیٹا کو حذف کر دے گا</translation>
<translation id="1736443181683099871">‏Chromium نیویگیشنز کو HTTPS میں اپ گریڈ کرنے کی کوشش کرے گا</translation>
<translation id="5490755016715767023">‏Ecosia <ph name="REMAINING_TIME"/> میں ری سٹارٹ ہو جائے گا</translation>
<translation id="1749104137266986751">‏HTTPS دستیاب نہ ہونے پر، Chromium آپ کو وارننگ دیے بغیر ایک غیر محفوظ کنکشن استعمال کرے گا</translation>
<translation id="8454595950895325762">‏Ecosia کو پس منظر میں چلنے دیں</translation>
<translation id="9125443060066914183">‏Ecosia کو محفوظ تر بنانے کیلئے، ہم نے کچھ ایکسٹینشنز کو غیر فعال کر دیا ہے جو <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> میں مندرج نہیں ہیں اور ہو سکتا ہے ان کو آپ کے علم کے بغیر شامل کیا گیا ہو۔</translation>
<translation id="6984747211123632080">‏Ecosia کو دوبارہ انسٹال کریں</translation>
<translation id="1251415775728969647">‏Ecosia <ph name="AUTHENTICATION_PURPOSE"/> کی کوشش کر رہا ہے</translation>
<translation id="1761584959558744002">‏براؤزنگ ڈیٹا کو اپنے Ecosia اکاؤنٹ میں برقرار رکھتے ہوئے، صرف اس آلہ سے اسے حذف کرنے کیلئے، <ph name="BEGIN_LINK"/>Ecosia سے سائن آؤٹ کریں<ph name="END_LINK"/>۔</translation>
<translation id="185970820835152459">‏آپ اپنے سائن ان کردہ Google اکاؤنٹس کا نظم کر سکتے ہیں۔ آپ کے Google اکاؤنٹس Chromium براؤزر، Play اسٹور، Gmail اور مزید کے لیے استعمال ہوتے ہیں۔ اگر آپ کسی اور کے لیے کوئی اکاؤنٹ شامل کرنا چاہتے ہیں جیسے آپ کی فیملی کا کوئی ممبر تو اس کی بجائے اپنے <ph name="DEVICE_TYPE"/> میں ایک نیا شخص شامل کریں۔ <ph name="LINK_BEGIN"/>مزید جانیں<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">‏سائٹس Chromium کے ساتھ آپ کی دلچسپیوں کے بارے میں معلومات اسٹور کر سکتی ہیں۔ مثلاً اگر آپ میراتھن کے لئے جوتے خریدنے کی خاطر کوئی سائٹ ملاحظہ کرتے ہیں تو سائٹ دوڑ کے میراتھنز کے بطور آپ کی دلچسپی کا تعین کر سکتی ہے۔ بعد میں اگر آپ دوڑ میں رجسٹر کرنے کے لئے کوئی دوسری سائٹ ملاحظہ کرتے ہیں تو وہ سائٹ آپ کو آپ کی دلچسپیوں کی بنیاد پر دوڑنے کے جوتوں کا اشتہار دکھا سکتی ہے۔</translation>
<translation id="4239392394637574967">‏آپ ایک منظم اکاؤنٹ کے ساتھ سائن ان کر رہے ہیں اور اپنے Ecosia پروفائل پر اس کا انتظامی کنٹرول دے رہے ہیں۔ آپ کا Ecosia ڈیٹا جیسے آپ کی ایپس، بُک مارکس، سرگزشت، پاس ورڈز اور دیگر ترتیبات <ph name="USER_NAME"/> سے مستقل طور پر جڑ جائیں گی۔ آپ اس ڈیٹا کو Ecosia اکاؤنٹس ڈیش بورڈ کے ذریعے حذف کر سکیں گے لیکن آپ اس ڈیٹا کو دوسرے اکاؤنٹ کے ساتھ وابستہ نہیں کر سکیں گے۔ آپ اپنا موجودہ Ecosia ڈیٹا الگ رکھنے کیلئے اختیاری طور پر ایک نیا پروفائل بنا سکتے ہیں۔ <ph name="LEARN_MORE"/></translation>
<translation id="1906696617298807388">‏جب آپ ایڈریس بار یا تلاش کے خانے میں ٹائپ کرتے ہیں تو Chromium آئٹم کی تجاویز حاصل کرنے کے لیے جو آپ ٹائپ کرتے ہیں اسے Google Drive کو بھیجتا ہے۔ یہ پوشیدگی میں آف ہے۔</translation>
<translation id="1911763535808217981">‏اسے آف کر کے، آپ Chromium میں سائن ان کیے بغیر Gmail جیسی Google سائٹس میں سائن ان کر سکتے ہیں</translation>
<translation id="18064594488616674">‏Ecosia جواب نہیں دے رہا ہے۔ ابھی دوبارہ شروع کریں؟</translation>
<translation id="8047394653992042491">‏اپ ڈیٹ لاگو کرنے کیلئے EcosiaOS کو دوبارہ شروع کرنے کی ضرورت ہے۔</translation>
<translation id="4988569127367972482">‏Ecosia نے اس ڈاؤن لوڈ کو مسدود کر دیا کیونکہ فائل کی یہ قسم عام طور پر ڈاؤن لوڈ نہیں ہوتی ہے اور یہ خطرناک ہو سکتی ہے</translation>
<translation id="1953553007165777902">ڈاؤن لوڈ ہو رہی ہے… <ph name="MINUTE"/> منٹ(منٹس) باقی ہے</translation>
<translation id="1966382378801805537">‏Chromium ڈیفالٹ براؤزر کا تعین یا اس کو سیٹ نہیں کر سکتا ہے</translation>
<translation id="6583697665130212310">‏جانیں کہ Ecosia کچھ فائلز کو کیوں مسدود کرتا ہے، نئے ٹیب میں کھلتا ہے</translation>
<translation id="2008474315282236005">‏یہ اس آلہ سے 1 آئٹم کو حذف کر دے گا۔ بعد میں اپنا ڈیٹا بازیافت کرنے کیلئے، Chromium میں <ph name="USER_EMAIL"/> کے بطور سائن ان کریں۔</translation>
<translation id="2018879682492276940">انسٹالیشن ناکام ہو گئی۔ دوبارہ کوشش کریں۔</translation>
<translation id="2020032459870799438">‏یہ دیکھنے کے لئے کہ آیا آپ کے دیگر پاس ورڈز ڈیٹا کی خلاف ورزیوں اور دیگر سیکیورٹی مسائل سے محفوظ ہیں، <ph name="BEGIN_LINK"/>Chromium میں سائن ان کریں<ph name="END_LINK"/>۔</translation>
<translation id="2049376729098081731">‏منتخب کریں کہ آیا Google سروسز میں مزید ذاتی نوعیت کے تجربات کے لیے Chromium کی سرگزشت کو شامل کریں</translation>
<translation id="7112125772061727648">‏Ecosia نے اس ڈاؤن لوڈ کو مسدود کر دیا کیونکہ یہ فائل فریب والی ہے اور آپ کے آلے میں غیر متوقع تبدیلیاں کر سکتی ہے</translation>
<translation id="2088953378266246249">‏اس بارے میں معلومات کہ کس طرح Chromium اپنے روٹ سرٹیفیکیٹس کا نظم کرتا ہے</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{‏1 منٹ تک Ecosia کا استعمال نہ ہونے پر آپ کی تنظیم خودکار طور پر براؤزنگ ڈیٹا حذف کر دیتی ہے۔ اس میں سرگزشت، آٹو فل اور ڈاؤن لوڈز شامل ہو سکتے ہیں۔ آپ کے ٹیبز کھلے رہیں گے۔}other{‏# منٹ تک Ecosia کا استعمال نہ ہونے پر آپ کی تنظیم خودکار طور پر براؤزنگ ڈیٹا کو حذف کر دیتی ہے۔ اس میں سرگزشت، آٹو فل اور ڈاؤن لوڈز شامل ہو سکتے ہیں۔ آپ کے ٹیبز کھلے رہیں گے۔}}</translation>
