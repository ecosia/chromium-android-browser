<translation id="1384607180773886645">‏پروفائل دوسرے کمپیوٹر (<ph name="HOST_NAME"/>) پر دوسری Ecosia کارروائی (<ph name="PROCESS_ID"/>) کے ذریعہ زیر استعمال معلوم پڑتا ہے۔ Ecosia نے کارروائی کو مقفل کر دیا ہے تاکہ یہ خراب نہ ہو جائے۔ اگر آپ کو یقین ہے کہ کوئی دیگر کارروائیاں اس پروفائل کو استعمال نہیں کر رہی ہیں تو آپ پروفائل کو غیر مقفل کر کے Ecosia کو دوبارہ شروع کر سکتے ہیں۔</translation>
<translation id="4680828127924988555">انسٹالیشن منسوخ کریں</translation>
<translation id="7898621536417126731">‏آپ کا کچھ Ecosia ڈیٹا ابھی تک آپ کے Ecosia اکاؤنٹ میں محفوظ نہیں ہوا ہے۔ سائن آؤٹ کرنے سے پہلے کچھ منٹ انتظار کر کے دیکھیں۔ اگر آپ ابھی سائن آؤٹ کرتے ہیں تو یہ ڈیٹا حذف ہو جائے گا۔</translation>
<translation id="4427878468534147875">‏جب آپ سائن ان ہوتے ہیں، آپ Ecosia میں اپنے Ecosia اکاؤنٹ سے اپنے پاس ورڈز وغیرہ استعمال کر سکتے ہیں۔ <ph name="SHORTCUT"/> آپ کی Ecosia سروسز کی ترتیبات کو تبدیل کر سکتا ہے۔</translation>
<translation id="4727435569202742773">‏کسی نے قبل ازیں اس کمپیوٹر پر Ecosia میں <ph name="ACCOUNT_EMAIL_LAST"/> کے بطور سائن ان کیا۔ اپنی معلومات علیحدہ رکھنے کیلئے براہ کرم ایک نیا Ecosia صارف بنائیں۔</translation>
<translation id="4724676981607797757">ایک غیر تعاون یافتہ پروٹوکول کی خرابی کی وجہ سے انسٹالیشن ناکام ہو گئی۔</translation>
<translation id="864244542982029641">‏بہر حال Ecosia بند کریں؟</translation>
<translation id="1025044809499013222">‏Ecosia کے لیے ایک خاص سیکیورٹی اپ ڈیٹ ابھی ابھی لاگو کیا گیا ہے۔ ابھی دوبارہ شروع کریں اور ہم آپ کے ٹیبز کو بحال کر دیں گے۔</translation>
<translation id="824192326282906244">‏آپ Ecosia کی ترتیبات میں کسی بھی وقت اپنا ارادہ بدل سکتے ہیں۔ ٹرائلز اشتہارات پیش کیے جانے کے موجودہ طریقے کے ساتھ چلتے ہیں لہذا آپ کو تبدیلیاں فورا نظر نہیں آئیں گی۔</translation>
<translation id="4788777615168560705">‏Chromium آپ کے پاس ورڈز چیک نہیں کر سکتا ہے۔ 24 گھنٹے بعد دوبارہ کوشش کریں یا <ph name="BEGIN_LINK"/>اپنے Google اکاؤنٹ میں پاس ورڈز چیک کریں<ph name="END_LINK"/>۔</translation>
<translation id="3543284013834505767">‏یہ وہی املا جانچ کنندہ استعمال کرتا ہے جسے Ecosia تلاش میں استعمال کیا جاتا ہے۔ آپ براؤزر میں جو متن ٹائپ کرتے ہیں، اسے Ecosia کو بھیجا جاتا ہے۔ آپ اس برتاؤ کو کسی بھی وقت ترتیبات میں تبدیل کر سکتے ہیں۔</translation>
