<translation id="3966234175958887595">Ecosia ცდილობს პაროლების ჩვენებას. აკრიფეთ თქვენი Windows-ის პაროლი, რათა დაუშვათ ეს.</translation>
<translation id="2290912123073552463">თქვენმა მშობელმა გამორთო „ნებართვები საიტებისთვის, აპებისა და გაფართოებებისთვის“ Ecosia-ისთვის. ეს <ph name="EXTENSION_TYPE_PARAMETER"/> ვერ ჩაირთვება.</translation>
<translation id="3216284932113164802">Ecosia-ში შეცდომაა. გადავტვირთოთ?</translation>
<translation id="8341646175450781745">ჩართვის შემთხვევაში, Chrome გამოათავისუფლებს მეხსიერებას არააქტიური ჩანართებიდან. აქტიურ ჩანართებსა და სხვა აპებს კომპიუტერის მეტი რესურსის გამოყენების საშუალება მიეცემა, რაც დააჩქარებს Chrome-საც. თქვენი არააქტიური ჩანართები ავტომატურად გააქტიურდება, როცა მათ დაუბრუნდებით. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი<ph name="END_LINK"/> ან <ph name="BEGIN_LINK_2"/>გამოგვეხმაურეთ<ph name="END_LINK_2"/></translation>
<translation id="6491651957026506753">Ecosia-მა დაბლოკა ეს ფაილი, რადგან ის სახიფათოა.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>ამ მონაცემთა გამოყენების წესი:<ph name="END_BOLD"/> საიტებს Ecosia-ის მეშვეობით შეუძლია თქვენს ინტერესებთან დაკავშირებული ინფორმაციის შენახვა. მაგალითად, თუ მარათონისთვის ფეხსაცმლის საყიდლად რომელიმე საიტს მოინახულებთ, აღნიშნულმა საიტმა შეიძლება განსაზღვროს, რომ მარათონებში მონაწილეობა გაინტერესებთ. მოგვიანებით, თუ განსხვავებულ საიტს მოინახულებთ, მაგალითად, რბოლაში მონაწილეობის მისაღებად რეგისტრაციისთვის, ამ საიტმა შეიძლება სპორტული ფეხსაცმლის რეკლამა გაჩვენოთ თქვენი ინტერესების საფუძველზე.</translation>
<translation id="8355171755788522183">© <ph name="YEAR"/>, Ecosia. ყველა უფლება დაცულია.</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>ამ მონაცემთა გამოყენების წესი:<ph name="END_BOLD"/> Ecosia-ს შეუძლია თქვენი ინტერესების პროგნოზირება. მოგვიანებით, თქვენ მიერ მონახულებულ საიტს საშუალება ექნება, Ecosia-ს სთხოვოს თქვენი ინტერესების ჩვენება, თქვენთვის ხილული რეკლამის პერსონალიზების მიზნით.</translation>
<translation id="5883025779824839861">Ecosia-ის გამოყენების გაგრძელება</translation>
<translation id="8394720698884623075">შეამოწმებს URL-ების თანხვედრას Chrome-ში შენახულ არაუსაფრთხო საიტების სიასთან</translation>
<translation id="4409756430498035341">Ecosia ითხოვს თქვენი პაროლების ექსპორტირებას.</translation>
<translation id="5902103164685487225">შეიტყვეთ მეტი Ecosia-ში რეკლამის პერსონალიზების შესახებ</translation>
<translation id="592990842052138727">EcosiaOS-მა ვერ დაასინქრონა თქვენი მონაცემები, რადგან თქვენი ანგარიშის შესვლის დეტალები მოძველდა.</translation>
<translation id="665177868576952817">აქედან თქვენს Android ტელეფონზე ნომრის გასაგზავნად შედით Ecosia-ში ორივე მოწყობილობაზე.</translation>
<translation id="4070480171055648632">თქვენს ანგარიშს მართავს <ph name="MANAGER_NAME"/>. თქვენს ადმინისტრატორს შეუძლია ამ Ecosia ბრაუზერის პროფილისა და მისი მონაცემების ნახვა და რედაქტირება, მაგალითად, სანიშნეების, ისტორიისა და პაროლების.</translation>
<translation id="1025044809499013222">Ecosia-ს ეს-ესაა მიესადაგა უსაფრთხოების საგანგებო განახლება. გადატვირთეთ ის ახლავე და თქვენი ჩანართებიც აღდგება.</translation>
<translation id="7864624828358709494">Ecosia-მა დაბლოკა ეს ფაილი, რადგან ის შეიცავს მავნე პროგრამას</translation>
<translation id="3816260943154642689">Ecosia-ის მიერ პროგნოზირებული თქვენი ინტერესები</translation>
<translation id="8023973672752791660">შემომავალი წესი Ecosia Dev-ისთვის mDNS ტრაფიკის დასაშვებად.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="8550334526674375523">სამსახურის ეს პროფილი თქვენი პირადი პროფილისგან სრულიად დამოუკიდებლად ფუნქციონირებს.</translation>
<translation id="7185777478310554774">ხელმისაწვდომია Ecosia-ის უფრო ახალი ვერსია, რომელიც უფრო სწრაფია.</translation>
<translation id="5622136942112821750">Ecosia პროფილები Ecosia-ში არსებული თქვენი კონტენტის განცალკევების საშუალებას გაძლევთ. მაგალითად, სამსახურებრივი და პირადი მონაცემების.</translation>
<translation id="18064594488616674">Ecosia არ პასუხობს. გავუშვათ ხელახლა?</translation>
<translation id="6896860023874996542">Ecosia საჭიროებს თქვენს კამერაზე წვდომის ნებართვას, თქვენი გარემოს 3-განზომილებიანი რუკის შექმნა რომ შეძლოს</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia ხელახლა გაეშვება 1 წუთში}other{Ecosia ხელახლა გაეშვება # წუთში}}</translation>
<translation id="8641606876632989680">Chrome შეგატყობინებთ, როცა სისტემაში გატეხილი პაროლით შეხვალთ</translation>
<translation id="8649026945479135076">თქვენ მიერ მონახულებული საიტები, როგორც წესი, ინახავს თქვენს ინტერესებს ფუნქციების თქვენზე მორგების მიზნით. საიტებს Chrome-ის მეშვეობითაც შეუძლია თქვენს ინტერესებთან დაკავშირებული ინფორმაციის შენახვა.</translation>
<translation id="9090890391337853620">Ecosia-ის დახმარება</translation>
<translation id="524314285625975879">იგი, ასევე, აკონტროლებს, თუ რომელი გვერდი გამოჩნდება Ecosia-ის გაშვებისას.</translation>
<translation id="4997668724897475215">Ecosia გირჩევთ, დაასკანიროთ ეს ფაილი, რადგან ის შეიძლება სახიფათო იყოს</translation>
<translation id="4170280082681554565">Ecosia პროფილები Ecosia-ში არსებული თქვენი კონტენტის განცალკევების საშუალებას გაძლევთ. შექმენით პროფილები ოჯახის წევრებისა და მეგობრებისთვის, ან განაცალკევეთ სამსახურებრივი და პირადი მონაცემები.</translation>
<translation id="8712767363896337380">ყველაფერი თითქმის მზადაა! განახლების დასასრულებლად ხელახლა გაუშვით Chrome.</translation>
<translation id="873133009373065397">Google Chrome ნაგულისხმევ ბრაუზერს ვერ საზღვრავს, ან ვერ აყენებს</translation>
<translation id="1975037445584526511">Ecosia-ის მომავალი განახლებების მისაღებად დაგჭირდებათ Windows 10 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს Windows 7-ს.</translation>
<translation id="2695952268686253864">Ecosia მოძველებულია</translation>
<translation id="8825634023950448068">თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. თუ Chrome შეცდომით გამოიცნობს თქვენს ინტერესს, ან რომელიმე ტიპის რეკლამის ნახვას არ მოისურვებთ, ინტერესის წაშლის საშუალება გექნებათ.</translation>
<translation id="5066194399237265772">Ecosia ცდილობს პაროლების რედაქტირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="6078545897140861225">ასევე აკონტროლებს, თუ რომელი გვერდი გამოჩნდება Ecosia-ის გაშვებისას ან როცა დააწკაპუნებთ ღილაკზე „საწყისი“.</translation>
<translation id="1401515072108809622">Ecosia არააქტიურია</translation>
<translation id="8862326446509486874">თქვენ არ გაქვთ შესაბამისი უფლებები სისტემის დონეზე ინსტალაციისთვის. სცადეთ ინსტალაციის პროგრამის ხელახლა გაშვება ადმინისტრატორის სტატუსით.</translation>
<translation id="8282620071565190081">Ecosia-ის ხელახლა გაშვება</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/>-დან თქვენს Android ტელეფონზე ნომრის გასაგზავნად შედით Ecosia-ში ორივე მოწყობილობაზე.</translation>
<translation id="7910693244647744044">თქვენს ანგარიშში ჩართული გაქვთ გაძლიერებული Safe Browsing. ახლა გაააქტიურეთ ის Ecosia-ში.</translation>
<translation id="8986207147630327271">თქვენ აპირებთ, ამ ბრაუზერს სამსახურის პროფილი დაამატოთ, რითაც თქვენს ადმინისტრატორს კონტროლს მხოლოდ სამსახურის პროფილზე მიანიჭებთ.</translation>
<translation id="8989968390305463310">თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chrome ავტომატურად წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით. ინტერესები გაახლდება, თუ რომელიმე მათგანს არ წაშლით.</translation>
<translation id="7348818664647668234">{0,plural, =0{ხელმისაწვდომია Ecosia-ის განახლება}=1{ხელმისაწვდომია Ecosia-ის განახლება}other{უკვე # დღეა, რაც ხელმისაწვდომია Ecosia-ის განახლება}}</translation>
<translation id="9003498785844995646">ჩართვის შემთხვევაში, Chrome დაზოგავს ბატარეის მუხტს ვიზუალური ეფექტებისა (მაგალითად, ლივლივა გადაადგილებისა და ვიდეოკადრების სიხშირის) და ფონური აქტივობის შეზღუდვის გზით. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი<ph name="END_LINK"/> ან <ph name="BEGIN_LINK_2"/>გამოგვეხმაურეთ<ph name="END_LINK_2"/></translation>
