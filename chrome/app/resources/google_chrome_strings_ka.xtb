<translation id="5357908757303442841">Ecosia პაროლების მმართველში ამ მოწყობილობაზე</translation>
<translation id="8859253218356192164">EcosiaOS Flex მუშაობს <ph name="BEGIN_LINK_CROS_OSS"/>ღია კოდის პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS"/> დამსახურებით.</translation>
<translation id="6676384891291319759">წვდომა ინტერნეტზე</translation>
<translation id="4586967042094107073">Ecosia-ისთვის ფონურ რეჟიმში მუშაობის დაშვება</translation>
<translation id="2173571365716863400">Ecosia საჭიროებს მიკროფონზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="6161025257729272170">ააჩქარეთ Ecosia-ის მუშაობა</translation>
<translation id="9165312115453649251">EcosiaOS Flex სისტემა</translation>
<translation id="8685318202174822382">გსურთ ახალ Ecosia პროფილში გაგრძელება?</translation>
<translation id="6750954913813541382">მართლწერის შეცდომების შესასწორებლად Chrome უგზავნის Google-ს თქვენ მიერ ბრაუზერში აკრეფილ ტექსტს</translation>
<translation id="88039520238670574">მაინც გსურთ Ecosia-იდან გასვლა?</translation>
<translation id="8583650869792032882">შიდა წესი Ecosia Canary-ისთვის mDNS ტრაფიკის დასაშვებად.</translation>
<translation id="6881299373831449287">მიმდინარეობს Chrome-ის განახლება</translation>
<translation id="6800892712521842441">Ecosia Beta აპები</translation>
<translation id="5267683457871579197">EcosiaOS სისტემა</translation>
<translation id="8963533629322868062">Ecosia-ის მომავალი განახლებების მისაღებად დაგჭირდებათ Windows 10 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს Windows 8.1-ს.</translation>
<translation id="2128110540135015661">ამ პიროვნების დათვალიერების მონაცემები წაიშლება ამ მოწყობილობიდან. მონაცემების აღსადგენად შედით Ecosia-ში, როგორც <ph name="USER_EMAIL"/>.</translation>
<translation id="2434044214904689670">შემომავალი წესი Ecosia Beta-სთვის mDNS ტრაფიკის დასაშვებად.</translation>
<translation id="7482156490649194631">Ecosia განახლდა, მაგრამ თქვენ არ იყენებდით მას მინიმუმ 30 დღის განმავლობაში.</translation>
<translation id="7025789849649390912">ინსტალაცია შეწყდა.</translation>
<translation id="4032832945953542360">აქ შეგიძლიათ Ecosia პროფილებს შორის გადართვა</translation>
<translation id="931416298178634530">თუ ამ ანგარიშის გამოყენება მხოლოდ ერთხელ გსურთ, ისარგებლეთ <ph name="GUEST_LINK_BEGIN"/>სტუმრის რეჟიმით<ph name="GUEST_LINK_END"/> Ecosia ბრაუზერში. თუ სხვისი ანგარიშის დამატება გსურთ, <ph name="LINK_BEGIN"/>დაამატეთ ახალი პიროვნება<ph name="LINK_END"/> თქვენს <ph name="DEVICE_TYPE"/>-ს.

ამ ანგარიშზე, შესაძლოა, ვრცელდებოდეს ნებართვები, რომლებიც უკვე მიანიჭეთ ვებსაიტებსა და აპებს. თქვენი Ecosia ანგარიშების მართვა შეგიძლიათ <ph name="SETTINGS_LINK_BEGIN"/>პარამეტრებიდან<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="4281355161119203663">თქვენმა მშობელმა გამორთო „ნებართვები საიტებისთვის, აპებისა და გაფართოებებისთვის“ Ecosia-ისთვის. ეს <ph name="EXTENSION_TYPE_PARAMETER"/> ვერ დაემატება.</translation>
<translation id="7085332316435785646">აირჩიეთ, დაერთოს თუ არა Chrome ისტორია, Google სერვისებში უფრო პერსონალიზებული ფუნქციებით რომ ისარგებლოთ</translation>
<translation id="7088681679121566888">Chrome განახლებულია</translation>
<translation id="1318059253725731825">Ecosia იყენებს თქვენს მიკროფონს.</translation>
<translation id="8933665254023068908">ხელახლა გაშვება &amp;EcosiaOS-ის გასაახლებლად</translation>
<translation id="7311066525704006840">ამოცანათა მმართველი - Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{ხელმისაწვდომია Ecosia-ის განახლება, რომელიც მას მიესადაგება ხელახლა გაშვებისთანავე.}=1{ხელმისაწვდომია Ecosia-ის განახლება, რომელიც მას მიესადაგება ხელახლა გაშვებისთანავე. თქვენი ინკოგნიტო ფანჯარა ხელახლა არ გაიხსნება.}other{ხელმისაწვდომია Ecosia-ის განახლება, რომელიც მას მიესადაგება ხელახლა გაშვებისთანავე. თქვენი # ინკოგნიტო ფანჯარა ხელახლა არ გაიხსნება.}}</translation>
<translation id="7155997830309522122">ამ შემთხევაში ჩაასწორეთ Chrome-ში შენახული პაროლი ახლის მიხედვით.</translation>
<translation id="1027331268335328576">მოგესალმებათ Ecosia!</translation>
<translation id="675365189802108507">ამ ფუნქციების შესახებ დამატებითი ინფორმაციის მიღება შეგიძლიათ Ecosia-ის პარამეტრებიდან.</translation>
<translation id="4239392394637574967">თქვენ სისტემაში შედიხართ მართული ანგარიშით და მის ადმინისტრატორს თქვენი Ecosia-ის პროფილის კონტროლის შესაძლებლობას აძლევთ. თქვენი Ecosia-ის მონაცემები, როგორიცაა თქვენი პროგრამები, სანიშნეები, ისტორია, პაროლები და სხვა პარამეტრები მუდმივად მიებმება <ph name="USER_NAME"/>-ს. თქვენ შეძლებთ ამ მონაცემების წაშლას Ecosia Accounts Dashboard-ის მეშვეობით, მაგრამ თქვენ ვერ შეძლებთ ამ მონაცემების დაკავშირებას სხვა ანგარიშთან. სურვილისამებრ, შეგიძლიათ ახალი პროფილის შექმნა თქვენი Ecosia-ის მონაცემების ცალე შესანახად. <ph name="LEARN_MORE"/></translation>
<translation id="7295052994004373688">ეს ენა გამოიყენება Google Chrome-ის სამომხმარებლო ინტერფეისისთვის</translation>
<translation id="7296210096911315575">მნიშნველოვანი ინფორმაცია გამოყენებისა და უსაფრთხოების შესახებ</translation>
<translation id="5549921590305750618">Ecosia საჭიროებს მეხსიერებაზე წვდომას ფაილების ჩამოსატვირთად</translation>
<translation id="7339898014177206373">ახალი ფანჯარა</translation>
<translation id="5337919616446681032">თუ ამ ანგარიშის გამოყენება მხოლოდ ერთხელ გსურთ, ისარგებლეთ სტუმრის რეჟიმით Ecosia ბრაუზერში. თუ სხვისი ანგარიშის დამატება გსურთ, <ph name="LINK_BEGIN"/>დაამატეთ ახალი პიროვნება<ph name="LINK_END"/> თქვენს <ph name="DEVICE_TYPE"/>-ს.

ამ ანგარიშზე, შესაძლოა, ვრცელდებოდეს ნებართვები, რომლებიც უკვე მიანიჭეთ ვებსაიტებსა და აპებს. თქვენი Ecosia ანგარიშების მართვა შეგიძლიათ <ph name="SETTINGS_LINK_BEGIN"/>პარამეტრებიდან<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="2412381038247037703">თქვენ შესული ხართ Ecosia ში როგორც <ph name="USER_EMAIL_ADDRESS"/>. შემდეგი შესვლისთვისაც გთხოვთ იგივე ანგარიში გამოიყენოთ.</translation>
<translation id="5669097765101132299">Ecosia-მა დაბლოკა ეს ფაილი, რადგან ის სახიფათოა</translation>
<translation id="3307959934543585795">Ecosia-მა შეიძლება არასწორად იმუშაოს, რადგან ის აღარ არის მხარდაჭერილი ამ Linux დისტრიბუტივზე</translation>
<translation id="12795904718916112">ისარგებლეთ Ecosia-ის უსაფრთხოების ყველაზე ძლიერი ფუნქციებით</translation>
<translation id="7486227612705979895">Chrome-ს ექნება წვდომა თქვენს Drive-ზე მისამართთა ზოლში შემოთავაზებების უზრუნველსაყოფად</translation>
<translation id="932641430818191661">Ecosia Dev</translation>
