<translation id="2797864378188255696">Google სერვისებში, მაგალითად, Gmail-სა თუ YouTube-ში <ph name="USER_EMAIL"/>-ით შესვლისას შეგიძლიათ ავტომატურად შეხვიდეთ Chrome-შიც იმავე ანგარიშით</translation>
<translation id="2799223571221894425">ხელახლა გაშვება</translation>
<translation id="2825024317344269723">სახიფათო საიტი Chrome-მა ამოშალა შეტყობინებები.</translation>
<translation id="2846251086934905009">შეცდომა ინსტალაციისას: ინსტალატორის მუშაობა ვერ დასრულდა. ინსტალაცია შეწყდა.</translation>
<translation id="2847461019998147611">Google Chrome-ის ამ ენაზე ჩვენება</translation>
<translation id="2853415089995957805">Chrome წინასწარ ჩატვირთავს გვერდებს, რომელთა ნახვასაც, სავარაუდოდ, დააპირებთ — ამგვარად, ამ გვერდებზე გადასვლისას, ისინი უფრო სწრაფად ჩაიტვირთება</translation>
<translation id="8109744984354428711">მიმდინარეობს Ecosia-ის გაშვება…</translation>
<translation id="812798451698099271">ამ ანგარიშის მქონე Ecosia პროფილი უკვე არსებობს</translation>
<translation id="3035352359183300151">შეიტყვეთ, რატომ ბლოკავს Ecosia ზოგიერთ ჩამოტვირთვას</translation>
<translation id="2861074815332034794">მიმდინარეობს Chrome-ის განახლება (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="727568860157522676">თქვენ შესული ხართ Ecosia-ში!</translation>
<translation id="2876628302275096482">შეიტყვეთ მეტი იმის შესახებ, თუ <ph name="BEGIN_LINK"/>როგორ ინარჩუნებს Chrome თქვენი მონაცემების კონფიდენციალურობას<ph name="END_LINK"/></translation>
<translation id="2885378588091291677">ამოცანების მმართველი</translation>
<translation id="2888126860611144412">Chrome-ის შესახებ</translation>
<translation id="29082080693925013">ორგანიზებული რომ იყოთ, ჩაამაგრეთ ხშირად მონახულებული ვებსაიტები და დააჯგუფეთ ჩანართები</translation>
<translation id="2915996080311180594">მოგვიანებით გადატვირთვა</translation>
<translation id="2926676257163822632">სუსტი პაროლები ადვილი გამოსაცნობია, ამიტომ მიეცით საშუალება Chrome-ს, <ph name="BEGIN_LINK"/>თქვენთვის შექმნას და დაიმახსოვროს ძლიერი პაროლები<ph name="END_LINK"/>.</translation>
<translation id="219546601381787154">Ecosia საჭიროებს კამერზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="2928420929544864228">ინსტალაცია დასრულდა.</translation>
<translation id="2929907241665500097">Chrome-ის განახლება ვერ მოხერხდა შეფერხების გამო. <ph name="BEGIN_LINK"/>შეასწორეთ Chrome-ის განახლებასთან დაკავშირებული პრობლემები და განუხორციელებელი განახლებები.<ph name="END_LINK"/></translation>
<translation id="2945997411976714835">შეცდომა ინსტალაციისას: ინსტალატორის პროცესი ვერ გაეშვა.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> — ქსელში შესვლა — Ecosia</translation>
<translation id="8696852719113991652">Ecosia-იდან Ecosia ანგარიში რომ ამოშალოთ, საჭიროა, სისტემიდან გახვიდეთ Ecosia-ის პარამეტრების გვერდზე</translation>
<translation id="5405885279794834338">ასევე, წაიშალოს მონაცემები Ecosia-იდან (<ph name="URL"/>)</translation>
<translation id="5622643576877267490">ხელახლა გაშვება &amp;EcosiaOS Flex-ის გასაახლებლად</translation>
<translation id="2234042158691635795">Ecosia ფონურ რეჟიმშია.</translation>
<translation id="3038232873781883849">ინსტალაციის მოლოდინში...</translation>
<translation id="3059710691562604940">Safe Browsing გამორთულია. Chrome გირჩევთ მის ჩართვას.</translation>
<translation id="780008372122710391">ისარგებლეთ მალსახმობით, Ecosia პაროლების მმართველზე სწრაფად რომ გადახვიდეთ. მალსახმობის გადატანა შეგიძლიათ თქვენი კომპიუტერის მთავარ ეკრანზე ან აპების გამშვებში.</translation>
<translation id="385080958066798123">Ecosia-ის ჩანართი</translation>
<translation id="3080151273017101988">გაგრძელება გაშვებული ფონური პროგრამებით Google Chrome-ის დახურვისას</translation>
<translation id="3100998948628680988">დაასათაურეთ თქვენი Chrome პროფილი</translation>
<translation id="7051119589302096163">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ამ ფაილს, როგორც წესი, არ ტვირთავენ ხოლმე და ის, შესაძლოა, სახიფათო იყოს</translation>
<translation id="3114643501466072395"><ph name="BEGIN_LINK"/>შედით Chrome-ში<ph name="END_LINK"/>, რომ შეამოწმოთ, შეეხო თუ არა პერსონალურ მონაცემთა გაჟონვის შემთხვევები და უსაფრთხოებასთან დაკავშირებული პრობლემები თქვენს სხვა პაროლებს.</translation>
<translation id="231621248561775155">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან არქივის ფაილი შეიცავს სხვა ფაილებს, რომლებშიც, შესაძლოა, მავნე პროგრამა იმალებოდეს</translation>
<translation id="1722634673917783018">თქვენი ცვლილებები Ecosia.ის გადატვირთვის შემდეგ შევა ძალაში.</translation>
<translation id="2636091632287013185">Ecosia-ის პროგრამები</translation>
<translation id="7580831958727159171">ცდების მსვლელობისას შეძლებთ იმ ინტერესთა თემების ნახვასა და ამოშლას, რომლებსაც საიტები იყენებს თქვენთვის რეკლამის საჩვენებლად. თქვენს ინტერესებს Ecosia პროგნოზირებს თქვენ მიერ ვების დათვალიერების ბოლოდროინდელი ისტორიის საფუძველზე.</translation>
<translation id="9068280473864300215">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ეს ფაილი სახიფათოა</translation>
<translation id="3226612997184048185">თუ თქვენს სანიშნეებს Google ანგარიშშიც ინახავთ, შეგიძლიათ თვალი მიადევნოთ პროდუქტების ფასებს Chrome-ში და შეიტყოთ, როცა ფასი დაიკლებს</translation>
<translation id="3234642784688107085">გამოცადეთ ხელოვნური ინტელექტის ახალი ფუნქციები, რომ შექმნათ თემები, მიიღოთ დახმარება წერისას და იყოთ ორგანიზებული</translation>
<translation id="3245429137663807393">თუ თქვენ აზიარებთ Chrome-ის მოხმარების ანგარიშებსაც, ეს ანგარიშები ასევე მოიცავს თქვენ მიერ მონახულებულ URL-ებს</translation>
<translation id="3261565993776444564">ცადეთ ახალი ფერი თქვენი ბრაუზერის მოსარგებად</translation>
<translation id="2388751143175762498">შესვლა Ecosia-ში</translation>
<translation id="3286538390144397061">გადატვირთეთ ახლა</translation>
<translation id="8268239447047453615">დაგჭირდებათ Ecosia-ის გადატვირთვა.</translation>
<translation id="9090890391337853620">Ecosia-ის დამხმარე</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia ახლა ხელახლა გაეშვება}=1{Ecosia ხელახლა გაეშვება 1 წამში}other{Ecosia ხელახლა გაეშვება # წამში}}</translation>
<translation id="7280797724682955539">ინსტალაციის დროს წარმოიქმნა ოპერატიული სისტემის შეცდომა. ხელახლა ჩამოტვირთეთ Ecosia.</translation>
<translation id="3428747202529429621">უზრუნველყოფს თქვენს უსაფრთხოებას Chrome-ში და Google-ის სხვა აპებში, როცა სისტემაში შესული ხართ</translation>
<translation id="3434246496373299699">პაროლების Chrome-ის მეშვეობით შესამოწმებლად შედით სისტემაში თქვენი Google ანგარიშით</translation>
<translation id="6094573000614590044">თქვენს ყველა მოწყობილობაზე პაროლებისა და სხვა კონტენტის მისაღებად შედით Ecosia-ში</translation>
<translation id="5032126307005935789">ეს ფაილი, შესაძლოა, სახიფათო იყოს<ph name="LINE_BREAK"/>Ecosia-ს შეუძლია, თქვენ ნაცვლად შეამოწმოს ეს ჩამოტვირთვა, თუ პაროლს მიუთითებთ. ფაილის შესახებ ინფორმაცია ეგზავნება Ecosia Safe Browsing-ს, თუმცა ფაილების შიგთავსი და პაროლი რჩება თქვენს მოწყობილობაზე.</translation>
<translation id="1762318218111418450">Ecosia-ში დამატება…</translation>
<translation id="6761747850241550887">საკუთარი თავის დამატება Ecosia-ში</translation>
<translation id="2149148292984034533">EcosiaOS პირობები</translation>
<translation id="6558895515431832002">Ecosia საჭიროებს თქვენს მდებარეობაზე წვდომის ნებართვას ამ საიტისთვის გასაზიარებლად</translation>
<translation id="3533694711092285624">შენახული პაროლები არ არის. პაროლების შემოწმებას Chrome მოახერხებს მათი შენახვის შემდეგ.</translation>
<translation id="3541482654983822893">Chrome ვერ ახერხებს პაროლების შემოწმებას. ცადეთ 24 საათში.</translation>
<translation id="7881897052591031502">Ecosia-ში შესვლის შემდეგ შეგიძლიათ სანიშნეების, პაროლებისა და სხვა მონაცემების შენახვა, რომ შემდეგ ისინი თქვენს ტელეფონში გამოიყენოთ</translation>
<translation id="8901409988302458368">თქვენი სისტემის ადმინისტრატორმა მოახდინა Ecosia-ის კონფიგურაცია იმგვარად, რომ <ph name="TARGET_URL_HOSTNAME"/>-ზე წვდომისთვის საჭიროა ალტერნატიული ბრაუზერის გახსნა.</translation>
<translation id="7174674455569790401">მოახდინეთ Ecosia-ის სინქრონიზაცია და პერსონალიზება თქვენს ყველა მოწყობილობას შორის</translation>
<translation id="8403827649521531901">თქვენ უკვე შესული ხართ Ecosia-ის სხვა პროფილში როგორც <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="3260765223735049374">გსურთ, შეხვიდეთ Ecosia-ის ახალ პროფილში?</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{განახლების მისასადაგებლად თქვენი ადმინისტრატორი მოითხოვს Ecosia-ის ხელახლა გაშვებას}=1{განახლების მისასადაგებლად თქვენი ადმინისტრატორი მოითხოვს Ecosia-ის ხელახლა გაშვებას. თქვენი ინკოგნიტო ფანჯარა ხელახლა არ გაიხსნება.}other{განახლების მისასადაგებლად თქვენი ადმინისტრატორი მოითხოვს Ecosia-ის ხელახლა გაშვებას. თქვენი # ინკოგნიტო ფანჯარა ხელახლა არ გაიხსნება.}}</translation>
<translation id="3597003331831379823">მაღალი პრივილეგიებით დაყენების გაშვება ვერ მოხერხდა. <ph name="METAINSTALLER_ERROR"/></translation>
<translation id="3609788354808247807">ბოლო დროს არ ყოფილხართ. Chrome-მა ამოშალა <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> და <ph name="PERMISSION_3"/></translation>
<translation id="464306605599005355">ადვილი გახდა თქვენი Ecosia-ის ანგარიშის მეშვეობით Ecosia-ის გამოყენება და საერთო მოხმარების კომპიუტერებზეც.</translation>
<translation id="3635073343384702370">პაროლების შემოწმებას Chrome შეძლებს მათი შენახვის შემდეგ</translation>
<translation id="3667616615096815454">ინსტალაცია ვერ მოხერხდა, რადგან აპლიკაცია სერვერისთვის ცნობილი არ არის.</translation>
<translation id="1490060441084292633">Ecosia-მა აღმოაჩინა, რომ „<ph name="EXTENSION_NAME"/>“ შეიცავს მავნე პროგრამას</translation>
<translation id="3695446226812920698">შეიტყვეთ როგორ</translation>
<translation id="6967821869905227561">სხვა Ecosia პროფილები</translation>
<translation id="5311911269004680646">EcosiaOS და <ph name="BEGIN_LINK_LINUX_OSS"/>Linux-ის შემუშავების გარემო <ph name="END_LINK_LINUX_OSS"/> მუშაობს <ph name="BEGIN_LINK_CROS_OSS"/>ღია კოდის დამატებითი პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS"/> დამსახურებით.</translation>
<translation id="3716540481907974026">ChromeOS Flex-ის ვერსია</translation>
<translation id="3718181793972440140">ეს მოქმედება წაშლის 1 ერთეულს ამ მოწყობილობიდან. თქვენი მონაცემების მოგვიანებით მისაღებად, შედით Chrome-ში, როგორც <ph name="USER_EMAIL"/>.</translation>
<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Ecosia გირჩევთ მის ამოშლას. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი მხარდაჭერილი გაფართოებების შესახებ<ph name="END_LINK"/>}other{Ecosia გირჩევთ მათ ამოშლას. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი მხარდაჭერილი გაფართოებების შესახებ<ph name="END_LINK"/>}}</translation>
<translation id="3744202345691150878">დახმარების მიღება ChromeOS-თან დაკავშირებით</translation>
<translation id="4600924482853773728">Ecosia — <ph name="PAGE_TITLE"/></translation>
<translation id="4969069484658032230">EcosiaOS Flex-მა ვერ მოახერხა თქვენი მონაცემების სინქრონიზაცია, რადგან შესვლისას მოხდა შეცდომა.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="2829233304432701500">Ecosia-ის მუშაობისთვის საჭიროა Windows 10 ან უფრო ახალი ვერსია.</translation>
<translation id="3952510753191144456">ეს მოქმედება შექმნის ახალ Ecosia პროფილს <ph name="USER_EMAIL_ADDRESS"/>-ისთვის</translation>
<translation id="4019094010333463261">Bluetooth მოწყობილობების აღმოსაჩენად Ecosia საჭიროებს 
 Bluetooth-ზე წვდომას. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="8534308095039131078">დახურეთ Ecosia-ის ყველა ფანჯარა და ხელახლა სცადეთ.</translation>
<translation id="3865754807470779944">დაინსტალირებულია Chrome-ის ვერსია <ph name="PRODUCT_VERSION"/></translation>
<translation id="8283315171506895091">ბმულის გახსნა Ecosia-ი ინკო&amp;გნიტო ფანჯარაში</translation>
<translation id="6496553866814956056">Ecosia-ის დეინსტალაცია</translation>
<translation id="3941890832296813527">შეცდომა ინსტალაციისას: ინსტალატორის ფაილის სახელი არასწორი ან მხარდაუჭერელია.</translation>
<translation id="4459596553899864514">Ecosia-ს სურს თქვენი Ecosia პაროლების მმართველის მონაცემების წაშლა. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი.</translation>
<translation id="8846463365332065180">Ecosia ინარჩუნებს სისწრაფეს ეფექტურობის გაძლიერების ფუნქციებით</translation>
<translation id="1118786556671181978">თქვენ შეძლებთ თქვენთვის საინტერესო იმ თემების ნახვასა და ამოშლას, რომლებსაც საიტები იყენებს თქვენთვის რეკლამის საჩვენებლად. თქვენს ინტერესებს Ecosia პროგნოზირებს თქვენ მიერ ვების დათვალიერების ბოლოდროინდელი ისტორიის საფუძველზე.</translation>
<translation id="8047394653992042491">განახლების მისასადაგებლად, EcosiaOS უნდა გადაიტვირთოს.</translation>
<translation id="4050175100176540509">უსაფრთხოების მნიშვნელოვანი გაუმჯობესება და ახალი თვისებები ხელმისაწვდომია უახლეს ვერსიაში.</translation>
<translation id="4817913198787198451">Ecosia-ის მორგება და კონტროლი</translation>
<translation id="4395802781633621239">თქვენს ყველა მოწყობილობაზე პაროლებისა და სხვა კონტენტის მისაღებად შედით Ecosia-ში. შესვლის შემდეგ ეს პაროლი შეინახება თქვენს Ecosia ანგარიშში.</translation>
<translation id="1330085168384841023">თქვენი ფანჯრის გასაზიარებლად დაუშვით ეკრანის ჩაწერა Ecosia-ისთვის სისტემის პარამეტრებში.</translation>
<translation id="3708834841667355707">Ecosia მუშაობს ახალ ფუნქციებზე, რომელთა მეშვეობითაც საიტებს იგივე ფუნქციონალი შეუნარჩუნდება თქვენი ნაკლები ინფორმაციის გამოყენებით</translation>
<translation id="319566061277127356">შექმენით ახალი Ecosia პროფილი</translation>
<translation id="7433581196371819898">Ecosia ვერ ადასტურებს ამ გაფართოების წარმომავლობას და შესაძლოა, ის სახიფათო იყოს. წაშალეთ ის Ecosia-იდან, რომ მას აღარ შეეძლოს თქვენი მონაცემების (მათ შორის, პერსონალური ინფორმაციის) ნახვა და შეცვლა თქვენ მიერ მონახულებულ საიტებზე.</translation>
<translation id="2198589091447191935">Ecosia უფრო სწრაფად, ხოლო ფუნქციები, რომლებიც JavaScript-ს იყენებს, დანიშნულებისამებრ იმუშავებს (რეკომენდებული)</translation>
<translation id="7105712012505419722">თქვენ სისტემაში შედიხართ მართული ანგარიშზით და მის ადმინისტრატორს აძლევთ თქვენი Ecosia-ის პროფილის კონტროლის შესაძლებლობას. თქვენი Ecosia მონაცემები, როგორიცაა თქვენი პროგრამები, სანიშნეები, ისტორია, პაროლები, და სხვა პარამეტრები გახდება მუდმივად <ph name="USER_NAME"/>-თან მიბმული. თქვენ შეძლებთ ამ მონაცემების წაშლას Ecosia Accounts Dashboard-ის მეშვეობით, მაგრამ თქვენ ვერ შეძლებთ ამ მონაცემების დაკავშირებას სხვა ანგარიშთან. <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">ინსტალაცია…</translation>
<translation id="7691143774653486474">ინსტალაციის პროგრამამ ვერ ამოიღო ფაილები არქივიდან. ხელახლა ჩამოტვირთეთ Ecosia.</translation>
<translation id="2446603005062458629">Ecosia მალე დაიხურება, ხოლო მონაცემები წაიშლება</translation>
<translation id="4173512894976930765">საიტები, სავარაუდოდ, არ იმუშავებს მოლოდინისამებრ. Chrome-ის ყველა ფანჯრის დახურვისას სისტემიდან გამოხვალთ საიტების უმეტესობაზე, გამონაკლისია თქვენი Google ანგარიში, თუ მასში შესული ხართ Chrome-იდან.</translation>
<translation id="2745180350547322293">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ეს საიტი არ იყენებს დაცულ კავშირს, ამიტომ ფაილი, შესაძლოა, მოდიფიცირებული იყოს</translation>
<translation id="6826163993811146231">{0,plural, =1{ხელახლა გაუშვით Ecosia დღის განმავლობაში}other{ხელახლა გაუშვით Ecosia # დღის განმავლობაში}}</translation>
<translation id="4205939740494406371">Chrome ვერ ახერხებს პაროლების შემოწმებას. ცადეთ 24 საათში ან <ph name="BEGIN_LINK"/>შეამოწმეთ პაროლები თქვენს Google ანგარიშში<ph name="END_LINK"/>.</translation>
<translation id="4222932583846282852">მიმდინარეობს გაუქმება…</translation>
<translation id="4224210481850767180">ინსტალაცია გაუქმდა.</translation>
<translation id="3554373328288278512">Ecosia საჭიროებს კამერისა და მიკროფონზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="424864128008805179">გსურთ Chrome-იდან გამოსვლა?</translation>
<translation id="8384922154025337808">მივამაგროთ Ecosia-ის მონაცემები ამ ანგარიშზე?</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>გამოყენებული მონაცემების ტიპები:<ph name="END_BOLD"/> თქვენ მიერ ვების დათვალიერების ისტორია, ამ მოწყობილობაზე თქვენ მიერ Ecosia-ის მეშვეობით მონახულებული საიტების ჩანაწერი.</translation>
<translation id="4281844954008187215">მომსახურების პირობები</translation>
<translation id="4293420128516039005">შედით სისტემაში, რათა მოახდინოთ Chrome-ის სინქრონიზაცია და პერსონალიზება თქვენს ყველა მოწყობილობას შორის</translation>
<translation id="6419542773162312746">გაფართოებისთვის Ecosia-ის ხელსაწყოთა ზოლში წვდომის მოთხოვნების ჩვენების დაშვება</translation>
<translation id="8864449561723972619">Ecosia Dev (mDNS-In)</translation>
<translation id="4329315893554541805">პერსონალიზაციის და სხვა ფუნქციებით რომ ისარგებლოთ, დაურთეთ Chrome როგორც ვებსა და აპებში აქტივობას, ისე მიბმულ Google სერვისებს</translation>
<translation id="4334294535648607276">ჩამოტვირთვა დასრულდა.</translation>
<translation id="4335235004908507846">Chrome დაგიცავთ პერსონალურ მონაცემთა გაჟონვის შემთხვევებისგან, არასათანადო გაფართოებებისა და სხვა უსიამოვნებისგან</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> დაემატა Ecosia-ს</translation>
<translation id="4348548358339558429">პერსონალიზაციით რომ ისარგებლოთ, დაურთეთ Chrome ვებსა და აპებში აქტივობას</translation>
<translation id="197803137365953132">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ფაილს შეუძლია თქვენი პირადი და სოციალური ქსელების ანგარიშების დაზიანება.</translation>
<translation id="4384570495110188418">Chrome ვერ ახერხებს თქვენი პაროლების შემოწმებას, რადგან შესული არ ხართ</translation>
<translation id="4389991535395284064">ვების ინკოგნიტო რეჟიმში დათვალიერებისას Chrome გაგაფრთხილებთ საიტის დაუცველი კავშირის გამოყენებით ჩატვირთვამდე</translation>
<translation id="4427306783828095590">გაძლიერებული დაცვა გთავაზობთ ფიშინგისა და მავნე პროგრამებისგან დაცვის მეტ საშუალებას</translation>
<translation id="4434353761996769206">ინსტალატორის შეცდომა: <ph name="INSTALLER_ERROR"/></translation>
<translation id="2297526912548649074">Ecosia-ში შესვლა, როგორც <ph name="USER_EMAIL"/></translation>
<translation id="9035946286843935549">Ecosia — ქსელში შესვლა — <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">Ecosia-ში სხვა ოპერაცია მიმდინარეობს. გთხოვთ, ცადოთ მოგვიანებით.</translation>
<translation id="4459234553906210702">რეკლამის ეფექტურობის გაზომვის მეშვეობით, თქვენ მიერ მონახულებულ საიტებს საშუალება ექნება, Chrome-ისგან მოითხოვონ გარკვეული ინფორმაცია, რომელიც ამა თუ იმ საიტს თავისი რეკლამის ეფექტურობის განსაზღვრაში დაეხმარება. რეკლამის ეფექტურობის გაზომვისას საიტებს შორის თვალის მიდევნების მექანიზმები შეზღუდულია, რაც ნიშნავს, რომ საიტებს შორის მინიმალური ინფორმაცია გადაიცემა.</translation>
<translation id="4501471624619070934">ინსტალაცია ვერ მოხერხდა, რადგან წვდომა შეზღუდულია ამ ქვეყანაში</translation>
<translation id="4567424176335768812">თქვენ შესული ხართ, როგორც <ph name="USER_EMAIL_ADDRESS"/>. ახლა შეგიძლიათ გახსნათ თქვენი სანიშნეები, ისტორია და სხვა პარამეტრები ყველა მოწყობილობიდან, რომელშიც შესული ხართ.</translation>
<translation id="6533266716128249922">Ecosia-ის შეტყობინების პარამეტრებზე გადასვლა</translation>
<translation id="7562371913339616107">Ecosia-ს შეუძლია, თქვენი ჩანართები უმოქმედო რეჟიმში გადაიტანოს, რათა გააუმჯობესოს თქვენი დათვალიერების გამოცდილება და გაასუფთაოს რესურსები.</translation>
<translation id="488806616089631539">Ecosia-ისთვის წვდომის მინიჭების შემდეგ ცალკეული ვებსაიტები შეძლებს თქვენგან წვდომის მოთხოვნას.</translation>
<translation id="3268039966078382323">Ecosia ვერ განახლდა უახლეს ვერსიაზე, რომელსაც დამატებულ აქვს ახალი ფუნქციები და უსაფრთხოების სისტემის შესწორებები.</translation>
<translation id="4624065194742029982">Chrome-ის ინკოგნიტო რეჟიმი</translation>
<translation id="4690206707618474800">არასავალდებულო: ხელი შეუწყვეთ EcosiaOS Flex-ის ფუნქციებისა თუ ეფექტურობის გაუმჯობესებას დიაგნოსტიკისა და გამოყენების მონაცემების Ecosia-ისთვის ავტომატურად გაგზავნის მეშვეობით.</translation>
<translation id="9125443060066914183">Ecosia-ის უსაფრთხოების გაზრდის მიზნით, ჩვენ გავთიშეთ რამდენიმე გაფართოება, რომელიც არ არის ჩამოთვლილი <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>-ში და, შესაძლოა, დამატებულია თქვენი თანხმობის გარეშე.</translation>
<translation id="4680828127924988555">ინსტალაციის გაუქმება</translation>
<translation id="8236553889322631924">უცნობი წყაროებიდან მომავალ გაფართოებებს, აპებსა და თემებს შეუძლია თქვენი მოწყობილობის დაზიანება. Ecosia გირჩევთ, დააინსტალიროთ ისინი მხოლოდ Ecosia Web Store-იდან.</translation>
<translation id="4710245680469034439">მოირგეთ ბრაუზერი ხელოვანების, ბუნებისა და სხვა კოლექციებით შთაგონებული თემებით</translation>
<translation id="4724676981607797757">ინსტალაცია ვერ მოხერხდა მხარდაუჭერელი პროტოკოლის შეცდომის გამო.</translation>
<translation id="3305517118160815955">ინსტალაცია ვერ გონხორციელდა გაურკვეველი შეცდომის გამო. თუ Ecosia ამჟამად გაშვებულია, დახურეთ იგი და ხელახლა სცადეთ.</translation>
<translation id="4747730611090640388">Chrome-ს შეუძლია თქვენი ინტერესების პროგნოზირება.  მოგვიანებით, თქვენ მიერ მონახულებულ საიტს საშუალება ექნება, Chrome-ს სთხოვოს თქვენი ინტერესების ჩვენება, თქვენთვის ხილული რეკლამის პერსონალიზების მიზნით.</translation>
<translation id="827222962844006655">Ecosia Canary (mDNS-In)</translation>
<translation id="3543284013834505767">ეს ფუნქცია იყენებს მართლწერის იმ შემმოწმებელს, რომელიც გამოიყენება Ecosia Search-ში. ბრაუზერში თქვენ მიერ აკრეფილი ტექსტი ეგზავნება Ecosia-ს. ამ ქცევის შეცვლა ნებისმიერ დროს შეგიძლიათ პარამეტრებიდან.</translation>
<translation id="4793679854893018356">შეიტყვეთ, როგორ ზრუნავს Chrome თქვენს უსაფრთხოებაზე</translation>
<translation id="8957938953005153147">Ecosia ცდილობს არსებული პაროლების ჩანაცვლებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი.</translation>
<translation id="8144706290339578682">EcosiaOS Flex-მა ვერ მოახერხა თქვენი მონაცემების სინქრონიზაცია, რადგან თქვენი დომენისთვის სინქრონიზაცია მიუწვდომელია.</translation>
<translation id="7984841734836997333"><ph name="EXISTING_USER"/> მზად არის შესასვლელად.  ცალკე დათვალიერების გასაგრძელებლად შედით Ecosia-ში თქვენს პირად პროფილში <ph name="USER_EMAIL_ADDRESS"/>.</translation>
<translation id="4264506519284061030">თქვენს ორგანიზაციას შეუძლია თქვენ მიერ ვების დათვალიერების მონაცემების ნახვა და მართვა თქვენს სამსახურის პროფილში (მაგალითად, თქვენი სანიშნეების, ისტორიისა და პაროლების). ის ვერ შეძლებს თქვენი პერსონალური Ecosia პროფილებით ვების დათვალიერების მონაცემების ნახვას.</translation>
<translation id="8701027951719712428">მომავალში Ecosia-ის განახლებების მისაღებად დაგჭირდებათ macOS 11 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს macOS 10.15-ს.</translation>
<translation id="4873783916118289636">გადახედეთ კონფიდენციალურობისა და უსაფრთხოების მართვის საკვანძო საშუალებებს Chrome-ში</translation>
<translation id="8454595950895325762">Ecosia გაიშვას ფონურ რეჟიმში</translation>
<translation id="489671036945006830">ბმულის გახსნა Ecosia-ის ახალ ჩა&amp;ნართში</translation>
<translation id="6566258574866003581">Ecosia გირჩევთ, შეამოწმოთ ეს გაფართოება</translation>
<translation id="4951177103388687412">იყავით ორგანიზებული და ფოკუსირებული ჩანართების ჯგუფების დახმარებით</translation>
<translation id="5581150090232500900">Ecosia-ის დაყენება ნაგულისხმევ ბრაუზერად</translation>
<translation id="6495878830719404098">Ecosia-ში</translation>
<translation id="6113625922434842626">EcosiaOS Flex-მა ვერ მოახერხა თქვენი მონაცემების სინქრონიზაცია, რადგან თქვენი ანგარიშის სისტემაში შესვლის მონაცემები მოძველდა.</translation>
<translation id="4410570812343670816">მოგესალმებათ Ecosia პროფილები</translation>
<translation id="4970880042055371251">ChromeOS ვერსია</translation>
<translation id="8570641140903702642">Ecosia Canary</translation>
<translation id="6735145163744656874">Ecosia-ს შეუძლია, თქვენი ჩანართები უმოქმედო რეჟიმში გადაიტანოს, რათა გააუმჯობესოს თქვენი დათვალიერების გამოცდილება და უზრუნველყოს სისწრაფე.</translation>
<translation id="2569934116750022163">დაწკაპუნებით აირჩიეთ „Ecosia პაროლების მმართველი“</translation>
<translation id="5120334927898581447">შედით Chrome-ში, როცა Google-ის სხვა სერვისებში შედიხართ</translation>
<translation id="5126049312684316860">Chrome წინასწარ ჩატვირთავს უფრო მეტ გვერდს, რომელთა ნახვასაც, სავარაუდოდ, დააპირებთ — ამგვარად, ამ გვერდებზე გადასვლისას, ისინი უფრო სწრაფად ჩაიტვირთება</translation>
<translation id="7782767522222146179">აღმოაჩინეთ დიდებული აპები, თამაშები, გაფართოებები და თემები Ecosia-ისთვის.</translation>
<translation id="6416551953415159186">თქვენი Ecosia პროფილის მორგება</translation>
<translation id="719484593754925816">Ecosia-ს შეუძლია, ეს ჩანართი უმოქმედო რეჟიმში გადაიტანოს, რათა გააუმჯობესოს თქვენი დათვალიერების გამოცდილება და გაასუფთაოს რესურსები.</translation>
<translation id="1859120614572957305">მოგესალმებით Ecosia-ში; გახსნილია ბრაუზერის ახალი ფანჯარა</translation>
<translation id="6648664289472946060">თქვენი პროფილის გამოყენება შეუძლებელია, რადგან იგი მიღებულია Ecosia-ის უფრო ახალი ვერსიიდან.

ზოგიერთი ფუნქცია შეიძლება მიუწვდომელი იყოს. მიუთითეთ პროფილის სხვა დირექტორია ან გამოიყენეთ Ecosia-ის უფრო ახალი ვერსია.</translation>
<translation id="5201744974236816379">Chrome-ის განახლება</translation>
<translation id="6960183526681645011">თუ საზიარო მოწყობილობა გაქვთ, თქვენს მეგობრებსა და ოჯახის წევრებს შეუძლიათ ვების დამოუკიდებლად დათვალიერება და Ecosia-ის საკუთარი შეხედულებისამებრ დაყენება</translation>
<translation id="3784023996375784431">გამოიყენეთ Ecosia შეტყობინებებში, დოკუმენტებსა და სხვა აპებში არსებულ ბმულებზე ყოველი დაწკაპუნებისას.</translation>
<translation id="1869027055332251164">სტუმრებს შეუძლიათ Ecosia-ის გამოყენება და მისი ყველა ფუნქციით სარგებლობა.</translation>
<translation id="5320351714793324716">ქუქი-ჩანაწერების დაშვების შემთხვევაში, Chrome-მა, შესაძლოა, გამოიყენოს ისინი წინასწარ ჩატვირთვისთვის</translation>
<translation id="143614250230771428">EcosiaOS-მა ვერ დაასინქრონა თქვენი მონაცემები, რადგან სინქრონიზაცია თქვენი დომენისთვის არ არის ხელმისაწვდომი.</translation>
<translation id="1809194740315140401">ფაილების ჩამოსატვირთად Ecosia საჭიროებს მეხსიერებაზე წვდომის ნებართვას</translation>
<translation id="8975930032513941502">არასავალდებულო: EcosiaOS-ის ფუნქციებისა და წარმადობის გაუმჯობესების ხელშეწყობა დიაგნოსტიკური და გამოყენების მონაცემების Ecosia-ისთვის ავტომატურად გაგზავნის მეშვეობით.</translation>
<translation id="5357889879764279201">დახმარების მიღება ChromeOS Flex-თან დაკავშირებით</translation>
<translation id="5368118228313795342">დამატებითი კოდი: <ph name="EXTRA_CODE"/>.</translation>
<translation id="6665128960039431910">იგი ასევე აკონტროლებს, თუ რომელი გვერდი გამოჩნდება Ecosia-ის გაშვებისას ან Omnibox-დან ძიების დროს.</translation>
<translation id="1861504561909287316">Ecosia-ის ჩანართის გაზიარება</translation>
<translation id="5412485296464121825">საიტებს Chrome-ის მეშვეობით შეუძლია თქვენს ინტერესებთან დაკავშირებული ინფორმაციის შენახვა. მაგალითად, თუ მარათონისთვის ფეხსაცმლის საყიდლად რომელიმე საიტს მოინახულებთ, აღნიშნულმა საიტმა შეიძლება განსაზღვროს, რომ მარათონებში მონაწილეობა გაინტერესებთ. მოგვიანებით, თუ განსხვავებულ საიტს მოინახულებთ, მაგალითად, რბოლაში მონაწილეობის მისაღებად რეგისტრაციისთვის, ამ საიტმა შეიძლება სპორტული ფეხსაცმლის რეკლამა გაჩვენოთ თქვენი ინტერესების საფუძველზე.</translation>
<translation id="6673288084648462613">თქვენი გამორჩეული ფაილი დაზიანებულია ან არასწორია.

Ecosia ვერ შეძლებს თქვენი პარამეტრების აღდგენას.</translation>
<translation id="5468572406162360320">ამ ფუნქციების გაუმჯობესების მიზნით, თქვენს მათთან ურთიერთქმედებას Chrome გაუგზავნის Google-ს. აღნიშნული მონაცემების წაკითხვა, დამუშავება და ანოტირება, შესაძლოა, განხორციელდეს ადამიანი მიმომხილველების მიერ.</translation>
<translation id="5524761631371622910">როცა ცდები ჩართულია და თუ Chrome შემთხვევითობის პრინციპით მიგაღებინებთ მონაწილეობას მიმდინარე ცდაში, თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chrome წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით.</translation>
<translation id="2905159584855395810">ააჩქარეთ Ecosia-ის მუშაობა</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="5167067155585861308">Ecosia გირჩევთ მის ამოშლას. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი მხარდაჭერილი გაფართოებების შესახებ<ph name="END_LINK"/></translation>
<translation id="7005470355724599337">Ecosia ყველაფერს აკეთებს თქვენს დასაცავად ონლაინ სივრცეში</translation>
<translation id="3625533701824359646">Ecosia-მა დაბლოკა <ph name="FILE_NAME"/>, რადგან ის შეიძლება სახიფათო იყოს.</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{ამ განახლების მისასადაგებლად ადმინისტრატორი გთხოვთ Ecosia-ის ხელახლა გაშვებას}=1{ამ განახლების მისასადაგებლად ადმინისტრატორი გთხოვთ Ecosia-ის ხელახლა გაშვებას. თქვენი ინკოგნიტო ფანჯარა ხელახლა არ გაიხსნება.}other{ამ განახლების მისასადაგებლად ადმინისტრატორი გთხოვთ Ecosia-ის ხელახლა გაშვებას. თქვენი # ინკოგნიტო ფანჯარა ხელახლა არ გაიხსნება.}}</translation>
<translation id="8544776492099331022">მოირგეთ და გააკონტროლეთ Ecosia. საჭიროა თქვენი ყურადღება — დააწკაპუნეთ დეტალური ინფორმაციისთვის.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="569897634095159764">ინტერნეტთან დაკავშირება ვერ ხერხდება. პროქსი-სერვერი საჭიროებს ავტორიზაციას.</translation>
<translation id="570005089986962444">ჩართვის შემთხვევაში, Chrome გამოათავისუფლებს მეხსიერებას არააქტიური ჩანართებიდან. აქტიურ ჩანართებსა და სხვა აპებს კომპიუტერის მეტი რესურსის გამოყენების საშუალება მიეცემა, რაც დააჩქარებს Chrome-საც. თქვენი არააქტიური ჩანართები ავტომატურად გააქტიურდება, როცა მათ დაუბრუნდებით.</translation>
<translation id="5581150090232500900">დააყენეთ Ecosia ნაგულისხმევ ბრაუზერად</translation>
<translation id="5727531838415286053">თუ Chrome შემთხვევითობის პრინციპით მიგაღებინებთ მონაწილეობას მიმდინარე ცდაში, თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chrome წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით. ინტერესები გაახლდება, თუ რომელიმე მათგანს არ წაშლით.</translation>
<translation id="5736850870166430177">საიტის მიერ პაროლის მოპარვის მცდელობის ან თქვენ მიერ საზიანო ფაილის ჩამოტვირთვის შემთხვევაში Chrome-ის მიერ Safe Browsing-ს გაეგზავნება URL-ები და შესაბამისი გვერდის კონტენტის გარკვეული ნაწილი</translation>
<translation id="8301840715671593762">Ecosia პროფილი ამ ანგარიშით უკვე არსებობს ამ მოწყობილობაზე</translation>
