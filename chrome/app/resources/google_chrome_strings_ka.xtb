<translation id="2695952268686253864">Ecosia მოძველებულია</translation>
<translation id="8825634023950448068">თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. თუ Chrome შეცდომით გამოიცნობს თქვენს ინტერესს, ან რომელიმე ტიპის რეკლამის ნახვას არ მოისურვებთ, ინტერესის წაშლის საშუალება გექნებათ.</translation>
<translation id="5066194399237265772">Ecosia ცდილობს პაროლების რედაქტირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="1152277553870553858">Ecosia რეგულარულად ამატებს ახალ ფუნქციებს, რომლებიც დაგეხმარებათ ამოცანების შესრულებაში</translation>
<translation id="4534680278117737254">{NUM_EXTENSIONS,plural, =1{Ecosia გირჩევთ, ამოშალოთ ის}other{Ecosia გირჩევთ, ამოშალოთ ისინი}}</translation>
<translation id="8862326446509486874">თქვენ არ გაქვთ შესაბამისი უფლებები სისტემის დონეზე ინსტალაციისთვის. სცადეთ ინსტალაციის პროგრამის ხელახლა გაშვება ადმინისტრატორის სტატუსით.</translation>
<translation id="8908277254462331033">უსაფრთხოების ფუნქციების ნახვა</translation>
<translation id="8282620071565190081">Ecosia-ის ხელახლა გაშვება</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/>-დან თქვენს Android ტელეფონზე ნომრის გასაგზავნად შედით Ecosia-ში ორივე მოწყობილობაზე.</translation>
<translation id="576192547306902465">ამ გაფართოებას არ გამოუქვეყნებია კონფიდენციალური ინფორმაციის გამოყენების პრაქტიკა, მაგალითად, მონაცემების შეგროვებისა და გამოყენების წესები. Ecosia გირჩევთ მის ამოშლას.</translation>
<translation id="8986207147630327271">თქვენ აპირებთ, ამ ბრაუზერს სამსახურის პროფილი დაამატოთ, რითაც თქვენს ადმინისტრატორს კონტროლს მხოლოდ სამსახურის პროფილზე მიანიჭებთ.</translation>
<translation id="8989968390305463310">თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chrome ავტომატურად წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით. ინტერესები გაახლდება, თუ რომელიმე მათგანს არ წაშლით.</translation>
<translation id="8999117580775242387">როცა HTTPS მიუწვდომელია, Chrome გამოიყენებს დაუცველ კავშირს თქვენი გაფრთხილების გარეშე</translation>
<translation id="7348818664647668234">{0,plural, =0{ხელმისაწვდომია Ecosia-ის განახლება}=1{ხელმისაწვდომია Ecosia-ის განახლება}other{უკვე # დღეა, რაც ხელმისაწვდომია Ecosia-ის განახლება}}</translation>
<translation id="4817309082638621362">რამდენიმე ორგანიზაცია მართავს Ecosia-ს</translation>
<translation id="4638085384909702681">Ecosia-ის დაყენება ნაგულისხმევად</translation>
<translation id="9047384314208087523">EcosiaOS Flex სისტემა</translation>
<translation id="350189837353493413">შეიტყვეთ, რატომ ბლოკავს Ecosia ზოგიერთ ფაილს</translation>
<translation id="911206726377975832">ასევე წაშალოთ თქვენი დათვალიერების მონაცემები?</translation>
<translation id="9138603949443464873">ცვლილებების მისასადაგებლად ხელახლა გაუშვით Chrome</translation>
<translation id="9195993889682885387">Chrome-ს შეუძლია თქვენი ინტერესების პროგნოზირება ბოლო რამდენიმე კვირის განმავლობაში თქვენ მიერ ვების დათვალიერების ისტორიის საფუძველზე. აღნიშნული ინფორმაცია დარჩება თქვენს მოწყობილობაზე.</translation>
<translation id="5704599732514791330">სინქრონიზაციის დასაწყებად, განაახლეთ Ecosia</translation>
<translation id="838842459108103907">Ecosia-ის მორგება</translation>
<translation id="92460355979482493">ჩართვის შემთხვევაში, Chrome წინასწარ ჩატვირთავს გვერდებს, რაც დააჩქარებს ვების დათვალიერებასა და ძიებას.</translation>
<translation id="3070276123152913305">გადატვირთეთ EcosiaOS Flex</translation>
<translation id="4512092435423703529">თქვენს Ecosia კონტენტზე თქვენი ნებისმიერი მოწყობილობიდან წვდომისთვის შედით სისტემაში, შემდეგ კი ჩართეთ სინქრონიზაცია.</translation>
<translation id="7972668220031382654">Ecosia გირჩევთ, დაასკანიროთ ეს ფაილი, რადგან ის შეიძლება სახიფათო იყოს.</translation>
<translation id="963650557422347554">ჩართვის შემთხვევაში, Chrome დაზოგავს ბატარეის მუხტს ვიზუალური ეფექტებისა (მაგალითად, ლივლივა გადაადგილებისა და ვიდეოკადრების სიხშირის) და ფონური აქტივობის შეზღუდვის გზით.</translation>
<translation id="983803489796659991">ინსტალაცია ვერ მოხერხდა, რადგან განახლების სერვერს არ აქვს ამ აპლიკაციის ჰეშ-მონაცემები.</translation>
<translation id="989369509083708165">Google Chrome თქვენი ნაგულისხმევი ბრაუზერია</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> გადართავს Ecosia პროფილებს</translation>
</translationbundle>
