<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="1027331268335328576">მოგესალმებათ Ecosia!</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> მოითხოვს, რომ ამ მოწყობილობის გამოყენებამდე წაიკითხოთ ქვემოთ მოცემული მომსახურების პირობები და დაეთანხმოთ მათ. აღნიშნული პირობები არ არის EcosiaOS-ის წესების დამატება, ასევე, არ ცვლის და არც ზღუდავს მათ.</translation>
<translation id="1263466865695943046">Ecosia გაცნობებთ, თუ თქვენს პაროლებს ვინმე გატეხავს</translation>
<translation id="7158975242722498086">თქვენი სისტემის ადმინისტრატორმა მოახდინა Ecosia-ის კონფიგურაცია იმგვარად, რომ <ph name="TARGET_URL_HOSTNAME"/>-ზე წვდომისთვის საჭიროა <ph name="ALTERNATIVE_BROWSER_NAME"/>-ის გახსნა.</translation>
<translation id="7649070708921625228">დახმარება</translation>
<translation id="93440396576488794">Ecosia Enterprise-ის ლოგო</translation>
<translation id="361644486359722423">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან Safe Browsing გამორთეთ და ფაილის შემოწმება ვერ ხერხდება</translation>
<translation id="7655455401911432608">თქვენ მიერ ვების დათვალიერების ისტორია, ამ მოწყობილობაზე თქვენ მიერ Chrome-ის მეშვეობით მონახულებული საიტების ჩანაწერი.</translation>
<translation id="8196791276481156937">ანგარიშის ამოშლა Ecosia-იდან</translation>
<translation id="7661924425853052955">ბოლო დროს არ ყოფილხართ. Chrome-მა ამოშალა <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> და კიდევ <ph name="COUNT"/></translation>
<translation id="7668816516367091728">შეასრულეთ ამოცანები, მაგალითად, თარგმნა, გამოთვლა და სხვა, უშუალოდ მისამართთა ზოლიდან</translation>
<translation id="3376578942612115781">Ecosia ანგარიში საჭიროებს ხელახლა ავტორიზაციას</translation>
<translation id="769538538642757151">Chrome გაცნობებთ, თუ რაიმეს შემოწმება დაგჭირდებათ</translation>
<translation id="7747138024166251722">ინსტალერმა ვერ შექმნა დროებითი დირექტორია. გთხოვთ, გადაამოწმოთ დისკზე თავისუფალი სივრცე და პროგრამული უზრუნველყოფის დაყენების ნებართვა.</translation>
<translation id="4871843754042758264">დააწკაპუნეთ თქვენს სახელზე Ecosia-ის გასახსნელად და დაიწყეთ დათვალიერება.</translation>
<translation id="7763983146198734674">შეინახეთ პაროლები და იქონიეთ მათზე წვდომა გზიდან</translation>
<translation id="2046160555506209000">თუ სურათს არ ექნება სასარგებლო აღწერილობა, Ecosia შეეცდება მის უზრუნველყოფას. აღწერილობების შესაქმნელად სურათები იგზავნება Ecosia-ში. ამის გამორთვა ნებისმიერ დროს შეგიძლიათ პარამეტრებიდან.</translation>
<translation id="5661123757512626239">Ecosia საჭიროებს მდებარეობაზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="5288148671319098666">Ecosia შექმნილია სწრაფი და უსაფრთხო გამოცდილების უზრუნველსაყოფად ყველა მოწყობილობაზე — ტელეფონსა თუ კომპიუტერზე.</translation>
<translation id="7722016758804384514">როგორც ჩანს, პროფილს იყენებს სხვა Ecosia პროცესი (<ph name="PROCESS_ID"/>) სხვა კომპიუტერზე (<ph name="HOST_NAME"/>). Ecosia-მა ჩაკეტა პროფილი, ასე რომ იგი არ დაზიანდება. თუ დარწმუნებული ხართ, რომ არც ერთი სხვა პროცესი არ იყენებს ამ პროფილს, თქვენ შეგიძლიათ პროფილის გახსნა და Ecosia-ის ხელახლა გაშვება.</translation>
<translation id="1047556320128249268">Ecosia ცდილობს პაროლების კოპირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="4685983030787735093">Ecosia გთავაზობთ უახლეს ტექნოლოგიას დათვალიერების უკეთესი გამოცდილებისთვის</translation>
<translation id="4199684616787081033">Ecosia-იდან ამოღება...</translation>
<translation id="2402290209407843024">ინსტალაცია ვერ განხორციელდა გაურკვეველი შეცდომის გამო. ხელახლა ჩამოტვირთეთ Ecosia.</translation>
<translation id="7836610565365456468">გაახალისეთ თქვენი ბრაუზერი ცოცხალი თემებით ხელოვანების, ბუნებისა და სხვა თემების შთაგონებით</translation>
<translation id="7845233973568007926">გმადლობთ დაინსტალირებისთვის. <ph name="BUNDLE_NAME"/>-ის გამოყენებამდე თქვენი კომპიუტერი უნდა გადატვირთოთ.</translation>
<translation id="937989526647879266">ხელოვნური ინტელექტი Ecosia-ში გეხმარებათ ვების სწრაფად, უსაფრთხოდ და მოხერხებულად დათვალიერებაში</translation>
<translation id="7872446069773932638">მიმდინარეობს ჩამოტვირთვა… დარჩენილია <ph name="SECONDS"/> წამი</translation>
<translation id="2381210243314074423"><ph name="ACCOUNT_FIRST_NAME"/>, მოგესალმებათ Ecosia</translation>
<translation id="6111519389633335269">თუ თქვენ აზიარებთ კომპიუტერს, თქვენი მეგობრები და ოჯახის წევრები შეძლებენ ინტერნეტ-გვერდების დამოუკიდებლად დათვალიერებას და Ecosia-ის დაყენებას საკუთარი სურვილის შესაბამისად.</translation>
<translation id="4727435569202742773">Ecosia-ში უკვე განხორციელდა შესვლა ამ კომპიუტერიდან, როგორც <ph name="ACCOUNT_EMAIL_LAST"/>. გთხოვთ, შექმნათ Ecosia-ის ახალი მომხმარებელი თქვენი ინფორმაციის ცალკე შესანახად.</translation>
<translation id="7917876797003313048">შეგიძლიათ მართოთ თქვენი სისტემაში შესული Google ანგარიშები. თქვენი Google ანგარიშები გამოიყენება Chrome ბრაუზერისთვის, Play Store-ისთვის, Gmail-ისთვის და სხვა პროდუქტებისთვის. თუ სხვისი, მაგალითად, ოჯახის წევრის, ანგარიშის დამატება გსურთ, სანაცვლოდ დაამატეთ ახალი პიროვნება თქვენს <ph name="DEVICE_TYPE"/>-ს. <ph name="LINK_BEGIN"/>შეიტყვეთ მეტი<ph name="LINK_END"/></translation>
<translation id="7112125772061727648">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ეს ფაილი შეცდომაში შემყვანია და მას შეუძლია მოულოდნელი ცვლილებების განხორციელება თქვენს მოწყობილობაზე</translation>
<translation id="7947083960301164556">იხილეთ სიახლეები</translation>
<translation id="4278262067490419012">EcosiaOS Flex უნდა გადაიტვირთოს განახლების გასააქტიურებლად.</translation>
<translation id="3140530394740845618">Ecosia-ის პროფილების მართვა</translation>
<translation id="7962368738413920945">საიტები, სავარაუდოდ, მოლოდინისამებრ იმუშავებს, თუმცა ისინი არ დაგიმახსოვრებთ, როცა Chrome-ის ყველა ფანჯარას დახურავთ</translation>
<translation id="5781596646235827063">ეს კომპიუტერი აღარ მიიღებს Ecosia-ის განახლებებს, რადგან Windows XP და Windows Vista აღარ არის მხარდაჭერილი</translation>
<translation id="7783708361278795460">Ecosia პაროლების მმართველში ამ მოწყობილობაზე</translation>
<translation id="6984747211123632080">ხელახლა დააინსტალირეთ Ecosia</translation>
<translation id="7787479292144635608">Ecosia-ის გამოყენება ანგარიშის გარეშე</translation>
<translation id="2838372953389311551">თუ სურათს არ ექნება სასარგებლო აღწერილობა, Ecosia შეეცდება მის უზრუნველყოფას. აღწერილობების შესაქმნელად სურათები იგზავნება Ecosia-ში.</translation>
<translation id="8863497461138396324">ამ გაფართოების გამოქვეყნება გაუქმდა მისი დეველოპერის მიერ და ის, შესაძლოა, არ იყოს უსაფრთხო. წაშალეთ ის Ecosia-იდან, რომ მას აღარ შეეძლოს თქვენი მონაცემების (მათ შორის, პერსონალური ინფორმაციის) ნახვა და შეცვლა თქვენ მიერ მონახულებულ საიტებზე.</translation>
<translation id="4882579364090762302">გაფართოების გამოსაყენებლად შედით Ecosia-ში</translation>
<translation id="80471789339884597">გმადლობთ დაინსტალირებისთვის. <ph name="BUNDLE_NAME"/>-ის გამოყენებამდე თქვენი ყველა ბრაუზერი უნდა გადატვირთოთ.</translation>
<translation id="8347473600923066837">Ecosia-ის მენიუდან, რომელიც მოცემულია ზედა მარჯვენა ნაწილში, შეგიძლიათ სანიშნეების, წაკითხვის რეჟიმისა და სხვა ერთეულების გახსნა</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="5251710252516682805">სხვა Ecosia პროფილები</translation>
<translation id="8086881907087796310">ინსტალაცია ვერ მოხერხდა, რადგან თქვენი კომპიუტერი არ აკმაყოფილებს მინიმალურ მოთხოვნებს აპარატურის კუთხით.</translation>
<translation id="2200308425865645682">Ecosia საჭიროებს თქვენი ვინაობის დადასტურებას, სანამ მონაცემები Ecosia ანგარიშში შეინახება და მოწყობილობებში გამოიყენება. გამოსვლის შემთხვევაში ეს მონაცემები დარჩება ამ მოწყობილობაში.</translation>
<translation id="7221868538334633215">&amp;Ecosia-ის შესახებ</translation>
<translation id="813913629614996137">მიმდინარეობს ინიცირება…</translation>
<translation id="5612740201368556834">Ecosia-ის გამოყენება ანგარიშის გარეშე</translation>
<translation id="4061472199368124600">Ecosia იყენებს თქვენს კამერასა და მიკროფონს.</translation>
<translation id="8296229475165428335">Ecosia-ის მენიუდან შეგიძლიათ სანიშნეების, წაკითხვის რეჟიმისა და სხვა ერთეულების გახსნა</translation>
<translation id="8267953129876836456">Chrome-მა თქვენთვის იპოვა უსაფრთხოებასთან დაკავშირებული რეკომენდაციები</translation>
<translation id="8270775718612349140">Chrome-ის მიერ მართული სერტიფიკატები</translation>
<translation id="3966234175958887595">Ecosia ცდილობს პაროლების ჩვენებას. აკრიფეთ თქვენი Windows-ის პაროლი, რათა დაუშვათ ეს.</translation>
<translation id="3216284932113164802">Ecosia-ში შეცდომაა. გადავტვირთოთ?</translation>
<translation id="9943971783680417">დაამატეთ Ecosia პაროლების მმართველის მალსახმობი</translation>
<translation id="8336463659890584292">როცა საიტი გთხოვთ, უფლება მისცეთ, კონფიდენციალურად ჩატვირთოს თავის გვერდზე არსებული ბმულები, Chrome გამოიყენებს Google-ის სერვერებს. აღნიშნული დამალავს თქვენს ვინაობას წინასწარ ჩატვირთული საიტისგან, თუმცა Google-ს ეცოდინება, რომელი საიტები იტვირთება წინასწარ.</translation>
<translation id="6491651957026506753">Ecosia-მა დაბლოკა ეს ფაილი, რადგან ის სახიფათოა.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>ამ მონაცემთა გამოყენების წესი:<ph name="END_BOLD"/> საიტებს Ecosia-ის მეშვეობით შეუძლია თქვენს ინტერესებთან დაკავშირებული ინფორმაციის შენახვა. მაგალითად, თუ მარათონისთვის ფეხსაცმლის საყიდლად რომელიმე საიტს მოინახულებთ, აღნიშნულმა საიტმა შეიძლება განსაზღვროს, რომ მარათონებში მონაწილეობა გაინტერესებთ. მოგვიანებით, თუ განსხვავებულ საიტს მოინახულებთ, მაგალითად, რბოლაში მონაწილეობის მისაღებად რეგისტრაციისთვის, ამ საიტმა შეიძლება სპორტული ფეხსაცმლის რეკლამა გაჩვენოთ თქვენი ინტერესების საფუძველზე.</translation>
<translation id="8355171755788522183">© <ph name="YEAR"/>, Ecosia. ყველა უფლება დაცულია.</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>ამ მონაცემთა გამოყენების წესი:<ph name="END_BOLD"/> Ecosia-ს შეუძლია თქვენი ინტერესების პროგნოზირება. მოგვიანებით, თქვენ მიერ მონახულებულ საიტს საშუალება ექნება, Ecosia-ს სთხოვოს თქვენი ინტერესების ჩვენება, თქვენთვის ხილული რეკლამის პერსონალიზების მიზნით.</translation>
