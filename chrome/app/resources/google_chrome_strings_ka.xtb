<!DOCTYPE translationbundle>
<translationbundle lang="ka">
<translation id="4033006861724039519">ინსტალატორის არქივი დაზიანებული ან არასწორია. გთხოვთ, ხელახლა ჩამოტვირთოთ Ecosia.</translation>
<translation id="1026101648481255140">ინსტალაციის გაგრძელება</translation>
<translation id="8296565077892323223">მოირგეთ და გააკონტროლეთ Ecosia. ხელმისაწვდომია განახლება.</translation>
<translation id="2804130178228362015">თქვენს კომპიუტერზე აღმოჩენილია საზიანო პროგრამული უზრუნველყოფა. Ecosia-ს შეუძლია მისი ამოშლა, თქვენი პარამეტრების აღდგენა და გაფართოებების გათიშვა, რომ ბრაუზერმა კვლავ ნორმალურად იმუშაოს.</translation>
<translation id="1065672644894730302">თქვენი პარამეტრების წაკითხვა შეუძლებელია.

ზოგიერთი ფუნქცია შეიძლება მიუწვდომელი იყოს და პარამეტრების ცვლილებები არ იქნება შენახული.</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> დრე იყენებდა Ecosia-ს</translation>
<translation id="2000339487270823788">ეს არის თქვენი Ecosia</translation>
<translation id="8078678931242443254">ვინ იყენებს Ecosia-ს?</translation>
<translation id="6346154190168496057">Ecosia-ის განახლება ვერ მოხერხდა</translation>
<translation id="1152920704813762236">ChromeOS-ის შესახებ</translation>
<translation id="7303930050538184306">Ecosia-ში &amp;გახსნა</translation>
<translation id="1203500561924088507">გმადლობთ დაინსტალირებისთვის. <ph name="BUNDLE_NAME"/>-ის გამოყენებამდე თქვენი ბრაუზერი უნდა გადატვირთოთ.</translation>
<translation id="6650631555168164414">თქვენ საშუალება გაქვთ, Ecosia-ის შესაძლებლობები მაქსიმალურად გამოიყენოთ</translation>
<translation id="1523806373970723624">ხელახლა გაშვება &amp;Ecosia-ის გასაახლებლად</translation>
<translation id="5279514147510747661">დაელოდეთ, სანამ Ecosia დააინსტალირებს სისტემის უახლეს განახლებებს.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> მოითხოვს, რომ ამ მოწყობილობის გამოყენებამდე წაიკითხოთ ქვემოთ მოცემული მომსახურების პირობები და დაეთანხმოთ მათ. აღნიშნული პირობები არ არის EcosiaOS Flex-ის წესების დამატება, ასევე, არ ცვლის და არც ზღუდავს მათ.</translation>
<translation id="8067423333018528301">Ecosia S-მა ვერ დაასინქრონა თქვენი მონაცემები შესვლის შეცდომის გამო.</translation>
<translation id="2926455547526018397">Ecosia Beta</translation>
<translation id="2995860351618948435">ამ კომპიუტერს უკვე აქვს Ecosia Chrom-ის უფრო ახალი ვერსია. იმ შემთხვევაში, თუ პროგრამა არ მუშაობს, გთხოვთ, განახორციელეთ Ecosia-ის დეინსტალაცია და სცადეთ ისევ.</translation>
<translation id="824192326282906244">აზრის შეცვლას ნებისმიერ დროს შეძლებთ Ecosia-ის პარამეტრებიდან. ცდები განხორციელდება რეკლამის ჩვენების ამჟამინდელი მექანიზმების მოქმედების პარალელურად, ამიტომ ცვლილებებს მომენტალურად არ შეამჩნევთ.</translation>
<translation id="4696685525015809740">Ecosia Canary პროგრამები</translation>
<translation id="3697186779259384993">მოირგეთ თქვენი ახალი Ecosia პროფილი</translation>
<translation id="4062366803229254216">დაწყვილების გასაგრძელებლად Ecosia საჭიროებს Bluetooth-ზე წვდომას. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="2441303983090031276">EcosiaOS მუშაობს <ph name="BEGIN_LINK_CROS_OSS"/>ღია კოდის პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS"/> დამსახურებით.</translation>
<translation id="5598074261782651109">Ecosia-ის განახლება</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> უკვე შესულია ამ Ecosia პროფილში. ეს მოქმედება შექმნის ახალ Ecosia პროფილს <ph name="USER_EMAIL_ADDRESS"/>-ისთვის</translation>
<translation id="4943938785458240142">Ecosia იყენებს თქვენს კამერას.</translation>
<translation id="1936361330890313940">Ecosia-მა დაბლოკა <ph name="FILE_NAME"/>, რადგან ის სახიფათოა.</translation>
<translation id="1597911401261118146"><ph name="BEGIN_LINK"/>შედით Chrome-ში<ph name="END_LINK"/>, რომ შეამოწმოთ, შეეხო თუ არა პერსონალურ მონაცემთა გაჟონვის შემთხვევები და უსაფრთხოებასთან დაკავშირებული პრობლემები თქვენს პაროლებს.</translation>
<translation id="5591151834004774364">Ecosia-მა დაბლოკა არქივის ეს ფაილი, ვინაიდან მასში, შესაძლოა, იმალებოდეს მავნე პროგრამა</translation>
<translation id="1597547208646178091">Ecosia-ის უსაფრთხოების გასაძლიერებლად, ჩვენ გავთიშეთ შემდეგი გაფართოება, რომელიც არ არის ხელმისაწვდომი <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>-ში და, შესაძლოა, თქვენი თანხმობის გარეშე დაემატა.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>თქვენი მონაცემების მართვის ხერხები:<ph name="END_BOLD"/> თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. სურვილისამებრ, შეგიძლიათ წაშალოთ ინტერესები, რომლებიც არ გსურთ, Ecosia-მა რომ გაითვალისწინოს.</translation>
<translation id="1628000112320670027">Chrome-თან დაკავშირებული დახმარების მიღება</translation>
<translation id="1640672724030957280">მიმდინარეობს ჩამოტვირთვა…</translation>
<translation id="1662146548738125461">ChromeOS Flex-ის შესახებ</translation>
<translation id="5500958820122281144">ბმულის გახსნა Ecosia-ის ინკო&amp;გნიტო ფანჯარაში</translation>
<translation id="7602423871874451395">Ecosia ვერ ახერხებს თავის მონაცემთა დირექტორიაში წაკითხვას და ჩაწერის განხორციელებას:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{თქვენი ადმინისტრატორის მიერ განსაზღვრული კონფიგურაციის მიხედვით, Ecosia უნდა დაიხუროს, თუ ის უმოქმედოა 1 წუთზე მეტი ხნის განმავლობაში.}other{თქვენი ადმინისტრატორის მიერ განსაზღვრული კონფიგურაციის მიხედვით, Ecosia უნდა დაიხუროს, თუ ის უმოქმედოა # წუთზე მეტი ხნის განმავლობაში.}}</translation>
<translation id="3939060118711873999">Ecosia არის ვებ-ბრაუზერი, რომელიც ძალიან სწრაფად ხსნის ვებ-გვერდებს და პროგრამებს. იგი სწრაფი, სტაბილური და ადვილად გამოსაყენებელია. უფრო უსაფრთხოდ დაათვალიერეთ ინტერნეტ-გვერდები, Ecosia-ში ჩაშენებული საზიანო პროგრამების და თაღლითობის საწინააღმდეგო დაცვის დახმარებით.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia ხელახლა გაეშვება 1 საათში}other{Ecosia ხელახლა გაეშვება # საათში}}</translation>
<translation id="4021894801595982809">Ecosia შეინახავს ამ პაროლს თქვენს Ecosia ანგარიშში. მისი დამახსოვრება აუცილებელი არ არის.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">დარწმუნდით, რომ თქვენს <ph name="TARGET_DEVICE_NAME"/>-ზე შესული ხართ Ecosia-ში, შემდეგ კი ხელახლა ცადეთ გაგზავნა.</translation>
<translation id="1812689907177901597">ამ პარამეტრის გამორთვის შემთხვევაში, Google-ის საიტებში (მაგალითად, Gmail-ში) შესვლას შეძლებთ Chrome-ში შესვლის გარეშე</translation>
<translation id="5055330219314726197">Ecosia საჭიროებს თქვენს კამერაზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="1508200558303644420">Ecosia არ არის თქვენი ნაგულისხმევი ბრაუზერი</translation>
<translation id="8135642897811755229">Ecosia Beta (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia მოძველებულია</translation>
<translation id="1919130412786645364">Chrome-ში შესვლის დაშვება</translation>
<translation id="6235917057647038042">Ecosia-ის მომავალი განახლებების მისაღებად დაგჭირდებათ macOS 10.13 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს macOS 10.12-ს.</translation>
<translation id="1953553007165777902">მიმდინარეობს ჩამოტვირთვა… დარჩენილია <ph name="MINUTE"/> წუთი</translation>
<translation id="8608092457636055141">თითოეულ პროფილში ინახება საკუთარი Ecosia ინფორმაცია, როგორიცაა სანიშნეები, ისტორია, პაროლები და სხვა</translation>
<translation id="2018879682492276940">ინსტალაცია ვერ მოხერხდა. ცადეთ ხელახლა.</translation>
<translation id="7375011918167125899">სხვა ანგარიში უკვე შესულია. თქვენი დათვალიერების მონაცემები რომ განაცალკეოთ, Ecosia-ს შეუძლია თქვენთვის პერსონალური პროფილის შექმნა.</translation>
<translation id="207902854391093810">როცა ცდები ჩართულია, რეკლამის ეფექტურობის გაზომვის მეშვეობით, თქვენ მიერ მონახულებულ საიტებს საშუალება ექნება, Chrome-ისგან მოითხოვონ გარკვეული ინფორმაცია, რომელიც ამა თუ იმ საიტს თავისი რეკლამის ეფექტურობის განსაზღვრაში დაეხმარება. რეკლამის ეფექტურობის გაზომვისას საიტებს შორის თვალის მიდევნების მექანიზმები შეზღუდულია, რაც ნიშნავს, რომ საიტებს შორის მინიმალური ინფორმაცია გადაიცემა.</translation>
<translation id="8655983536493871574">Ecosia-ის მომავალი განახლებების მისაღებად დაგჭირდებათ Windows 10 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს Windows 8-ს.</translation>
<translation id="3590393640971125498">EcosiaOS Flex-ის პირობები</translation>
<translation id="864244542982029641">მაინც გსურთ Ecosia-იდან გასვლა?</translation>
<translation id="3791194915692553395">EcosiaOS Flex და <ph name="BEGIN_LINK_LINUX_OSS"/>Linux-ის შემუშავების გარემო<ph name="END_LINK_LINUX_OSS"/> მუშაობს <ph name="BEGIN_LINK_CROS_OSS"/>ღია კოდის დამატებითი პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS"/> დამსახურებით.</translation>
<translation id="2120620239521071941">ეს მოქმედება წაშლის <ph name="ITEMS_COUNT"/> ერთეულს ამ მოწყობილობიდან. თქვენი მონაცემების მოგვიანებით მისაღებად, შედით Chrome-ში, როგორც <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">ხელახლა გაშვება &amp;Ecosia-ის გასაახლებლად</translation>
<translation id="2123055963409958220">ხელი შეუწყვეთ Chrome-ის გაუმჯობესებას <ph name="BEGIN_LINK"/>მიმდინარე პარამეტრების<ph name="END_LINK"/> გამოგზავნის მეშვეობით</translation>
<translation id="2131230230468101642">თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. სურვილისამებრ, შეგიძლიათ წაშალოთ ინტერესები, რომლებიც არ გსურთ, Chrome-მა რომ გაითვალისწინოს.</translation>
<translation id="5404489723475681578">გადატვირთეთ EcosiaOS</translation>
<translation id="5982672133249369264">გთხოვთ, ახლავე გადატვირთოთ Ecosia</translation>
<translation id="2174917724755363426">ინსტალაცია არ დასრულებულა. ნამდვილად გსურთ გაუქმება?</translation>
<translation id="223889379102603431">ინფორმაცია Chrome-ის მიერ თავისი ძირეული სერტიფიკატების მართვის შესახებ</translation>
<translation id="4337034173783952373">Ecosia ბრაუზერში თქვენს კონტენტზე თქვენი ნებისმიერი მოწყობილობიდან წვდომისთვის შედით სისტემაში, შემდეგ კი ჩართეთ სინქრონიზაცია</translation>
<translation id="4735588186234302898">Ecosia API გასაღები გამოტოვებულია. Ecosia-ის ზოგიერთი ფუნქცია გამორთული იქნება.</translation>
<translation id="7908111389403807005">ნამდვილად გსურთ მოახდინოთ Ecosia-ის დეინსტალაცია?</translation>
<translation id="2309047409763057870">ეს Google Chrome-ის მეორადი ინსტალაცია არის და ნაგულისხმევ ბრაუზერად ის ვერ დაყენდება.</translation>
<translation id="7613817989637275906">Ecosia-მა აღმოაჩინა, რომ შემდეგი გაფართოებები შეიცავს მავნე პროგრამას:</translation>
<translation id="7273750863406285983">Ecosia საჭიროებს თქვენს კამერასა და მიკროფონზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="234869673307233423">Chrome ვერ ახერხებს პაროლების შემოწმებას. ცადეთ მოგვიანებით.</translation>
<translation id="5707346538075088068">ამ პროფილის გამოყენებისას შექმნილი Ecosia მონაცემების (მაგ., შექმნილი სანიშნეების, ისტორიის, პაროლებისა და სხვა პარამეტრების) ამოშლა შეუძლია სამსახურის პროფილის ადმინისტრატორს. <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">გაგრძელება</translation>
<translation id="3959732324458144441">EcosiaOS სისტემა</translation>
<translation id="3632544319066562282">Ecosia ითხოვს თქვენი პაროლების ექსპორტირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი.</translation>
<translation id="2485422356828889247">დეინსტალაცია</translation>
<translation id="2534507159460261402">Google Pay (Chrome-ში კოპირებული)</translation>
<translation id="2559253115192232574">მოგვიანებით, თქვენ მიერ მონახულებულ საიტს საშუალება ექნება, Chrome-ს სთხოვოს თქვენი ინტერესების ჩვენება, თქვენთვის ხილული რეკლამის პერსონალიზების მიზნით. Chrome-ს შეუძლია 3-მდე ინტერესის გაზიარება.</translation>
<translation id="2563121210305478421">გსურთ Chrome-ის ხელახლა გაშვება?</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> უკვე შესულია ამ Ecosia პროფილში. თქვენი დათვალიერების მონაცემები რომ განაცალკევოთ, Ecosia-ს შეუძლია თქვენთვის პერსონალური პროფილის შექმნა.</translation>
<translation id="80155189677487610">შეუძლებელია იმავე Ecosia-ის ვერსიის დაყენება, რომელიც ამჟამად გაშვებულია. დახურეთ Ecosia და ხელახლა სცადეთ.</translation>
<translation id="2586406160782125153">ეს მოქმედება წაშლის თქვენს დათვალიერების მონაცემებს ამ მოწყობილობიდან. თქვენი მონაცემების მოგვიანებით მისაღებად, შედით Chrome-ში, როგორც <ph name="USER_EMAIL"/>.</translation>
<translation id="6391863622742187823">მიიღეთ Ecosia ბრაუზერში შენახული თქვენი კონტენტი <ph name="ACCOUNT_EMAIL"/>-დან</translation>
<translation id="2622559029861875898">Chrome ვერ ახერხებს განახლებების შემოწმებას. შეამოწმეთ კავშირი ინტერნეტთან.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="7774247008790177839">ბმულის გახსნა Ecosia-ის ახალ ჩა&amp;ნართში</translation>
<translation id="9178613517891824246">დაგვეხმარეთ Ecosia-ის გაუმჯობესებაში: გამოგზავნეთ მოხსენებები შეცდომების შესახებ <ph name="UMA_LINK"/> Ecosia-ში</translation>
<translation id="815199437159352723">ამ გაფართოებამ თქვენ მიერ Ecosia-ის გაშვებისას ნაჩვენები გვერდი შეცვალა.</translation>
<translation id="1676748966275099244">გაფრთხილება: Ecosia ვერ შეუშლის ხელს გაფართოებებს ვების დათვალიერების ისტორიის შენახვაში. ამ გაფართოების ინკოგნიტო რეჟიმში გამოსართავად მოხსენით მონიშვნა ამ ვარიანტზე.</translation>
<translation id="1831192335802727557">Ecosia საჭიროებს თქვენს მიკროფონზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="2770231113462710648">შეცვალეთ ნაგულისხმევი ბრაუზერი-ით:</translation>
