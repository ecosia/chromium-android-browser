<!DOCTYPE translationbundle>
<translationbundle lang="sl">
<translation id="4033006861724039519">Arhiv namestitvenega programa je poškodovan ali neveljaven. Ponovno prenesite program Ecosia.</translation>
<translation id="1026101648481255140">Nadaljuj namestitev</translation>
<translation id="8296565077892323223">Prilagodite in nadzirajte Ecosia. Posodobitev je na voljo.</translation>
<translation id="1761584959558744002">Če želite izbrisati podatke brskanja samo iz te naprave, v računu Ecosia pa jih želite ohraniti, <ph name="BEGIN_LINK"/>se odjavite iz Chroma<ph name="END_LINK"/>.</translation>
<translation id="3271929752667225813">Kliknite, če želite zapreti pogovorno okno za prijavo v Ecosia</translation>
<translation id="2056307067005384438">Če želite to razširitev uporabljati kot <ph name="USER_EMAIL_ADDRESS"/>, se prijavite v Ecosia.</translation>
<translation id="1065672644894730302">Nastavitev ni mogoče prebrati.

Nekatere funkcije morda niso na voljo in spremembe nastavitev ne bodo shranjene.</translation>
<translation id="8055222671516987714">Uporabnik <ph name="USER_EMAIL_ADDRESS"/> je prej uporabljal Ecosia</translation>
<translation id="2000339487270823788">To je vaš Ecosia</translation>
<translation id="8078678931242443254">Kdo uporablja Ecosia?</translation>
<translation id="6346154190168496057">Chroma ni mogoče posodobiti</translation>
<translation id="5312730628132049495">Prijavite se v Ecosia. Če se želite v račun prijaviti samo enkrat, lahko <ph name="GUEST_LINK_BEGIN"/>napravo uporabljate kot gost<ph name="GUEST_LINK_END"/>.</translation>
<translation id="1152920704813762236">O sistemu ChromeOS</translation>
<translation id="7303930050538184306">&amp;Odpri v Chromu</translation>
<translation id="1184145431117212167">Namestitev ni uspela, ker vaša različica sistema Windows ni podprta.</translation>
<translation id="4988569127367972482">Ecosia je blokiral ta prenos, ker se vrsta datoteke ne prenaša pogosto in je morda nevarna</translation>
<translation id="1203500561924088507">Hvala, ker ste se odločili za namestitev. Preden uporabite <ph name="BUNDLE_NAME"/>, morate znova zagnati brskalnik.</translation>
<translation id="4517165228415697265">Ecosia priporoča, da nastavite Ecosia kot privzeto možnost</translation>
<translation id="1265739287306757398">Več o tem</translation>
<translation id="1523806373970723624">Znova zaženite, če želite posodobiti &amp;Ecosia</translation>
<translation id="1290883685122687410">Napaka pri nastavitvi: <ph name="METAINSTALLER_EXIT_CODE"/>. <ph name="WINDOWS_ERROR"/></translation>
<translation id="5279514147510747661">Počakajte, da Ecosia namesti najnovejše sistemske posodobitve.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> zahteva, da preberete in sprejmete pogoje storitve, preden začnete uporabljati napravo. Ti pogoji ne dopolnjujejo, spreminjajo ali omejujejo pogojev za EcosiaOS Flex.</translation>
<translation id="3592624492063123732">Če si želite ogledati gesla v drugem profilu za Ecosia, lahko preklopite</translation>
<translation id="8067423333018528301">Ecosia OS ni mogel sinhronizirati podatkov zaradi napake pri prijavi.</translation>
<translation id="2926455547526018397">Ecosia Beta</translation>
<translation id="2995860351618948435">V tem računalniku je že nameščena novejša različica Ecosia Chroma. Če programska oprema ne deluje, odstranite Ecosia in poskusite znova.</translation>
<translation id="824192326282906244">Kadar koli si lahko premislite v nastavitvah za Ecosia. Preizkusi potekajo skupaj s trenutnim načinom prikazovanja oglasov, zato spremembe ne bodo takoj vidne.</translation>
<translation id="3621704124701415791">Ecosia ima vgrajen Ecosia Prevajalnik, tako da lahko prevajate, ko to potrebujete</translation>
<translation id="5043324171996581320">{COUNT,plural, =0{Ecosia je posodobljen. Najnovejšo različico lahko uporabite takoj po vnovičnem zagonu. Nato se bodo trenutni zavihki znova odprli.}=1{Ecosia je posodobljen. Najnovejšo različico lahko uporabite takoj po vnovičnem zagonu. Nato se bodo trenutni zavihki znova odprli. Anonimno okno se ne bo znova odprlo.}one{Ecosia je posodobljen. Najnovejšo različico lahko uporabite takoj po vnovičnem zagonu. Nato se bodo trenutni zavihki znova odprli. # anonimno okno se ne bo znova odprlo.}two{Ecosia je posodobljen. Najnovejšo različico lahko uporabite takoj po vnovičnem zagonu. Nato se bodo trenutni zavihki znova odprli. # anonimni okni se ne bosta znova odprli.}few{Ecosia je posodobljen. Najnovejšo različico lahko uporabite takoj po vnovičnem zagonu. Nato se bodo trenutni zavihki znova odprli. # anonimna okna se ne bodo znova odprla.}other{Ecosia je posodobljen. Najnovejšo različico lahko uporabite takoj po vnovičnem zagonu. Nato se bodo trenutni zavihki znova odprli. # anonimnih oken se ne bo znova odprlo.}}</translation>
<translation id="4696685525015809740">Delovne različice aplikacij za Ecosia</translation>
<translation id="7045045549868370797">Se želite prijaviti v Ecosia?</translation>
<translation id="1691902349688685912">Znova zaženite, če želite dokončati posodobitev Chroma</translation>
<translation id="1497802159252041924">Napaka pri namestitvi: <ph name="INSTALL_ERROR"/></translation>
<translation id="3697186779259384993">Prilagajanje novega profila v Chromu</translation>
<translation id="2441303983090031276">Ecosia OS omogoča dodatna <ph name="BEGIN_LINK_CROS_OSS"/>odprtokodna programska oprema<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="5598074261782651109">Posodobi Ecosia</translation>
<translation id="847970842635669371">Uporabnik <ph name="EXISTING_USER"/> je že prijavljen v ta profil v Chromu. S tem bo ustvarjen novi profil v Chromu za uporabnika <ph name="USER_EMAIL_ADDRESS"/>.</translation>
<translation id="4943938785458240142">Ecosia uporablja vašo kamero.</translation>
<translation id="1936361330890313940">Datoteka <ph name="FILE_NAME"/> je nevarna, zato jo je Ecosia blokiral.</translation>
<translation id="1597911401261118146">Če želite preveriti, ali so gesla varna pred podatkovnimi kršitvami in drugimi varnostnimi težavami, <ph name="BEGIN_LINK"/>se prijavite v Chrome<ph name="END_LINK"/>.</translation>
<translation id="1597547208646178091">Zaradi večje varnosti smo v Chromu onemogočili to razširitev, ki ni navedena tukaj in je bila morda dodana brez vaše vednosti: <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Kako lahko upravljate podatke:<ph name="END_BOLD"/> Zaradi zaščite vaše varnosti samodejno izbrišemo vaša zanimanja, starejša od 4 tednov. Ko brskate naprej, se zanimanje morda znova prikaže na seznamu. Odstranite lahko tudi zanimanja, za katera ne želite, da jih Ecosia predlaga.</translation>
<translation id="1628000112320670027">Pomoč za Chrome</translation>
<translation id="1640672724030957280">Prenos ...</translation>
<translation id="1662146548738125461">O sistemu ChromeOS Flex</translation>
<translation id="5500958820122281144">Odpiranje povezave v Chromovem oknu brez belež&amp;enja zgodovine</translation>
<translation id="7602423871874451395">Ecosia ne more brati svojega imenika s podatki ali pisati vanj:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="2020747823154282691">Ecosia lahko zaradi izboljšanja izkušnje brskanja in hitrejšega delovanja ta zavihek spremeni v neaktivnega.</translation>
<translation id="3939060118711873999">Ecosia je spletni brskalnik, ki bliskovito odpira spletna mesta in izvaja programe. Je hiter, stabilen in preprost za uporabo. V Ecosia je vgrajena zaščita pred zlonamerno programsko opremo in lažnim predstavljanjem, kar omogoča varnejše brskanje v spletu.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia se bo znova zagnal čez eno uro}one{Ecosia se bo znova zagnal čez # uro}two{Ecosia se bo znova zagnal čez # uri}few{Ecosia se bo znova zagnal čez # ure}other{Ecosia se bo znova zagnal čez # ur}}</translation>
<translation id="1722488837206509557">Tako boste lahko izbirali med razpoložljivimi napravami in v njih prikazali vsebino.</translation>
<translation id="4021894801595982809">Ecosia bo shranil to geslo v Ecosia Računu. Ni si vam ga treba zapomniti.</translation>
<translation id="2346323077583431428">Preverite, ali ste v napravi <ph name="TARGET_DEVICE_NAME"/> prijavljeni v Ecosia, nato poskusite znova poslati.</translation>
<translation id="788366290112401490">Bližnjice, odprte v Chromu</translation>
<translation id="6180968682827452331">Ta razširitev ni več podprta. Ecosia priporoča, da jo odstranite.</translation>
<translation id="1812689907177901597">Če to izklopite, se lahko prijavite na Googlovih spletnih mestih, kot je Gmail, ne da bi se morali prijaviti v Chrome</translation>
<translation id="5055330219314726197">Ecosia potrebuje dovoljenje za dostop do fotoaparata za to spletno mesto</translation>
<translation id="1508200558303644420">Ecosia ni privzeti brskalnik</translation>
<translation id="8135642897811755229">Ecosia Beta (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia je zastarel</translation>
<translation id="8228132389897276908">Če želite deliti okno, v sistemskih nastavitvah omogočite snemanje zaslona za Ecosia</translation>
<translation id="1919130412786645364">Omogočanje prijave v Chrome</translation>
<translation id="1953553007165777902">Prenašanje … Še <ph name="MINUTE"/> min.</translation>
<translation id="8116259102110666562">Ecosia deluje v več okoljih in vam tako zagotavlja znano izkušnjo ne glede na napravo</translation>
<translation id="2001586581944147178">Ljudem z dostopom do vašega internetnega prometa otežite ogled spletnih mest, ki jih obiskujete. Chrome uporablja varno povezavo za iskanje naslova IP spletnega mesta v DNS-ju (imenskem sistemu domen).</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{Ta razširitev ni več podprta. Ecosia priporoča, da jo odstranite.}one{Te razširitve niso več podprte. Ecosia priporoča, da jih odstranite.}two{Te razširitve niso več podprte. Ecosia priporoča, da jih odstranite.}few{Te razširitve niso več podprte. Ecosia priporoča, da jih odstranite.}other{Te razširitve niso več podprte. Ecosia priporoča, da jih odstranite.}}</translation>
<translation id="8608092457636055141">Vsak profil ima svoje podatke v Chromu, kot so zaznamki, zgodovina, gesla in drugo.</translation>
<translation id="2018879682492276940">Namestitev ni uspela. Poskusite znova.</translation>
<translation id="686474599126256998">Medtem ko nastavljamo dostop do računa, lahko še vedno uporabljate Ecosia. Dokler nastavitev ne bo dokončana, morda ne boste mogli dostopati do nekaterih virov.</translation>
<translation id="2034233344106846793">Povezave, ki niso varne, Chrome samodejno nadgradi na HTTPS, ko je to mogoče</translation>
<translation id="207902854391093810">Če so preizkusi vklopljeni, merjenje oglasov spletnim mestom omogoča, da od Chroma zahtevajo podatke, ki jim pomagajo pri merjenju učinkovitosti oglasov. Merjenje oglasov omejuje sledenje na več spletnih mestih s prenašanjem čim manj podatkov med spletnimi mesti.</translation>
<translation id="8655983536493871574">Če želite prejemati prihodnje posodobitve Ecosia Chroma, potrebujete Windows 10 ali novejšega. V tem računalniku je nameščen Windows 8.</translation>
<translation id="3590393640971125498">Pogoji za EcosiaOS Flex</translation>
<translation id="864244542982029641">Želite vseeno zapreti Ecosia?</translation>
<translation id="3791194915692553395">EcosiaOS Flex omogoča dodatna <ph name="BEGIN_LINK_CROS_OSS"/>odprtokodna programska oprema<ph name="END_LINK_CROS_OSS"/>, enako kot <ph name="BEGIN_LINK_LINUX_OSS"/>razvojno okolje Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="2120620239521071941">S tem bo iz te naprave izbrisanih več elementov (<ph name="ITEMS_COUNT"/>). Če želite pozneje prenesti podatke, se v Chrome prijavite kot <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">Znova zaženite, če želite posodobiti &amp;Ecosia</translation>
<translation id="2123055963409958220">Pomagajte izboljšati Google Chrome s <ph name="BEGIN_LINK"/>poročanjem trenutnih nastavitev<ph name="END_LINK"/></translation>
<translation id="2126108037660393668">Napaka pri preverjanju prenesene datoteke.</translation>
<translation id="2985399486579137606">Upravljanje profilov v Chromu</translation>
<translation id="2131230230468101642">Zaradi zaščite vaše varnosti samodejno izbrišemo vaša zanimanja, starejša od 4 tednov. Ko brskate naprej, se zanimanje morda znova prikaže na seznamu. Odstranite lahko tudi zanimanja, za katera ne želite, da jih Chrome predlaga.</translation>
<translation id="5404489723475681578">Vnovičen zagon sistema Ecosia OS</translation>
<translation id="5982672133249369264">Znova zaženite Ecosia</translation>
<translation id="2174917724755363426">Namestitev še ni končana. Ali ste prepričani, da jo želite preklicati?</translation>
<translation id="2190166659037789668">Napaka pri preverjanju posodobitev: <ph name="UPDATE_CHECK_ERROR"/>.</translation>
<translation id="2199691482078155239">Chrome omogoča večji nadzor nad prikazanimi oglasi in omejuje, kaj lahko spletna mesta izvedo o vas, ko vam prikazujejo osebno prilagojene oglase</translation>
<translation id="7347725536241560534">Če želite račun Ecosia odstraniti iz Chroma, se odjavite</translation>
<translation id="223889379102603431">Informacije o tem, kako Chrome upravlja korenska potrdila.</translation>
<translation id="4337034173783952373">Če želite do stvari v brskalniku Ecosia dostopati v vseh svojih napravah, se prijavite in nato vklopite sinhronizacijo.</translation>
<translation id="4735588186234302898">Manjkajo ključi za Ecosia API. Nekatere funkcije Ecosia Chroma bodo onemogočene.</translation>
<translation id="7908111389403807005">Ali ste prepričani, da želite odstraniti Ecosia?</translation>
<translation id="2309047409763057870">To je sekundarna namestitev Google Chroma in ga ni mogoče nastaviti kot privzeti brskalnik.</translation>
<translation id="7613817989637275906">Ecosia je ugotovil, da te razširitve vsebujejo zlonamerno programsko opremo:</translation>
<translation id="7273750863406285983">Ecosia potrebuje dovoljenje za dostop do fotoaparata in mikrofona za to spletno mesto</translation>
<translation id="234869673307233423">Chrome ne more preveriti vaših gesel. Poskusite pozneje.</translation>
<translation id="5707346538075088068">Podatke v Chromu, ki se ustvarijo med uporabo tega profila (na primer zaznamke, zgodovino, gesla in druge nastavitve), lahko odstrani skrbnik delovnega profila. <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">Naprej</translation>
<translation id="2390624519615263404">Ogled varnostnih funkcij</translation>
<translation id="3959732324458144441">Sistem EcosiaOS</translation>
<translation id="2526043366208696235">{NUM_DEVICES,plural, =0{Najmanj ena razširitev za Ecosia je dostopala do 1 naprave HID}=1{Najmanj ena razširitev za Ecosia dostopa do 1 naprave HID}one{Najmanj ena razširitev za Ecosia dostopa do # naprave HID}two{Najmanj ena razširitev za Ecosia dostopa do # naprav HID}few{Najmanj ena razširitev za Ecosia dostopa do # naprav HID}other{Najmanj ena razširitev za Ecosia dostopa do # naprav HID}}</translation>
<translation id="8172133981892685841">Ta razširitev krši pravilnik Spletne trgovine Ecosia in morda ni varna. Odstranite jo iz Chroma, da si ne bo mogla več ogledati vaših podatkov na obiskanih spletnih mestih, vključno z osebnimi podatki, in jih spreminjati.</translation>
<translation id="3632544319066562282">Ecosia želi izvoziti gesla. Če želite omogočiti to, vnesite geslo za Windows.</translation>
<translation id="3077076541395306362">Ta razširitev vsebuje zlonamerno programsko opremo in ni varna. Odstranite jo iz Chroma, da si ne bo mogla več ogledati vaših podatkov na obiskanih spletnih mestih, vključno z osebnimi podatki, in jih spreminjati.</translation>
<translation id="2485422356828889247">Odmeščanje</translation>
<translation id="2513154137948333830">Potreben je vnovičen zagon: <ph name="INSTALL_SUCCESS"/></translation>
<translation id="2534365042754120737">Zaradi zaščite podatkov dovolite Chromu, da odstrani dovoljenja za spletna mesta, ki jih nedavno niste obiskali. Prikazovanje obvestil se ne ustavi.</translation>
<translation id="2280934980919215876">Vaša organizacija zapre Ecosia, če se ne uporablja <ph name="TIMEOUT_DURATION"/>. Podatki brskanja so bili izbrisani. To lahko vključuje zgodovino, samodejno izpolnjene podatke in prenose.</translation>
<translation id="2559253115192232574">Pozneje lahko stran, ki jo obiščete, od Chroma zahteva ogled vaših zanimanj zaradi osebnega prilagajanj oglasov, ki so vam prikazani. Chrome lahko deli do 3 zanimanja.</translation>
<translation id="2563121210305478421">Želite znova zagnati Chrome?</translation>
<translation id="2569974318947988067">Chrome bo poskusil nadgraditi pomikanje na HTTPS</translation>
<translation id="7527831132809333552">Ecosia upravlja vaša organizacija</translation>
<translation id="5824812022890208563">Uporabnik <ph name="EXISTING_USER"/> je že prijavljen v ta profil v Chromu. Če želite ločiti brskanje, lahko Ecosia za vas ustvari nov profil.</translation>
<translation id="80155189677487610">Ni mogoče namestiti različice Ecosia Chroma, enake tisti, ki se trenutno izvaja. Zaprite Ecosia in poskusite znova.</translation>
<translation id="2586406160782125153">S tem bodo iz te naprave izbrisani podatki brskanja. Če želite pozneje prenesti podatke, se v Chrome prijavite kot <ph name="USER_EMAIL"/>.</translation>
<translation id="6391863622742187823">Prenesite stvari za brskalnik Ecosia iz računa <ph name="ACCOUNT_EMAIL"/></translation>
<translation id="259935314519650377">Prenesenega namestitvenega programa ni bilo mogoče predpomniti. Napaka: <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="2622559029861875898">Chrome ne more preveriti, ali so na voljo posodobitve. Poskusite preveriti internetno povezavo.</translation>
<translation id="5656828929762509280">Opravite več z razširitvami za Ecosia</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="2649768380733403658">Chrome redno preverja, ali so v brskalniku na voljo najvarnejše nastavitve Če boste morali kaj pregledati, vam bomo sporočili.</translation>
<translation id="7774247008790177839">Odpiranje povezave na novem &amp;zavihku v Chromu</translation>
<translation id="9178613517891824246">Pomagajte izboljšati Ecosia – Googlu pošiljajte poročila o zrušitvah in ta dokument: <ph name="UMA_LINK"/>.</translation>
<translation id="6154325450733409298">Odprite <ph name="URL"/> na novem zavihku v Ecosia Chromu.</translation>
<translation id="2738871930057338499">Internetne povezave ni mogoče vzpostaviti. Koda napake HTTP je »403 Forbidden«. Preverite konfiguracijo strežnika proxy configuration.</translation>
<translation id="1676748966275099244">Opozorilo: Ecosia razširitvam ne more preprečiti beleženja zgodovine brskanja. Če želite onemogočiti to razširitev v anonimnem načinu, počistite to možnost.</translation>
<translation id="1831192335802727557">Ecosia potrebuje dovoljenje za dostop do mikrofona za to spletno mesto</translation>
<translation id="2770231113462710648">Spremeni privzeti brskalnik na:</translation>
<translation id="2775140325783767197">Chrome ne more preveriti vaših gesel. Poskusite preveriti internetno povezavo.</translation>
<translation id="2797864378188255696">Pri prijavi v Googlove storitve, kot je Gmail ali YouTube, z računom <ph name="USER_EMAIL"/> se lahko z istim računom samodejno prijavite v Chrome</translation>
<translation id="2799223571221894425">Vnovičen zagon</translation>
<translation id="2825024317344269723">Nevarno spletno mesto. Chrome je odstranil dovoljenje za obvestila.</translation>
<translation id="2846251086934905009">Napaka pri namestitvi: Namestitveni program se ni dokončal. Namestitev je bila prekinjena.</translation>
<translation id="2847461019998147611">Prikaži Google Chrome v tem jeziku</translation>
<translation id="2853415089995957805">Chrome vnaprej naloži strani, ki jih boste verjetno obiskali, da se ob obisku naložijo še hitreje</translation>
<translation id="8109744984354428711">Zagon Chroma …</translation>
<translation id="812798451698099271">Profil v Chromu s tem računom že obstaja.</translation>
<translation id="3035352359183300151">Preberite, zakaj Ecosia blokira nekatere prenose</translation>
<translation id="2861074815332034794">Posodabljanje Chroma (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="727568860157522676">Zdaj ste prijavljeni v Ecosia.</translation>
<translation id="2876628302275096482">Preberite več o tem, <ph name="BEGIN_LINK"/>kako Chrome zagotavlja zasebnost vaših podatkov<ph name="END_LINK"/></translation>
<translation id="2885378588091291677">Upravitelj opravil</translation>
<translation id="2888126860611144412">O brskalniku Chrome</translation>
<translation id="29082080693925013">Če želite ostati organizirani, lahko pripnete pogosto obiskana spletna mesta in razvrstite zavihke v skupine</translation>
<translation id="2915996080311180594">Znova zaženi pozneje</translation>
<translation id="2926676257163822632">Šibka gesla je preprosto ugotoviti. Chromu omogočite, da <ph name="BEGIN_LINK"/>ustvari zapletena gesla za vas in jih shrani<ph name="END_LINK"/>.</translation>
<translation id="219546601381787154">Ecosia potrebuje dovoljenje za fotoaparat za to spletno mesto.</translation>
<translation id="2928420929544864228">Namestitev je dokončana.</translation>
<translation id="2929907241665500097">Chrome se ni posodobil, prišlo je do napake. <ph name="BEGIN_LINK"/>Odpravite težave s posodobitvijo Chroma in neuspelimi posodobitvami Chroma.<ph name="END_LINK"/></translation>
<translation id="2945997411976714835">Napaka pri namestitvi: Proces namestitvenega programa se ni zagnal.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> – Prijava v omrežje – Ecosia</translation>
<translation id="8696852719113991652">Če želite račun Ecosia odstraniti iz Chroma, se na strani z nastavitvami odjavite iz Chroma.</translation>
<translation id="5405885279794834338">Izbriši tudi podatke iz Chroma (<ph name="URL"/>)</translation>
<translation id="5622643576877267490">Znova zaženi za posodobitev sistema &amp;EcosiaOS Flex</translation>
<translation id="2234042158691635795">Ecosia se izvaja v ozadju.</translation>
<translation id="3038232873781883849">Čakanje na namestitev …</translation>
<translation id="3059710691562604940">Varno brskanje je izklopljeno. Chrome priporoča, da ga vklopite.</translation>
<translation id="780008372122710391">Z bližnjico lahko hitro odprete Googlovega upravitelja gesel. Bližnjico lahko premaknete na začetni zaslon računalnika ali v zaganjalnik aplikacij.</translation>
<translation id="385080958066798123">Zavihek v Chromu</translation>
<translation id="3080151273017101988">Nadaljuj izvajanje programov v ozadju, ko je Google Chrome zaprt</translation>
<translation id="3100998948628680988">Poimenujte profil v Chromu</translation>
<translation id="7051119589302096163">Ecosia je blokiral ta prenos, ker se datoteka ne prenaša pogosto in je morda nevarna</translation>
<translation id="3114643501466072395">Če želite preveriti, ali so druga gesla varna pred podatkovnimi kršitvami in drugimi varnostnimi težavami, <ph name="BEGIN_LINK"/>se prijavite v Chrome<ph name="END_LINK"/>.</translation>
<translation id="231621248561775155">Ecosia je blokiral ta prenos, ker arhivska datoteka vsebuje druge datoteke, ki morda skrivajo zlonamerno programsko opremo</translation>
<translation id="1722634673917783018">Spremembe bodo začele veljati ob naslednjem zagonu Ecosia Chroma.</translation>
<translation id="2636091632287013185">Aplikacije za Ecosia</translation>
<translation id="7580831958727159171">Med temi preizkusi lahko vidite ali odstranite teme zanimanja, ki jih spletna mesta uporabljajo, da vam prikazujejo oglase. Ecosia oceni vaša zanimanja glede na nedavno zgodovino brskanja.</translation>
<translation id="9068280473864300215">Ecosia je blokiral ta prenos, ker je datoteka nevarna</translation>
<translation id="3226612997184048185">Če v računu Google shranite tudi zaznamke, lahko v Chromu spremljate cene izdelkov in prejmete obvestilo, ko se cena zniža</translation>
<translation id="3234642784688107085">Preizkusite nove funkcije umetne inteligence in ustvarite teme, prejmite pomoč pri pisanju in ostanite organizirani</translation>
<translation id="3245429137663807393">Če delite tudi poročila o uporabi Chroma, so v teh poročilih vključeni URL-ji, ki jih obiščete.</translation>
<translation id="3261565993776444564">Preizkusite novo barvo za prilagajanje brskalnika</translation>
<translation id="2388751143175762498">Prijava v Ecosia</translation>
<translation id="3286538390144397061">Znova zaženi</translation>
<translation id="8268239447047453615">Nato boste morali znova zagnati Ecosia.</translation>
<translation id="9090890391337853620">Pomočnik za Ecosia</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia se bo zdaj znova zagnal}=1{Ecosia se bo znova zagnal čez eno sekundo}one{Ecosia se bo znova zagnal čez # sekundo}two{Ecosia se bo znova zagnal čez # sekundi}few{Ecosia se bo znova zagnal čez # sekunde}other{Ecosia se bo znova zagnal čez # sekund}}</translation>
<translation id="7280797724682955539">Med namestitvijo je prišlo do napake v operacijskem sistemu. Ponovno prenesite program Ecosia.</translation>
<translation id="3428747202529429621">Skrbi za vašo varnost v Chromu in ga je mogoče uporabiti za okrepitev varnosti v drugih Googlovih aplikacijah, ko ste prijavljeni.</translation>
<translation id="3434246496373299699">Chrome lahko preveri vaša gesla, ko se prijavite z računom Google</translation>
<translation id="6094573000614590044">Če želite dostopati do gesel in drugega v vseh napravah, se prijavite v Ecosia</translation>
<translation id="5032126307005935789">Ta datoteka je morda nevarna<ph name="LINE_BREAK"/>Ecosia lahko preveri ta prenos, če navedete geslo. Podatki o datoteki se pošljejo v Ecosia Varno brskanje, vsebina datoteke in geslo pa ostaneta v napravi.</translation>
<translation id="1762318218111418450">Dodajanje v Ecosia ...</translation>
<translation id="6761747850241550887">Dodajte se v Ecosia</translation>
<translation id="2149148292984034533">Pogoji za Ecosia OS</translation>
<translation id="6558895515431832002">Ecosia potrebuje dostop do vaše lokacije, da jo bo lahko delil s tem spletnim mestom</translation>
<translation id="3533694711092285624">Ni shranjenih gesel. Chrome lahko preveri gesla, če jih shranite.</translation>
<translation id="3541482654983822893">Chrome ne more preveriti vaših gesel. Poskusite znova čez 24 ur.</translation>
<translation id="7881897052591031502">Ko se prijavite v Ecosia, lahko shranite zaznamke, gesla in drugo, nato pa jih uporabljate v telefonu</translation>
<translation id="8901409988302458368">Skrbnik sistema je Ecosia nastavil tako, da za dostop do <ph name="TARGET_URL_HOSTNAME"/> odpre drug brskalnik.</translation>
<translation id="7174674455569790401">V vseh svojih napravah sinhronizirajte in prilagodite Ecosia</translation>
<translation id="8403827649521531901">V drugem profilu za Ecosia ste že prijavljeni kot <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="3260765223735049374">Se želite v Chromu prijaviti v novem profilu?</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{Skrbnik zahteva, da za uveljavitev te posodobitve znova zaženete Ecosia.}=1{Skrbnik zahteva, da za uveljavitev te posodobitve znova zaženete Ecosia. Anonimno okno se ne bo znova odprlo.}one{Skrbnik zahteva, da za uveljavitev te posodobitve znova zaženete Ecosia. # anonimno okno se ne bo znova odprlo.}two{Skrbnik zahteva, da za uveljavitev te posodobitve znova zaženete Ecosia. # anonimni okni se ne bosta znova odprli.}few{Skrbnik zahteva, da za uveljavitev te posodobitve znova zaženete Ecosia. # anonimna okna se ne bodo znova odprla.}other{Skrbnik zahteva, da za uveljavitev te posodobitve znova zaženete Ecosia. # anonimnih oken se ne bo znova odprlo.}}</translation>
<translation id="3597003331831379823">Nastavitve s povečanimi pravicami ni bilo mogoče izvesti. <ph name="METAINSTALLER_ERROR"/></translation>
<translation id="3609788354808247807">Nedavno niste obiskali tega mesta. Chrome je odstranil ta dovoljenja: <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> in <ph name="PERMISSION_3"/>.</translation>
<translation id="464306605599005355">Zdaj je Ecosia lažje uporabljati z Ecosia Računom in v računalnikih, ki so v skupni rabi.</translation>
<translation id="3635073343384702370">Chrome lahko preveri gesla, če jih shranite</translation>
<translation id="3667616615096815454">Namestitev ni mogoča, ker strežnik ne pozna aplikacije.</translation>
<translation id="1490060441084292633">Ecosia je ugotovil, da razširitev »<ph name="EXTENSION_NAME"/>« vsebuje zlonamerno programsko opremo.</translation>
<translation id="3695446226812920698">Oglejte si navodila</translation>
<translation id="6967821869905227561">Drugi profili v Chromu</translation>
<translation id="5311911269004680646">Ecosia OS omogoča dodatna <ph name="BEGIN_LINK_CROS_OSS"/>odprtokodna programska oprema<ph name="END_LINK_CROS_OSS"/>, enako kot <ph name="BEGIN_LINK_LINUX_OSS"/>razvojno okolje Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
