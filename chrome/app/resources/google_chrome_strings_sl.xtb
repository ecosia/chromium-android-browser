<!DOCTYPE translationbundle>
<translationbundle lang="sl">
<translation id="4033006861724039519">Arhiv namestitvenega programa je poškodovan ali neveljaven. Ponovno prenesite program Ecosia.</translation>
<translation id="1026101648481255140">Nadaljuj namestitev</translation>
<translation id="8296565077892323223">Prilagodite in nadzirajte Ecosia. Posodobitev je na voljo.</translation>
<translation id="2804130178228362015">V računalniku je nameščena škodljiva programska oprema. Ecosia jo lahko odstrani, obnovi vaše nastavitve in onemogoči razširitve, da bo brskalnik spet normalno deloval.</translation>
<translation id="1065672644894730302">Nastavitev ni mogoče prebrati.

Nekatere funkcije morda niso na voljo in spremembe nastavitev ne bodo shranjene.</translation>
<translation id="8055222671516987714">Uporabnik <ph name="USER_EMAIL_ADDRESS"/> je prej uporabljal Ecosia</translation>
<translation id="2000339487270823788">To je vaš Ecosia</translation>
<translation id="8078678931242443254">Kdo uporablja Ecosia?</translation>
<translation id="6346154190168496057">Chroma ni mogoče posodobiti</translation>
<translation id="1152920704813762236">O sistemu Chrome OS</translation>
<translation id="7303930050538184306">&amp;Odpri v Chromu</translation>
<translation id="1203500561924088507">Hvala, ker ste se odločili za namestitev. Preden uporabite <ph name="BUNDLE_NAME"/>, morate znova zagnati brskalnik.</translation>
<translation id="6650631555168164414">Kar najbolje lahko izkoristite Ecosia</translation>
<translation id="1523806373970723624">Znova zaženite, če želite posodobiti &amp;Ecosia</translation>
<translation id="5279514147510747661">Počakajte, da Ecosia namesti najnovejše sistemske posodobitve.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> zahteva, da preberete in sprejmete pogoje storitve, preden začnete uporabljati napravo. Ti pogoji ne dopolnjujejo, spreminjajo ali omejujejo pogojev za EcosiaOS Flex.</translation>
<translation id="8067423333018528301">Ecosia OS ni mogel sinhronizirati podatkov zaradi napake pri prijavi.</translation>
<translation id="2926455547526018397">Ecosia Beta</translation>
<translation id="2995860351618948435">V tem računalniku je že nameščena novejša različica Ecosia Chroma. Če programska oprema ne deluje, odstranite Ecosia in poskusite znova.</translation>
<translation id="824192326282906244">Kadar koli si lahko premislite v nastavitvah za Ecosia. Preizkusi potekajo skupaj s trenutnim načinom prikazovanja oglasov, zato spremembe ne bodo takoj vidne.</translation>
<translation id="4696685525015809740">Delovne različice aplikacij za Ecosia</translation>
<translation id="3697186779259384993">Prilagajanje novega profila v Chromu</translation>
<translation id="4062366803229254216">Ecosia potrebuje dostop do Bluetootha za nadaljevanje 
 seznanjanja. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="2441303983090031276">Ecosia OS omogoča dodatna <ph name="BEGIN_LINK_CROS_OSS"/>odprtokodna programska oprema<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="5598074261782651109">Posodobi Ecosia</translation>
<translation id="847970842635669371">Uporabnik <ph name="EXISTING_USER"/> je že prijavljen v ta profil v Chromu. S tem bo ustvarjen novi profil v Chromu za uporabnika <ph name="USER_EMAIL_ADDRESS"/>.</translation>
<translation id="4943938785458240142">Ecosia uporablja vašo kamero.</translation>
<translation id="1936361330890313940">Datoteka <ph name="FILE_NAME"/> je nevarna, zato jo je Ecosia blokiral.</translation>
<translation id="1597911401261118146">Če želite preveriti, ali so gesla varna pred podatkovnimi kršitvami in drugimi varnostnimi težavami, <ph name="BEGIN_LINK"/>se prijavite v Chrome<ph name="END_LINK"/>.</translation>
<translation id="5591151834004774364">Ecosia je blokiral to datoteko arhiva, ker morda skriva zlonamerno programsko opremo.</translation>
<translation id="1597547208646178091">Zaradi večje varnosti smo v Chromu onemogočili to razširitev, ki ni navedena tukaj in je bila morda dodana brez vaše vednosti: <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Kako lahko upravljate podatke:<ph name="END_BOLD"/> Zaradi zaščite vaše varnosti samodejno izbrišemo vaša zanimanja, starejša od 4 tednov. Ko brskate naprej, se zanimanje morda znova prikaže na seznamu. Odstranite lahko tudi zanimanja, za katera ne želite, da jih Ecosia predlaga.</translation>
<translation id="1628000112320670027">Pomoč za Chrome</translation>
<translation id="1640672724030957280">Prenos ...</translation>
<translation id="1662146548738125461">O sistemu ChromeOS Flex</translation>
<translation id="5500958820122281144">Odpiranje povezave v Chromovem oknu brez belež&amp;enja zgodovine</translation>
<translation id="7602423871874451395">Ecosia ne more brati svojega imenika s podatki ali pisati vanj:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{Skrbnik je Ecosia konfiguriral tako, da se zapre, če je nedejaven več kot 1 minuto.}one{Skrbnik je Ecosia konfiguriral tako, da se zapre, če je nedejaven več kot # minuto.}two{Skrbnik je Ecosia konfiguriral tako, da se zapre, če je nedejaven več kot # minuti.}few{Skrbnik je Ecosia konfiguriral tako, da se zapre, če je nedejaven več kot # minute.}other{Skrbnik je Ecosia konfiguriral tako, da se zapre, če je nedejaven več kot # minut.}}</translation>
<translation id="3939060118711873999">Ecosia je spletni brskalnik, ki bliskovito odpira spletna mesta in izvaja programe. Je hiter, stabilen in preprost za uporabo. V Ecosia je vgrajena zaščita pred zlonamerno programsko opremo in lažnim predstavljanjem, kar omogoča varnejše brskanje v spletu.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia se bo znova zagnal čez eno uro}one{Ecosia se bo znova zagnal čez # uro}two{Ecosia se bo znova zagnal čez # uri}few{Ecosia se bo znova zagnal čez # ure}other{Ecosia se bo znova zagnal čez # ur}}</translation>
<translation id="4021894801595982809">Ecosia bo shranil to geslo v Ecosia Računu. Ni si vam ga treba zapomniti.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">Preverite, ali ste v napravi <ph name="TARGET_DEVICE_NAME"/> prijavljeni v Ecosia, nato poskusite znova poslati.</translation>
<translation id="1812689907177901597">Če to izklopite, se lahko prijavite na Googlovih spletnih mestih, kot je Gmail, ne da bi se morali prijaviti v Chrome</translation>
<translation id="5055330219314726197">Ecosia potrebuje dovoljenje za dostop do fotoaparata za to spletno mesto</translation>
<translation id="1508200558303644420">Ecosia ni privzeti brskalnik</translation>
<translation id="8135642897811755229">Ecosia Beta (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia je zastarel</translation>
<translation id="1919130412786645364">Omogočanje prijave v Chrome</translation>
<translation id="6235917057647038042">Če želite prejemati prihodnje posodobitve Ecosia Chroma, potrebujete macOS 10.13 ali novejšega. V tem računalniku je nameščen macOS 10.12.</translation>
<translation id="1953553007165777902">Prenašanje … Še <ph name="MINUTE"/> min.</translation>
<translation id="8608092457636055141">Vsak profil ima svoje podatke v Chromu, kot so zaznamki, zgodovina, gesla in drugo.</translation>
<translation id="2018879682492276940">Namestitev ni uspela. Poskusite znova.</translation>
<translation id="7375011918167125899">Drug račun je že prijavljen. Če želite ločiti brskanje, lahko Ecosia za vas ustvari nov profil.</translation>
<translation id="207902854391093810">Če so preizkusi vklopljeni, merjenje oglasov spletnim mestom omogoča, da od Chroma zahtevajo podatke, ki jim pomagajo pri merjenju učinkovitosti oglasov. Merjenje oglasov omejuje sledenje na več spletnih mestih s prenašanjem čim manj podatkov med spletnimi mesti.</translation>
<translation id="8655983536493871574">Če želite prejemati prihodnje posodobitve Ecosia Chroma, potrebujete Windows 10 ali novejšega. V tem računalniku je nameščen Windows 8.</translation>
<translation id="3590393640971125498">Pogoji za EcosiaOS Flex</translation>
<translation id="864244542982029641">Želite vseeno zapreti Ecosia?</translation>
<translation id="3791194915692553395">EcosiaOS Flex omogoča dodatna <ph name="BEGIN_LINK_CROS_OSS"/>odprtokodna programska oprema<ph name="END_LINK_CROS_OSS"/>, enako kot <ph name="BEGIN_LINK_LINUX_OSS"/>razvojno okolje Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="2120620239521071941">S tem bo iz te naprave izbrisanih več elementov (<ph name="ITEMS_COUNT"/>). Če želite pozneje prenesti podatke, se v Chrome prijavite kot <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">Znova zaženite, če želite posodobiti &amp;Ecosia</translation>
<translation id="2123055963409958220">Pomagajte izboljšati Google Chrome s <ph name="BEGIN_LINK"/>poročanjem trenutnih nastavitev<ph name="END_LINK"/></translation>
<translation id="2131230230468101642">Zaradi zaščite vaše varnosti samodejno izbrišemo vaša zanimanja, starejša od 4 tednov. Ko brskate naprej, se zanimanje morda znova prikaže na seznamu. Odstranite lahko tudi zanimanja, za katera ne želite, da jih Chrome predlaga.</translation>
<translation id="5404489723475681578">Vnovičen zagon sistema Ecosia OS</translation>
<translation id="5982672133249369264">Znova zaženite Ecosia</translation>
<translation id="2174917724755363426">Namestitev še ni končana. Ali ste prepričani, da jo želite preklicati?</translation>
<translation id="223889379102603431">Informacije o tem, kako Chrome upravlja korenska potrdila.</translation>
<translation id="4337034173783952373">Če želite do stvari v brskalniku Ecosia dostopati v vseh svojih napravah, se prijavite in nato vklopite sinhronizacijo.</translation>
<translation id="4735588186234302898">Manjkajo ključi za Ecosia API. Nekatere funkcije Ecosia Chroma bodo onemogočene.</translation>
<translation id="7908111389403807005">Ali ste prepričani, da želite odstraniti Ecosia?</translation>
<translation id="2309047409763057870">To je sekundarna namestitev Google Chroma in ga ni mogoče nastaviti kot privzeti brskalnik.</translation>
<translation id="7613817989637275906">Ecosia je ugotovil, da te razširitve vsebujejo zlonamerno programsko opremo:</translation>
<translation id="7273750863406285983">Ecosia potrebuje dovoljenje za dostop do fotoaparata in mikrofona za to spletno mesto</translation>
<translation id="234869673307233423">Chrome ne more preveriti vaših gesel. Poskusite pozneje.</translation>
<translation id="5707346538075088068">Podatke v Chromu, ki se ustvarijo med uporabo tega profila (na primer zaznamke, zgodovino, gesla in druge nastavitve), lahko odstrani skrbnik delovnega profila. <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">Naprej</translation>
<translation id="3959732324458144441">Sistem Ecosia OS</translation>
<translation id="3632544319066562282">Ecosia želi izvoziti gesla. Če želite omogočiti to, vnesite geslo za Windows.</translation>
<translation id="2485422356828889247">Odmeščanje</translation>
<translation id="2534507159460261402">Google Pay (kopirano v Chrome)</translation>
<translation id="2559253115192232574">Pozneje lahko stran, ki jo obiščete, od Chroma zahteva ogled vaših zanimanj zaradi osebnega prilagajanj oglasov, ki so vam prikazani. Chrome lahko deli do 3 zanimanja.</translation>
<translation id="2563121210305478421">Želite znova zagnati Chrome?</translation>
<translation id="5824812022890208563">Uporabnik <ph name="EXISTING_USER"/> je že prijavljen v ta profil v Chromu. Če želite ločiti brskanje, lahko Ecosia za vas ustvari nov profil.</translation>
<translation id="80155189677487610">Ni mogoče namestiti različice Ecosia Chroma, enake tisti, ki se trenutno izvaja. Zaprite Ecosia in poskusite znova.</translation>
<translation id="2586406160782125153">S tem bodo iz te naprave izbrisani podatki brskanja. Če želite pozneje prenesti podatke, se v Chrome prijavite kot <ph name="USER_EMAIL"/>.</translation>
<translation id="6391863622742187823">Prenesite stvari za brskalnik Ecosia iz računa <ph name="ACCOUNT_EMAIL"/></translation>
<translation id="2622559029861875898">Chrome ne more preveriti, ali so na voljo posodobitve. Poskusite preveriti internetno povezavo.</translation>
<translation id="1761341660094265938">Ecosia OS</translation>
<translation id="7774247008790177839">Odpiranje povezave na novem &amp;zavihku v Chromu</translation>
<translation id="9178613517891824246">Pomagajte izboljšati Ecosia – Googlu pošiljajte poročila o zrušitvah in ta dokument: <ph name="UMA_LINK"/>.</translation>
<translation id="815199437159352723">Zaradi te razširitve se je spremenila stran, ki je prikazana, ko zaženete Ecosia.</translation>
<translation id="1676748966275099244">Opozorilo: Ecosia razširitvam ne more preprečiti beleženja zgodovine brskanja. Če želite onemogočiti to razširitev v anonimnem načinu, počistite to možnost.</translation>
<translation id="1831192335802727557">Ecosia potrebuje dovoljenje za dostop do mikrofona za to spletno mesto</translation>
<translation id="2770231113462710648">Spremeni privzeti brskalnik na:</translation>
<translation id="2775140325783767197">Chrome ne more preveriti vaših gesel. Poskusite preveriti internetno povezavo.</translation>
<translation id="2799223571221894425">Vnovičen zagon</translation>
<translation id="2847461019998147611">Prikaži Google Chrome v tem jeziku</translation>
<translation id="8109744984354428711">Zagon Chroma …</translation>
<translation id="812798451698099271">Profil v Chromu s tem računom že obstaja.</translation>
<translation id="2861074815332034794">Posodabljanje Chroma (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="727568860157522676">Zdaj ste prijavljeni v Ecosia.</translation>
<translation id="2885378588091291677">Upravitelj opravil</translation>
<translation id="2888126860611144412">O brskalniku Chrome</translation>
<translation id="2915996080311180594">Znova zaženi pozneje</translation>
<translation id="2926676257163822632">Šibka gesla je preprosto ugotoviti. Chromu omogočite, da <ph name="BEGIN_LINK"/>ustvari zapletena gesla za vas in jih shrani<ph name="END_LINK"/>.</translation>
<translation id="219546601381787154">Ecosia potrebuje dovoljenje za fotoaparat za to spletno mesto.</translation>
<translation id="2928420929544864228">Namestitev je dokončana.</translation>
<translation id="2929907241665500097">Chrome se ni posodobil, prišlo je do napake. <ph name="BEGIN_LINK"/>Odpravite težave s posodobitvijo Chroma in neuspelimi posodobitvami Chroma.<ph name="END_LINK"/></translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> – Prijava v omrežje – Ecosia</translation>
<translation id="5622643576877267490">Znova zaženi za posodobitev sistema &amp;EcosiaOS Flex</translation>
<translation id="303514781271618814">Chrome raziskuje nove funkcije, ki spletnim mestom omogočajo, da z manjšo količino prenesenih podatkov zagotavljajo isto izkušnjo pri brskanju.</translation>
<translation id="2234042158691635795">Ecosia se izvaja v ozadju.</translation>
<translation id="3038232873781883849">Čakanje na namestitev …</translation>
<translation id="3059710691562604940">Varno brskanje je izklopljeno. Chrome priporoča, da ga vklopite.</translation>
<translation id="385080958066798123">Zavihek v Chromu</translation>
<translation id="3080151273017101988">Nadaljuj izvajanje programov v ozadju, ko je Google Chrome zaprt</translation>
<translation id="6876820794875877783">Na voljo je nova, varnejša različica Ecosia Chroma.</translation>
<translation id="3100998948628680988">Poimenujte profil v Chromu</translation>
<translation id="3114643501466072395">Če želite preveriti, ali so druga gesla varna pred podatkovnimi kršitvami in drugimi varnostnimi težavami, <ph name="BEGIN_LINK"/>se prijavite v Chrome<ph name="END_LINK"/>.</translation>
<translation id="1722634673917783018">Spremembe bodo začele veljati ob naslednjem zagonu Ecosia Chroma.</translation>
<translation id="2636091632287013185">Aplikacije za Ecosia</translation>
<translation id="7580831958727159171">Med temi preizkusi lahko vidite ali odstranite teme zanimanja, ki jih spletna mesta uporabljajo, da vam prikazujejo oglase. Ecosia oceni vaša zanimanja glede na nedavno zgodovino brskanja.</translation>
<translation id="2899530016847324742">{NUM_DEVICES,plural, =1{Ecosia je povezan z napravo HID}one{Ecosia je povezan z napravami HID}two{Ecosia je povezan z napravami HID}few{Ecosia je povezan z napravami HID}other{Ecosia je povezan z napravami HID}}</translation>
<translation id="3245429137663807393">Če delite tudi poročila o uporabi Chroma, so v teh poročilih vključeni URL-ji, ki jih obiščete.</translation>
