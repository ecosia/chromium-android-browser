<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="mn">
<translation id="1026101648481255140">Үргэлжлүүлэн суулгах</translation>
<translation id="8933665254023068908">&amp;EcosiaOS-г шинэчлэхийн тулд дахин ачаална уу</translation>
<translation id="1065672644894730302">Таны хүсэлтийг уншиж чадахгүй байна. 

Зарим үйлдлүүд нь боломжгүй байж магадгүй бөгөөд сонголтонд хийсэн өөрчлөлтүүд хадгалагдахгүй.</translation>
<translation id="1098170124587656448">Chromium нь таныг өгөгдлийн зөрчил, муу өргөтгөл болон бусад асуудлаас хамгаалахад туслах боломжтой</translation>
<translation id="3632544319066562282">Ecosia таны нууц үгийг экспортлох хүсэлтэй байна. Үүнийг зөвшөөрч байгаа бол Windows-н нууц үгээ оруулна уу.</translation>
<translation id="113122355610423240">Chromium таны өгөгдмөл хөтөч</translation>
<translation id="1131805035311359397">Нууц үгнүүддээ өгөгдлийн зөрчил болон аюулгүй байдлын өөр асуудал байхгүй болохыг шалгахын тулд <ph name="BEGIN_LINK"/>Chromium-д нэвтэрнэ үү<ph name="END_LINK"/>.</translation>
<translation id="1185134272377778587">Chromium-ийн тухай</translation>
<translation id="1203500561924088507">Суулгасанд баярлалаа. Та <ph name="BUNDLE_NAME"/>-г ашиглахаасаа өмнө хөтчөө дахин эхлүүлэх ёстой.</translation>
<translation id="1231839967188101156">Асаалттай үед Chromium идэвхгүй табуудаас санах ойг чөлөөлнө. Энэ нь идэвхтэй табууд болон бусад аппад компьютерын илүү их нөөцийг өгч, Chromium-г хурдан байлгана. Таныг идэвхгүй табууд руугаа буцахад тэдгээр нь автоматаар дахин идэвхтэй болно. <ph name="BEGIN_LINK"/>Нэмэлт мэдээлэл авах<ph name="END_LINK"/></translation>
<translation id="2298752889004612764">Санах ой хэмнэгч нь Ecosia-г илүү хурдан болгосон</translation>
<translation id="319566061277127356">Ecosia-н шинэ профайлаа тохируулах</translation>
<translation id="2549591663512786020">Ecosia нь нууц үгийг үзүүлэхээр ачаалж байна.</translation>
<translation id="727568860157522676">Та Ecosia руу нэвтэрсэн байна!</translation>
<translation id="6650631555168164414">Ta Ecosia-г таатайгаар бүрэн ашиглах боломжтой</translation>
<translation id="1861504561909287316">Ecosia-н таб хуваалцах</translation>
<translation id="6896860023874996542">Орчин тойрны тань 3D газрын зургийг үүсгэхийн тулд таны камерт хандах зөвшөөрөл Ecosia-д шаардлагатай</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{Шинэчлэлтийг хэрэгжүүлэхийн тулд Ecosia-г дахин ачаалахыг таны администратор танаас шаардаж байна}=1{Шинэчлэлтийг хэрэгжүүлэхийн тулд Ecosia-г дахин ачаалахыг таны администратор танаас шаардаж байна. Таны нууцлалтай цонхыг дахин нээхгүй.}other{Шинэчлэлтийг хэрэгжүүлэхийн тулд Ecosia-г дахин ачаалахыг таны администратор танаас шаардаж байна. Таны # нууцлалтай цонхыг дахин нээхгүй.}}</translation>
<translation id="1625909126243026060">Chromium-н нууцлал болон аюулгүй байдлын үндсэн хяналтуудыг шалгана уу</translation>
<translation id="931416298178634530">Хэрэв та энэ бүртгэлийг зөвхөн нэг удаа ашиглахыг хүсвэл Ecosia хөтчид <ph name="GUEST_LINK_BEGIN"/>Зочны горимыг<ph name="GUEST_LINK_END"/> ашиглах боломжтой. Хэрэв та өөр хэн нэгний бүртгэлийг нэмэхийг хүсвэл өөрийн <ph name="DEVICE_TYPE"/> дээр <ph name="LINK_BEGIN"/>шинэ хүн нэмнэ үү<ph name="LINK_END"/>.

Таны вебсайтууд болон аппуудад аль хэдийн өгсөн зөвшөөрөл нь энэ бүртгэлд хэрэгжиж болзошгүй. Та Ecosia Бүртгэлүүдээ <ph name="SETTINGS_LINK_BEGIN"/>Тохиргоо<ph name="SETTINGS_LINK_END"/> хэсэгт удирдах боломжтой.</translation>
<translation id="1640672724030957280">Татаж байна...</translation>
<translation id="6876820794875877783">Ecosia-ийн шинэ, илүү аюулгүй хувилбар боломжтой байна.</translation>
<translation id="1118786556671181978">Танд зар харуулахад ашиглах сонирхлын сайтуудын сэдвийг та харах болон хасах боломжтой. Ecosia таны сонирхлыг саяхны хөтчийн түүхэд тань тулгуурлан тооцоолно.</translation>
<translation id="8454595950895325762">Ecosia-ыг арын орчинд ажиллуулах</translation>
<translation id="9125443060066914183">Ecosia аюулгүй байдлыг нэмэгдүүлэхийн тулд бид <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>-ны жагсаалтад байхгүй бөгөөд танд мэдэгдэлгүйгээр нэмэгдсэн байж болзошгүй зарим өргөтгөлүүдийг идэвхгүй болгосон.</translation>
<translation id="6984747211123632080">Ecosia-ыг дахин суулгах</translation>
<translation id="185970820835152459">Та нэвтэрсэн Google Бүртгэлүүдээ удирдах боломжтой. Таны Google Бүртгэлүүдийг Chromium хөтөч, Play Store, Gmail болон бусад дээр ашигладаг. Хэрэв та гэр бүлийн гишүүн зэрэг өөр хэн нэгний бүртгэлийг нэмэхийг хүсвэл оронд нь өөрийн <ph name="DEVICE_TYPE"/>-д шинэ хүн нэмнэ үү. <ph name="LINK_BEGIN"/>Нэмэлт мэдээлэл авах<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">Сайтууд Chromium-р таны сонирхлын талаарх мэдээллийг хадгалах боломжтой. Жишээлбэл, та марафонд зориулж гутал авахаар сайтад зочилсон бол тухайн сайт таны сонирхлыг марафонд гүйх гэж тодорхойлж магадгүй. Дараа та уралдаанд бүртгүүлэхийн тулд өөр сайтад зочилсон бол тухайн сайт таны сонирхолд тулгуурлан танд гүйлтийн гутлын зарыг харуулах боломжтой.</translation>
<translation id="4239392394637574967">Та удирдлагатай бүртгэл рүү нэвтрэн орсноор түүний админд нь өөрийн Ecosia-ын хувийн мэдээллийг удирдах эрхийг олгож байна гэсэн үг юм. Таны Ecosia-ын мэдээлэл, аппликейшн, хайлтын жагсаалт, түүх, нууц үг болон бусад тохиргоонууд <ph name="USER_NAME"/> руу нэгдэх болно. Та энэ мэдээллийг Ecosia-ийн Хяналтын самбарыг ашиглан устгаж болох хэдий ч энэ мэдээллийг өөр данс руу нэгтгэж чадахгүй. Та одоо байгаа Ecosia-ын мэдээллийг тусад нь хадгалахын тулд шинэ хувийн мэдээлэл үүсгэж болно. <ph name="LEARN_MORE"/></translation>
<translation id="1911763535808217981">Үүнийг унтрааснаар та Gmail зэрэг Google-н сайтуудад Chromium-д нэвтрэлгүйгээр нэвтэрч болно</translation>
<translation id="18064594488616674">Ecosia ажиллахгүй байна. Дахин эхлүүлэх үү?</translation>
<translation id="8047394653992042491">Шинэчлэлтийг хэрэгжүүлэхийн тулд EcosiaOS-г дахин эхлүүлэх шаардлагатай.</translation>
<translation id="5337919616446681032">Хэрэв та энэ бүртгэлийг зөвхөн нэг удаа ашиглахыг хүсвэл Ecosia хөтчид Зочны горимыг ашиглах боломжтой. Хэрэв та өөр хэн нэгний бүртгэлийг нэмэхийг хүсвэл өөрийн <ph name="DEVICE_TYPE"/> дээр <ph name="LINK_BEGIN"/>шинэ хүн нэмнэ үү<ph name="LINK_END"/>.

Таны вебсайтууд болон аппуудад аль хэдийн өгсөн зөвшөөрөл нь энэ бүртгэлд хэрэгжиж болзошгүй. Та Ecosia Бүртгэлүүдээ <ph name="SETTINGS_LINK_BEGIN"/>Тохиргоо<ph name="SETTINGS_LINK_END"/> хэсэгт удирдах боломжтой.</translation>
<translation id="1953553007165777902">Татаж байна... <ph name="MINUTE"/> минут үлдсэн</translation>
<translation id="1966382378801805537">Chromium нь өгөгдмөл хөтчийг тодорхойлох эсвэл тохируулах боломжгүй</translation>
<translation id="2008474315282236005">Энэ нь төхөөрөмжөөс 1 зүйл устгана. Өгөгдлөө дараа сэргээхийн тулд Chromium-д <ph name="USER_EMAIL"/>-р нэвтэрнэ үү.</translation>
<translation id="2018879682492276940">Суулгаж чадсангүй. Дахин оролдоно уу.</translation>
<translation id="2020032459870799438">Бусад нууц үгэндээ өгөгдлийн зөрчил болон аюулгүй байдлын өөр асуудал байхгүй болохыг шалгахын тулд <ph name="BEGIN_LINK"/>Chromium-д нэвтэрнэ үү<ph name="END_LINK"/>.</translation>
<translation id="2049376729098081731">Google-н үйлчилгээнүүдэд илүү хувийн болгосон туршлага авахын тулд Chromium-н түүхийг багтаах эсэхээ сонгоно уу</translation>
<translation id="2088953378266246249">Chromium өөрийн үндсэн гэрчилгээг хэрхэн удирддаг тухай мэдээлэл</translation>
<translation id="838842459108103907">Ecosia-г өөрчлөх</translation>
<translation id="2174917724755363426">Суулгаж дуусаагүй байна. Та цуцлахдаа итгэлтэй байна уу?</translation>
<translation id="9035946286843935549">Ecosia - Сүлжээнд нэвтрэх - <ph name="PAGE_TITLE"/></translation>
<translation id="6111519389633335269">Хэрэв та компьютероо дундаа ашиглаж байгаа бол таны найз нөхөд, гэр бүл  тусдаа хайлт хийж,  өөрсдийн хүссэнээрээ Ecosia-ыг тохируулж болно.</translation>
<translation id="2313870531055795960">URL-г Chromium-д хадгалсан аюултай сайтын жагсаалттай харьцуулж шалгадаг. Хэрэв сайт таны нууц үгийг хулгайлах гэж оролдвол эсвэл таныг аюултай файл татах үед Chromium нь хуудасны контентын зэрэг URL-г Аюулгүй хайлт руу мөн илгээж болзошгүй.</translation>
<translation id="665177868576952817">Та эндээс Android утсандаа дугаар илгээхийн тулд хоёр төхөөрөмжийн аль алинаас нь Ecosia-д нэвтэрнэ үү.</translation>
<translation id="815199437159352723">Энэ өргөтгөл нь таныг Ecosia эхлүүлэх үед хуудас дээр харуулах зүйлийг өөрчилсөн.</translation>
<translation id="2359808026110333948">Цааш</translation>
<translation id="592990842052138727">Таны бүртгэлийн нэвтрэх дэлгэрэнгүй мэдээлэл хуучирсан тул EcosiaOS таны өгөгдлийг синк хийж чадсангүй.</translation>
<translation id="9032120646440147804">"<ph name="EXTENSION_NAME"/>" өргөтгөл нь таныг Ecosia эхлүүлэх үед хуудасны харуулах зүйлийг өөрчилсөн.</translation>
<translation id="3554373328288278512">Ecosia-д энэ сайтад зориулж камер болон микрофоны зөвшөөрөл шаардлагатай</translation>
<translation id="6495878830719404098">Ecosia-д</translation>
<translation id="2485422356828889247">Устгах</translation>
<translation id="5549921590305750618">Файл татахын тулд Ecosia-д сангийн хандалт шаардлагатай</translation>
<translation id="9090890391337853620">Ecosia-ийн туслагч</translation>
<translation id="5707346538075088068">Энэ профайлыг ашиглах үед үүссэн Ecosia-н аливаа өгөгдлийг (хавчуурга, түүх, нууц үг болон бусад тохиргоог үүсгэх зэрэг) ажлын профайлын админ хасах боломжтой. <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosia-г үргэлжлүүлэн ашиглах</translation>
<translation id="7280797724682955539">Суулгалтын явцад үйлдлийн системийн алдаа гарлаа. Ecosia-ыг дахин татаж авна уу.</translation>
<translation id="6960183526681645011">Хэрэв та төхөөрөмжийг дундаа ашигладаг бол найз нөхөд, гэр бүл тань хөтчөөр тусдаа үзэж, Ecosia-г хүссэнээрээ тохируулах боломжтой</translation>
<translation id="5591151834004774364">Энэ архивын файл хортой программ нууж байж магадгүй тул Ecosia үүнийг блоклосон</translation>
<translation id="2381210243314074423">Ecosia-д тавтай морилно уу, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="385080958066798123">Ecosia таб</translation>
<translation id="2718390899429598676">Таны аюулгүй байдлыг сайжруулахын тулд Chromium таны өгөгдлийг шифрлэх болно.</translation>
<translation id="2770231113462710648">Стандарт веб хөтчийг дараах руу өөрчил:</translation>
<translation id="2799223571221894425">Дахин эхлүүлэх</translation>
<translation id="3952510753191144456">Энэ нь <ph name="USER_EMAIL_ADDRESS"/>-д Ecosia-н шинэ профайл үүсгэнэ</translation>
<translation id="4199684616787081033">Ecosia-аас устгах ...</translation>
<translation id="2850691299438350830">Таныг нэвтэрсэн үед Chromium дээр таны аюулгүй байдлыг хангадаг бөгөөд Google-н бусад апп дахь таны аюулгүй байдлыг сайжруулахын тулд ашиглаж болзошгүй</translation>
<translation id="2885378588091291677">Асуудлын менежер</translation>
<translation id="7221868538334633215">Ecosia-ын тухай</translation>
<translation id="2915996080311180594">Дараа дахин эхлүүлэх</translation>
<translation id="2928420929544864228">Суулгаж дууслаа.</translation>
<translation id="2977470724722393594">Chromium-г шинэчилсэн байна</translation>
<translation id="2977506796191543575">Хэрэв сайт таны нууц үгийг хулгайлахаар оролдох эсвэл таныг аюултай файл татах үед Chromium URL-г хуудасны бага зэрэг контентын хамт Аюулгүй үзэх рүү мөн илгээж болзошгүй</translation>
<translation id="6338684070520405381">Ecosia нууц үгсийг засахаар оролдож байна.</translation>
<translation id="2899530016847324742">{NUM_DEVICES,plural, =1{Ecosia HID төхөөрөмжтэй холбогдсон байна}other{Ecosia HID төхөөрөмжүүдтэй холбогдсон байна}}</translation>
<translation id="3032706164202344641">Chromium таны нууц үгсийг шалгах боломжгүй байна. Дараа дахин оролдоно уу.</translation>
<translation id="1762318218111418450">Ecosia-д өгөгдөл нэмэх нь ...</translation>
<translation id="3038232873781883849">Суулгахыг хүлээж байна...</translation>
<translation id="9178613517891824246">Алдаа ослын тайлан болон <ph name="UMA_LINK"/>-ыг Ecosia рүү илгээх замаар Ecosia-ыг улам сайжруулахад тусална уу.</translation>
<translation id="3101560983689755071">Таны хөтчийн түүх таны хардаг зар болон доор тооцоолсны дагуу сонирхолд нөлөөлнө. Таны нууцлалыг хамгаалахын тулд Chromium тодорхойгүй хугацаанд сар бүр таны сонирхлыг автоматаар устгана. Та сонирхлыг хасаагүй бол сэргээх боломжтой.</translation>
<translation id="7691143774653486474">Програм суулгагч нь архивыг задалж үл чадсан тул Ecosia-г дахин татаж авна уу.</translation>
<translation id="1318059253725731825">Ecosia нь таны микрофоныг ашиглаж байна.</translation>
<translation id="8282620071565190081">Ecosia-г дахин эхлүүлэх</translation>
<translation id="5500958820122281144">Холбоосыг Ecosia-н нууцлалтай цонхонд нээх</translation>
<translation id="3697186779259384993">Ecosia-н шинэ профайлаа тохируулна уу</translation>
<translation id="3216284932113164802">Ecosia-д гамтал гарлаа. Дахин эхлүүлэх үү?</translation>
<translation id="4409756430498035341">Ecosia таны төхөөрөмжийг экспортлох хүсэлтэй байна.</translation>
<translation id="7602423871874451395">Ecosia нь өөрийн өгөгдлийн сан руу уншуулж бас бичиж чадахгүй байна: <ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="3283186697780795848">Chromium <ph name="PRODUCT_VERSION"/> хувилбарыг суулгасан</translation>
<translation id="3286538390144397061">Одоо дахин эхлүүлнэ үү</translation>
<translation id="4735588186234302898">Ecosia-ийн API түлхүүр байхгүй байна. Ecosia-ийн зарим функц идэвхгүй болно.</translation>
<translation id="3296368748942286671">Chromium-ийг хаахад ард байгаа програмуудыг ажиллуулсан хэвээр бай.</translation>
<translation id="812798451698099271">Энэ бүртгэлтэй Ecosia-н профайл аль хэдийн байна</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="4781882243268600858">Ecosia-н одоо байгаа профайл руу сэлгэх үү?</translation>
<translation id="3412460710772753638">Энэ төхөөрөмж дээрх Нууц үгний менежерт</translation>
<translation id="1914619467562029368">{COUNT,plural, =1{Таны администратор Ecosia-г 1 минутаас дээш хугацаагаар идэвхгүй байсан тохиолдолд хаахаар тохируулсан.}other{Таны администратор Ecosia-г # минутаас дээш хугацаагаар идэвхгүй байсан тохиолдолд хаахаар тохируулсан.}}</translation>
<translation id="4170280082681554565">Та Ecosia профайлаар Ecosia-н бүх зүйлээ тусгаарлах боломжтой. Найзууд, гэр бүлдээ профайл үүсгэх эсвэл ажил болон дуртай зүйлээ хооронд нь хуваагаарай.</translation>
<translation id="347328004046849135">Таныг алдагдсан нууц үгээр нэвтрэх үед Chromium танд мэдэгдэнэ</translation>
<translation id="3474745554856756813">Энэ нь төхөөрөмжөөс <ph name="ITEMS_COUNT"/> зүйл устгана. Өгөгдлөө дараа сэргээхийн тулд Chromium-д <ph name="USER_EMAIL"/>-р нэвтэрнэ үү.</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> Ecosia-н профайлууд хооронд сэлгэх боломжтой</translation>
<translation id="8534308095039131078">Ecosia-н бүх цонхыг хаасны дараагаар дахин хандана уу.</translation>
<translation id="3533435340678213462">Таны нууцлалыг хамгаалахын тулд бид таны 4 долоо хоногоос дээш хугацаатай сонирхлыг автоматаар устгадаг. Таныг үргэлжлүүлэн үзэх үед сонирхол нь жагсаалтад дахин харагдаж магадгүй. Эсвэл та Chromium-г харгалзан үзэхгүй байхыг хүсэж буй сонирхлоо хасах боломжтой.</translation>
<translation id="3567254597502212821">Таны хөтчийн түүх буюу энэ төхөөрөмж дээр Chromium-г ашиглан зочилсон сайтуудын бүртгэл.</translation>
<translation id="2804130178228362015">Таны компьютер дээр аюултай программ хангамж байна. Ecosia таны хөтчийн ажиллагааг дахин хэвийн болгохын тулд үүнийг устгах, таны тохиргоог сэргээх болон өргөтгөлүүдийг идэвхгүй болгох боломжтой.</translation>
<translation id="7375011918167125899">Өөр бүртгэл аль хэдийн нэвтэрсэн байна. Таны хөтчийн үзэлтийг тусад нь байлгахын тулд Ecosia танд өөрийн гэсэн профайл үүсгэж өгөх боломжтой.</translation>
<translation id="2128110540135015661">Энэ хэрэглэгчийн хөтчийн өгөгдлийг энэ төхөөрөмжөөс устгана. Өгөгдлийг сэргээхийн тулд Ecosia-д <ph name="USER_EMAIL"/>-р нэвтэрнэ үү.</translation>
<translation id="1323499021727766710">{COUNT,plural, =0{Ecosia-н шинэ шинэчлэлт боломжтой байгаа бөгөөд таныг дахин ачаалах үед түүнийг хэрэгжүүлэх болно.}=1{Ecosia-н шинэ шинэчлэлт боломжтой байгаа бөгөөд таныг дахин ачаалах үед түүнийг хэрэгжүүлэх болно. Таны нууцлалтай цонхыг дахин нээхгүй.}other{Ecosia-н шинэ шинэчлэлт боломжтой байгаа бөгөөд таныг дахин ачаалах үед түүнийг хэрэгжүүлэх болно. Таны # нууцлалтай цонхыг дахин нээхгүй.}}</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/>-с Android утсандаа дугаар илгээхийн тулд хоёр төхөөрөмжийнхөө аль алинаас нь Ecosia-д нэвтэрнэ үү.</translation>
<translation id="3685209450716071127">Chromium таны нууц үгсийг шалгах боломжгүй байна. Интернэт холболтоо шалгаж үзнэ үү.</translation>
<translation id="5902103164685487225">Ecosia-н сонирхсон зарын тохируулгын талаар нэмэлт мэдээлэл авах</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{Энэ шинэчлэлтийг хэрэгжүүлэхийн тулд Ecosia-г дахин ачаалахыг таны администратор танаас хүсэж байна}=1{Энэ шинэчлэлтийг хэрэгжүүлэхийн тулд Ecosia-г дахин ачаалахыг таны администратор танаас хүсэж байна. Таны нууцлалтай цонхыг дахин нээхгүй.}other{Энэ шинэчлэлтийг хэрэгжүүлэхийн тулд Ecosia-г дахин ачаалахыг таны администратор танаас хүсэж байна. Таны # нууцлалтай цонхыг дахин нээхгүй.}}</translation>
<translation id="489671036945006830">Холбоосыг шинэ Ecosia болон табад нээх</translation>
<translation id="3728336900324680424">Chromium хаяг оруулах хэсэгт зөвлөмж харуулахын тулд таны Драйвт хандах болно</translation>
<translation id="6107290018380796650">Ecosia танд веб сайтад байгаа дугаар дээр дараад Skype-тай дуудлага хийх боломжийг олгоно.</translation>
<translation id="3959732324458144441">EcosiaOS систем</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - Ecosia</translation>
<translation id="386822487697155367">ChromiumOS-тэй холбоотой тусламж авах</translation>
<translation id="6391863622742187823">Ecosia хөтчийн зүйлсээ <ph name="ACCOUNT_EMAIL"/>-с авна уу</translation>
<translation id="8544776492099331022">Ecosia-г өөрчилж, хянана уу. Та ямар нэг зүйлд анхаарлаа хандуулах шаардлагатай байна. Дэлгэрэнгүй мэдээлэл авахын тулд товшино уу.</translation>
<translation id="4871843754042758264">Ecosia-г нээх мөн хөтөчийг ашиглаж эхлэхийн тулд өөрийн нэр дээр дарна уу.</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> Ecosia-н энэ профайлд аль хэдийн нэвтэрсэн байна. Таны хөтчийн үзэлтийг тусад нь байлгахын тулд Ecosia танд өөрийн гэсэн профайл үүсгэж өгөх боломжтой.</translation>
<translation id="4070480171055648632">Таны бүртгэлийг <ph name="MANAGER_NAME"/> удирддаг. Танай администратор энэ Ecosia хөтчийн профайл болон үүний хавчуурга, түүх, нууц үг зэрэг өгөгдлийг харах болон засах боломжтой.</translation>
<translation id="1047556320128249268">Ecosia нь нууц үгс хуулахыг оролдож байна. Үүнийг зөвшөөрөхийн тулд Windows-н нууц үгээ бичнэ үү.</translation>
<translation id="4997668724897475215">Энэ файл аюултай байж магадгүй тул Ecosia үүнийг скан хийхийг зөвлөж байна</translation>
<translation id="3997429360543082038">ChromiumOS-н тухай</translation>
<translation id="5311911269004680646">EcosiaOS-г <ph name="BEGIN_LINK_LINUX_OSS"/>Linux-н хөгжүүлэлтийн орчин <ph name="END_LINK_LINUX_OSS"/> болох нэмэлт <ph name="BEGIN_LINK_CROS_OSS"/>нээлттэй эх кодын программ хангамжаар<ph name="END_LINK_CROS_OSS"/> боломжтой болгосон.</translation>
<translation id="4036079820698952681"><ph name="BEGIN_LINK"/>Одоогийн тохиргоог<ph name="END_LINK"/> мэдэгдэж Chromium-г сайжруулахад тусална уу</translation>
<translation id="4050175100176540509">Хамгийн сүүлийн хувилбар дээр аюулгүй байдлын чухал сайжруулалт болон шинэ функцийг санал болгож байна.</translation>
<translation id="4148957013307229264">Суулгаж байна...</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - Сүлжээнд нэвтрэх - Ecosia</translation>
<translation id="7782767522222146179">Ecosia-д зориулсан гайхалтай апп, тоглоом, өргөтгөл болон дэлгэцийн зургуудыг олж сонирхоорой.</translation>
<translation id="4216212958613226427">Энэ хэлийг Chromium UI-г харуулахад ашигладаг</translation>
<translation id="4222932583846282852">Цуцалж байна...</translation>
<translation id="8384922154025337808">Та өөрийн Ecosia өгөгдлийг энэ хаягтай холбох хүсэлтэй байна уу?</translation>
<translation id="4271805377592243930">Chromium-с тусламж авах</translation>
<translation id="3305517118160815955">Гэнэтийн асуудлаас болж суулгах ажиллагаа амжилтгүй боллоо. Хэрвээ Ecosia яг одоо ажиллаж байгаа бол хаагаад дахин оролдож үзнэ үү.</translation>
<translation id="4304713468139749426">Нууц үгний менежер</translation>
<translation id="4334294535648607276">Татаж дууслаа.</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> танаас энэ төхөөрөмжийг ашиглахаасаа өмнө дараах үйлчилгээний нөхцөлийг уншиж, зөвшөөрөхийг шаардаж байна. Эдгээр нөхцөл нь EcosiaOS-н нөхцөлийг өргөтгөх, өөрчлөх эсвэл хязгаарлахгүй.</translation>
<translation id="88039520238670574">Ямар ч байсан Ecosia-с гарах уу?</translation>
<translation id="4586967042094107073">Ecosia-г цаана ажиллуулахыг зөвшөөрөх</translation>
<translation id="4817913198787198451">Ecosia-ыг гүйцэтгэх ба хянах</translation>
<translation id="4427306783828095590">Сайжруулсан хамгаалалт нь фишинг болон хортой кодыг блоклохын тулд илүү ихийг хийдэг</translation>
<translation id="1859120614572957305">Ecosia-д тавтай морилно уу; хөтчийн шинэ цонхыг нээсэн</translation>
<translation id="4544142686420020088">Chromium-г шинэчлээгүй, ямар нэг алдаа гарлаа. <ph name="BEGIN_LINK"/>Chromium-г шинэчлэхтэй холбоотой асуудлууд болон амжилтгүй болсон шинэчлэлтүүдийг засна уу.<ph name="END_LINK"/></translation>
<translation id="8685318202174822382">Ecosia-н шинэ профайлд үргэлжлүүлэх үү?</translation>
<translation id="4567424176335768812">Та <ph name="USER_EMAIL_ADDRESS"/> ингэж нэвтэрсэн байна. Одоо та өөрийн нэвтэрсэн бүх төхөөрөмжүүд дээрээ хайлтын жагсаалт, түүх болон бусад тохиргоонууд руугаа нэвтэрч болно.</translation>
<translation id="4594305310729380060">Энэ төхөөрөмж дээрх Нууц үгний менежерт</translation>
<translation id="2636091632287013185">Ecosia App</translation>
<translation id="4613863813562375431">ChromiumOS-н хувилбар</translation>
<translation id="4621240073146040695">Удахгүй шинэчилж дууслаа! Chromium-н шинэчлэлийг дуусгахын тулд дахин ачаалж эхлүүлнэ үү.</translation>
<translation id="1676748966275099244">Анхааруулга: Ecosia өргөтгөлүүдийг таны хөтчийн түүхийг бичихээс хамгаалж чадахгүй. Энэ өргөтгөлийг Нууцлалтай горимд идэвхгүй болгохын тулд энэ сонголтыг болиулна уу.</translation>
<translation id="4673151026126227699">Хэрэв та мөн Chromium-н ашиглалтын тайланг хуваалцвал тэдгээр тайланд таны зочилсон URL багтана</translation>
<translation id="1384607180773886645">Хувийн мэдээллийг (<ph name="HOST_NAME"/>) өөр компьютер дээр өөр Ecosia үйлдэлд (<ph name="PROCESS_ID"/>) ашиглаж байна гэж харагдаж байна. Ecosia-аас хувийн мэдээллийг түгжсэн байгаа учраас үүнийг өөр зүйлд ашиглах боломжгүй юм. Хэрэв та өөр ямар ч үйлдэлд энэ хувийн мэдээллийг ашиглахгүй байгаа гэдэгт та итгэлтэй байгаа бол хувийн мэдээллээ цоожилж Ecosia-ыг дахин эхлүүлж болно.</translation>
<translation id="4680828127924988555">Суулгахыг цуцлах</translation>
<translation id="4727435569202742773">Хэн нэгэн энэ компьютерт <ph name="ACCOUNT_EMAIL_LAST"/> бүртгэлээр Ecosia-д нэвтэрсэн байна. Мэдээллээ тусад нь хадгалахын тулд Ecosia-н шинэ хэрэглэгч үүсгэнэ үү.</translation>
<translation id="864244542982029641">Ямар ч байсан Ecosia-г орхих уу?</translation>
<translation id="1025044809499013222">Ecosia-н аюулгүй байдлын тусгай шинэчлэлт хийгдэж дууслаа. Одоо дахин эхлүүлнэ үү. Бид таны табыг сэргээх болно.</translation>
<translation id="824192326282906244">Та Ecosia-н тохиргоо хэсэгт хүссэн үедээ бодлоо өөрчлөх боломжтой. Туршилтын хугацаа нь зарыг хүргэдэг одоогийн аргын хамт үргэлжлэх бөгөөд ингэснээр та өөрчлөлтүүдийг тэр даруй харахгүй.</translation>
<translation id="4788777615168560705">Chromium таны нууц үгсийг шалгах боломжгүй байна. 24 цагийн дараа дахин оролдоно уу эсвэл <ph name="BEGIN_LINK"/>өөрийн Google Бүртгэл дэх нууц үгсийг шалгана уу<ph name="END_LINK"/>.</translation>
<translation id="3543284013834505767">Энэ нь Ecosia хайлтад ашигладаг зөв бичгийн ижил алдаа шалгагчийг ашигладаг. Таны хөтчид бичсэн текстийг Ecosia-д илгээдэг. Та энэ ажиллах төлөвийг хүссэн үедээ тохиргоонд өөрчилж болно</translation>
<translation id="4154538917942874814">MDNS урсгалыг зөвшөөрөхийн тулд Ecosia-д зориулсан хөндлөнгийн дүрэм.</translation>
<translation id="2159716220295742156">&amp;Ecosia-г шинэчлэхийн тулд дахин ачаалах</translation>
<translation id="2234042158691635795">Ecosia нь суурь горимд байна.</translation>
<translation id="1869027055332251164">Зочид Ecosia-ийг ашигласнаар хамгийн сүүлийн үеийн мэдээллийг авна.</translation>
<translation id="6761747850241550887">Өөрийгөө Ecosia руу нэмэх</translation>
<translation id="3708834841667355707">Ecosia нь сайтуудад таны өгөгдлийг бага хэмжээгээр ашиглан ижил үзэх туршлагыг хүргэх боломжийг олгох шинэ онцлогуудыг судалж байна</translation>
<translation id="5224391634244552924">Хадгалсан ямар ч нууц үг алга. Таныг нууц үгсээ хадгалах үед Chromium тэднийг шалгах боломжтой.</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> Ecosia-н энэ профайлд аль хэдийн нэвтэрсэн байна. Энэ нь <ph name="USER_EMAIL_ADDRESS"/>-д Ecosia-н шинэ профайл үүсгэнэ</translation>
<translation id="5277894862589591112">Өөрчлөлтөө хэрэгжүүлэхийн тулд Chromium-г дахин ажиллуулна уу</translation>
<translation id="5296845517486664001">Туршилтын хугацаанд байгаа бөгөөд Chromium таныг санамсаргүй байдлаар идэвхтэй туршилтын хугацаанд байрлуулсан бол таны хөтчийн түүх доор тооцоолсны дагуу таны хардаг зар болон сонирхолд нөлөөлнө. Таны нууцлалыг хамгаалахын тулд Chromium тодорхойгүй хугацаанд сар бүр таны сонирхлыг устгана.</translation>
<translation id="7105712012505419722">Та удирдан ажиллаж буй хаягт нэвтэрч байгаагаас гадна таны Ecosia профайлыг хянах эрхийг системийн ажилтанд шилжүүлж байна. Таны апп, хавчуурга, түүх, нууц үг болон бусад тохиргоо гэх мэт таны Ecosia өгөгдлийг <ph name="USER_NAME"/>-тэй холбох болно. Та энэхүү өгөгдлийг Ecosia Accounts Dashboard-р дамжуулан устгах боломжтой боловч та энэхүү өгөгдлийн өөр хаягтай холбох боломжгүй байна. <ph name="LEARN_MORE"/></translation>
<translation id="5386450000063123300">Chromium-г шинэчилж байна (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">Chromium-д нэвтрэхийг зөвшөөрөх</translation>
<translation id="8447746441670667471">Ашиглах боломжтой Ecosia-ийн шинэ хувилбар байна.</translation>
<translation id="330264384086604869">Ecosia-аас устга</translation>
<translation id="3138995062177413515">{0,plural, =0{Ecosia-г одоо хаана.}=1{Ecosia-г 1 секундийн дараа хаана.}other{Ecosia-г # секундийн дараа хаана.}}</translation>
<translation id="5581150090232500900">Ecosia-ыг өөрийн анхдагч веб хөтөч болгон тохируулах</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia Бета</translation>
<translation id="3307959934543585795">Үүнийг Linux дистрибьютер дээр цаашид дэмжихгүй тул Ecosia буруу ажиллаж болзошгүй</translation>
<translation id="6558895515431832002">Таны байршлыг энэ сайттай хуваалцахын тулд Ecosia-д таны байршилд хандах зөвшөөрөл шаардлагатай</translation>
<translation id="5487574057737591516">Таны нууцлалыг хамгаалахын тулд бид таны 4 долоо хоногоос дээш хугацаатай сонирхлыг автоматаар устгадаг. Таныг үргэлжлүүлэн үзэх үед сонирхол нь жагсаалтад дахин харагдаж магадгүй. Мөн Chromium үүнийг буруу тооцоолсон эсвэл та тодорхой зарыг харахыг хүсэхгүй байвал та сонирхлыг хасах боломжтой.</translation>
<translation id="5279514147510747661">Ecosia нь хамгийн сүүлийн үеийн системийн шинэчлэлтүүдийг суулгаж байгаа тул түр хүлээнэ үү.</translation>
<translation id="5066194399237265772">Ecosia нь нууц үгсийг засах гэж оролдож байна. Үүнийг зөвшөөрөхийн тулд Windows-н нууц үгээ бичнэ үү.</translation>
<translation id="5527463683072221100">PDF-г Chromium-д нээх</translation>
<translation id="5614091477838198795">Асаалттай үед таныг мөн Chromium-с гаргана</translation>
<translation id="7348818664647668234">{0,plural, =0{Ecosia-н шинэчлэлт боломжтой байна}=1{Ecosia-н шинэчлэлт боломжтой байна}other{Ecosia-н шинэчлэлт # хоногийн турш боломжтой байсаар байна}}</translation>
<translation id="5675757883980078189">Ecosia-д Windows 7 болон үүнээс дээших хувилбарууд шаардлагатай.</translation>
