<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="si">
<translation id="4033006861724039519">ස්ථාපන ගබඩාව නරක් වී හෝ වැරදිය. කරුණාකර නැවත Ecosia බාගන්න.</translation>
<translation id="1026101648481255140">ස්ථාපනය නැවත ආරම්භ කරන්න</translation>
<translation id="8296565077892323223">Ecosia අභිරුචිකරණය සහ පාලනය කරන්න. යාවත්කාලීන ලද හැකිය.</translation>
<translation id="2804130178228362015">ඔබගේ පරිගණකයෙහි හානිකර මෘදුකාංග ඇත. ඔබේ බ්‍රවුසරය නැවතත් සාමාන්‍ය පරිදි ක්‍රියා කරවීමට, Ecosia හට එය ඉවත් කිරීම, ඔබේ සැකසීම් ප්‍රතිසාධන කිරීම, සහ දිගු අබල කිරීම කළ හැක.</translation>
<translation id="1065672644894730302">ඔබේ තේරීම් කියවිය නොහැක.

ඇතැම් විශේෂාංගයන් නොපැවතිය හැකි අතර තේරීම් වල සිදුකරන වෙනස්ක්ම් නොසුරැකෙනු ඇත.</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> පෙරදී Ecosia භාවිත කරමින් තිබිණි</translation>
<translation id="2000339487270823788">මේ ඔබේ Ecosiaය.</translation>
<translation id="8078678931242443254">Ecosia භාවිත කරමින් සිටින්නේ කවුද?</translation>
<translation id="6346154190168496057">Ecosia යාවත්කාලීන කළ නොහැක</translation>
<translation id="1152920704813762236">ChromeOS ගැන</translation>
<translation id="7303930050538184306">&amp;Ecosia තුළ විවෘත කරන්න</translation>
<translation id="1203500561924088507">ස්ථාපනය කිරීම වෙනුවෙන් ස්තුතියි. ඔබ <ph name="BUNDLE_NAME"/> භාවිත කිරීමට පෙර ඔබගේ බ්‍රවුසරය යළි ඇරඹිය යුතුය.</translation>
<translation id="6650631555168164414">ඔබට Ecosia වෙතින් උපරිමය භුක්ති විඳිය හැක</translation>
<translation id="1523806373970723624">&amp;Ecosia යාවත්කාලීන කිරීමට යළි දියත් කරන්න</translation>
<translation id="5279514147510747661">කරුණාකර Ecosia නවතම පද්ධති යාවත්කාලීන ස්ථාපනය කරන අතරතුර රැඳී සිටින්න.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> හට ඔබ මෙම උපාංගය භාවිත කිරීමට පෙර පහත සේවා නියම කියවා පිළිගැනීමට අවශ්‍යයි. මෙම නියම EcosiaOS Flex නියම පුළුල් කිරීම, වෙනස් කිරීම හෝ සීමා කිරීම නොකරයි.</translation>
<translation id="8067423333018528301">EcosiaOS හට පිරීමේ දෝෂයක් හේතුවෙන් ඔබගේ දත්ත සමමුහුර්ත කළ නොහැකි විය.</translation>
<translation id="2926455547526018397">Ecosia බීටා</translation>
<translation id="2995860351618948435">මෙම පරිගණකය සතුව දැනටමත් Ecosia නවතම සංස්කරණය පවතී. මෘදුකාංගය ක්‍රියා නොකරයි නම්, කරුණාකර Ecosia ඉවත් කර නැවත උත්සහ කරන්න.</translation>
<translation id="824192326282906244">ඔබට Ecosia සැකසීම් තුළ ඕනෑම වේලාවක ඔබගේ අදහස වෙනස් කළ හැකිය. අත්හදා බැලීම් වත්මන් වෙළඳ දැන්වීම් සපයන ආකාරය සමඟ ක්‍රියාත්මක වේ, එබැවින් ඔබ වෙනස් කිරීම් වහාම නොදකිනු ඇත.</translation>
<translation id="4696685525015809740">Ecosia Canary යෙදුම්</translation>
<translation id="3697186779259384993">ඔබගේ නව Ecosia පැතිකඩ අභිරුචිකරණය කරන්න</translation>
<translation id="4062366803229254216">යුගල කිරීම දිගටම කර ගෙන යාමට Ecosia හට බ්ලූටූත් ප්‍රවේශය අවශ්‍යයි. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="2441303983090031276">අතිරේක <ph name="BEGIN_LINK_CROS_OSS"/>විවෘත මූලාශ්‍ර මෘදුකාංග<ph name="END_LINK_CROS_OSS"/> මගින් EcosiaOS සඳහා හැකියාව ලබා දී ඇත.</translation>
<translation id="5598074261782651109">Ecosia යාවත් කරන්න</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> දැනටමත් මෙම Ecosia පැතිකඩට පුරා ඇත. මෙය <ph name="USER_EMAIL_ADDRESS"/> සඳහා නව Ecosia පැතිකඩක් තනනු ඇත</translation>
<translation id="4943938785458240142">Ecosia ඔබේ කැමරාව භාවිතා කරයි.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> අනතුරුදායක විය හැකිය, එම නිසා Ecosia එය අවහිර කර ඇත.</translation>
<translation id="1597911401261118146">ඔබගේ මුරපද දත්ත කඩ කිරීම්වලින් සහ අනෙකුත් ආරක්ෂක ගැටලුවලින් සුරක්ෂිතද යන්න පරීක්ෂා කිරීමට, <ph name="BEGIN_LINK"/>Chrome වෙත පුරන්න<ph name="END_LINK"/>.</translation>
<translation id="5591151834004774364">Ecosia මෙම ලේඛනාරක්ෂිත ගොනුව අවහිර කළේ එය අනිෂ්ට මෘදුකාංග සැඟවිය හැකි බැවිනි</translation>
<translation id="1597547208646178091">Ecosia වඩාත් ආරක්ෂිත කිරීම සඳහා, අප විසින් <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> ලැයිස්තුගත කර නොමැති හා ඔබේ දැනුමෙන් තොරව එක් කර ඇති ඇතැම් දිගු අබල කර ඇත.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>ඔබට ඔබගේ දත්ත කළමනාකරණය කළ හැකි ආකාරය:<ph name="END_BOLD"/> ඔබගේ පෞද්ගලිකත්වය ආරක්ෂා කිරීමට, අපි සති 4කට වඩා පැරණි ඔබගේ ලැදිකම් ස්වයංක්‍රියව මකමු. ඔබ දිගටම බ්‍රවුස් කරන විට, ලැදිකමක් නැවත ලැයිස්තුවේ දිස් විය හැකිය. නැතහොත් Ecosia සලකා බැලීමට අවශ්‍ය නොවන ලැදිකම් ඔබට ඉවත් කළ හැකිය.</translation>
<translation id="1628000112320670027">Chrome සමගින් උදවු ලබා ගන්න</translation>
<translation id="1640672724030957280">බාගනිමින්...</translation>
<translation id="1662146548738125461">ChromeOS Flex පිළිබඳ</translation>
<translation id="5500958820122281144">සබැඳිය Ecosia අ&amp;ප්‍රසිද්ධ කවුළුව තුළ විවෘත කරන්න</translation>
<translation id="7602423871874451395">Ecosia හට එහි දත්ත නාමාවලිය කියවීම හෝ ලිවීම කළ නොහැක:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{ඔබේ පරිපාලක Ecosia මිනිත්තු 1කට වඩා අක්‍රිය නම් එය වැසීමට වින්‍යාස කර ඇත.}one{ඔබේ පරිපාලක Ecosia මිනිත්තු #කට වඩා අක්‍රිය නම් එය වැසීමට වින්‍යාස කර ඇත.}other{ඔබේ පරිපාලක Ecosia මිනිත්තු #කට වඩා අක්‍රිය නම් එය වැසීමට වින්‍යාස කර ඇත.}}</translation>
<translation id="3939060118711873999">Ecosia යනු ආලෝකයේ වේගය, ස්ථාවරත්වය, සහ භාවිතයට පහසුව සහිත වෙබ් පිටු හා යෙදුම් ධාවනය වන වෙබ් බ්‍රව්සරයකි. Ecosia තුළට සවි කරන ලද මැල්වෙයා සහ ෆිෂිං සහිත වෙබ් වඩා ආරක්ෂිත බ්‍රව්ස් කරන්න.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia පැයකින් යළි දියත් වෙයි}one{Ecosia පැය # කින් යළි දියත් වෙයි}other{Ecosia පැය # කින් යළි දියත් වෙයි}}</translation>
<translation id="4021894801595982809">Ecosia මෙම මුරපදය ඔබගේ Ecosia ගිණුමට සුරකිනු ඇත. ඔබට එය මතක තබා ගැනීමට සිදු නොවේ.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">ඔබ ඔබගේ <ph name="TARGET_DEVICE_NAME"/> හි Ecosia වෙත පුරා ඇති බව සහතික කර ගෙන අනතුරුව නැවත යැවීමට උත්සාහ කරන්න.</translation>
<translation id="1812689907177901597">මෙය අක්‍රිය කිරීමෙන්, ඔබට Chrome වෙත පුරනය නොවී Gmail වැනි Google වෙබ් අඩවිවලට පුරනය විය හැක.</translation>
<translation id="5055330219314726197">Ecosia හට මෙම අඩවිය සදහා ඔබේ කැමරාවට ප්‍රවේශ වීමට අවසර අවශ්‍යයි</translation>
<translation id="1508200558303644420">Ecosia ඔබේ පෙරනිමි බ්‍රව්සරය නොවේ</translation>
<translation id="8135642897811755229">Ecosia බීටා (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia යල් පැන ගොස් ඇත</translation>
<translation id="1919130412786645364">Chrome පුරනයට ඉඩ දෙන්න</translation>
<translation id="6235917057647038042">අනාගත Ecosia යාවත්කාලීන ලබා ගැනීමට, ඔබට macOS 10.13 හෝ පසු අනුවාදයක් අවශ්‍ය වේ. මෙම පරිගණකය macOS 10.12 භාවිත කරමින් සිටියි.</translation>
<translation id="1953553007165777902">බාගනිමින්... මිනිත්තු <ph name="MINUTE"/>ක් ඉතිරිව ඇත</translation>
<translation id="8608092457636055141">එක් එක් පැතිකඩ පිටුසන්, ඉතිහාසය, මුරපද සහ තවත් දේවල් වැනි එහිම Ecosia තොරතුරු දරයි</translation>
<translation id="2018879682492276940">ස්ථාපනය අසාර්ථක විය. කරුණාකර නැවත උත්සාහ කරන්න.</translation>
<translation id="7375011918167125899">වෙනත් ගිණුමක් දැනටමත් පුරා ඇත. ඔබගේ බ්‍රවුස් කිරීම වෙනම තබා ගැනීමට, Ecosia හට ඔබ සඳහා ඔබගේම පැතිකඩක් තැනිය හැකිය.</translation>
<translation id="207902854391093810">අත්හදා බැලීම් ක්‍රියාත්මක විට, වෙළඳ දැන්වීම් මිනුම ඔබ පිවිසෙන අඩවිවලට Chrome වෙතින් තොරතුරු ඉල්ලීමට ඉඩදෙන අතර එය අඩවියට ඔවුන්ගේ වෙළඳ දැන්වීම්වල කාර්ය සාධනය මැනීමට උපකාරී වේ. වෙළඳ දැන්වීම් මිනුම අඩවි අතර හැකි තරම් අඩුවෙන් තතු මාරු කිරීමෙන් හරස්-අඩවි ලුහුබැඳීම සීමා කරයි.</translation>
<translation id="8655983536493871574">අනාගත Ecosia යාවත්කාලීන ලබා ගැනීමට, ඔබට Windows 10 හෝ ඊට පසු අනුවාද අවශ්‍ය වෙයි. මෙම පරිගණකය Windows 8 භාවිත කරයි.</translation>
<translation id="3590393640971125498">EcosiaOS Flex නියම</translation>
<translation id="864244542982029641">කෙසේ වුවත් Ecosia වෙතින් ඉවත් වන්න ද?</translation>
<translation id="3791194915692553395">EcosiaOS Flex අතිරේක <ph name="BEGIN_LINK_CROS_OSS"/>විවෘත මූලාශ්‍ර මෘදුකාංගය<ph name="END_LINK_CROS_OSS"/> මගින්, <ph name="BEGIN_LINK_LINUX_OSS"/>Linux සංවර්ධන පරිසරය<ph name="END_LINK_LINUX_OSS"/> ලෙස හැකියාව ලබා දී ඇත.</translation>
<translation id="2120620239521071941">මෙය අයිතම <ph name="ITEMS_COUNT"/> මෙම උපාංගයෙන් මකනු ඇත. ඔබගේ දත්ත පසුව ලබා ගැනීමට, <ph name="USER_EMAIL"/> ලෙස Chrome වෙත පුරන්න.</translation>
<translation id="2159716220295742156">&amp;Ecosia යාවත්කාලීන කිරීමට යළි දියත් කරන්න</translation>
<translation id="2123055963409958220"><ph name="BEGIN_LINK"/>වත්මන් සැකසීම්<ph name="END_LINK"/> වාර්තා කිරීමෙන් Chrome වඩා යහපත් කිරීමට උදවු වන්න</translation>
<translation id="2131230230468101642">ඔබගේ පෞද්ගලිකත්වය ආරක්ෂා කිරීමට, අපි සති 4කට වඩා පැරණි ඔබගේ ලැදිකම් ස්වයංක්‍රියව මකමු. ඔබ දිගටම බ්‍රවුස් කරන විට, ලැදිකමක් නැවත ලැයිස්තුවේ දිස් විය හැකිය. නැතහොත් ඔබට Chrome සලකා බැලීමට අවශ්‍ය නොවන ලැදිකම් ඉවත් කළ හැකිය.</translation>
<translation id="5404489723475681578">EcosiaOS යළි අරඹන්න</translation>
<translation id="5982672133249369264">දැන් Ecosia යළි අරඹන්න</translation>
<translation id="2174917724755363426">ස්ථාපනය සම්පූර්ණ නැත. ඔබට අවලංගු කිරීමට අවශ්‍ය බව විශ්වාසද?</translation>
<translation id="223889379102603431">Chrome එහි මූල සහතික කළමනාකරණය කරන ආකාරය පිළිබඳ තොරතුරු</translation>
<translation id="4337034173783952373">ඔබගේ සියලු උපාංග හරහා ඔබගේ Ecosia බ්‍රවුසර දේවල්වලට ප්‍රවේශ වීමට, පුරා සමමුහුර්ත කිරීම ක්‍රියාත්මක කරන්න</translation>
<translation id="4735588186234302898">Ecosia API යතුරු අහිමිව ඇත. Ecosia හි ඇතැම් ක්‍රියාකාරීත්ව අක්‍රීය වනු ඇත.</translation>
<translation id="7908111389403807005">ඔබට Ecosia ඉවත්කිරීමට අවශ්‍ය බව විශ්වාසද?</translation>
<translation id="2309047409763057870">මෙය Google Chrome හි දෙවන ස්ථාපනයක් වන අතර, ඔබේ පෙරනිමි බ්‍රව්සරය කළ නොහැකිය.</translation>
<translation id="7613817989637275906">මෙම දිගුවල අනිෂ්ට මෘදුකාංග අඩංගු බව Ecosia සොයා ගෙන ඇත:</translation>
<translation id="7273750863406285983">Ecosia හට මෙම අඩවිය සදහා ඔබේ කැමරාවට සහ මයික්‍රෆෝනයට ප්‍රවේශ වීමට අවසර අවශ්‍යයි</translation>
<translation id="234869673307233423">Chrome හට ඔබේ මුරපද පරීක්‍ෂා කළ නොහැක. පසුව නැවත උත්සාහ කරන්න.</translation>
<translation id="5707346538075088068">මෙම පැතිකඩ භාවිතා කරන විට ජනනය කරන කිනම් හෝ Ecosia දත්ත (පිටුසන්, ඉතිහාසය, මුරපද සහ වෙනත් සැකසීම් වැනි) කාර්යාල පැතිකඩ පරිපාලක විසින් ඉවත් කළ හැකිය. <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">කරගෙන යන්න</translation>
<translation id="3959732324458144441">EcosiaOS පද්ධතිය</translation>
<translation id="3632544319066562282">Ecosia හට ඔබගේ මුරපද නිර්යාත කිරීමට අවශ්‍යය. මේ සඳහා අවසර දීමට ඔබගේ Windows මුරපදය ටයිප් කරන්න.</translation>
<translation id="2485422356828889247">අස්ථාපනය</translation>
<translation id="2534507159460261402">Google Pay (Chrome වෙත පිටපත් කෙරිණි)</translation>
<translation id="2559253115192232574">පසුව, ඔබ පිවිසෙන අඩවියක් ඔබ දකින වෙළඳ දැන්වීම් පුද්ගලිකකරණය කිරීම සඳහා ඔබගේ ලැදිකම් බැලීමට Chrome වෙතින් ඉල්ලිය හැකිය. Chrome හට ලැදිකම් 3ක් දක්වා බෙදා ගත හැකිය.</translation>
<translation id="2563121210305478421">Chrome යළි දියත් කරන්නද?</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> දැනටමත් මෙම Ecosia පැතිකඩට පුරා ඇත. ඔබගේ බ්‍රවුස් කිරීම වෙනම තබා ගැනීමට, Ecosia හට ඔබ සඳහා ඔබගේම පැතිකඩක් තැනිය හැකිය.</translation>
<translation id="80155189677487610">දැන් ඇති Ecosia සංස්කරණයම ස්ථාපනය කළ නොහැක. Ecosia වසා නැවත උත්සාහ කරන්න.</translation>
<translation id="2586406160782125153">මෙය ඔබගේ බ්‍රවුස් කිරීමේ දත්ත මෙම උපාංගයෙන් මකනු ඇත. ඔබගේ දත්ත පසුව ලබා ගැනීමට, <ph name="USER_EMAIL"/> ලෙස Chrome වෙත පුරන්න.</translation>
<translation id="6391863622742187823"><ph name="ACCOUNT_EMAIL"/> වෙතින් ඔබගේ Ecosia බ්‍රවුසරයේ දේවල් ලබා ගන්න</translation>
<translation id="2622559029861875898">Chrome හට යාවත්කාලීන පරීක්‍ෂා කළ නොහැක. ඔබේ අන්තර්ජාල සම්බන්ධතාව පරීක්‍ෂා කිරීමට උත්සාහ කරන්න.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="7774247008790177839">සබැඳිය නව Ecosia ප&amp;ටිත්තක විවෘත කරන්න</translation>
<translation id="9178613517891824246">බිඳ වැටුම් වාර්තා සහ <ph name="UMA_LINK"/> Ecosia වෙත යවමින් Ecosia ක්‍රෝම් දියුණු කිරීමට සහය වන්න</translation>
<translation id="815199437159352723">මෙම දිගුව විසින් ඔබ Ecosia ආරම්භ කරන විට පෙන්වන පිටුව වෙනස් කර ඇත.</translation>
<translation id="1676748966275099244">අනතුරු ඇඟවීමයි: Ecosia හට ඔබගේ බ්‍රවුස් කිරීමේ ඉතිහාසය පටිගත කිරීමෙන් දිගු වැළැක්විය නොහැකිය. මෙම දිගුව අප්‍රසිද්ධ ප්‍රකාරය තුළ අබල කිරීමට, මෙම විකල්පය තේරීම ඉවත් කරන්න.</translation>
<translation id="1831192335802727557">Ecosia හට මෙම අඩවිය සදහා ඔබේ මයික්‍රෆෝනයට ප්‍රවේශ වීමට අවසර අවශ්‍යයි</translation>
<translation id="2770231113462710648">පෙර නිමි බ්‍රවුසරය වෙනස් කරන්න:</translation>
<translation id="2775140325783767197">Chrome හට ඔබේ මුරපද පරීක්‍ෂා කළ නොහැක. ඔබේ අන්තර්ජාල සම්බන්ධතාව පරීක්‍ෂා කිරීමට උත්සාහ කරන්න.</translation>
