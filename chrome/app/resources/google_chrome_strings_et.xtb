<translation id="4586967042094107073">Luba Ecosia'il taustal töötada</translation>
<translation id="2173571365716863400">Ecosia vajab selle saidi puhul mikrofoni kasutamise luba</translation>
<translation id="6161025257729272170">Muutke Ecosia kiiremaks</translation>
<translation id="9165312115453649251">Ecosia OS Flexi süsteem</translation>
<translation id="8685318202174822382">Kas jätkata uuel Ecosia'i profiilil?</translation>
<translation id="6750954913813541382">Õigekirjavigade parandamiseks saadab Chrome brauseris sisestatava teksti Google'ile</translation>
<translation id="88039520238670574">Kas väljuda Ecosia'ist ikkagi?</translation>
<translation id="6794858689789885890">Saidiandmed kustutatakse alati seadmest, kui Chrome’i sulgete</translation>
<translation id="8583650869792032882">Sissetuleku reegel Ecosia Canaryle mDNS-liikluse lubamiseks.</translation>
<translation id="6881299373831449287">Chrome'i värskendamine</translation>
<translation id="6800892712521842441">Ecosia'i beetaversiooni rakendused</translation>
<translation id="5267683457871579197">Ecosia OS-i süsteem</translation>
<translation id="8963533629322868062">Ecosia'i tulevaste värskenduste saamiseks on teil vaja operatsioonisüsteemi Windows 10 või uuemat versiooni. See arvuti kasutab operatsioonisüsteemi Windows 8.1.</translation>
<translation id="2128110540135015661">Selle isiku sirvimisandmed kustutatakse seadmest. Andmete taastamiseks logige Ecosia'i sisse kasutajana <ph name="USER_EMAIL"/>.</translation>
