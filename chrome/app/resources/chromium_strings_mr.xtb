<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="mr">
<translation id="1026101648481255140">इंस्टॉलेशन पुन्‍हा सुरू करा</translation>
<translation id="8933665254023068908">&amp;EcosiaOS अपडेट करण्यासाठी पुन्हा लाँच करा</translation>
<translation id="1065672644894730302">तुमची प्राधान्ये वाचता आली नाहीत.
काही वैशिष्‍ट्ये अनुपलब्ध असू शकतात आणि प्राधान्यांमधील बदल सेव्ह केले जाणार नाहीत.</translation>
<translation id="1098170124587656448">Chromium तुम्हाला डेटा भंग, खराब एक्स्टेंशन आणि बर्‍याच गोष्टींपासून सुरक्षित ठेवण्यात मदत करू शकते</translation>
<translation id="3632544319066562282">Ecosia ला तुमचे पासवर्ड निर्यात करायचे आहेत. हे करू देण्यासाठी तुमचा Windows पासवर्ड टाइप करा.</translation>
<translation id="113122355610423240">Chromium तुमचा डीफॉल्ट ब्राउझर आहे</translation>
<translation id="1131805035311359397">तुमचे पासवर्ड डेटा भंग आणि इतर सुरक्षा समस्यांपासून सुरक्षित आहेत हे तपासण्यासाठी, <ph name="BEGIN_LINK"/>Chromium मध्ये साइन इन करा<ph name="END_LINK"/>.</translation>
<translation id="1185134272377778587">Chromium बद्दल</translation>
<translation id="1203500561924088507">इंस्टॉल केल्याबद्दल धन्यवाद. तुम्ही <ph name="BUNDLE_NAME"/> वापरण्यापूर्वी तुमचा ब्राउझर रीस्टार्ट करणे आवश्यक आहे.</translation>
<translation id="1231839967188101156">सुरू असेल, तेव्हा Chromium हे निष्क्रिय टॅबमधील मेमरी मोकळी करते. हे अ‍ॅक्टिव्ह टॅब आणि इतर अ‍ॅप्सना आणखी कॉंप्युटर स्रोत देते व Chromium ला जलद ठेवते. तुम्ही तुमच्या निष्क्रिय टॅबवर परत गेल्यावर ते पुन्हा आपोआप अ‍ॅक्टिव्ह होतात. <ph name="BEGIN_LINK"/>अधिक जाणून घ्या<ph name="END_LINK"/></translation>
<translation id="2298752889004612764">मेमरी सेव्हरने Ecosia ला आणखी जलद केले आहे</translation>
<translation id="319566061277127356">तुमची नवीन Ecosia प्रोफाइल सेट करा</translation>
<translation id="2549591663512786020">Ecosia पासवर्ड दर्शविण्याचा प्रयत्न करत आहे.</translation>
<translation id="727568860157522676">तुम्ही Ecosia मध्ये साइन इन केले आहे!</translation>
<translation id="6650631555168164414">तुम्ही Ecosia चा पुरेपूर आनंद घेऊ शकता</translation>
<translation id="1861504561909287316">Ecosia टॅब शेअर करा</translation>
<translation id="6896860023874996542">तुमच्या आसपासचा 3D नकाशा तयार करण्यासाठी Ecosia ला तुमचा कॅमेरा अ‍ॅक्सेस करण्याची परवानगी हवी आहे</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{अपडेट लागू करता यावे यासाठी तुम्ही Ecosia पुन्हा लाँच करण्याची तुमच्या ॲडमिनिस्ट्रेटरला गरज आहे}=1{अपडेट लागू करता यावे यासाठी तुम्ही Ecosia पुन्हा लाँच करण्याची तुमच्या ॲडमिनिस्ट्रेटरला गरज आहे. तुमची गुप्त विंडो पुन्हा उघडणार नाही.}other{अपडेट लागू करता यावे यासाठी तुम्ही Ecosia पुन्हा लाँच करण्याची तुमच्या ॲडमिनिस्ट्रेटरला गरज आहे. तुमच्या # गुप्त विंडो पुन्हा उघडणार नाहीत.}}</translation>
<translation id="1625909126243026060">Chromium मधील महत्त्वाच्या गोपनीयता आणि सुरक्षा नियंत्रणांचे पुनरावलोकन करा</translation>
<translation id="931416298178634530">तुम्हाला हे खाते फक्त एकदाच वापरायचे असल्यास, तुम्ही Ecosia ब्राउझरमध्ये <ph name="GUEST_LINK_BEGIN"/>अतिथी मोड<ph name="GUEST_LINK_END"/> वापरू शकता. तुम्हाला दुसऱ्या व्यक्तीसाठी खाते जोडायचे असल्यास, तुमच्या <ph name="DEVICE_TYPE"/> मध्ये <ph name="LINK_BEGIN"/>नवीन व्यक्ती जोडा<ph name="LINK_END"/>.

तुम्ही वेबसाइट आणि अ‍ॅप्सना आधीपासून दिलेल्या परवानग्या या खात्याला लागू होऊ शकतात. तुम्ही तुमची Ecosia खाती <ph name="SETTINGS_LINK_BEGIN"/>सेटिंग्ज<ph name="SETTINGS_LINK_END"/> मध्ये व्यवस्थापित करू शकता.</translation>
<translation id="1640672724030957280">डाऊनलोड करीत आहे...</translation>
<translation id="6876820794875877783">Ecosia ची नवीन, सुरक्षित आवृत्ती उपलब्ध आहे.</translation>
<translation id="1118786556671181978">तुम्हाला जाहिराती दाखवण्यासाठी साइट जे स्वारस्याचे विषय वापरतात, ते तुम्ही पाहू आणि काढून टाकू शकता. तुमच्या अलीकडील ब्राउझिंग इतिहासाच्या आधारे Ecosia तुमच्या स्वारस्यांचा अंदाज लावते.</translation>
<translation id="8454595950895325762">Ecosia बॅकग्राउंडमध्ये सुरू द्या</translation>
<translation id="9125443060066914183">Ecosia अधिक सुरक्षित बनविण्‍यासाठी, आम्‍ही <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> मध्‍ये सूचीबद्ध नसलेले आणि आपल्‍या माहिती शिवाय कदाचित जोडले गेलेले काही विस्‍तार अक्षम केले.</translation>
<translation id="6984747211123632080">Ecosia पुनर्स्थापित करा</translation>
<translation id="185970820835152459">तुम्ही तुमची साइन इन केलेली Google खाती व्यवस्थापित करू शकता. तुमची Google खाती Chromium ब्राउझर, Play Store, Gmail आणि बर्‍याच गोष्टींसाठी वापरली जातात. तुम्हाला कुटुंब सदस्यासारख्या इतर कोणासाठी खाते जोडायचे असल्यास, त्याऐवजी तुमच्या <ph name="DEVICE_TYPE"/> वर नवीन व्यक्ती जोडा. <ph name="LINK_BEGIN"/>अधिक जाणून घ्या<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">साइट तुमच्या स्वारस्यांबद्दलची माहिती Chromium वापरून स्टोअर करू शकतात. उदाहरणार्थ, तुम्ही मॅरेथॉनसाठी शूज खरेदी करण्यासाठी एखाद्या साइटला भेट दिल्यास, ती साइट तुमचे स्वारस्य मॅरेथॉनमध्ये धावणे म्हणून परिभाषित करू शकते. त्यानंतर, तुम्ही एखाद्या शर्यतीसाठी नोंदणी करण्याकरिता वेगळ्या साइटला भेट दिल्यास, ती साइट तुम्हाला तुमच्या स्वारस्यांनुसार धावण्यासाठीच्या शूजची जाहिरात दाखवू शकते.</translation>
<translation id="4239392394637574967">तुम्ही एका व्यवस्थापित खात्यासह साइन इन करत आहात आणि तुमच्या Ecosia प्रोफाइलवर त्याच्या ॲडमिनिस्ट्रेटरला नियंत्रण देत आहात. तुमचा Ecosia डेटा, जसे की तुमचे अ‍ॅप्स, बुकमार्क, इतिहास, पासवर्ड आणि अन्य सेटिंग्ज <ph name="USER_NAME"/> वर कायमच्या बद्ध होतील. तुम्ही Ecosia खाती डॅशबोर्डद्वारे हा डेटा हटवण्यात सक्षम व्हाल, परंतु तुम्ही दुसर्‍या खात्यासह हा डेटा संबद्ध करण्यात सक्षम असणार नाही. तुम्ही तुमचा विद्यमान Ecosia डेटा वेगळी ठेवण्यासाठी एक नवीन पर्यायी प्रोफाइल तयार करू शकता. <ph name="LEARN_MORE"/></translation>
<translation id="1911763535808217981">हे बंद करून, तुम्ही Chromium वर साइन इन न करता Gmail सारख्या Google साइटवर साइन इन करू शकता</translation>
<translation id="18064594488616674">Ecosia असंवादी आहे. आता पुन्‍हा लाँच करायचे?</translation>
<translation id="8047394653992042491">अपडेट लागू करण्यासाठी EcosiaOS रीस्टार्ट करणे आवश्यक आहे.</translation>
<translation id="5337919616446681032">तुम्हाला हे खाते फक्त एकदाच वापरायचे असल्यास, तुम्ही Ecosia ब्राउझरमध्ये अतिथी मोड वापरू शकता. तुम्हाला दुसऱ्या व्यक्तीसाठी खाते जोडायचे असल्यास, तुमच्या <ph name="DEVICE_TYPE"/> मध्ये <ph name="LINK_BEGIN"/>नवीन व्यक्ती जोडा<ph name="LINK_END"/>.

तुम्ही वेबसाइट आणि अ‍ॅप्सना आधीपासून दिलेल्या परवानग्या या खात्याला लागू होऊ शकतात. तुम्ही तुमची Ecosia खाती <ph name="SETTINGS_LINK_BEGIN"/>सेटिंग्ज<ph name="SETTINGS_LINK_END"/> मध्ये व्यवस्थापित करू शकता.</translation>
<translation id="1953553007165777902">डाउनलोड करत आहे... <ph name="MINUTE"/> मिनिट(मिनिटे) शिल्‍लक आहे(आहेत)</translation>
<translation id="1966382378801805537">Chromium डीफॉल्ट ब्राउझर निर्धारित किंवा सेट करू शकत नाही</translation>
<translation id="2008474315282236005">हे या डिव्‍हाइस मधून 1 आयटम हटवेल. नंतर तुमचा डेटा पुनर्प्राप्त करण्‍यासाठी, Chromium मध्ये <ph name="USER_EMAIL"/> म्हणून साइन इन करा.</translation>
<translation id="2018879682492276940">इंस्टॉलेशन करता आले नाही. कृपया पुन्हा प्रयत्न करा.</translation>
<translation id="2020032459870799438">तुमचे इतर पासवर्ड डेटा भंग आणि इतर सुरक्षा समस्यांपासून सुरक्षित आहेत हे तपासण्यासाठी, <ph name="BEGIN_LINK"/>Chromium मध्ये साइन इन करा<ph name="END_LINK"/>.</translation>
<translation id="2049376729098081731">Google सेवांमध्ये आणखी पर्सनलाइझ केलेल्या अनुभवासाठी Chromium इतिहासाचा समावेश करायचा की नाही हे ठरवा</translation>
<translation id="2088953378266246249">Chromium त्याची रूट सर्टिफिकेट कशी व्यवस्थापित करते याबद्दल माहिती</translation>
<translation id="838842459108103907">Ecosia कस्टमाइझ करा</translation>
<translation id="2174917724755363426">इंस्टॉलेशन पूर्ण झाले नाही. तुम्हाला नक्की रद्द करायचे आहे का?</translation>
<translation id="9035946286843935549">Ecosia - नेटवर्क साइन इन - <ph name="PAGE_TITLE"/></translation>
<translation id="6111519389633335269">तुम्ही कॉंप्युटर शेअर केल्यास, मित्र आणि कुटुंब स्वतंत्रपणे ब्राउझ करू शकतात आणि त्यांना पाहिजे तसे Ecosia सेट अप करू शकतात.</translation>
<translation id="2313870531055795960">Chromium मध्ये स्टोअर केलेल्या असुरक्षित साइटच्या सूचीमध्ये URL तपासतो. एखाद्या साइटने तुमचा पासवर्ड चोरण्याचा प्रयत्न केल्यास किंवा तुम्ही हानीकारक फाइल डाउनलोड केल्यावर, Chromium हे पेजवरील काही आशयाच्या समावेशासह, URL सुरक्षित ब्राउझिंग कडे पाठवू शकते.</translation>
<translation id="665177868576952817">येथून तुमच्या Android फोनवर नंबर पाठवण्यासाठी, दोन्ही डिव्हाइसवर Ecosia मध्ये साइन इन करा.</translation>
<translation id="815199437159352723">तुम्ही Ecosia सुरू करता तेव्हा कोणते पेज दर्शविले जाते हे या एक्स्टेंशनने बदलले आहे.</translation>
<translation id="2359808026110333948">सुरू ठेवा</translation>
<translation id="592990842052138727">तुमच्या खात्याचे साइन-इन तपशील कालबाह्य झाल्यामुळे, EcosiaOS ला तुमचा डेटा सिंक करता आला नाही.</translation>
<translation id="9032120646440147804">तुम्ही Ecosia सुरू करता तेव्हा कोणते पेज दर्शविले जाते हे "<ph name="EXTENSION_NAME"/>" एक्स्टेंशनने बदलले आहे.</translation>
<translation id="3554373328288278512">Ecosia ला या साइटसाठी कॅमेरा आणि मायक्रोफोनची परवानगी आवश्यक आहे</translation>
<translation id="6495878830719404098">Ecosia मध्ये</translation>
<translation id="2485422356828889247">अनइंस्टॉल करा</translation>
<translation id="5549921590305750618">फाइल डाउनलोड करण्यासाठी Ecosia ला स्टोरेज ॲक्सेस हवा आहे</translation>
<translation id="9090890391337853620">Ecosia मदतनीस</translation>
<translation id="5707346538075088068">या प्रोफाइलच्या वापरादरम्यान जनरेट केला गेलेला कोणताही Ecosia डेटा (जसे की बुकमार्क, इतिहास, पासवर्ड आणि इतर सेटिंग्जची निर्मिती) कार्य प्रोफाइल अ‍ॅडमिनिस्ट्रेटरला हटवता येतो. <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosia वापरणे पुढे सुरू ठेवा</translation>
<translation id="7280797724682955539">स्‍थापनेदरम्‍यान ऑपरेटिंग सिस्टीम एरर आली. कृपया Ecosia पुन्‍हा डाउनलोड करा.</translation>
<translation id="6960183526681645011">तुम्ही डिव्हाइस शेअर केल्यास, मित्रमैत्रिणी आणि कुटुंब स्वतंत्रपणे ब्राउझ करू शकतात आणि त्यांना हवे तसे Ecosia सेट करू शकतात</translation>
<translation id="5591151834004774364">Ecosia ने ही संग्रहण फाइल ब्लॉक केली, कारण त्यामध्ये मालवेअर लपलेले असू शकते</translation>
<translation id="2381210243314074423">Ecosia वर स्‍वागत आहे, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="385080958066798123">Ecosia टॅब</translation>
<translation id="2718390899429598676">अतिरिक्त सुरक्षिततेसाठी, Chromium तुमचा डेटा एंक्रिप्ट करेल.</translation>
<translation id="2770231113462710648">डीफॉल्ट ब्राउझर यावर बदला:</translation>
<translation id="2799223571221894425">पुन्हा लाँच करा</translation>
<translation id="3952510753191144456">हे <ph name="USER_EMAIL_ADDRESS"/> साठी नवीन Ecosia प्रोफाइल तयार करेल</translation>
<translation id="4199684616787081033">Ecosia मधून काढून टाका...</translation>
<translation id="2850691299438350830">तुम्ही साइन इन केलेले असते तेव्हा, तुम्हाला Chromium वर सुरक्षित ठेवतो आणि इतर Google अ‍ॅप्सवरील तुमच्या सुरक्षेमध्ये सुधारणा करण्यासाठी वापरला जाऊ शकतो</translation>
<translation id="2885378588091291677">टास्क मॅनेजर</translation>
<translation id="7221868538334633215">&amp;Ecosia बद्दल</translation>
<translation id="2915996080311180594">नंतर रीस्टार्ट करा</translation>
<translation id="2928420929544864228">इंस्टॉलेशन पूर्ण झाले.</translation>
