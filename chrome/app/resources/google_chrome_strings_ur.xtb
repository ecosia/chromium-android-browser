<translation id="7655455401911432608">‏آپ کی براؤزنگ کی سرگزشت، ان سائٹس کا ریکارڈ جو آپ اس آلے پر Chrome کا استعمال کر کے ملاحظہ کر چکے ہیں۔</translation>
<translation id="7747138024166251722">انسٹالر ایک عارضی ڈائرکٹری نہیں بنا سکا۔ سافٹ ویئر انسٹال کرنے کیلئے براہ کرم ڈسک کی خالی جگہ اور اجازت کو چیک کریں۔</translation>
<translation id="4871843754042758264">‏Ecosia کھولنے اور براؤزنگ شروع کرنے کیلئے اپنے نام پر کلک کریں۔</translation>
<translation id="2046160555506209000">‏اگر کسی تصویر میں مفید تفصیل موجود نہیں ہے تو Ecosia آپ کے لیے تفصیل فراہم کرنے کی کوشش کرے گا۔ تفصیلات تخلیق کرنے کے لیے، تصاویر Ecosia کو بھیجی جاتی ہیں۔ آپ اسے ترتیبات میں کسی بھی وقت آف کر سکتے ہیں۔</translation>
<translation id="8447746441670667471">‏Ecosia کا ایک نیا ورژن دستیاب ہے۔</translation>
<translation id="5661123757512626239">‏Ecosia کو اس سائٹ کے لیے مقام کی اجازت درکار ہے</translation>
<translation id="7722016758804384514">‏ایسا لگتا ہے کہ پروفائل کسی دوسری Ecosia کارروائی (<ph name="PROCESS_ID"/>) کے ذریعے کسی دوسرے کمپیوٹر (<ph name="HOST_NAME"/>) پر استعمال میں ہے۔  Ecosia نے پروفائل کو مقفل کر دیا ہے تاکہ یہ خراب نہ ہو۔  اگر آپ کو یقین ہے کہ کوئی دیگر کارروائیاں اس پروفائل کا استعمال نہیں کر رہی ہیں تو آپ پروفائل کو غیر مقفل کر سکتے اور Ecosia کو دوبارہ شروع کر سکتے ہیں۔</translation>
<translation id="1047556320128249268">‏Ecosia پاس ورڈز کاپی کرنے کی کوشش کر رہا ہے۔ اس کی اجازت دینے کے لیے اپنا Windows پاس ورڈ ٹائپ کریں۔</translation>
<translation id="4199684616787081033">‏Ecosia سے ہٹائیں…</translation>
<translation id="2402290209407843024">‏غیر متعین خرابی کی وجہ سے انسٹالیشن ناکام ہو گیا۔ براہ کرم Ecosia دوبارہ ڈاؤن لوڈ کریں۔</translation>
<translation id="7845233973568007926">انسٹال کرنے کا شکریہ۔ آپ کو <ph name="BUNDLE_NAME"/> استعمال کرنے سے پہلے اپنا کمپیوٹر لازمی طور سے ری اسٹارٹ کرنا چاہیے۔</translation>
<translation id="7872446069773932638">ڈاؤن لوڈ ہو رہی ہے… <ph name="SECONDS"/> سیکنڈ(سیکنڈز) باقی ہے</translation>
<translation id="2381210243314074423">‏Ecosia میں خوش آمدید، <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">‏اگر آپ ایک کمپیوٹر کا اشتراک کرتے ہیں تو دوست اور خاندان الگ الگ براؤز کر سکتے ہیں اورEcosia کو اپنی مرضی کے موافق ترتیب دے سکتے ہیں۔</translation>
<translation id="4727435569202742773">‏کسی نے قبل ازیں اس کمپیوٹر پر Ecosia میں <ph name="ACCOUNT_EMAIL_LAST"/> کے بطور سائن ان کیا۔ اپنی معلومات علیحدہ رکھنے کیلئے براہ کرم ایک نیا Ecosia صارف بنائیں۔</translation>
<translation id="7917876797003313048">‏آپ اپنے سائن ان کردہ Google اکاؤنٹس کا نظم کر سکتے ہیں۔ آپ کے Google اکاؤنٹس Chrome براؤزر، Play اسٹور، Gmail اور مزید کے لیے استعمال ہوتے ہیں۔ اگر آپ کسی اور کے لیے کوئی اکاؤنٹ شامل کرنا چاہتے ہیں جیسے آپ کی فیملی کا کوئی ممبر تو اس کی بجائے اپنے <ph name="DEVICE_TYPE"/> میں ایک نیا شخص شامل کریں۔ <ph name="LINK_BEGIN"/>مزید جانیں<ph name="LINK_END"/></translation>
