<!DOCTYPE translationbundle>
<translationbundle lang="sw">
<translation id="4033006861724039519">Kumbukumbu ya kisanidi imevurugika au ni batili. Tafadhali pakua Ecosia tena.</translation>
<translation id="1026101648481255140">Endelea na Usakinishaji</translation>
<translation id="8296565077892323223">Weka mapendeleo na udhibiti Ecosia. Sasisho linapatikana.</translation>
<translation id="1761584959558744002">Ili ufute data ya kuvinjari kwenye kifaa hiki pekee, bila kuifuta katika Akaunti yako ya Ecosia, <ph name="BEGIN_LINK"/>ondoka kwenye akaunti ya Ecosia<ph name="END_LINK"/>.</translation>
<translation id="3271929752667225813">Bofya ili ufunge kidirisha cha kuingia katika Ecosia</translation>
<translation id="2056307067005384438">Ili utumie kiendelezi hiki ukitumia <ph name="USER_EMAIL_ADDRESS"/>, ingia katika Ecosia.</translation>
<translation id="1065672644894730302">Mapendeleo yako hayawezi kusomwa.

Baadhi ya vipengele huenda visipatikane na mabadiliko katika mapendeleo hayatahifadhiwa.</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> ilikuwa ikitumia Ecosia awali</translation>
<translation id="2000339487270823788">Hii ndiyo Ecosia yako</translation>
<translation id="8078678931242443254">Ungependa kutumia wasifu gani wa Ecosia?</translation>
<translation id="6346154190168496057">Imeshindwa kusasisha Ecosia</translation>
<translation id="5312730628132049495">Ingia katika akaunti kwenye Ecosia. Iwapo ungependa kuingia katika akaunti mara moja tu, unaweza <ph name="GUEST_LINK_BEGIN"/>kutumia kifaa kama mgeni<ph name="GUEST_LINK_END"/>.</translation>
<translation id="1152920704813762236">Kuhusu ChromeOS</translation>
<translation id="7303930050538184306">na Fungua katika Ecosia</translation>
<translation id="1184145431117212167">Imeshindwa kuweka kwenye kifaa kwa sababu toleo la Windows ulilonalo halitumiki.</translation>
<translation id="4988569127367972482">Ecosia imezuia upakuaji huu kwa sababu aina hii ya faili kwa kawaida haipakuliwi na huenda si salama</translation>
<translation id="1203500561924088507">Asante kwa kusakinisha. Ni lazima uzime kisha uwashe tena kivinjari chako kabla ya kutumia <ph name="BUNDLE_NAME"/>.</translation>
<translation id="4517165228415697265">Ecosia inapendekeza uweke Ecosia iwe kivinjari chaguomsingi</translation>
<translation id="1265739287306757398">Pata Maelezo Zaidi</translation>
<translation id="1523806373970723624">Fungua tena ili usasishe &amp;Ecosia</translation>
<translation id="1290883685122687410">Hitilafu ya kuweka mipangilio: <ph name="METAINSTALLER_EXIT_CODE"/>. <ph name="WINDOWS_ERROR"/></translation>
<translation id="5279514147510747661">Tafadhali subiri Ecosia inaposakinisha sasisho mpya za mfumo.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> inahitaji usome na ukubali Sheria na Masharti yafuatayo kabla ya kutumia kifaa hiki. Masharti haya hayapanui, hayarekebishi wala hayapunguzi Sheria na Masharti ya EcosiaOS Flex.</translation>
<translation id="3592624492063123732">Unaweza kubadilisha ili uone manenosiri kwenye wasifu mwingine wa Ecosia</translation>
<translation id="8067423333018528301">Mfumo wa Uendeshaji wa Ecosia haukusawazisha data yako kutokana na hitilafu wakati wa kuingia katika akaunti.</translation>
<translation id="2926455547526018397">Ecosia Beta</translation>
<translation id="2995860351618948435">Kompyuta hii tayari ina toleo jipya zaidi la Ecosia. Ikiwa programu haifanyi kazi, tafadhali ondoa Ecosia kisha ujaribu tena.</translation>
<translation id="824192326282906244">Unaweza kubadilisha mawazo yako wakati wowote kwenye mipangilio ya Ecosia. Vipindi vya kujaribu vinatekelezwa pamoja na jinsi matangazo yanavyoonyeshwa kwa sasa, hivyo hutaona mabadiliko papo hapo.</translation>
<translation id="3621704124701415791">Ecosia ina programu ya Ecosia Tafsiri iliyojumuishwa ili uweze kutafsiri unapohitaji</translation>
<translation id="5043324171996581320">{COUNT,plural, =0{Ecosia imemaliza kusasisha. Unaweza kutumia toleo jipya zaidi mara tu utakapofungua tena. Baada ya hapo, vichupo vya sasa vitafunguka upya.}=1{Ecosia imemaliza kusasisha. Unaweza kutumia toleo jipya zaidi mara tu utakapofungua tena. Baada ya hapo, vichupo vya sasa vitafunguka upya. Dirisha lako fiche halitafunguka upya.}other{Ecosia imemaliza kusasisha. Unaweza kutumia toleo jipya zaidi mara tu utakapofungua tena. Baada ya hapo, vichupo vya sasa vitafunguka upya. Madirisha fiche yako # hayatafunguka upya.}}</translation>
<translation id="4696685525015809740">Programu za Ecosia Canary</translation>
<translation id="7045045549868370797">Ungependa kuingia kwenye Ecosia?</translation>
<translation id="1691902349688685912">Fungua tena ili umalize kusasisha Ecosia</translation>
<translation id="1497802159252041924">Hitilafu ya kusakinisha: <ph name="INSTALL_ERROR"/></translation>
<translation id="3697186779259384993">Weka wasifu wako mpya wa Ecosia uwe upendavyo</translation>
<translation id="2441303983090031276">Mfumo wa Uendeshaji wa Ecosia umewezeshwa na <ph name="BEGIN_LINK_CROS_OSS"/>programu huria<ph name="END_LINK_CROS_OSS"/> za ziada.</translation>
<translation id="5598074261782651109">Sasisha Ecosia</translation>
<translation id="847970842635669371">Tayari <ph name="EXISTING_USER"/> ameingia katika akaunti kwenye wasifu huu wa Ecosia. Hatua hii itafungua wasifu mpya wa <ph name="USER_EMAIL_ADDRESS"/> kwenye Ecosia</translation>
<translation id="4943938785458240142">Ecosia inatumia kamera yako.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> ni hatari, kwa hivyo Ecosia imeizuia.</translation>
<translation id="1597911401261118146">Ili uangalie kama manenosiri yako ni salama dhidi ya ufichuzi haramu wa data na matatizo mengine ya usalama, <ph name="BEGIN_LINK"/>ingia katika akaunti kwenye Chrome<ph name="END_LINK"/>.</translation>
<translation id="1597547208646178091">Ili kufanya Ecosia salama zaidi, tumezima kiendelezi kinachofuata ambacho hakijaorodheshwa katika <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> na huenda kimeongezwa bila ridhaa yako.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Jinsi unavyoweza kudhibiti data yako:<ph name="END_BOLD"/> Ili kulinda faragha yako, tunafuta kiotomatiki mambo yanayokuvutia ambayo yamehifadhiwa kwa zaidi ya wiki nne. Kadiri unavyoendelea kuvinjari, jambo linalokuvutia linaweza kuonekana tena kwenye orodha. Au unaweza kuondoa mambo yanayokuvutia ambayo usingependa Ecosia iyazingatie.</translation>
<translation id="1628000112320670027">Pata usaidizi wa kutumia Chrome</translation>
<translation id="1640672724030957280">Inapakua...</translation>
<translation id="1662146548738125461">Kuhusu ChromeOS Flex</translation>
<translation id="5500958820122281144">Fungua Kiungo katika Dirisha Fiche la Ecosia</translation>
<translation id="7602423871874451395">Ecosia haiwezi kusoma na kuandika kwenye saraka yake ya data:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="2020747823154282691">Ecosia inaweza kufanya kichupo hiki kisitumike ili kuboresha hali yako ya kuvinjari na kufanya mambo haraka.</translation>
<translation id="3939060118711873999">Ecosia ni kivinjari cha wavuti kinachoendesha kurasa za wavuti na programu kwa kasi ya umeme. Ni ya kasi, thabiti, na rahisi kutumia. Vinjari wavuti kwa usalama zaidi kwa kinga dhidi ya programu hasidi na hadaa iliyojengwa ndani ya Ecosia.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia itafunguka upya ndani ya saa moja}other{Ecosia itafunguka upya ndani ya saa #}}</translation>
<translation id="1722488837206509557">Hii itakuruhusu kuchagua kwenye vifaa vinavyopatikana na kuonyesha maudhui kwenye vifaa hivyo.</translation>
<translation id="4021894801595982809">Ecosia itahifadhi nenosiri hili kwenye Akaunti yako ya Ecosia. Hutahitaji kulikumbuka.</translation>
<translation id="2346323077583431428">Hakikisha kwamba umeingia katika akaunti kwenye Ecosia kwa kutumia <ph name="TARGET_DEVICE_NAME"/> yako kisha ujaribu kutuma tena.</translation>
<translation id="788366290112401490">Njia za mkato hufunguka katika Ecosia</translation>
<translation id="6180968682827452331">Kiendelezi hiki hakitumiki tena. Badala yake, Ecosia inapendekeza ukiondoe.</translation>
<translation id="1812689907177901597">Kwa kuzima kipengele hiki, unaweza kuingia katika tovuti za Google kama vile Gmail bila kuingia katika akaunti ya Chrome</translation>
<translation id="5055330219314726197">Ecosia inahitaji ruhusa ya kufikia kamera yako katika tovuti hii</translation>
<translation id="1508200558303644420">Ecosia si kivinjari chako chaguomsingi</translation>
<translation id="8135642897811755229">Ecosia Beta (mDNS-In)</translation>
<translation id="7268098999602465369">Toleo hili la Ecosia limepitwa na wakati</translation>
<translation id="8228132389897276908">Ili uonyeshe dirisha lako, washa kipengele cha kunasa skrini katika Ecosia kwenye Mapendeleo ya Mfumo</translation>
<translation id="1919130412786645364">Ruhusu kuingia katika akaunti ya Chrome</translation>
<translation id="1953553007165777902">Inapakua... Zimesalia dakika <ph name="MINUTE"/></translation>
<translation id="8116259102110666562">Ecosia hufanya kazi kwenye mifumo mbalimbali ili kukupatia hali ya utumiaji uliyoizoea bila kujali kifaa unachotumia</translation>
<translation id="2001586581944147178">Fanya iwe vigumu watu wanaoweza kufikia shughuli yako kwenye intaneti kuona tovuti unazotembelea. Chrome hutumia muunganisho salama kutafuta anwani ya IP ya tovuti katika DNS (Mfumo wa Majina ya Vikoa).</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{Kiendelezi hiki hakitumiki tena. Ecosia inapendekeza ukiondoe.}other{Viendelezi hivi havitumiki tena. Ecosia inapendekeza uviondoe.}}</translation>
<translation id="8608092457636055141">Kila wasifu una maelezo yake ya Ecosia kama vile alamisho, historia, manenosiri na mengine</translation>
<translation id="2018879682492276940">Imeshindwa kusakinisha. Tafadhali jaribu tena.</translation>
<translation id="686474599126256998">Tunapoweka mipangillio ya idhini ya kufikia akaunti, bado unaweza kutumia Ecosia. Huenda usiweze kufikia baadhi ya nyenzo hadi uwekaji wa mipangilio ukamilike.</translation>
<translation id="2034233344106846793">Chrome husasisha kiotomatiki miunganisho isiyo salama kuwa HTTPS inapowezekana</translation>
<translation id="207902854391093810">Vipindi vya kujaribu vinapowashwa, Upimaji wa tangazo huruhusu tovuti unazotembelea ziombe maelezo kutoka Chrome ambayo yanasaidia tovuti kupima ufanisi wa matangazo yao. Upimaji wa tangazo huzuia ufuatiliaji katika tovuti mbalimbali kwa kuhamisha maelezo machache kadiri iwezekanavyo miongoni mwa tovuti.</translation>
<translation id="8655983536493871574">Ili upate masasisho yajayo ya Ecosia, utahitaji kutumia toleo la Windows 10 au toleo jipya zaidi. Kompyuta hii inatumia toleo la Windows 8.</translation>
<translation id="3590393640971125498">Sheria na masharti ya EcosiaOS Flex</translation>
<translation id="864244542982029641">Ungependa kufunga Ecosia?</translation>
<translation id="3791194915692553395">EcosiaOS Flex imewezeshwa na <ph name="BEGIN_LINK_CROS_OSS"/>programu huria<ph name="END_LINK_CROS_OSS"/> za ziada kama vile, <ph name="BEGIN_LINK_LINUX_OSS"/>mazingira ya wasanidi programu wa Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="2120620239521071941">Hatua hii itafuta vipengee <ph name="ITEMS_COUNT"/> kwenye kifaa hiki. Ili urejeshe data yako baadaye, ingia katika Chrome ukitumia <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">Fungua tena ili Usasishe &amp;Ecosia</translation>
<translation id="2123055963409958220">Saidia kuboresha Chrome kwa kuripoti kuhusu <ph name="BEGIN_LINK"/>mipangilio ya sasa<ph name="END_LINK"/></translation>
<translation id="2126108037660393668">Faili iliyopakuliwa imeshindwa kuthibitishwa.</translation>
<translation id="2985399486579137606">Dhibiti wasifu wa Ecosia</translation>
<translation id="2131230230468101642">Ili kulinda faragha yako, tunafuta kiotomatiki mambo yanayokuvutia ambayo yapo kwenye orodha kwa zaidi ya wiki nne. Kadiri unavyoendelea kuvinjari, jambo linalokuvutia linaweza kuonekana tena kwenye orodha. Au unaweza kuondoa mambo yanayokuvutia ambayo usingependa Chrome iyazingatie.</translation>
<translation id="5404489723475681578">Zima kisha uwashe Mfumo wa Uendeshaji wa Ecosia</translation>
<translation id="5982672133249369264">Tafadhali zima kisha uwashe Ecosia sasa</translation>
<translation id="2174917724755363426">Usakinishaji haujakamilika. Je, una uhakika unataka kughairi?</translation>
<translation id="2190166659037789668">Hitilafu ya ukaguzi wa sasisho: <ph name="UPDATE_CHECK_ERROR"/>.</translation>
<translation id="2199691482078155239">Chrome hukupa udhibiti zaidi wa matangazo unayoona na hudhibiti taarifa kukuhusu ambazo tovuti zinaweza kupata zinapokuonyesha matangazo yaliyowekewa mapendeleo</translation>
<translation id="7347725536241560534">Ili uondoe Akaunti yako ya Ecosia kwenye Ecosia, ondoka kwenye akaunti</translation>
<translation id="223889379102603431">Maelezo kuhusu jinsi Chrome inavyodhibiti vyeti vyake vya msingi</translation>
<translation id="4337034173783952373">Ili uweze kufikia vitu vyako vya kivinjari cha Ecosia kwenye vifaa vyako vyote, ingia katika akaunti kisha uwashe kipengele cha kusawazisha.</translation>
<translation id="4735588186234302898">Funguo za API za Ecosia zinakosekana. Baadhi ya utendaji wa Ecosia utazimwa.</translation>
<translation id="7908111389403807005">Je, una hakika kuwa ungependa kusanidua Ecosia?</translation>
<translation id="2309047409763057870">Huu ni usakinishaji wa pili wa Google Chrome, na haiwezi kufanywa kuwa kivinjari chako chaguomsingi.</translation>
<translation id="7613817989637275906">Ecosia imegundua kwamba viendelezi hivi vina programu hasidi:</translation>
<translation id="7273750863406285983">Ecosia inahitaji ruhusa ya kufikia kamera na maikrofoni yako katika tovuti hii</translation>
<translation id="234869673307233423">Chrome imeshindwa kukagua manenosiri yako. Jaribu tena baadaye.</translation>
<translation id="5707346538075088068">Data yoyote ya Ecosia inayozalishwa unapotumia wasifu huu (kama vile alamisho ulizoweka, historia, manenosiri na mipangilio mingine) inaweza kuondolewa na msimamizi wa wasifu huu wa kazini. <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">Endelea</translation>
<translation id="2390624519615263404">Angalia vipengele vya usalama</translation>
<translation id="3959732324458144441">Mfumo wa EcosiaOS</translation>
<translation id="2526043366208696235">{NUM_DEVICES,plural, =0{Kiendelezi kimoja au zaidi cha Ecosia kilikuwa kinafikia kifaa 1 cha HID}=1{Kiendelezi kimoja au zaidi cha Ecosia kinafikia kifaa 1 cha HID}other{Kiendelezi kimoja au zaidi cha Ecosia kinafikia vifaa # vya HID}}</translation>
<translation id="8172133981892685841">Kiendelezi hiki kinakiuka sera ya Duka la Ecosia kwenye Wavuti na huenda kisiwe salama. Kiondoe kwenye Ecosia ili kisiweze tena kuona na kubadilisha data yako kwenye tovuti unazotembelea, ikiwa ni pamoja na taarifa zako binafsi.</translation>
<translation id="3632544319066562282">Ecosia ingependa kuhamisha manenosiri yako. Andika nenosiri lako la Windows ili uruhusu shughuli hii.</translation>
<translation id="3077076541395306362">Kiendelezi hiki kina programu hasidi na si salama. Kiondoe kwenye Ecosia ili kisiweze tena kuona na kubadilisha data yako kwenye tovuti unazotembelea, ikiwa ni pamoja na taarifa zako binafsi.</translation>
<translation id="2485422356828889247">Ondoa</translation>
<translation id="2513154137948333830">Unahitaji kuwashwa tena: <ph name="INSTALL_SUCCESS"/></translation>
<translation id="2534365042754120737">Ili kulinda data yako, ruhusu Chrome iondoe ruhusa kwenye tovuti ambazo hujazitembelea hivi karibuni. Hali hii haikomeshi arifa.</translation>
<translation id="2280934980919215876">Shirika lako hufunga Ecosia isipotumika kwa <ph name="TIMEOUT_DURATION"/>. Data ya kuvinjari ilifutwa. Data hii inaweza kujumuisha historia, maelezo yaliyojazwa kiotomatiki na vipakuliwa.</translation>
<translation id="2559253115192232574">Baadaye, tovuti unayoitembelea inaweza kuiomba Chrome ili ione mambo yanayokuvutia na iweze kukuonyesha matangazo kulingana na mapendeleo yako. Chrome inaweza kushiriki hadi mambo matatu yanayokuvutia.</translation>
<translation id="2563121210305478421">Ungependa kufungua Chrome tena?</translation>
<translation id="2569974318947988067">Chrome itajaribu kuboresha usogezaji ili utumie HTTPS</translation>
<translation id="7527831132809333552">Shirika lako linadhibiti Ecosia</translation>
<translation id="5824812022890208563">Tayari <ph name="EXISTING_USER"/> ameingia katika akaunti kwenye wasifu huu wa Ecosia. Ili utenganishe shughuli zako za kuvinjari, Ecosia inaweza kukutengenezea wasifu wako mwenyewe.</translation>
<translation id="80155189677487610">Huwezi kusakinisha toleo la Ecosia ambalo tayari linatumika. Tafadhali funga Ecosia na ujaribu tena.</translation>
<translation id="2586406160782125153">Hatua hii itafuta data yako ya kuvinjari kwenye kifaa hiki. Ili urejeshe data yako baadaye, ingia katika Chrome ukitumia <ph name="USER_EMAIL"/>.</translation>
<translation id="6391863622742187823">Pata vitu vinavyohusu kivinjari chako cha Ecosia kwenye <ph name="ACCOUNT_EMAIL"/></translation>
<translation id="259935314519650377">Imeshindwa kuweka akiba ya kisakinishaji kilichopakuliwa. Hitilafu: <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="2622559029861875898">Chrome imeshindwa kukagua masasisho. Jaribu kuangalia muunganisho wako wa Intaneti.</translation>
<translation id="5656828929762509280">Fanikisha mengi ukitumia viendelezi vya Ecosia</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="2649768380733403658">Chrome hukagua kila mara ili kuhakikisha kuwa kivinjari chako kina mipangilio salama zaidi. Tutakufahamisha ikiwa kuna chochote kinachohitaji ukague.</translation>
<translation id="7774247008790177839">Fungua Kiungo katika kichupo kipya cha Ecosia</translation>
<translation id="9178613517891824246">Saidia kuboresha Ecosia kwa kutuma ripoti za kuacha kufanya kazi na <ph name="UMA_LINK"/> kwenda Ecosia</translation>
<translation id="6154325450733409298">Fungua <ph name="URL"/> kwenye kichupo kipya katika Ecosia.</translation>
<translation id="2738871930057338499">Imeshindwa kuunganisha kwenye Intaneti. HTTP 403 Hairuhusiwi. Tafadhali angalia mipangilio yako ya seva mbadala.</translation>
<translation id="1676748966275099244">Onyo: Ecosia haiwezi kuzuia viendelezi kurekodi historia yako ya kuvinjari. Ili uzime kiendelezi hiki katika Hali fiche, usiteue chaguo hili.</translation>
<translation id="1831192335802727557">Ecosia inahitaji ruhusa ya kufikia maikrofoni yako katika tovuti hii</translation>
<translation id="2770231113462710648">Badilisha kivinjari chaguomsingi kiwe:</translation>
<translation id="2775140325783767197">Chrome imeshindwa kukagua manenosiri yako. Jaribu kuangalia muunganisho wako wa Intaneti.</translation>
<translation id="2797864378188255696">Unapoingia katika akaunti za huduma za Google kama Gmail au YouTube ukitumia <ph name="USER_EMAIL"/>, unaweza kuingia katika akaunti kwenye Chrome ukitumia akaunti ile ile.</translation>
<translation id="2799223571221894425">Funga na ufungue</translation>
<translation id="2825024317344269723">Tovuti hatari. Chrome imeondoa arifa.</translation>
<translation id="2846251086934905009">Hitilafu ya kusakinisha: Kisakinishaji hakikukamilisha mchakato. Usakinishaji umeghairiwa.</translation>
<translation id="2847461019998147611">Onyesha Google Chrome katika lugha hii</translation>
<translation id="2853415089995957805">Chrome hupakia mapema kurasa ambazo unaweza kutembelea, ili zipakiwe kwa haraka zaidi unapozitembelea</translation>
<translation id="8109744984354428711">Inaanzisha Ecosia...</translation>
<translation id="812798451698099271">Tayari kuna wasifu kwenye Ecosia unaotumia akaunti hii</translation>
<translation id="3035352359183300151">Fahamu kwa nini Ecosia huzuia baadhi ya vipakuliwa</translation>
<translation id="2861074815332034794">Inasasisha Chrome (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="727568860157522676">Umeingia kwenye Ecosia!</translation>
<translation id="2876628302275096482">Pata maelezo zaidi kuhusu <ph name="BEGIN_LINK"/>jinsi Chrome inavyoweka data yako kuwa ya faragha<ph name="END_LINK"/></translation>
<translation id="2885378588091291677">Kidhibiti cha Shughuli</translation>
<translation id="2888126860611144412">Kuhusu Chrome</translation>
<translation id="29082080693925013">Ili uendelee kupanga mambo yako, unaweza kubandika tovuti unazotembelea sana na upange vichupo katika vikundi</translation>
<translation id="2915996080311180594">Ifunge kisha Uifungue Baadaye</translation>
<translation id="2926676257163822632">Ni rahisi kukisia manenosiri dhaifu. Iruhusu Chrome <ph name="BEGIN_LINK"/>itunge na ikumbuke manenosiri thabiti kwa niaba yako<ph name="END_LINK"/>.</translation>
<translation id="219546601381787154">Ecosia inahitaji ruhusa ya kufikia kamera kwa ajili ya tovuti hii</translation>
<translation id="2928420929544864228">Usakinishaji umekamilika.</translation>
<translation id="2929907241665500097">Chrome haijasasishwa, hitilafu fulani imetokea. <ph name="BEGIN_LINK"/>Rekebisha matatizo ya sasisho la Chrome na masasisho ambayo hayakuwekwa.<ph name="END_LINK"/></translation>
<translation id="2945997411976714835">Hitilafu ya kusakinisha: Mchakato wa kisakinishaji umeshindwa kuanza.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - Kuingia katika Akaunti ya Mtandao - Ecosia</translation>
<translation id="8696852719113991652">Ili uondoe Akaunti yako ya Ecosia kwenye Ecosia, ondoka kwenye Ecosia katika ukurasa wa Mipangilio</translation>
<translation id="5405885279794834338">Futa pia data kutoka Ecosia (<ph name="URL"/>)</translation>
<translation id="5622643576877267490">Fungua tena ili usasishe EcosiaOS Flex</translation>
<translation id="2234042158691635795">Ecosia iko katika hali ya chini chini.</translation>
<translation id="3038232873781883849">Inasubiri kusakinisha...</translation>
<translation id="3059710691562604940">Kipengele cha Kuvinjari Salama kimezimwa. Chrome inapendekeza ukiwashe.</translation>
<translation id="780008372122710391">Tumia njia yako ya mkato ili ufikie Kidhibiti cha Manenosiri cha Ecosia kwa haraka. Unaweza kuhamishia njia yako ya mkato kwenye skrini ya kwanza ya kompyuta yako au kifungua programu.</translation>
<translation id="385080958066798123">Kichupo cha Ecosia</translation>
<translation id="3080151273017101988">Endelea kuendesha programu zinazofanya kazi chini chini wakati Google Chrome imefungwa</translation>
<translation id="3100998948628680988">Upe wasifu wako wa Chrome jina</translation>
<translation id="7051119589302096163">Ecosia imezuia upakuaji huu kwa sababu faili hii kwa kawaida haipakuliwi na huenda si salama</translation>
<translation id="3114643501466072395">Ili uangalie kama manenosiri yako mengine ni salama dhidi ya ufichuzi haramu wa data na matatizo mengine ya usalama, <ph name="BEGIN_LINK"/>ingia katika akaunti kwenye Chrome<ph name="END_LINK"/>.</translation>
<translation id="231621248561775155">Ecosia imezuia upakuaji huu kwa sababu faili iliyo kwenye kumbukumbu inajumuisha faili nyingine ambazo huenda zimeficha programu hasidi</translation>
<translation id="1722634673917783018">Mabadiliko yako yataanza kufanya kazi wakati ujao utakapozindua Ecosia.</translation>
<translation id="2636091632287013185">Programu za Ecosia</translation>
<translation id="7580831958727159171">Vipindi vya kujaribu vinapotumika, unaweza kuona na kuondoa mada za tovuti zinazokuvutia zinazotumika kukuonyesha matangazo. Ecosia hukadiria mambo yanayokuvutia kulingana na historia yako ya kuvinjari ya hivi karibuni.</translation>
<translation id="9068280473864300215">Ecosia imezuia upakuaji huu kwa sababu faili si salama</translation>
<translation id="3226612997184048185">Iwapo pia unahifadhi alamisho kwenye Akaunti yako ya Google, unaweza kufuatilia bei za bidhaa katika Chrome na upate arifa bei inapopunguzwa</translation>
<translation id="3234642784688107085">Jaribu vipengele vipya vya AI ili ubuni mandhari, upate usaidizi wa kuandika na upange mambo yako</translation>
<translation id="3245429137663807393">Ikiwa pia unashiriki ripoti za matumizi ya Chrome, ripoti hizo zinajumuisha URL unazotembelea</translation>
<translation id="3261565993776444564">Jaribu rangi mpya ili uwekee kivinjari chako mapendeleo</translation>
<translation id="2388751143175762498">Ingia katika Ecosia</translation>
<translation id="3286538390144397061">Zima na uwashe sasa</translation>
<translation id="8268239447047453615">Na utahitaji kuzima kisha uwashe Ecosia.</translation>
<translation id="9090890391337853620">Msaidizi wa Ecosia</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia itafunguka upya sasa hivi}=1{Ecosia itafunguka upya baada ya sekunde 1}other{Ecosia itafunguka upya baada ya sekunde #}}</translation>
<translation id="7280797724682955539">Hitilafu ya mfumo wa uendeshaji imetokea wakati wa kusanidi. Tafadhali pakua Ecosia tena.</translation>
<translation id="3428747202529429621">Hulinda usalama wako kwenye Chrome na inaweza kutumiwa kuboresha usalama wako kwenye programu nyingine za Google ukiwa umeingia katika akaunti</translation>
<translation id="3434246496373299699">Chrome inaweza kukagua manenosiri unapoingia ukitumia Akaunti yako ya Google</translation>
<translation id="6094573000614590044">Ili upate manenosiri yako na zaidi kwenye vifaa vyako vyote, ingia katika akaunti kwenye Ecosia</translation>
<translation id="5032126307005935789">Huenda faili hii ni hatari<ph name="LINE_BREAK"/>Ecosia inaweza kukagua kwa niaba yako kipakuliwa hiki ikiwa utaweka nenosiri. Maelezo kuhusu faili hutumwa katika Kipengele cha Kuvinjari Salama na Ecosia, lakini maudhui ya faili na nenosiri husalia kwenye kifaa chako.</translation>
<translation id="1762318218111418450">Inaongeza kwenye Ecosia...</translation>
<translation id="6761747850241550887">Jiongeze kwenye Ecosia</translation>
<translation id="2149148292984034533">Sheria na masharti ya Mfumo wa Uendeshaji wa Ecosia</translation>
<translation id="6558895515431832002">Ecosia inahitaji kufikia maelezo ya mahali ulipo ili kuyashiriki na tovuti hii</translation>
<translation id="3533694711092285624">Hakuna manenosiri yaliyohifadhiwa. Chrome inaweza kukagua manenosiri yako unapoyahifadhi.</translation>
<translation id="3541482654983822893">Chrome imeshindwa kukagua manenosiri yako. Jaribu tena baada ya saa 24.</translation>
<translation id="7881897052591031502">Unapoingia katika akaunti kwenye Ecosia, unaweza kuhifadhi alamisho, manenosiri na zaidi kisha uyatumie kwenye simu yako</translation>
<translation id="8901409988302458368">Msimamizi wa mfumo unaotumia ameweka mipangilio ya Ecosia ifungue kivinjari mbadala ili kufikia <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="7174674455569790401">Sawazisha na uweke mapendeleo kwenye Ecosia katika vifaa vyako vyote</translation>
<translation id="8403827649521531901">Tayari umeingia katika akaunti ukitumia <ph name="USER_EMAIL_ADDRESS"/> katika wasifu mwingine wa Ecosia</translation>
<translation id="3260765223735049374">Ungependa kuingia katika akaunti kwenye Ecosia katika wasifu mpya?</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{Msimamizi wako anataka ufungue Ecosia tena ili utumie sasisho}=1{Msimamizi wako anataka ufungue Ecosia tena ili utumie sasisho. Haitafungua upya dirisha fiche.}other{Msimamizi wako anataka ufungue Ecosia tena ili utumie sasisho. Haitafungua upya madirisha # fiche.}}</translation>
<translation id="3597003331831379823">Imeshindwa kuweka mipangilio ikitumia ufikiaji maalum. <ph name="METAINSTALLER_ERROR"/></translation>
<translation id="3609788354808247807">Hujatembelea hivi majuzi. Chrome imeondoa <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/>, <ph name="PERMISSION_3"/></translation>
<translation id="464306605599005355">Sasa ni rahisi zaidi kutumia Ecosia pamoja na Akaunti yako ya Ecosia na kwenye kompyuta zinazoshirikiwa.</translation>
<translation id="3635073343384702370">Chrome inaweza kukagua manenosiri yako unapoyahifadhi</translation>
<translation id="3667616615096815454">Imeshindwa kusakinisha, seva haitambui programu hii.</translation>
<translation id="1490060441084292633">Ecosia imegundua kwamba "<ph name="EXTENSION_NAME"/>" ina programu hasidi</translation>
<translation id="3695446226812920698">Pata maelezo</translation>
<translation id="6967821869905227561">Wasifu mwingine kwenye Ecosia</translation>
<translation id="5311911269004680646">Mfumo wa uendeshaji wa Ecosia unawezeshwa na <ph name="BEGIN_LINK_CROS_OSS"/>programu huria<ph name="END_LINK_CROS_OSS"/> za ziada, kama vile <ph name="BEGIN_LINK_LINUX_OSS"/>mazingira ya wasanidi programu wa Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="3716540481907974026">Toleo la ChromeOS Flex</translation>
<translation id="3718181793972440140">Hatua hii itafuta kipengee 1 kwenye kifaa hiki. Ili urejeshe data yako baadaye, ingia katika Chrome ukitumia <ph name="USER_EMAIL"/>.</translation>
<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Ecosia inapendekeza ukiondoe. <ph name="BEGIN_LINK"/>Pata maelezo zaidi kuhusu viendelezi vinavyotumika<ph name="END_LINK"/>}other{Ecosia inapendekeza uviondoe. <ph name="BEGIN_LINK"/>Pata maelezo zaidi kuhusu viendelezi vinavyotumika<ph name="END_LINK"/>}}</translation>
<translation id="3744202345691150878">Pata usaidizi wa jinsi ya kutumia Mfumo wa Uendeshaji wa Chrome</translation>
<translation id="4600924482853773728">Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="4969069484658032230">EcosiaOS Flex haikuweza kusawazisha data yako kutokana na hitilafu wakati wa kuingia.</translation>
<translation id="1761341660094265938">Mfumo wa Uendeshaji wa Ecosia</translation>
<translation id="2829233304432701500">Ecosia inahitaji Windows 10 au toleo jipya zaidi.</translation>
<translation id="3952510753191144456">Hatua hii itafungua wasifu mpya wa <ph name="USER_EMAIL_ADDRESS"/> kwenye Ecosia</translation>
<translation id="4019094010333463261">Ecosia inahitaji ruhusa ya kufikia Bluetooth ili kugundua 
 vifaa vyenye Bluetooth. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="8534308095039131078">Tafadhali funga madirisha yote ya Ecosia na ujaribu tena.</translation>
<translation id="3865754807470779944">Umesakinisha toleo la Chrome la <ph name="PRODUCT_VERSION"/></translation>
<translation id="8283315171506895091">Fungua kiungo katika dirisha fiche la Ecosia</translation>
<translation id="6496553866814956056">Ondoa Ecosia</translation>
<translation id="3941890832296813527">Hitilafu ya kusakinisha: Jina la faili ya kisakinishaji si sahihi au haliwezi kutumika.</translation>
<translation id="4459596553899864514">Ecosia ingependa kufuta data yako ya Kidhibiti cha Manenosiri cha Ecosia. Weka nenosiri lako la Windows ili uruhusu hatua hii.</translation>
<translation id="8846463365332065180">Ecosia huendelea kufanya kazi kwa kasi ikiwa na vipengele vya kuboresha utendaji</translation>
<translation id="1118786556671181978">Unaweza kuona na kuondoa mada zinazokuvutia zinazotumiwa na tovuti kukuonyesha matangazo. Ecosia hukadiria mambo yanayokuvutia kulingana na historia yako ya kuvinjari ya hivi karibuni.</translation>
<translation id="8047394653992042491">Mfumo wa Uendeshaji wa Ecosia unahitaji kuzimwa na kuwashwa ili utekeleze sasisho.</translation>
<translation id="4050175100176540509">Maboresho muhimu ya usalama na vipengele vipya vinapatikana katika toleo jipya.</translation>
<translation id="4817913198787198451">Dhibiti  na ugeuze Ecosia ikufae</translation>
<translation id="4395802781633621239">Ili upate manenosiri yako na zaidi kwenye vifaa vyako vyote, ingia katika akaunti kwenye Ecosia. Ukishaingia katika akaunti, nenosiri hili litahifadhiwa kwenye Akaunti yako ya Ecosia.</translation>
<translation id="1330085168384841023">Ili uonyeshe dirisha lako, washa kinasa skrini katika Ecosia kwenye Mapendeleo ya Mfumo.</translation>
<translation id="3708834841667355707">Ecosia inachunguza vipengele vipya vinavyoruhusu tovuti zikupatie hali ileile ya kuvinjari kwa kutumia taarifa zako chache</translation>
<translation id="319566061277127356">Weka mipangilio ya wasifu wako mpya wa Ecosia</translation>
<translation id="7433581196371819898">Ecosia haiwezi kuthibitisha chanzo cha kiendelezi hiki na huenda si salama. Kiondoe kwenye Ecosia ili kisiweze tena kuona na kubadilisha data yako kwenye tovuti unazotembelea, ikiwa ni pamoja na taarifa zako binafsi.</translation>
<translation id="2198589091447191935">Ecosia hufanya kazi kwa kasi na vipengele vinavyotumia JavaScript vinapaswa kufanya kazi kama vilivyobuniwa (inapendekezwa)</translation>
<translation id="7105712012505419722">Unaingia katika akaunti ukitumia akaunti inayodhibitiwa na kumpa msimamizi wa akaunti hiyo udhibiti wa wasifu wako kwenye Ecosia. Data yako ya Ecosia, kama vile programu zako, alamisho, historia, manenosiri, na mipangilio mingine itahusishwa na <ph name="USER_NAME"/> daima . Utaweza kufuta data hii kupitia Dashibodi ya Akaunti za Ecosia, lakini hutaweza kuhusisha data hii na akaunti nyingine. <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">Inasakinisha...</translation>
<translation id="7691143774653486474">Kisanidi kimeshindwa kufungua saraka. Tafadhali pakua Ecosia tena.</translation>
<translation id="2446603005062458629">Ecosia itafungwa na kufuta data hivi karibuni</translation>
<translation id="4173512894976930765">Huenda tovuti zitafanya kazi kama inavyotarajiwa. Utaondolewa kwenye tovuti nyingi ukifunga madirisha yote ya Chrome, isipokuwa katika Akaunti yako ya Google ikiwa umeingia kwenye Chrome.</translation>
<translation id="2745180350547322293">Ecosia imezuia upakuaji huu kwa sababu tovuti haitumii muunganisho salama na huenda faili imeharibiwa</translation>
<translation id="6826163993811146231">{0,plural, =1{Fungua Ecosia upya ndani ya siku moja}other{Fungua Ecosia upya ndani ya siku #}}</translation>
<translation id="4205939740494406371">Chrome imeshindwa kukagua manenosiri yako. Jaribu tena baada ya saa 24 au <ph name="BEGIN_LINK"/>kagua manenosiri katika Akaunti yako ya Google<ph name="END_LINK"/>.</translation>
<translation id="4222932583846282852">Inaghairi...</translation>
<translation id="4224210481850767180">Mchakato wa kuweka kwenye kifaa umekatishwa.</translation>
<translation id="3554373328288278512">Ecosia inahitaji ruhusa ya kufikia kamera na maikrofoni kwa ajili ya tovuti hii</translation>
<translation id="424864128008805179">Ungependa kuondoka kwenye Chrome?</translation>
<translation id="8384922154025337808">Ungependa kuunganisha data yako ya Ecosia kwenye akaunti hii?</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>Data gani inatumiwa:<ph name="END_BOLD"/> Historia yako ya kuvinjari, kumbukumbu ya tovuti ulizozitembelea ukitumia Ecosia kwenye kifaa hiki.</translation>
<translation id="4281844954008187215">Sheria na Masharti</translation>
<translation id="4293420128516039005">Ingia katika akaunti ili usawazishe na uweke mapendeleo kwenye Chrome katika vifaa vyako vyote</translation>
<translation id="6419542773162312746">Ruhusu kiendelezi kionyeshe maombi ya ufikiaji katika upau wa vidhibiti wa Ecosia</translation>
<translation id="8864449561723972619">Ecosia Dev (mDNS-In)</translation>
<translation id="4329315893554541805">Ili upate mapendeleo na vipengele vingine, jumuisha Chrome kwenye Historia ya Shughuli kwenye Wavuti na Programu pamoja na huduma za Google zilizounganishwa</translation>
<translation id="4334294535648607276">Upakuaji umekamilika.</translation>
<translation id="4335235004908507846">Chrome inaweza kukusaidia ulinde akaunti yako dhidi ya ufichuzi haramu wa data, viendelezi vibaya na zaidi</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> imeongezwa kwenye Ecosia</translation>
<translation id="4348548358339558429">Ili upate mapendeleo, jumuisha Chrome kwenye Historia ya Shughuli kwenye Wavuti na Programu</translation>
<translation id="197803137365953132">Ecosia imezuia upakuaji huu kwa sababu faili inaweza kuathiri akaunti zako binafsi na za mitandao ya kijamii</translation>
<translation id="4384570495110188418">Chrome imeshindwa kukagua manenosiri yako kwa sababu hujaingia katika akaunti</translation>
<translation id="4389991535395284064">Unapovinjari katika hali fiche, Chrome itakutahadharisha kabla ya kupakia tovuti kwa kutumia muunganisho usio salama</translation>
<translation id="4427306783828095590">Kipengele cha ulinzi wa hali ya juu hufanya mengi zaidi ili kuzuia programu hasidi na wizi wa data binafsi</translation>
<translation id="4434353761996769206">Hitilafu ya kisakinishaji: <ph name="INSTALLER_ERROR"/></translation>
<translation id="2297526912548649074">Ingia kwenye Ecosia ukitumia <ph name="USER_EMAIL"/></translation>
<translation id="9035946286843935549">Ecosia - Kuingia katika Akaunti ya Mtandao - <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">Kuna shughuli nyingine zinaendelea kwenye Ecosia. Tafadhali jaribu tena baadaye.</translation>
<translation id="4459234553906210702">Upimaji wa tangazo huruhusu tovuti unazotembelea ziombe maelezo kutoka Chrome ambayo yanasaidia tovuti kupima ufanisi wa matangazo yao. Upimaji wa tangazo huzuia ufuatiliaji katika tovuti mbalimbali kwa kuhamisha maelezo machache kadiri iwezekanavyo miongoni mwa tovuti.</translation>
<translation id="4501471624619070934">Imeshindwa kusakinisha kwa sababu ufikiaji umedhibitiwa katika nchi hii.</translation>
<translation id="4567424176335768812">Umeingia katika akaunti kama <ph name="USER_EMAIL_ADDRESS"/>. Sasa unaweza kupata alamisho, historia, na mipangilio yako mingine kwenye vifaa vyako vyote vilivyoingia katika akaunti.</translation>
<translation id="6533266716128249922">Nenda kwenye mipangilio ya arifa za Ecosia</translation>
<translation id="7562371913339616107">Ecosia inaweza kufanya vichupo hivi visitumike ili kuboresha hali yako ya kuvinjari na kufuta data ili upate nyenzo.</translation>
<translation id="488806616089631539">Ecosia itakapopata idhini, tovuti zitaweza kukuomba idhini ya kufikia.</translation>
<translation id="3268039966078382323">Imeshindwa kupata toleo jipya la Ecosia, kwa hivyo hutapata masasisho ya usalama na vipengele vipya.</translation>
<translation id="4624065194742029982">Hali fiche kwenye Chrome</translation>
<translation id="4690206707618474800">Hiari: Tusaidie kuboresha vipengele na utendaji wa EcosiaOS Flex kwa kutuma kiotomatiki uchunguzi na data ya matumizi kwa Ecosia.</translation>
<translation id="9125443060066914183">Ili kufanya Ecosia salama zaidi, tumezima baadhi ya viendelezi ambavyo havijaorodheshwa katika <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> na ambavyo huendwa viliongezwa pasipo ridhaa yako.</translation>
<translation id="4680828127924988555">Ghairi Usakinishaji</translation>
<translation id="8236553889322631924">Viendelezi, programu na mandhari kutoka kwenye vyanzo visivyojulikana vinaweza kuathiri kifaa chako. Ecosia inapendekeza tu usakinishaji kutoka Duka la Ecosia kwenye Wavuti</translation>
<translation id="4710245680469034439">Wekea kivinjari chako mapendeleo ukitumia mandhari yaliyohamasishwa na mazingira, mikusanyiko ya wasanii na zaidi</translation>
<translation id="4724676981607797757">Imeshindwa kusakinisha kwa sababu ya hitilafu ya itifaki isiyotumika.</translation>
<translation id="3305517118160815955">Usanidi umeshindwa kwa sababu ya hitilafu isiyojulikana. Ikiwa Ecosia haitumiki kwa sasa, tafadhali ifunge na ujaribu tena.</translation>
<translation id="4747730611090640388">Chrome inaweza kukadiria mambo yanayokuvutia.  Baadaye, tovuti unayoitembelea inaweza kuiomba Chrome ili ione mambo yanayokuvutia na iweze kukuonyesha matangazo kulingana na mapendeleo yako.</translation>
<translation id="827222962844006655">Ecosia Canary (mDNS-In)</translation>
<translation id="3543284013834505767">Huduma hii hutumia kikagua tahajia sawa na kinachotumika kwenye Huduma ya Tafuta na Ecosia. Maandishi unayoandika kwenye kivinjari yanatumwa kwa Ecosia. Unaweza kubadilisha hali hii katika mipangilio wakati wowote.</translation>
<translation id="4793679854893018356">Pata maelezo ya jinsi Chrome inavyohakikisha usalama wako</translation>
<translation id="8957938953005153147">Ecosia inajaribu kubadilisha manenosiri yaliyopo. Andika nenosiri lako la Windows ili uiruhusu.</translation>
<translation id="8144706290339578682">EcosiaOS Flex haikuweza kusawazisha data yako kwa sababu usawazishaji haupatikani katika kikoa chako.</translation>
<translation id="7984841734836997333">Tayari umeingia katika akaunti ya <ph name="EXISTING_USER"/>.  Ili utenganishe shughuli zako za kuvinjari, ingia katika akaunti kwenye Ecosia katika wasifu wako binafsi ukitumia <ph name="USER_EMAIL_ADDRESS"/>.</translation>
<translation id="4264506519284061030">Shirika lako linaweza kuona na kudhibiti data ya kuvinjari katika wasifu wako wa kazini, kama vile alamisho, historia na manenosiri yako. Haliwezi kuona data ya kuvinjari katika wasifu wa binafsi kwenye Ecosia.</translation>
<translation id="8701027951719712428">Utahitaji toleo la macOS 11 au toleo jipya zaidi ili upate masasisho ya Ecosia ya siku zijazo Kompyuta hii inatumia toleo la macOS 10.15.</translation>
<translation id="4873783916118289636">Kagua vidhibiti muhimu vya faragha na usalama katika Chrome</translation>
<translation id="8454595950895325762">Ruhusu Ecosia iendeshe katika mandharinyuma</translation>
<translation id="489671036945006830">Fungua kiungo katika kichupo kipya cha Ecosia</translation>
<translation id="6566258574866003581">Ecosia inapendekeza ukague kiendelezi hiki</translation>
<translation id="4951177103388687412">Endelea kupanga na kumakinikia mambo yako kwa kutumia vikundi vya vichupo</translation>
<translation id="5581150090232500900">Weka Ecosia iwe kivinjari chako chaguomsingi</translation>
<translation id="6495878830719404098">Katika Ecosia</translation>
<translation id="6113625922434842626">EcosiaOS Flex haikuweza kusawazisha data yako kwa sababu maelezo ya kuingia kwenye akaunti yako yamepitwa na wakati.</translation>
<translation id="4410570812343670816">Karibu kwenye kipengele cha wasifu kwenye Ecosia</translation>
<translation id="4970880042055371251">Toleo la Mfumo wa Uendeshaji wa Chrome</translation>
<translation id="8570641140903702642">Kanari ya Ecosia</translation>
<translation id="6735145163744656874">Ecosia inaweza kufanya vichupo hivi visitumike ili kuboresha hali yako ya kuvinjari na kutekeleza shughuli kwa haraka.</translation>
<translation id="2569934116750022163">Bofya “Kidhibiti cha Manenosiri cha Ecosia”</translation>
<translation id="5120334927898581447">Ingia katika akaunti kwenye Chrome unapoingia kwenye akaunti za huduma nyingine za Google</translation>
<translation id="5126049312684316860">Chrome hupakia mapema kurasa nyingi zaidi ambazo unaweza kutembelea, ili zipakie kwa haraka zaidi unapozitembelea</translation>
<translation id="7782767522222146179">Gundua programu, michezo, viendelezi na mandhari bora ya Ecosia.</translation>
<translation id="6416551953415159186">Weka mapendeleo ya wasifu wako kwenye Ecosia</translation>
<translation id="719484593754925816">Ecosia inaweza kufanya kichupo hiki kisitumike ili kuboresha hali yako ya kuvinjari na kufuta data ili upate nyenzo.</translation>
<translation id="1859120614572957305">Karibu kwenye Ecosia; dirisha jipya la kivinjari limefunguliwa</translation>
<translation id="6648664289472946060">Wasifu wako huenda usitumike kwa sababu unatoka katika toleo jipya la Ecosia.

Huenda baadhi ya vipengele visipatikane. Tafadhali bainisha saraka tofauti ya wasifu au tumia toleo jipya la Ecosia.</translation>
<translation id="5201744974236816379">Sasisho la Chrome</translation>
<translation id="6960183526681645011">Kama unatumia kifaa pamoja na wengine, marafiki na familia wanaweza kuvinjari kivyao na kuweka mipangilio ya Ecosia wapendavyo</translation>
<translation id="3784023996375784431">Tumia Ecosia wakati wowote unapobofya viungo kwenye ujumbe, hati na programu zingine.</translation>
<translation id="1869027055332251164">Walioalikwa wanaweza kutumia Ecosia bila kuacha chochote nyuma.</translation>
<translation id="5320351714793324716">Ukiruhusu vidakuzi, Chrome inaweza kuvitumia inapopakia mapema</translation>
<translation id="143614250230771428">Mfumo wa Uendeshaji wa Ecosia haukusawazisha data yako kwa sababu Usawazishaji haupatikani katika kikoa chako.</translation>
<translation id="1809194740315140401">Ecosia inahitaji ruhusa ya kufikia nafasi ya hifadhi ili ipakue faili</translation>
<translation id="8975930032513941502">Si lazima: Tusaidie kuboresha utendaji na vipengele vya Mfumo wa Uendeshaji wa Ecosia kwa kutuma kiotomatiki data ya matumizi na uchunguzi kwa Ecosia.</translation>
<translation id="5357889879764279201">Pata usaidizi wa jinsi ya kutumia ChromeOS Flex</translation>
<translation id="5368118228313795342">Msimbo wa ziada: <ph name="EXTRA_CODE"/>.</translation>
<translation id="6665128960039431910">Pia inadhibiti ukurasa unaoonyeshwa unapoanzisha Ecosia au unapotafuta kutoka Sanduku Kuu.</translation>
<translation id="1861504561909287316">Shiriki kichupo cha Ecosia</translation>
<translation id="5412485296464121825">Tovuti zinaweza kuhifadhi maelezo kuhusu mambo yanayokuvutia kwa kutumia Chrome. Kwa mfano, iwapo utatembelea tovuti ili kununua viatu kwa ajili ya kukimbia mbio za marathoni, tovuti hiyo huenda ikatambua kuwa moja ya mambo yanayokuvutia ni kukimbia mbio za marathoni. Baadaye, iwapo utatembelea tovuti tofauti ili kujisajili kwa ajili ya mbio, tovuti hiyo huenda ikakuonyesha tangazo la viatu vya kukimbilia kulingana na mambo yanayokuvutia.</translation>
<translation id="6673288084648462613">Faili yako ya mapendekezo imeharibika au ni batili.

Ecosia haiwezi kufufua mipangilio yako.</translation>
<translation id="5468572406162360320">Ili kusaidia kuboresha vipengele hivi, Chrome hutumia Google data ya jinsi unavyovitumia. Data hii inaweza kusomwa, kuchakatwa na kuwekewa vidokezo na wahakiki wanadamu.</translation>
<translation id="5524761631371622910">Vipindi vya kujaribu vinapowashwa na iwapo Chrome imekuweka kwa unasibu katika kipindi cha kujaribu kinachoendelea, historia yako ya kuvinjari huathiri matangazo unayoyaona na mambo yanayokuvutia kama inavyokadiriwa hapa chini. Ili kulinda faragha yako, Chrome hufuta mambo yanayokuvutia kadiri unavyoendelea kutumia kila mwezi.</translation>
<translation id="2905159584855395810">Ifanye Ecosia Iwe na Kasi Zaidi ya Utendaji</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="5167067155585861308">Ecosia inapendekeza ukiondoe. <ph name="BEGIN_LINK"/>Pata maelezo zaidi kuhusu viendelezi vinavyotumika<ph name="END_LINK"/></translation>
<translation id="7005470355724599337">Ecosia hufanya mengi ili kuimarisha usalama wako mtandaoni</translation>
<translation id="3625533701824359646">Huenda <ph name="FILE_NAME"/> ni hatari, kwa hivyo Ecosia imeizuia.</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{Msimamizi wako anataka ufungue Ecosia tena ili utumie sasisho hili}=1{Msimamizi wako anataka ufungue Ecosia tena ili utumie sasisho hili. Haitafungua upya dirisha fiche.}other{Msimamizi wako anataka ufungue Ecosia tena ili utumie sasisho hili. Haitafungua upya madirisha # fiche.}}</translation>
<translation id="8544776492099331022">Dhibiti na uweke mapendeleo kwenye Ecosia. Unahitaji kushughulikia jambo fulani. Bofya ili upate maelezo.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="569897634095159764">Imeshindwa kuunganisha kwenye Intaneti. Seva mbadala inahitaji uthibitishaji.</translation>
<translation id="570005089986962444">Kiokoa hifadhi kinapowashwa, Chrome hurejesha hifadhi iliyopo kwenye vichupo ambavyo havitumiki. Hatua hii hufanya vichupo vinavyotumika na programu nyinginezo ziwe na nyenzo zaidi za kompyuta na huifanya Chrome iwe na kasi ya utendaji. Vichupo ambavyo hutumii vinaanza kutumika tena kiotomatiki unaporudi kwenye vichupo hivyo.</translation>
<translation id="5581150090232500900">Weka Ecosia iwe kivinjari chako chaguomsingi</translation>
<translation id="5727531838415286053">Iwapo Chrome imekuweka kwa unasibu katika kipindi cha kujaribu kinachoendelea, historia ya kuvinjari huathiri matangazo unayoyaona na mambo yanayokuvutia kama inavyokadiriwa hapa chini. Ili kulinda faragha yako, Chrome hufuta mambo yanayokuvutia kadiri unavyoendelea kutumia kila mwezi. Mambo yanayokuvutia yataonyeshwa upya isipokuwa ukiyaondoa.</translation>
<translation id="5736850870166430177">Ikiwa tovuti inajaribu kuiba nenosiri lako au unapopakua faili hatari, Chrome inaweza pia kutuma URL, ikiwa ni pamoja na sehemu za maudhui ya ukurasa, kwenye kipengele cha Kuvinjari Salama</translation>
<translation id="8301840715671593762">Tayari kuna wasifu kwenye Ecosia unaotumia akaunti hii katika kifaa hiki</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Toleo la Jaribio la Ecosia</translation>
<translation id="2542649989941327712">Imeshindwa kuanzisha Ecosia. Jaribu tena.</translation>
<translation id="5809516625706423866">Imeshindwa kuunganisha kwenye Intaneti. HTTP 401 Haijaidhinishwa. Tafadhali angalia mipangilio yako ya seva mbadala.</translation>
<translation id="9091453616111683919">Ondoa <ph name="EXTENSION_NAME"/> kwenye Ecosia</translation>
<translation id="1773882594264682232">Wakati umeingia katika akaunti, unaweza kutumia manenosiri yako na mengineyo kwenye Akaunti yako ya Ecosia katika Ecosia. Unaweza kubadilisha hali hii wakati wowote kwenye mipangilio.</translation>
<translation id="5513857521842828996">Utaondolewa kwenye tovuti nyingi ukifunga madirisha yote ya Ecosia, isipokuwa katika Akaunti yako ya Ecosia ikiwa umeingia katika Ecosia. Ili uruhusu tovuti zikukumbuke, <ph name="SETTINGS_LINK"/>.</translation>
<translation id="586971344380992563"><ph name="BEGIN_LINK"/>Chrome inakuonya<ph name="END_LINK"/> kuhusu tovuti na vipakuliwa ambavyo si salama</translation>
<translation id="5895138241574237353">Zima na uwashe</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - Kuingia katika Akaunti ya Mtandao</translation>
<translation id="5924017743176219022">Inaunganisha kwenye Intaneti...</translation>
<translation id="5932997892801542621">Unapoandika kwenye sehemu ya anwani au kisanduku cha kutafutia, Chrome hutuma unachokiandika kwenda kwenye Hifadhi ya Google ili upate mapendekezo ya kipengee. Kipengele hiki huwa kimezimwa katika Hali fiche.</translation>
<translation id="4960252760049500399">Wavuti, alamisho, na vitu vyako vingine vya Ecosia vinapatikana hapa.</translation>
