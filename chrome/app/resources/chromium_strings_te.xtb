<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="te">
<translation id="1026101648481255140">ఇన్‌స్టలేషన్‌ను కొనసాగించండి</translation>
<translation id="8933665254023068908">&amp;EcosiaOSను అప్‌డేట్ చేయడానికి రీ-లాంచ్ చేయండి</translation>
<translation id="1065672644894730302">మీ ప్రాధాన్యతలు చదవబడలేవు. కొన్ని లక్షణాలు అందుబాటులో ఉండకపోవచ్చు మరియు ప్రాధాన్యతలకు మార్పులు సేవ్ చేయబడకపోవచ్చు.</translation>
<translation id="1098170124587656448">డేటా ఉల్లంఘనలు, చెడు ఎక్స్‌టెన్షన్‌లు మొదలైన వాటి నుండి మిమ్మల్ని సురక్షితంగా ఉంచడంలో Chromium సహాయపడగలదు</translation>
<translation id="3632544319066562282">Ecosia మీ పాస్‌వర్డ్‌లను ఎగుమతి చేయాలనుకుంటోంది. దీనిని అనుమతించడం కోసం మీ Windows పాస్‌వర్డ్‌ని టైప్ చేయండి.</translation>
<translation id="113122355610423240">మీ డిఫాల్ట్ బ్రౌజర్ Chromium</translation>
<translation id="1131805035311359397">డేటా ఉల్లంఘనల నుండి, ఇతర భద్రతా సమస్యల నుండి మీ పాస్‌వర్డ్‌లు సురక్షితంగా ఉన్నాయో లేదో చెక్ చేయడానికి, <ph name="BEGIN_LINK"/>Chromiumకు సైన్ ఇన్ చేయండి<ph name="END_LINK"/>.</translation>
<translation id="1185134272377778587">Chromium గురించి</translation>
<translation id="1203500561924088507">ఇన్‌స్టాల్ చేసినందుకు ధన్యవాదాలు. <ph name="BUNDLE_NAME"/>‌ను ఉపయోగించడానికి ముందు మీరు బ్రౌజర్‌ను తప్పకుండా రీస్టార్ట్ చేయాలి.</translation>
<translation id="1231839967188101156">ఆన్‌లో ఉన్నప్పుడు, Chromium ఇన్‌యాక్టివ్ ట్యాబ్‌ల నుండి మెమరీని ఖాళీ చేస్తుంది. దీని ద్వారా యాక్టివ్ ట్యాబ్‌లకు, ఇతర యాప్‌లకు మరిన్ని కంప్యూటర్ రిసోర్స్‌లు లభిస్తాయి, దీనితో Chromium వేగంగా పని చేస్తుంది. మీ ఇన్‌యాక్టివ్ ట్యాబ్‌లకు మీరు తిరిగి వచ్చినప్పుడు, అవి ఆటోమేటిక్‌గా మళ్లీ యాక్టివ్‌గా మారతాయి. <ph name="BEGIN_LINK"/>మరింత తెలుసుకోండి<ph name="END_LINK"/></translation>
<translation id="2298752889004612764">మెమరీ సేవర్ Ecosiaను వేగవంతం చేస్తుంది</translation>
<translation id="319566061277127356">మీ కొత్త Ecosia ప్రొఫైల్‍ను సెట్ అప్ చేయండి</translation>
<translation id="2549591663512786020">Ecosia పాస్‌వర్డ్‌లను చూపడానికి ప్రయత్నిస్తోంది.</translation>
<translation id="727568860157522676">మీరు Ecosiaకు సైన్ ఇన్ చేశారు!</translation>
<translation id="6650631555168164414">Ecosia అందించే ప్రయోజనాలన్నింటినీ మీరు ఆస్వాదించవచ్చు</translation>
<translation id="1861504561909287316">Ecosia ట్యాబ్‌ను షేర్ చేయండి</translation>
<translation id="6896860023874996542">మీ పరిసరాల 3D మ్యాప్‌ను క్రియేట్ చేయడానికి Ecosiaకు మీ కెమెరాను యాక్సెస్ చేసే అనుమతి కావాలి</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{అప్‌డేట్‌ను వర్తింపజేయడం కోసం మీరు Ecosiaను పునఃప్రారంభించాలని మీ నిర్వాహకుడు కోరుతున్నారు}=1{అప్‌డేట్‌ను వర్తింపజేయడం కోసం మీరు Ecosiaను పునఃప్రారంభించాలని మీ నిర్వాహకుడు కోరుతున్నారు. మీ అజ్ఞాత విండో మళ్లీ తెరవబడదు.}other{అప్‌డేట్‌ను వర్తింపజేయడం కోసం మీరు Ecosiaను పునఃప్రారంభించాలని మీ నిర్వాహకుడు కోరుతున్నారు. మీ # అజ్ఞాత విండోలు మళ్లీ తెరవబడవు.}}</translation>
<translation id="1625909126243026060">Chromiumలోని ముఖ్య గోప్యతా, సెక్యూరిటీ కంట్రోల్స్‌ను రివ్యూ చేయండి</translation>
<translation id="931416298178634530">మీరు ఈ ఖాతాను ఒకసారి మాత్రమే ఉపయోగించాలనుకుంటే, Ecosia బ్రౌజర్‌లో <ph name="GUEST_LINK_BEGIN"/>గెస్ట్ మోడ్‌ను<ph name="GUEST_LINK_END"/> ఉపయోగించండి. వేరెవరి కోసం అయినా మీరు ఖాతాను జోడించాలనుకుంటే, మీ <ph name="DEVICE_TYPE"/>‌కు <ph name="LINK_BEGIN"/>కొత్త వ్యక్తిని జోడించండి<ph name="LINK_END"/>.

మీరు వెబ్‌సైట్‌లు, యాప్‌లకు ఇప్పటికే ఇచ్చిన అనుమతులు ఈ ఖాతాకు వర్తించవచ్చు. మీ Ecosia ఖాతాలను మీరు <ph name="SETTINGS_LINK_BEGIN"/>సెట్టింగ్‌లు<ph name="SETTINGS_LINK_END"/> లింక్‌లో మేనేజ్ చేయవచ్చు.</translation>
<translation id="1640672724030957280">డౌన్‌లోడ్ చేయబడుతోంది...</translation>
<translation id="6876820794875877783">Ecosia యొక్క కొత్త సురక్షితమైన వెర్షన్ అందుబాటులో ఉంది.</translation>
<translation id="1118786556671181978">మీకు యాడ్‌లను చూపడానికి సైట్‌లు ఉపయోగించే ఆసక్తి ఉన్న టాపిక్‌లను మీరు చూడవచ్చు, తీసివేయవచ్చు. Ecosia మీ ఇటీవలి బ్రౌజింగ్ హిస్టరీ ఆధారంగా మీ ఆసక్తులను అంచనా వేస్తుంది.</translation>
<translation id="8454595950895325762">బ్యాక్‌గ్రౌండ్‌లో Ecosiaని అమలు చేయడానికి అనుమతించండి</translation>
<translation id="9125443060066914183">Ecosiaను సురక్షితం చేయడానికి, మేము <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>లో లిస్ట్‌ చేయబడని మరియు మీకు తెలియకుండానే జోడించబడిన కొన్ని ఎక్స్‌టెన్షన్‌లను నిలిపివేసాము.</translation>
<translation id="6984747211123632080">Ecosiaను మళ్లీ ఇన్‌స్టాల్ చేయి</translation>
<translation id="185970820835152459">మీరు సైన్ ఇన్ చేసిన Google ఖాతాలను మీరు మేనేజ్ చేయవచ్చు. Chromium బ్రౌజర్, Play Store, Gmail, ఇంకా మరిన్నింటి కోసం మీ Google ఖాతాలు ఉపయోగించబడతాయి. ఫ్యామిలీ మెంబర్ వంటి వారి కోసం మీరు ఖాతాను జోడించాలనుకుంటే, బదులుగా కొత్త వ్యక్తిని మీ <ph name="DEVICE_TYPE"/>కు జోడించండి. <ph name="LINK_BEGIN"/>మరింత తెలుసుకోండి<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">మీ ఆసక్తులకు సంబంధించిన సమాచారాన్ని సైట్‌లు Chromiumతో స్టోర్ చేయగలవు. ఉదాహరణకు, మారథాన్ కోసం షూస్ కొనడానికి మీరు ఒక సైట్‌ను సందర్శించినట్లయితే, మారథాన్‌లలో పరిగెత్తడం మీకు ఆసక్తి అని ఆ సైట్ స్టోర్ చేయవచ్చు. తర్వాత, రేస్ కోసం రిజిస్టర్ చేసుకోవడానికి మీరు వేరొక సైట్‌ను సందర్శిస్తే, మీ ఆసక్తుల ఆధారంగా ఆ సైట్ మీకు పరిగెత్తడానికి అవసరమైన షూస్ యాడ్‌ను చూపిస్తుంది.</translation>
<translation id="4239392394637574967">మీరు నిర్వహించబడే ఖాతాతో సైన్ ఇన్ చేస్తున్నారు. దీని నిర్వాహకునికి మీ Ecosia ప్రొఫైల్‌పై నియంత్రణను అందిస్తున్నారు. మీ యాప్‌లు, బుక్‌మార్క్‌లు, హిస్టరీ, పాస్‌వర్డ్‌లు, ఇతర సెట్టింగ్‌ల వంటి మీ Ecosia డేటా శాశ్వతంగా <ph name="USER_NAME"/>కు అనుబంధించబడుతుంది. మీరు Ecosia ఖాతాల డ్యాష్‌బోర్డ్ ద్వారా ఈ డేటాను తొలగించవచ్చు. కానీ ఈ డేటాను మరో ఖాతాతో అనుబంధించలేరు. మీరు ప్రస్తుతం ఉన్న మీ Ecosia డేటాను వేరుగా ఉంచడానికి ఐచ్ఛికంగా కొత్త ప్రొఫైల్‌ను క్రియేట్ చేయవచ్చు. <ph name="LEARN_MORE"/></translation>
<translation id="1911763535808217981">దీనిని ఆఫ్ చేయడం ద్వారా, మీరు Chromiumకి సైన్ ఇన్ చేయకుండానే Gmail లాంటి Google సైట్‌లలో సైన్ ఇన్ చేయగలరు</translation>
<translation id="18064594488616674">Ecosia ప్రతిస్పందించడం లేదు. ఇప్పుడు మళ్లీ ప్రారంభించాలా?</translation>
<translation id="8047394653992042491">అప్‌డేట్‌ను వర్తింపజేయడానికి EcosiaOSను రీస్టార్ట్ చేయాలి.</translation>
<translation id="5337919616446681032">మీరు ఈ ఖాతాను ఒకసారి మాత్రమే ఉపయోగించాలనుకుంటే, Ecosia బ్రౌజర్‌లో గెస్ట్ మోడ్‌ను ఉపయోగించండి. వేరెవరి కోసం అయినా మీరు ఖాతాను జోడించాలనుకుంటే, మీ <ph name="DEVICE_TYPE"/>‌కు <ph name="LINK_BEGIN"/>కొత్త వ్యక్తిని జోడించండి<ph name="LINK_END"/>.

మీరు వెబ్‌సైట్‌లు, యాప్‌లకు ఇప్పటికే ఇచ్చిన అనుమతులు ఈ ఖాతాకు వర్తించవచ్చు. మీ Ecosia ఖాతాలను మీరు <ph name="SETTINGS_LINK_BEGIN"/>సెట్టింగ్‌లు<ph name="SETTINGS_LINK_END"/> లింక్‌లో మేనేజ్ చేయవచ్చు.</translation>
<translation id="1953553007165777902">డౌన్‌లోడ్ అవుతోంది... <ph name="MINUTE"/> నిమిషం(లు) సమయం మిగిలి ఉంది</translation>
<translation id="1966382378801805537">Chromium డిఫాల్ట్ బ్రౌజర్‌ను నిశ్చయించలేదు లేదా సెట్ చేయలేదు</translation>
<translation id="2008474315282236005">ఇది ఈ పరికరం నుండి 1 అంశాన్ని తొలగిస్తుంది. మీ డేటాను తర్వాత తిరిగి పొందడానికి, Chromiumకు <ph name="USER_EMAIL"/> లాగా సైన్ ఇన్ చేయండి.</translation>
<translation id="2018879682492276940">ఇన్‌స్టాల్ చేయడం విఫలమైంది. దయచేసి మళ్లీ ట్రై చేయండి.</translation>
<translation id="2020032459870799438">డేటా ఉల్లంఘనల నుండి, ఇతర భద్రతా సమస్యల నుండి మీ ఇతర పాస్‌వర్డ్‌లు సురక్షితంగా ఉన్నాయో లేదో చెక్ చేయడానికి, <ph name="BEGIN_LINK"/>Chromiumకు సైన్ ఇన్ చేయండి<ph name="END_LINK"/>.</translation>
<translation id="2049376729098081731">Google సర్వీస్‌లలో మరింత వ్యక్తిగతీకరించిన అనుభవం కోసం Chromium హిస్టరీని చేర్చాలో, లేదో ఎంచుకోండి</translation>
<translation id="2088953378266246249">Chromium, దాని రూట్ సర్టిఫికేట్‌లను ఎలా మేనేజ్ చేస్తుంది అనే దాని గురించిన సమాచారం</translation>
<translation id="838842459108103907">Ecosiaను అనుకూలంగా మార్చండి</translation>
<translation id="2174917724755363426">ఇన్‌స్టాలేషన్ పూర్తి కాలేదు. మీరు ఖచ్చితంగా రద్దు చేయాలనుకుంటున్నారా?</translation>
<translation id="9035946286843935549">Ecosia - నెట్‌వర్క్ సైన్ ఇన్ - <ph name="PAGE_TITLE"/></translation>
<translation id="6111519389633335269">మీరు కంప్యూటర్‌ను షేర్‌ చేస్తే, స్నేహితులు, ఫ్యామిలీ మెంబర్‌లు విడివిడిగా బ్రౌజ్ చేయవచ్చు. Ecosiaను వారికి నచ్చిన రీతిలో సెటప్ చేసుకోవచ్చు.</translation>
<translation id="2313870531055795960">Chromiumలో స్టోర్ చేయబడిన సురక్షితం కాని సైట్‌ల లిస్ట్‌తో కూడిన URLలను చెక్ చేస్తుంది. ఏదైనా సైట్ మీ పాస్‌వర్డ్‌ను దొంగిలించే ప్రయత్నం చేసినా, లేదంటే ఏదైనా హానికరమైన ఫైల్‌ను మీరు డౌన్‌లోడ్ చేసినా, సదరు URLలను, ఆయా పేజీల కంటెంట్‌లోని కొన్ని భాగాలను కూడా Chromium, 'సురక్షిత బ్రౌజింగ్'కు పంపవచ్చు.</translation>
<translation id="665177868576952817">ఇక్కడి నుండి మీ Android ఫోన్‌కు నంబర్‌ను పంపడానికి, రెండు పరికరాలలోని Ecosiaకు సైన్ ఇన్ చేయండి.</translation>
<translation id="815199437159352723">ఈ ఎక్స్‌టెన్షన్‌ మీరు Ecosiaని ప్రారంభించినప్పుడు చూపబడే పేజీని మార్చింది.</translation>
<translation id="2359808026110333948">కొనసాగించండి</translation>
<translation id="592990842052138727">మీ ఖాతా సైన్ ఇన్ వివరాల గడువు ముగిసినందున EcosiaOS మీ డేటాను సింక్ చేయలేకపోయింది.</translation>
<translation id="9032120646440147804"><ph name="EXTENSION_NAME"/> ఎక్స్‌టెన్షన్‌ మీరు Ecosiaని ప్రారంభించినప్పుడు చూపబడే పేజీని మార్చింది.</translation>
<translation id="3554373328288278512">ఈ సైట్ కోసం Ecosiaకు కెమెరా, ఇంకా మైక్రోఫోన్ అనుమతులు అవసరం</translation>
<translation id="6495878830719404098">Ecosiaలో</translation>
<translation id="2485422356828889247">అన్ఇన్‌స్టాల్ చేయి</translation>
<translation id="5549921590305750618">ఫైళ్లను డౌన్‌లోడ్ చేయడానికి Ecosiaకు నిల్వ యాక్సెస్ అవసరం</translation>
<translation id="9090890391337853620">Ecosia సహాయకం</translation>
<translation id="5707346538075088068">ఈ ప్రొఫైల్‌ను ఉపయోగిస్తున్నప్పుడు జెనరేట్ అయిన ఏదైనా Ecosia డేటాను (బుక్‌మార్క్‌లు, హిస్టరీ, పాస్‌వర్డ్‌లు, ఇంకా ఇతర సెట్టింగ్‌లు వంటివి క్రియేట్ చేయడం) వర్క్ ప్రొఫైల్ అడ్మినిస్ట్రేటర్ తీసివేయవచ్చు. <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosiaని ఉపయోగించడం కొనసాగించండి</translation>
<translation id="7280797724682955539">ఇన‌స్ట‌లేష‌న్‌ సమయంలో ఆపరేటింగ్ సిస్టమ్ ఎర్ర‌ర్‌ ఏర్పడింది. దయచేసి Ecosiaను మళ్లీ డౌన్‌లోడ్ చేయండి.</translation>
<translation id="6960183526681645011">మీరు ఒక పరికరాన్ని షేర్ చేస్తే, ఫ్రెండ్స్, ఫ్యామిలీ విడివిడిగా బ్రౌజ్ చేయవచ్చు, Ecosiaను వారికి నచ్చిన విధంగా సెటప్ చేసుకోవచ్చు</translation>
<translation id="5591151834004774364">Ecosia ఈ ఆర్కైవ్ ఫైల్‌ను బ్లాక్ చేసింది ఎందుకంటే ఇందులో మాల్‌వేర్ దాచబడి ఉండవచ్చు</translation>
<translation id="2381210243314074423">Ecosiaకు స్వాగతం, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="385080958066798123">Ecosia ట్యాబ్</translation>
<translation id="2718390899429598676">అదనపు భద్రత కోసం, Chromium మీ డేటాను ఎన్‌క్రిప్ట్ చేస్తుంది.</translation>
<translation id="2770231113462710648">డిఫాల్ట్ బ్రౌజర్‌ను దీనికి మార్చు:</translation>
<translation id="2799223571221894425">మళ్లీ ప్రారంభించండి</translation>
<translation id="3952510753191144456">ఇది <ph name="USER_EMAIL_ADDRESS"/>కు కొత్త Ecosia ప్రొఫైల్‌ను క్రియేట్ చేస్తుంది</translation>
<translation id="4199684616787081033">Ecosia నుండి తీసివేయండి...</translation>
<translation id="2850691299438350830">Chromiumలో మిమ్మల్ని సురక్షితంగా ఉంచుతుంది, మీరు సైన్ ఇన్ చేసినప్పుడు ఇతర Google యాప్‌లలో మీ సెక్యూరిటీని మెరుగుపరచడానికి ఉపయోగించబడవచ్చు</translation>
<translation id="2885378588091291677">విధి సంచాలకులు</translation>
<translation id="7221868538334633215">&amp;Ecosia గురించి</translation>
<translation id="2915996080311180594">తర్వాత రీస్టార్ట్ చేయండి</translation>
<translation id="2928420929544864228">ఇన్‌స్టాలేషన్ పూర్తయింది.</translation>
<translation id="2977470724722393594">Chromium తాజాగా ఉంది</translation>
<translation id="2977506796191543575">ఏదైనా సైట్ మీ పాస్‌వర్డ్‌ను దొంగిలించే ప్రయత్నం చేసినా, లేదంటే ఏదైనా హానికరమైన ఫైల్‌ను మీరు డౌన్‌లోడ్ చేసినా, సదరు URLలను, ఆయా పేజీల కంటెంట్‌లోని కొన్ని భాగాలను కూడా Chromium, 'సురక్షిత బ్రౌజింగ్'కు పంపవచ్చు</translation>
<translation id="6338684070520405381">Ecosia పాస్‌వర్డ్‌లను ఎడిట్ చేయడానికి ప్రయత్నిస్తోంది.</translation>
<translation id="2899530016847324742">{NUM_DEVICES,plural, =1{Ecosia HID పరికరానికి కనెక్ట్ చేయబడింది}other{Ecosia HID పరికరాలకు కనెక్ట్ చేయబడింది}}</translation>
<translation id="3032706164202344641">Chromium మీ పాస్‌వర్డ్‌లను చెక్ చేయలేకపోయింది. తర్వాత మళ్లీ ట్రై చేయండి.</translation>
<translation id="1762318218111418450">Ecosiaకి జోడిస్తోంది...</translation>
<translation id="3038232873781883849">ఇన్‌స్టాల్ చేయడానికి వేచి ఉంది...</translation>
<translation id="9178613517891824246">Ecosiaకు వినియోగ గణాంకాలు, <ph name="UMA_LINK"/>ను పంపడం ద్వారా Ecosiaను మెరుగుపరచడంలో సహాయపడండి</translation>
<translation id="3101560983689755071">మీ బ్రౌజింగ్ హిస్టరీ మీరు చూసే యాడ్‌లను, దిగువున అంచనా వేసిన ఆసక్తులపై ప్రభావం చూపుతుంది. మీ గోప్యతను రక్షించడానికి, Chromium ప్రతి నెలా దశల వారీగా మీ ఆసక్తులను ఆటోమేటిక్‌గా తొలగిస్తుంది. ఆసక్తులు మీరు తీసివేస్తే మినహా, రిఫ్రెష్ అవుతూనే ఉంటాయి.</translation>
<translation id="7691143774653486474">ఇన్‌స్టాలర్ ఆర్కైవ్‌ను వాస్తవ పరిమాణానికి తీసుకుని రావడంలో విఫలమైంది. దయచేసి Ecosiaను మళ్లీ డౌన్‌లోడ్ చేయండి.</translation>
<translation id="1318059253725731825">Ecosia మీ మైక్రోఫోన్‌ని ఉపయోగిస్తోంది.</translation>
<translation id="8282620071565190081">Ecosiaను పునఃప్రారంభించండి</translation>
<translation id="5500958820122281144">Ecosia అజ్ఞా&amp;త విండోలో లింక్‌ను తెరువు</translation>
<translation id="3697186779259384993">మీ కొత్త Ecosia ప్రొఫైల్‌ను అనుకూలంగా మార్చుకోండి</translation>
<translation id="3216284932113164802">అయ్యో! Ecosia క్రాష్ అయ్యింది. ఇప్పుడే మళ్లీ ప్రారంభించాలా?</translation>
<translation id="4409756430498035341">Ecosia మీ పాస్‌వర్డ్‌లను ఎగుమతి చేయాలనుకుంటోంది.</translation>
<translation id="7602423871874451395">Ecosia దీని డేటా డైరెక్టరీని చదవలేదు మరియు దీనిలో రాయ‌లేదు: <ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="3283186697780795848">Chromium వెర్షన్ <ph name="PRODUCT_VERSION"/> ఇన్‌స్టాల్ చేయబడింది</translation>
<translation id="3286538390144397061">ఇప్పుడు పునఃప్రారంభించండి</translation>
<translation id="4735588186234302898">Ecosia API కీలు లేవు. Ecosia కార్యాచరణలో కొంత భాగం నిలిపివేయబడుతుంది.</translation>
<translation id="3296368748942286671">Chromium మూసివేయబడినప్పుడు నేపథ్య యాప్‌లను అమలు చేయడాన్ని కొనసాగించండి</translation>
<translation id="812798451698099271">ఈ ఖాతాతో ఇప్పటికే ఒక Ecosia ప్రొఫైల్ ఉంది</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="4781882243268600858">ప్రస్తుతం ఉన్న Ecosia ప్రొఫైల్‌కు స్విచ్ చేయాలా?</translation>
<translation id="3412460710772753638">ఈ పరికరంలోని పాస్‌వర్డ్ మేనేజర్‌లో</translation>
<translation id="1914619467562029368">{COUNT,plural, =1{మీ అడ్మినిస్ట్రేటర్ Ecosia 1 నిమిషం కంటే ఎక్కువ సేపు ఇన్‌యాక్టివ్‌గా ఉంటే మూసివేయబడేలా కాన్ఫిగర్ చేశారు.}other{మీ అడ్మినిస్ట్రేటర్ Ecosia # నిమిషాల కంటే ఎక్కువ సేపు ఇన్‌యాక్టివ్‌గా ఉంటే మూసివేయబడేలా కాన్ఫిగర్ చేశారు.}}</translation>
<translation id="4170280082681554565">మీ మొత్తం Ecosia అంశాలను Ecosia ప్రొఫైళ్లతో విభజించవచ్చు. స్నేహితులు, ఫ్యామిలీ కోసం ప్రొఫైళ్లను క్రియేట్ చేయండి, లేదా ఆఫీస్, వినోదం మధ్య విభజించండి.</translation>
<translation id="347328004046849135">చోరీకి గురైన పాస్‌వర్డ్‌తో మీరు సైన్ ఇన్ చేసినప్పుడు Chromium మీకు తెలియజేస్తుంది</translation>
<translation id="3474745554856756813">ఇది ఈ పరికరం నుండి <ph name="ITEMS_COUNT"/> అంశాలను తొలగిస్తుంది. మీ డేటాను తర్వాత తిరిగి పొందడానికి, Chromiumకు <ph name="USER_EMAIL"/> లాగా సైన్ ఇన్ చేయండి.</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> Ecosia ప్రొఫైళ్ల మధ్య స్విచ్ చేయగలదు</translation>
<translation id="8534308095039131078">దయచేసి అన్ని Ecosia విండోలను మూసివేసి, మళ్లీ ప్రయత్నించండి.</translation>
<translation id="3533435340678213462">మీ గోప్యతను రక్షించడానికి, 4 వారాల కంటే పాతవైన మీ ఆసక్తులను మేము ఆటోమేటిక్‌గా తొలగిస్తాము. మీరు బ్రౌజ్ చేస్తూ ఉంటే, ఆసక్తి ఉన్న ఆ టాపిక్ మళ్లీ లిస్ట్‌లో కనిపించవచ్చు. లేదా Chromium పరిగణనలోకి తీసుకోకూడదు అని మీరు భావించే ఆసక్తులను తీసివేయవచ్చు.</translation>
<translation id="3567254597502212821">మీ బ్రౌజింగ్ హిస్టరీ, ఈ పరికరంలో Chromiumను ఉపయోగించి మీరు సందర్శించిన సైట్‌ల రికార్డ్.</translation>
<translation id="2804130178228362015">మీ కంప్యూటర్‌లో మీ భద్రతకు హాని కలిగించే సాఫ్ట్‌వేర్‌ ఉంది. మీ బ్రౌజర్‌ని మళ్లీ సాధారణంగా పని చేసేలా చేయడానికి Ecosia దానిని తీసివేసి, మీ సెట్టింగ్‌లను పునరుద్ధరించి, ఎక్స్‌టెన్షన్‌లను నిలిపివేయగలదు.</translation>
<translation id="7375011918167125899">వేరొక ఖాతాతో ఇప్పటికే సైన్ ఇన్ చేశారు. మీరు బ్రౌజ్ చేసిన వాటిని విడిగా ఉంచడానికి, Ecosia మీ కోసం మీ సొంత ప్రొఫైల్‌ను క్రియేట్ చేయగలదు.</translation>
<translation id="2128110540135015661">ఈ వ్యక్తి బ్రౌజింగ్ డేటా‌ ఈ పరికరం నుండి తొలగించబడుతుంది. డేటాను పునరుద్ధరించడానికి, <ph name="USER_EMAIL"/>గా Ecosiaకు సైన్ ఇన్ చేయండి.</translation>
<translation id="1323499021727766710">{COUNT,plural, =0{Ecosiaకు కొత్త అప్‌డేట్ అందుబాటులో ఉంది, మీరు పునఃప్రారంభించిన వెంటనే వర్తింపజేయబడుతుంది.}=1{Ecosiaకు కొత్త అప్‌డేట్ అందుబాటులో ఉంది, మీరు పునఃప్రారంభించిన వెంటనే వర్తింపజేయబడుతుంది. మీ అజ్ఞాత విండో మళ్లీ తెరవబడదు.}other{Ecosiaకు కొత్త అప్‌డేట్ అందుబాటులో ఉంది, మీరు పునఃప్రారంభించిన వెంటనే వర్తింపజేయబడుతుంది. మీ # అజ్ఞాత విండోలు మళ్లీ తెరవబడవు.}}</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/> నుండి మీ Android ఫోన్‌కు నంబర్‌ను పంపడానికి, రెండు పరికరాలలోని Ecosiaకు సైన్ ఇన్ చేయండి.</translation>
<translation id="3685209450716071127">Chromium మీ పాస్‌వర్డ్‌లను చెక్ చేయలేకపోయింది. మీ ఇంటర్నెట్ కనెక్షన్ సరిచూసుకుని, తర్వాత ట్రై చేయండి.</translation>
<translation id="5902103164685487225">Ecosiaలో యాడ్ వ్యక్తిగతీకరణ గురించి మరింత తెలుసుకోండి</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{ఈ అప్‌డేట్‌ను వర్తింపజేయడం కోసం మీరు Ecosiaను పునఃప్రారంభించాలని మీ నిర్వాహకుడు కోరుతున్నారు}=1{ఈ అప్‌డేట్‌ను వర్తింపజేయడం కోసం మీరు Ecosiaను పునఃప్రారంభించాలని మీ నిర్వాహకుడు కోరుతున్నారు. మీ అజ్ఞాత విండో మళ్లీ తెరవబడదు.}other{ఈ అప్‌డేట్‌ను వర్తింపజేయడం కోసం మీరు Ecosiaను పునఃప్రారంభించాలని మీ నిర్వాహకుడు కోరుతున్నారు. మీ # అజ్ఞాత విండోలు మళ్లీ తెరవబడవు.}}</translation>
<translation id="489671036945006830">కొత్త Ecosia &amp;ట్యాబ్‌లో లింక్‌ని తెరువు</translation>
<translation id="3728336900324680424">అడ్రస్‌ బార్‌లో సూచనలు చేయడానికి Chromium మీ డిస్క్‌ను యాక్సెస్ చేస్తుంది</translation>
<translation id="6107290018380796650">Ecosia వెబ్‌లో ఫోన్ నంబర్ క్లిక్ చేయడానికి మరియు Skypeతో కాల్ చేయడానికి మిమ్మల్ని అనుమతిస్తుంది!</translation>
<translation id="3959732324458144441">EcosiaOS సిస్టమ్</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - Ecosia</translation>
<translation id="386822487697155367">ChromiumOSతో సహాయాన్ని పొందండి</translation>
<translation id="6391863622742187823"><ph name="ACCOUNT_EMAIL"/> నుండి మీ Ecosia బ్రౌజర్ సంబంధిత అంశాలను పొందండి</translation>
<translation id="8544776492099331022">Ecosiaను అనుకూలంగా మార్చండి మరియు నియంత్రించండి. మీరు గమనించాల్సిన విషయం ఒకటి ఉంది - వివరాల కోసం క్లిక్ చేయండి.</translation>
<translation id="4871843754042758264">Ecosiaను తెరిచి, బ్రౌజింగ్‌ను ప్రారంభించడానికి మీ పేరును క్లిక్ చేయండి.</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> ఇప్పటికే ఈ Ecosia ప్రొఫైల్‌కు సైన్ ఇన్ చేశారు. మీరు బ్రౌజ్ చేసిన వాటిని విడిగా ఉంచడానికి, Ecosia మీ కోసం మీ సొంత ప్రొఫైల్‌ను క్రియేట్ చేయగలదు.</translation>
<translation id="4070480171055648632">మీ ఖాతాను <ph name="MANAGER_NAME"/> మేనేజ్ చేస్తున్నారు. మీ అడ్మినిస్ట్రేటర్ ఈ Ecosia బ్రౌజర్ ప్రొఫైల్‌ను, అలాగే బుక్‌మార్క్‌లు, హిస్టరీ, పాస్‌వర్డ్‌ల వంటి దాని డేటాను చూడగలరు, ఎడిట్ చేయగలరు.</translation>
<translation id="1047556320128249268">పాస్‌వర్డ్‌లను కాపీ చేయడానికి Ecosia ప్రయత్నిస్తోంది. దీన్ని అనుమతించడానికి మీ Windows పాస్‌వర్డ్‌ను టైప్ చేయండి.</translation>
<translation id="4997668724897475215">ఈ ఫైల్ ప్రమాదకరమైనది కావచ్చు, కాబట్టి దీనిని స్కాన్ చేయమని Ecosia సిఫార్సు చేస్తోంది</translation>
<translation id="3997429360543082038">ChromiumOS గురించి</translation>
<translation id="5311911269004680646">EcosiaOS అనేది <ph name="BEGIN_LINK_LINUX_OSS"/>Linux డెవలప్‌మెంట్ ఎన్విరాన్‌మెంట్<ph name="END_LINK_LINUX_OSS"/> తరహాలోనే, అదనపు <ph name="BEGIN_LINK_CROS_OSS"/>ఓపెన్ సోర్స్ సాఫ్ట్‌వేర్<ph name="END_LINK_CROS_OSS"/> ద్వారా సాధ్యమైంది.</translation>
<translation id="4036079820698952681"><ph name="BEGIN_LINK"/>ప్రస్తుత సెట్టింగ్‌లను<ph name="END_LINK"/> రిపోర్ట్ చేయడం ద్వారా Chromiumను మెరుగుపరచడంలో సహాయపడండి</translation>
<translation id="4050175100176540509">ముఖ్యమైన భద్రతా మెరుగుదలలు మరియు కొత్త ఫీచర్‌లు తాజా వెర్షన్‌లో అందుబాటులో ఉన్నాయి.</translation>
<translation id="4148957013307229264">వ్యవస్థాపిస్తోంది...</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - నెట్‌వర్క్ సైన్ ఇన్ - Ecosia</translation>
<translation id="7782767522222146179">Ecosia కోసం గొప్ప యాప్‌లు, ఆటలు, ఎక్స్‌టెన్షన్‌లు మరియు థీమ్‌లను కనుగొనండి.</translation>
<translation id="4216212958613226427">Chromium UI ప్రదర్శించడం కోసం ఈ భాష ఉపయోగించబడింది</translation>
<translation id="4222932583846282852">రద్దు చేస్తోంది...</translation>
<translation id="8384922154025337808">మీ Ecosia డేటాను ఈ ఖాతాకు జోడించాలా?</translation>
<translation id="4271805377592243930">Chromium గురించి సహాయాన్ని పొందండి</translation>
<translation id="3305517118160815955">పేర్కొనబడని ఎర్రర్ కారణంగా ఇన్‌స్టాలేషన్ విఫలమైంది. ప్రస్తుతం Ecosia అమలు చేయబడుతుంటే, దయచేసి దీనిని మూసివేసి, మళ్లీ ప్రయత్నించండి.</translation>
<translation id="4304713468139749426">పాస్‌వర్డ్ మేనేజర్</translation>
<translation id="4334294535648607276">డౌన్‌లోడ్ పూర్తయింది.</translation>
<translation id="8411844745163855310">మీరు ఈ పరికరాన్ని ఉపయోగించడానికి ముందు సర్వీస్ నియమాలను చదివి, అంగీకరించాలని <ph name="MANAGER"/> కోరుతోంది. ఈ నియమాలు EcosiaOS నియమాలను విస్తరింపజేయవు, సవరించవు లేదా పరిమితం చేయవు.</translation>
<translation id="88039520238670574">ఏదేమైనా Ecosia నుండి నిష్క్రమించాలా?</translation>
<translation id="4586967042094107073">బ్యాక్‌గ్రౌండ్‌లో అమలయ్యేందుకు Ecosiaని అనుమతించండి</translation>
<translation id="4817913198787198451">Ecosiaను అనుకూలంగా మార్చండి మరియు నియంత్రించండి</translation>
<translation id="4427306783828095590">ఫిషింగ్, అలాగే మాల్‌వేర్‌ను బ్లాక్ చేయడానికి మెరుగుపరచిన రక్షణ మరింత చేయగలదు</translation>
<translation id="1859120614572957305">Ecosiaకు స్వాగతం; కొత్త బ్రౌజర్ విండో తెరవబడింది</translation>
<translation id="4544142686420020088">Chromium అప్‌డేట్ అవ్వలేదు, ఏదో తప్పు జరిగింది. <ph name="BEGIN_LINK"/>Chromium అప్‌డేట్ సమస్యలు, విఫలమైన అప్‌డేట్‌లను పరిష్కరించండి.<ph name="END_LINK"/></translation>
<translation id="8685318202174822382">కొత్త Ecosia ప్రొఫైల్‌లో కొనసాగించాలా?</translation>
<translation id="4567424176335768812">మీరు <ph name="USER_EMAIL_ADDRESS"/>గా సైన్ ఇన్ చేశారు. ఇప్పుడు మీరు సైన్ ఇన్ చేసిన అన్ని పరికరాల్లో మీ బుక్‌మార్క్‌లు, హిస్టరీ మరియు ఇతర సెట్టింగ్‌లను యాక్సెస్ చేయవచ్చు.</translation>
<translation id="4594305310729380060">ఈ పరికరంలోని పాస్‌వర్డ్ మేనేజర్‌కు</translation>
<translation id="2636091632287013185">Ecosia యాప్‌లు</translation>
<translation id="4613863813562375431">ChromiumOS వెర్షన్</translation>
<translation id="4621240073146040695">దాదాపుగా నవీకృతంగా ఉంది! అప్‌డేట్‌ను పూర్తి చేయడానికి Chromiumని పునఃప్రారంభించండి.</translation>
<translation id="1676748966275099244">హెచ్చరిక: Ecosia మీ బ్రౌజింగ్ హిస్టరీను రికార్డ్ చేయకుండా ఎక్స్‌టెన్ష‌న్‌లను నివారించలేదు. ఈ ఎక్స్‌టెన్ష‌న్‌ను అజ్ఞాత మోడ్‌లో డిజేబుల్ చేయడానికి, ఈ ఆప్షన్‌ను రద్దు చేయండి.</translation>
<translation id="4673151026126227699">మీరు Chromium వినియోగ రిపోర్ట్‌లను కూడా షేర్ చేస్తున్నట్లయితే, ఆ రిపోర్ట్‌లలో మీరు సందర్శించే URLలు ఉంటాయి</translation>
<translation id="1384607180773886645">ఈ ప్రొఫైల్‌ను మరొక కంప్యూటర్ (<ph name="HOST_NAME"/>)లో మరో Ecosia ప్రాసెస్ (<ph name="PROCESS_ID"/>) ఉపయోగిస్తున్నట్లు కనిపిస్తోంది. Ecosia ప్రొఫైల్‌ను లాక్ చేసినందున అది పాడవదు. ఈ ప్రొఫైల్‌ను వేరే ప్రాసెస్‌లు ఏవీ ఉపయోగించడం లేదని మీకు ఖచ్చితంగా తెలిస్తే, ప్రొఫైల్‌ను అన్‌లాక్ చేసి Ecosiaను మళ్లీ ప్రారంభించవచ్చు.</translation>
<translation id="4680828127924988555">ఇన్‌స్టాలేషన్‌ను రద్దు చేయండి</translation>
<translation id="4727435569202742773">ఒకరు ఈ కంప్యూటర్‌లో మునుపు <ph name="ACCOUNT_EMAIL_LAST"/> లాగా Ecosiaకు సైన్ ఇన్ చేశారు. దయచేసి మీ సమాచారాన్ని విడిగా ఉంచేందుకు కొత్త Ecosia వినియోగదారును క్రియేట్ చేయండి.</translation>
<translation id="864244542982029641">ఏదేమైనా Ecosiaని మూసివేయాలా?</translation>
<translation id="1025044809499013222">Ecosiaకి సంబంధించిన ప్రత్యేక భద్రతా అప్‌డేట్ వర్తింపజేయబడింది. ఇప్పుడే పునఃప్రారంభించండి, మేము మీ ట్యాబ్‌లను పునరుద్ధరిస్తాము.</translation>
<translation id="824192326282906244">మీరు మనస్సు మార్చుకుంటే, మీ ఆసక్తిని Ecosia సెట్టింగ్‌లలో ఎప్పుడైనా మార్చుకోవచ్చు. మీరు ఈ మార్పులను వెంటనే చూడలేరు. ఎందుకంటే, యాడ్‌లను అందించే మార్గంలోనే వాటితో పాటు ట్రయల్స్ కూడా రన్ అవుతాయి.</translation>
<translation id="4788777615168560705">Chromium మీ పాస్‌వర్డ్‌లను చెక్ చేయలేకపోయింది. 24 గంటల తర్వాత మళ్లీ ట్రై చేయండి లేదా <ph name="BEGIN_LINK"/>మీ Google ఖాతాలో పాస్‌వర్డ్‌లను చెక్ చేయండి<ph name="END_LINK"/>.</translation>
<translation id="3543284013834505767">Ecosia Searchలో ఉపయోగించే స్పెల్ చెకర్‌నే ఇది ఉపయోగిస్తుంది. మీరు బ్రౌజర్‌లో టైప్ చేసే టెక్స్ట్‌ను Ecosiaకు పంపుతుంది. ఈ ఆప్షన్‌ను తర్వాత ఎప్పుడైనా మీరు సెట్టింగ్‌లలో మార్చవచ్చు.</translation>
<translation id="4154538917942874814">mDNS ట్రాఫిక్‌ను అనుమతించడానికి Ecosia ఇన్‌బౌండ్ నియమం.</translation>
<translation id="2159716220295742156">&amp;Ecosiaను అప్‌డేట్ చేయడానికి రీ-లాంచ్ చేయండి</translation>
<translation id="2234042158691635795">Ecosia నేపథ్య మోడ్‌లో ఉంది.</translation>
<translation id="1869027055332251164">అతిథులు ఎటువంటి హిస్టరీని వదలకుండానే Ecosiaను ఉపయోగించవచ్చు.</translation>
<translation id="6761747850241550887">Ecosiaకు మిమ్మల్ని జోడించుకోండి</translation>
<translation id="3708834841667355707">Ecosia మీ సమాచారాన్ని తక్కువగా ఉపయోగిస్తూ అదే బ్రౌజింగ్ అనుభవాన్ని అందించడానికి సైట్‌లను అనుమతించే కొత్త ఫీచర్‌ల కోసం అన్వేషిస్తోంది</translation>
<translation id="5224391634244552924">సేవ్ చేసిన పాస్‌వర్డ్‌లు లేవు. మీరు మీ పాస్‌వర్డ్‌లను సేవ్ చేసినప్పుడు Chromium వాటిని చెక్ చేయగలదు.</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> ఇప్పటికే ఈ Ecosia ప్రొఫైల్‌కు సైన్ ఇన్ చేశారు. ఇది <ph name="USER_EMAIL_ADDRESS"/>కు కొత్త Ecosia ప్రొఫైల్‌ను క్రియేట్ చేస్తుంది</translation>
<translation id="5277894862589591112">మీ మార్పులను వర్తింపజేయడానికి, Chromiumని పునఃప్రారంభించండి</translation>
<translation id="5296845517486664001">ట్రయల్స్ ఆన్‌లో ఉన్నప్పుడు, Chromium ర్యాండమ్‌గా మిమ్మల్ని యాక్టివ్‌గా ఉన్న ఒక ట్రయల్‌లో ఉంచినట్లయితే, మీ బ్రౌజింగ్ హిస్టరీ మీరు చూసే యాడ్‌లను, దిగువున అంచనా వేసిన ఆసక్తులపై ప్రభావం చూపుతుంది. మీ గోప్యతను రక్షించడానికి, Chromium ప్రతి నెలా దశల వారీగా మీ ఆసక్తులను తొలగిస్తుంది.</translation>
<translation id="7105712012505419722">మీరు నిర్వహించబడే ఖాతాతో సైన్ ఇన్ చేస్తున్నారు. దీని నిర్వాహకునికి మీ Ecosia ప్రొఫైల్‌పై నియంత్రణను అందిస్తున్నారు. మీ యాప్‌లు, బుక్‌మార్క్‌లు, హిస్టరీ, పాస్‌వర్డ్‌లు, ఇతర సెట్టింగ్‌ల వంటి మీ Ecosia డేటా శాశ్వతంగా <ph name="USER_NAME"/>కు అనుబంధించబడుతుంది. మీరు Ecosia ఖాతాల డ్యాష్‌బోర్డ్ ద్వారా ఈ డేటాను తొలగించవచ్చు. కానీ ఈ డేటాను మరో ఖాతాతో అనుబంధించలేరు. <ph name="LEARN_MORE"/></translation>
<translation id="5386450000063123300">Chromium నవీకరించబడుతోంది (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">Chromium సైన్-ఇన్‌ని అనుమతించండి</translation>
<translation id="8447746441670667471">కొత్త Ecosia వెర్షన్ అందుబాటులో ఉంది.</translation>
<translation id="330264384086604869">Ecosia నుండి తీసివేయండి</translation>
<translation id="3138995062177413515">{0,plural, =0{Ecosia ఇప్పుడు మూసివేయబడుతుంది.}=1{Ecosia 1 సెకనులో మూసివేయబడుతుంది.}other{Ecosia # సెకన్లలో మూసివేయబడుతుంది.}}</translation>
<translation id="5581150090232500900">Ecosiaను మీ డిఫాల్ట్ బ్రౌజర్‌గా సెట్ చేయండి</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia బీటా</translation>
<translation id="3307959934543585795">Ecosiaకు ఇక ఈ Linux డిస్ట్రిబ్యూషన్‌లో సపోర్ట్ లేనందున అది సరిగ్గా పని చేయకపోవచ్చు</translation>
<translation id="6558895515431832002">ఈ సైట్‌తో మీ స్థానాన్ని షేర్ చేయడానికి Ecosiaకు మీ స్థాన యాక్సెస్ అవసరం</translation>
<translation id="5487574057737591516">మీ గోప్యతను రక్షించడానికి, 4 వారాల కంటే పాతవైన మీ ఆసక్తులను మేము ఆటోమేటిక్‌గా తొలగిస్తాము. మీరు బ్రౌజ్ చేస్తూ ఉంటే, ఆసక్తి ఉన్న ఆ టాపిక్ మళ్లీ లిస్ట్‌లో కనిపించవచ్చు. Chromium మీ ఆసక్తిని తప్పుగా చూపించినా లేదా మీరు నిర్దిష్టమైన యాడ్‌లను చూడకూడదు అనుకున్నా, మీరు ఆసక్తి ఉన్న ఆ టాపిక్‌ను తీసివేయవచ్చు.</translation>
<translation id="5279514147510747661">దయచేసి Ecosia తాజా సిస్టమ్ అప్‌డేట్‌లను ఇన్‌స్టాల్ చేస్తున్నప్పుడు వేచి ఉండండి.</translation>
<translation id="5066194399237265772">పాస్‌వర్డ్‌లను ఎడిట్ చేయడానికి Ecosia ప్రయత్నిస్తోంది. దీన్ని అనుమతించడానికి మీ Windows పాస్‌వర్డ్‌ను టైప్ చేయండి.</translation>
<translation id="5527463683072221100">Chromiumలో PDFలను తెరవండి</translation>
<translation id="5614091477838198795">దీన్ని ఆన్ చేసినప్పుడు, మీరు Chromium నుండి కూడా సైన్ అవుట్ చేయబడతారు</translation>
<translation id="7348818664647668234">{0,plural, =0{ఒక Ecosia అప్‌డేట్ అందుబాటులో ఉంది}=1{ఒక Ecosia అప్‌డేట్ అందుబాటులో ఉంది}other{ఒక Ecosia అప్‌డేట్ # రోజులుగా అందుబాటులో ఉంది}}</translation>
<translation id="5675757883980078189">Ecosiaకి Windows 7 లేదా అంతకంటే ఆధునికమైనది ఉండటం ఆవశ్యకం.</translation>
<translation id="5982672133249369264">దయచేసి ఇప్పుడు Ecosiaను మళ్ళీ ప్రారంభించండి</translation>
<translation id="5698481217667032250">Chromiumను ఈ భాషలో ప్రదర్శించు</translation>
<translation id="1027331268335328576">Ecosiaకు స్వాగతం</translation>
<translation id="2942675027725878581">ఈ ఐటెమ్‌లు మాల్‌వేర్‌ను కలిగి ఉన్నట్టుగా Ecosia కనుగొన్నది:</translation>
<translation id="5895138241574237353">మళ్ళీ ప్రారంభించండి</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - నెట్‌వర్క్ సైన్ ఇన్</translation>
<translation id="5924017743176219022">ఇంటర్నెట్‌కు కనెక్ట్ చేస్తోంది...</translation>
<translation id="5941711191222866238">కనిష్టీకరించు</translation>
<translation id="5972142260211327093">Chromium ర్యాండమ్‌గా మిమ్మల్ని యాక్టివ్‌గా ఉన్న ఒక ట్రయల్‌లో ఉంచినట్లయితే, మీ బ్రౌజింగ్ హిస్టరీ మీరు చూసే యాడ్‌లను, దిగువున అంచనా వేసిన ఆసక్తులపై ప్రభావం చూపుతుంది. మీ గోప్యతను రక్షించడానికి, Chromium ప్రతి నెలా దశల వారీగా మీ ఆసక్తులను తొలగిస్తుంది. ఆసక్తులు మీరు తీసివేస్తే మినహా, రిఫ్రెష్ అవుతూనే ఉంటాయి.</translation>
<translation id="5704599732514791330">సింక్‌ను ప్రారంభించడానికి Ecosiaను అప్‌డేట్ చేయండి</translation>
<translation id="5988505247484123880">మీకు వ్యక్తిగతీకరించిన అనుభవాన్ని అందించడం కోసం, సైట్‌లు మీకు ఆసక్తి ఉన్న విషయాలను గుర్తుంచుకోవడం సర్వసాధారణం. మీ ఆసక్తులకు సంబంధించిన సమాచారాన్ని కూడా సైట్‌లు Chromiumతో స్టోర్ చేయగలవు.</translation>
<translation id="6003112304606738118">డౌన్‌లోడ్ అవుతోంది... <ph name="HOURS"/> గంట(లు) సమయం మిగిలి ఉంది</translation>
<translation id="6040143037577758943">మూసివేయి</translation>
<translation id="7185777478310554774">కొత్త Ecosia వెర్షన్ అందుబాటులో ఉంది, ఇది మునుపటి కంటే వేగవంతంగా ఉంటుంది.</translation>
<translation id="7303930050538184306">&amp;Ecosiaలో తెరవండి</translation>
<translation id="2227704215309956084">Ecosiaకు <ph name="EXTENSION_NAME"/> జోడించబడింది</translation>
<translation id="2905159584855395810">Ecosiaను వేగవంతం చేయండి</translation>
<translation id="608006075545470555">ఈ బ్రౌజర్‌కు వర్క్ ప్రొఫైల్‌ను జోడించండి</translation>
<translation id="8296565077892323223">Ecosiaను అనుకూలంగా మార్చండి మరియు నియంత్రించండి. అప్‌డేట్ అందుబాటులో ఉంది.</translation>
<translation id="6419542773162312746">Ecosia టూల్‌బార్‌లో యాక్సెస్ రిక్వెస్ట్‌లను చూపడానికి ఎక్స్‌టెన్షన్‌ను అనుమతించండి</translation>
<translation id="4021894801595982809">Ecosia ఈ పాస్‌వర్డ్‌ను మీ Ecosia ఖాతాలో సేవ్ చేస్తుంది. మీరు దీనిని గుర్తుంచుకోవాల్సిన అవసరం లేదు.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> హానికరం, కావున Ecosia దాన్ని బ్లాక్ చేసింది.</translation>
<translation id="6134968993075716475">సురక్షిత బ్రౌజింగ్ ఆఫ్ చేయబడింది. దాన్ని ఆన్ చేయమని Chromium సిఫార్సు చేస్తోంది.</translation>
<translation id="4032832945953542360">మీరు ఇక్కడ Ecosia ప్రొఫైళ్ల మధ్య స్విచ్ అవ్వవచ్చు</translation>
<translation id="2346323077583431428">మీ <ph name="TARGET_DEVICE_NAME"/>లో మీరు Ecosiaకు సైన్ ఇన్ చేశారని నిర్ధారించుకుని, ఆపై మళ్లీ పంపడానికి ట్రై చేయండి.</translation>
<translation id="2995860351618948435">ఈ కంప్యూటర్‌లో ఇప్పటికే మరింత తాజాదైన Ecosia వెర్షన్ ఉంది. సాఫ్ట్‌వేర్ పని చేయకపోతే, దయచేసి Ecosiaను అన్ఇన్‌స్టాల్ చేసి, మళ్లీ ప్రయత్నించండి.</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia ఇప్పుడు తిరిగి ప్రారంభించబడుతుంది}=1{1 సెకనులో Ecosia తిరిగి ప్రారంభించబడుతుంది}other{# సెకన్లలో Ecosia తిరిగి ప్రారంభించబడుతుంది}}</translation>
<translation id="1809194740315140401">ఫైళ్లను డౌన్‌లోడ్ చేయడానికి Ecosiaకు స్టోరేజ్ యాక్సెస్‌కు సంబంధించిన అనుమతి అవసరం</translation>
<translation id="6245734527075554892">Chromiumలో స్టోర్ చేయబడిన సురక్షితం కాని సైట్‌ల లిస్ట్‌తో కూడిన URLలను చెక్ చేస్తుంది</translation>
<translation id="4662363689050405237">Ecosiaను డిఫాల్ట్ బ్రౌజర్‌గా చేయి</translation>
<translation id="6266342355635466082">అప్‌డేట్‌లను Chromium చెక్ చేయలేకపోయింది. మీ ఇంటర్నెట్ కనెక్షన్ సరిచూసుకుని, తర్వాత ట్రై చేయండి.</translation>
<translation id="6268381023930128611">Chromium నుండి సైన్ అవుట్ చేయాలా?</translation>
<translation id="6273793429163604305">మీ స్థానంలో ఉండండి...</translation>
<translation id="6416551953415159186">మీ Ecosia ప్రొఫైల్‌ను అనుకూలంగా మార్చండి</translation>
<translation id="6290827346642914212">మీ Chromium ప్రొఫైల్‌కు పేరు పెట్టండి</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/> హానికరం కావచ్చు, కావున Ecosia దాన్ని బ్లాక్ చేసింది.</translation>
<translation id="4943938785458240142">Ecosia మీ కెమెరాను ఉపయోగిస్తోంది.</translation>
<translation id="5669097765101132299">Ecosia ఈ ఫైల్‌ను బ్లాక్ చేసింది, ఎందుకంటే ఇది ప్రమాదకరమైనది</translation>
<translation id="6327105987658262776">అప్‌డేట్ ఏదీ అందుబాటులో లేదు.</translation>
<translation id="6450895420388847775">Ecosiaలో మరొక వ్యవస్థాపన జరుగుతోంది. దయచేసి తర్వాత మళ్లీ ప్రయత్నించండి.</translation>
<translation id="464306605599005355">ఇప్పుడు మీ Ecosia ఖాతాతో, షేర్ చేయ‌బ‌డిన కంప్యూట‌ర్‌ల‌లో Ecosiaను సులభంగా ఉపయోగించవచ్చు.</translation>
<translation id="7908111389403807005">మీరు ఖచ్చితంగా Ecosiaను అన్ఇన్‌స్టాల్ చేయాలనుకుంటున్నారా?</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>మేము ఈ డేటాను ఎలా ఉపయోగిస్తాము:<ph name="END_BOLD"/> Ecosia మీ ఆసక్తులను అంచనా వేయగలదు. తర్వాత, మీరు చూసే యాడ్‌లను వ్యక్తిగతీకరించడం కోసం, మీరు సందర్శించే సైట్ మీ ఆసక్తులను చూడమని Ecosiaను అడగవచ్చు.</translation>
<translation id="3939060118711873999">Ecosia అనేది మెరుపు వేగంతో వెబ్‌పేజీలను మరియు యాప్‌ల‌ను అమలు చేసే వెబ్ బ్రౌజర్. ఇది వేగవంతమైనది, స్థిరమైనది మరియు ఉపయోగించడానికి సులభమైనది. Ecosiaలో రూపొందించిన మాల్‌వేర్‌ మరియు ఫిషింగ్ రక్షణతో మరింత సురక్షితంగా వెబ్‌లో బ్రౌజ్ చేయండి.</translation>
<translation id="5404489723475681578">EcosiaOSను రీస్టార్ట్ చేయండి</translation>
<translation id="4410570812343670816">Ecosia ప్రొఫైళ్లకు స్వాగతం</translation>
<translation id="5789438819244101666">{SECONDS,plural, =1{Ecosia 1 సెకనులో పునఃప్రారంభమవుతుంది}other{Ecosia # సెకన్లలో పునఃప్రారంభమవుతుంది}}</translation>
<translation id="524314285625975879">ఇది మీరు Ecosiaని ప్రారంభించేటప్పుడు చూపబడే పేజీని కూడా నియంత్రిస్తుంది.</translation>
<translation id="6496553866814956056">Ecosiaను అన్ఇన్‌స్టాల్ చేయి</translation>
<translation id="8608092457636055141">ప్రతి ప్రొఫైల్‌లో బుక్‌మార్క్‌లు, హిస్టరీ, పాస్‌వర్డ్‌లు లాంటి దాని సొంత Ecosia సమాచారం ఉంటుంది</translation>
<translation id="6570579332384693436">అక్షరక్రమ లోపాలను పరిష్కరించడానికి, మీరు వచన ఫీల్డ్‌లలో టైప్ చేసే వచనాన్ని, Chromium Googleకు పంపుతుంది</translation>
<translation id="6533266716128249922">Ecosia నోటిఫికేషన్ సెట్టింగ్‌లకు వెళ్లు</translation>
<translation id="1722634673917783018">మీ మార్పులు మీరు Ecosiaని మరుసటిసారి ప్రారంభించినప్పుడు ప్రభావాన్ని చూపుతాయి.</translation>
<translation id="2537426042760364251">మీ పరిసరాల 3D మ్యాప్‌ను క్రియేట్ చేయడానికి Ecosiaకు కెమెరా అనుమతి అవసరం</translation>
<translation id="6663852025006259149">సైట్‌లు మీరు ఊహించిన విధంగానే పని చేయవచ్చు కానీ మీరు అన్ని Chromium విండోలను మూసివేసిన తర్వాత అవి మిమ్మల్ని గుర్తుంచుకోవు</translation>
<translation id="6676384891291319759">ఇంటర్నెట్‌ను యాక్సెస్ చేయండి</translation>
<translation id="8067423333018528301">సైన్ ఇన్ చేయడంలో ఎర్రర్ ఏర్పడినందున EcosiaOS మీ డేటాను సింక్ చేయలేకపోయింది.</translation>
<translation id="2173571365716863400">ఈ సైట్ కోసం Ecosiaకు మైక్రోఫోన్ అనుమతి అవసరం</translation>
<translation id="6648664289472946060">మీ ప్రొఫైల్, కొత్త Ecosia వెర్షన్‌కు చెందినది కాబట్టి, దీనిని ఉపయోగించడం సాధ్యపడదు.

కొన్ని ఫీచర్‌లు అందుబాటులో ఉండకపోవచ్చు. దయచేసి వేరొక ప్రొఫైల్ డైరెక్టరీని పేర్కొనండి లేదా Ecosia యొక్క కొత్త వెర్షన్‌ను ఉపయోగించండి.</translation>
<translation id="6039735020616040749">మెమరీ సేవర్ Ecosiaను వేగవంతం చేస్తుంది</translation>
<translation id="4870057811531036437">మీ కంప్యూటర్‌లోని వినియోగదారులందరికీ Ecosia ఇప్పటికే ఇన్‌స్టాల్ చేయబడింది.</translation>
<translation id="4512092435423703529">మీ అన్ని పరికరాలలో మీ Ecosia సంబంధిత అంశాలను యాక్సెస్ చేయడానికి, సైన్ ఇన్ చేసి, ఆపై సింక్‌ను ఆన్ చేయండి.</translation>
<translation id="7972668220031382654">ఈ ఫైల్ ప్రమాదకరమైనది కావచ్చు, కాబట్టి దీనిని స్కాన్ చేయమని Ecosia సిఫార్సు చేస్తోంది.</translation>
<translation id="2290912123073552463">Ecosiaలో సైట్‌లు, యాప్‌లు, ఎక్స్‌టెన్షన్‌లకు సంబంధించిన అనుమతులను మీ తల్లి/తండ్రి ఆఫ్ చేశారు. ఈ <ph name="EXTENSION_TYPE_PARAMETER"/>ను ఎనేబుల్ చేయడానికి అనుమతి లేదు.</translation>
<translation id="2441303983090031276">EcosiaOS అనేది అదనపు <ph name="BEGIN_LINK_CROS_OSS"/>ఓపెన్ సోర్స్ సాఫ్ట్‌వేర్<ph name="END_LINK_CROS_OSS"/> ద్వారా సాధ్యమైంది.</translation>
<translation id="1263466865695943046">మీ పాస్‌వర్డ్‌లు ఎప్పుడైనా హ్యాక్ అయితే, Ecosia మీకు తెలియచేస్తుంది</translation>
<translation id="7864624828358709494">ఈ ఫైల్ మాల్‌వేర్‌ను కలిగి ఉన్నందున Ecosia దీనిని బ్లాక్ చేసింది</translation>
<translation id="4600924482853773728">Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="6863361426438995919">Google Pay (Chromiumకి కాపీ చేయబడింది)</translation>
<translation id="1490060441084292633">"<ph name="EXTENSION_NAME"/>"లో మాల్‌వేర్ ఉన్నట్టుగా Ecosia కనుగొన్నది</translation>
<translation id="7482156490649194631">Ecosia అప్‌డేట్ చేయబడింది, కానీ మీరు దీన్ని గత 30 రోజులుగా ఉపయోగించలేదు.</translation>
<translation id="4062366803229254216">పెయిరింగ్‌ను కొనసాగించడానికి Ecosiaకు 
 బ్లూటూత్ యాక్సెస్ అవసరం. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="6929417474050522668">ట్రయల్స్ ఆన్‌లో ఉన్నప్పుడు, మీరు సందర్శించే సైట్‌లను Chromium నుండి సమాచారాన్ని రిక్వెస్ట్ చేసేలా 'యాడ్‌ల అంచనా' అనుమతిస్తుంది, ఇది యాడ్‌ల పనితీరును అంచనా వేయడంలో సైట్‌కు సహాయపడుతుంది. 'యాడ్‌ల అంచనా', సైట్‌ల మధ్య వీలయినంత తక్కువ సమాచారాన్ని బదిలీ చేసి, క్రాస్-సైట్ ట్రాకింగ్‌ను తగ్గిస్తుంది.</translation>
<translation id="6940431691900807093">తర్వాత, మీరు చూసే యాడ్‌లను వ్యక్తిగతీకరించడం కోసం, మీరు సందర్శించే సైట్ మీ ఆసక్తులను చూడమని Chromiumను అడగవచ్చు. Chromium 3 ఆసక్తుల వరకు షేర్ చేయగలదు.</translation>
<translation id="8283315171506895091">Ecosia అజ్ఞా&amp;త విండోలో లింక్‌ను తెరువు</translation>
<translation id="6978145336957848883">బలహీనమైన పాస్‌వర్డ్‌లను ఊహించడం చాలా సులభం. <ph name="BEGIN_LINK"/>మీ కోసం శక్తివంతమైన పాస్‌వర్డ్‌లను క్రియేట్ చేయడం, గుర్తుంచుకోవడం<ph name="END_LINK"/> చేయడానికి Chromiumను అనుమతించండి.</translation>
<translation id="1401515072108809622">Ecosia ఇన్‌యాక్టివ్‌గా ఉంది</translation>
<translation id="2149148292984034533">EcosiaOS నియమాలు</translation>
<translation id="1831192335802727557">ఈ సైట్ కోసం మీ మైక్రోఫోన్‌ను యాక్సెస్ చేయడానికి Ecosiaకు అనుమతి అవసరం</translation>
<translation id="7025789849649390912">ఇన్‌స్టాలేషన్ ఆగిపోయింది.</translation>
<translation id="5598074261782651109">Ecosiaను అప్‌డేట్ చేయి</translation>
<translation id="2838372953389311551">చిత్రంలో ఉపయోగకరమైన వివరణ లేకుంటే, మీ కోసం ఒక వివరణను అందించడానికి Ecosia ప్రయత్నిస్తుంది. వివరణలను క్రియేట్ చేయడానికి, చిత్రాలు Ecosiaకు పంపబడతాయి.</translation>
<translation id="219546601381787154">ఈ సైట్ కోసం Ecosiaకు కెమెరా అనుమతి అవసరం</translation>
<translation id="2542649989941327712">Ecosiaను ప్రారంభించడం సాధ్యపడలేదు. మళ్లీ ప్రయత్నించండి.</translation>
<translation id="7197677400338048821">Chromium మీ పాస్‌వర్డ్‌లను చెక్ చేయలేకపోయింది. 24 గంటల తర్వాత మళ్లీ ట్రై చేయండి.</translation>
<translation id="7311066525704006840">విధి నిర్వాహకుడు - Ecosia</translation>
<translation id="3816260943154642689">Ecosia అంచనా ఆధారంగా మీ ఆసక్తులు</translation>
<translation id="7309928523159922338">మీరు సందర్శించే సైట్‌లను Chromium నుండి సమాచారాన్ని రిక్వెస్ట్ చేసేలా 'యాడ్‌ల అంచనా' అనుమతిస్తుంది, ఇది యాడ్‌ల పనితీరును అంచనా వేయడంలో సైట్‌కు సహాయపడుతుంది. 'యాడ్‌ల అంచనా', సైట్‌ల మధ్య వీలయినంత తక్కువ సమాచారాన్ని బదిలీ చేసి, క్రాస్-సైట్ ట్రాకింగ్‌ను తగ్గిస్తుంది.</translation>
<translation id="731795002583552498">Chromiumని అప్‌డేట్ చేస్తోంది</translation>
<translation id="6673288084648462613">మీ ప్రాధాన్యతల ఫైల్ పాడైంది లేదా చెల్లదు. Ecosia మీ సెట్టింగ్‌లను పునరుద్ధరించలేకపోయింది.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="7339898014177206373">కొత్త విండో</translation>
<translation id="4960252760049500399">మీ వెబ్, బుక్‌మార్క్‌లు మరియు ఇతర Ecosia అంశాలు ఇక్కడ చూపబడతాయి.</translation>
<translation id="7158975242722498086"><ph name="TARGET_URL_HOSTNAME"/>ను యాక్సెస్ చేయడం కోసం <ph name="ALTERNATIVE_BROWSER_NAME"/>ను తెరిచే విధంగా Ecosiaను మీ సిస్టమ్ నిర్వాహకుడు కాన్ఫిగర్ చేశారు.</translation>
<translation id="5622136942112821750">మీ మొత్తం Ecosia అంశాలను, మీరు Ecosia ప్రొఫైళ్లతో వేరు చేయండి. ఇలా చేయడం వలన ఆఫీస్, వినోదాన్ని వేర్వేరుగా ఉంచవచ్చు.</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia Dev</translation>
<translation id="5055330219314726197">ఈ సైట్ కోసం మీ కెమెరాను యాక్సెస్ చేయడానికి Ecosiaకు అనుమతి అవసరం</translation>
<translation id="1975037445584526511">భవిష్యత్తులో Ecosia అప్‌డేట్‌లను పొందడానికి, మీకు Windows 10 లేదా ఆ తర్వాత వచ్చిన ఏదైనా వెర్షన్ అవసరం అవుతుంది. ఈ కంప్యూటర్ Windows 7ను ఉపయోగిస్తోంది.</translation>
<translation id="7467949745582939695">Chromiumను రీ-లాంచ్ చేయాలా?</translation>
<translation id="80155189677487610">ప్రస్తుతం అమలు అవుతోన్న అదే Ecosia వెర్షన్‌ను ఇన్‌స్టాల్ చేయలేరు. దయచేసి Ecosiaను మూసివేసి, మళ్లీ ప్రయత్నించండి.</translation>
<translation id="7558678848273505235">{0,plural, =1{1 నిమిషంలో Ecosia తిరిగి ప్రారంభించబడుతుంది}other{# నిమిషాల్లో Ecosia తిరిగి ప్రారంభించబడుతుంది}}</translation>
<translation id="3674955518940155608">అలాగే (<ph name="URL"/>)లో ఉన్న Ecosiaకి సంబంధించిన డేటాను తీసివేయండి</translation>
<translation id="7582945390259497898">Chromium మీ ఆసక్తులను అంచనా వేయగలదు. తర్వాత, మీరు చూసే యాడ్‌లను వ్యక్తిగతీకరించడం కోసం, మీరు సందర్శించే సైట్ మీ ఆసక్తులను చూడమని Chromiumను అడగవచ్చు.</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME"/> ఇన్‌స్టాలర్</translation>
<translation id="7910693244647744044">మీరు మీ ఖాతాలో మెరుగైన సురక్షిత బ్రౌజింగ్‌ను ఆన్ చేశారు. ఇప్పుడు దాన్ని Ecosiaలో పొందండి.</translation>
<translation id="4061472199368124600">Ecosia మీ కెమెరా మరియు మైక్రోఫోన్‌ని ఉపయోగిస్తోంది.</translation>
<translation id="170259281605734125">Ecosia ఇప్పుడు మెరుగైంది</translation>
<translation id="7649070708921625228">సహాయం</translation>
<translation id="675365189802108507">మీరు ఈ ఫీచర్‌ల గురించి Ecosia సెట్టింగ్‌లలో మరింత తెలుసుకోవచ్చు.</translation>
<translation id="7682601070171973634">Chromium మీ డేటాను తక్కువగా ఉపయోగిస్తూ అదే బ్రౌజింగ్ అనుభవాన్ని అందించడానికి సైట్‌లను అనుమతించే కొత్త ఫీచర్‌లను అన్వేషిస్తోంది</translation>
<translation id="1508200558303644420">Ecosia మీ డిఫాల్ట్ బ్రౌజర్ కాదు</translation>
<translation id="7174674455569790401">మీ పరికరాల అంతటా Ecosiaను సింక్ చేయండి మరియు వ్యక్తిగతీకరించండి</translation>
<translation id="7745317241717453663">ఇది ఈ పరికరం నుండి మీ బ్రౌజింగ్ డేటాను తొలగిస్తుంది. మీ డేటాను తర్వాత తిరిగి పొందడానికి, Chromiumకు <ph name="USER_EMAIL"/> లాగా సైన్ ఇన్ చేయండి.</translation>
<translation id="7747138024166251722">ఇన్‌స్టాలర్ ఒక తాత్కాలిక డైరక్టరీని సృష్టించలేకపోయింది. సాఫ్ట్‌వేర్‌ను ఇన్‌స్టాల్ చేయడానికి దయచేసి ఖాళీ డిస్క్ స్థలం, అనుమతిని చెక్ చేయండి.</translation>
<translation id="6161025257729272170">Ecosiaను వేగవంతం చేయండి</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia Canary</translation>
<translation id="8301840715671593762">ఈ పరికరంలో ఇప్పటికే ఈ ఖాతాతో ఒక Ecosia ప్రొఫైల్ ఉంది</translation>
<translation id="7845233973568007926">ఇన్‌స్టాల్ చేసినందుకు ధన్యవాదాలు. <ph name="BUNDLE_NAME"/>‌ను ఉపయోగించడానికి ముందు మీరు కంప్యూటర్‌ను తప్పకుండా రీస్టార్ట్ చేయాలి.</translation>
<translation id="3268039966078382323">Ecosiaను తాజా వెర్షన్‌కు అప్‌డేట్ చేయడం సాధ్యం కాలేదు, కాబట్టి మీరు కొత్త ఫీచర్‌లు మరియు భద్రతా పరిష్కారాలను పొందడం లేదు.</translation>
<translation id="7872446069773932638">డౌన్‌లోడ్ అవుతోంది... <ph name="SECONDS"/> సెకను(లు) సమయం మిగిలి ఉంది</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>మీరు మీ డేటాను ఎలా మేనేజ్ చేసుకోగలరు:<ph name="END_BOLD"/> మీ గోప్యతను రక్షించడానికి, 4 వారాల కంటే పాతవైన మీ ఆసక్తులను మేము ఆటోమేటిక్‌గా తొలగిస్తాము. మీరు బ్రౌజ్ చేస్తూ ఉంటే, ఆసక్తి ఉన్న ఆ టాపిక్ మళ్లీ లిస్ట్‌లో కనిపించవచ్చు. లేదా Ecosia పరిగణనలోకి తీసుకోకూడదు అని మీరు భావించే ఆసక్తులను తీసివేయవచ్చు.</translation>
<translation id="2412381038247037703">మీరు <ph name="USER_EMAIL_ADDRESS"/>గా Ecosiaకు సైన్ ఇన్ చేశారు. దయచేసి మళ్లీ సైన్ ఇన్ చేయడానికి ఇదే ఖాతాను ఉపయోగించండి.</translation>
<translation id="7975919845073681630">ఇది Chromium రెండవ ఇన‌స్ట‌లేష‌న్. దీన్ని మీ డిఫాల్ట్ బ్రౌజర్‌గా చేయడం సాధ్యపడదు.</translation>
<translation id="851583113375911087">తెలియని మూలాలకు చెందిన ఎక్స్‌టెన్షన్‌లు, యాప్‌లు, రూపాలు మీ పరికరానికి హాని కలిగించవచ్చు. <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> నుండి మాత్రమే వాటిని ఇన్‌స్టాల్ చేయని Ecosia సిఫార్సు చేస్తోంది</translation>
<translation id="488806616089631539">ఓసారి Ecosiaకి యాక్సెస్ లభించాక, ఆపై వెబ్‌సైట్‌లకు ఏమైనా యాక్సెస్‌ కావాలంటే అవి మిమ్మల్ని అడగవచ్చు.</translation>
<translation id="80471789339884597">ఇన్‌స్టాల్ చేసినందుకు ధన్యవాదాలు. <ph name="BUNDLE_NAME"/>‌ను ఉపయోగించే ముందు మీరు తప్పకుండా మీ అన్ని బ్రౌజర్‌లను రీస్టార్ట్ చేయాలి.</translation>
<translation id="5661123757512626239">ఈ సైట్ కోసం Ecosiaకు లొకేషన్ అనుమతి అవసరం</translation>
<translation id="143614250230771428">మీ డొమైన్ కోసం సింక్ అందుబాటులో లేనందున, EcosiaOS మీ డేటాను సింక్ చేయలేకపోయింది.</translation>
<translation id="813913629614996137">ప్రారంభిస్తోంది...</translation>
<translation id="6491651957026506753">ఈ ఫైల్ అపాయకరమైనది, కాబట్టి Ecosia దీన్ని బ్లాక్ చేసింది.</translation>
<translation id="796435732739009892">ఈ ఫైల్ రకం ప్రమాదకరమైనందున Ecosia ఈ ఫైల్‌ను బ్లాక్ చేసింది</translation>
<translation id="2046160555506209000">చిత్రంలో ఉపయోగకరమైన వివరణ లేకుంటే, మీ కోసం ఒక వివరణను అందించడానికి Ecosia ప్రయత్నిస్తుంది. వివరణలను క్రియేట్ చేయడానికి, చిత్రాలు Ecosiaకు పంపబడతాయి. మీరు దీన్ని ఎప్పుడైనా సెట్టింగ్‌లలో ఆఫ్ చేయవచ్చు.</translation>
<translation id="8266560134891435528">మీరు సైన్ ఇన్ చేయనందున Chromium మీ పాస్‌వర్డ్‌లను చెక్ చేయలేదు</translation>
<translation id="8633885040939757689">పాస్‌వర్డ్‌లను కాపీ చేయడానికి Ecosia ప్రయత్నిస్తోంది.</translation>
<translation id="2243562167758283214">ఈ ఫైల్ అపాయకరం కావచ్చు, కాబట్టి Ecosia దీన్ని బ్లాక్ చేసింది.</translation>
<translation id="8330519371938183845">మీ పరికరాల అంతటా Chromiumను సింక్ చేయడానికి, వ్యక్తిగతీకరించడానికి సైన్ ఇన్ చేయండి</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> మునుపు Ecosiaని ఉపయోగించింది</translation>
<translation id="4337034173783952373">మీ అన్ని పరికరాలలో మీ Ecosia బ్రౌజర్ సంబంధిత అంశాలను యాక్సెస్ చేయడానికి, సైన్ ఇన్ చేసి, ఆపై సింక్‌ను ఆన్ చేయండి</translation>
<translation id="8655983536493871574">భవిష్యత్తు Ecosia అప్‌డేట్‌లను పొందడానికి, మీకు Windows 10 లేదా ఆ తర్వాత వచ్చిన ఏదైనా వెర్షన్ అవసరం అవుతుంది. ఈ కంప్యూటర్ Windows 8ను ఉపయోగిస్తోంది.</translation>
<translation id="6826163993811146231">{0,plural, =1{ఒక రోజులోపు Ecosiaను తిరిగి ప్రారంభించండి}other{# రోజులలోపు Ecosiaను తిరిగి ప్రారంభించండి}}</translation>
<translation id="4033006861724039519">ఇన్‌స్టాలర్ ఆర్కైవ్ పాడైంది లేదా చెల్లదు. దయచేసి Ecosiaను మళ్లీ డౌన్‌లోడ్ చేయండి.</translation>
<translation id="8975930032513941502">ఆప్షనల్: Ecosiaకు సమస్య విశ్లేషణ, అలాగే వినియోగ డేటాను ఆటోమేటిక్‌గా పంపడం ద్వారా EcosiaOS ఫీచర్‌లను, ఇంకా పనితీరును మెరుగుపరచడంలో సహాయపడండి.</translation>
<translation id="2695952268686253864">Ecosia కాలం చెల్లినది</translation>
<translation id="8550334526674375523">ఈ వర్క్ ప్రొఫైల్, మీ వ్యక్తిగత ప్రొఫైల్ నుండి పూర్తిగా భిన్నంగా ఉంది.</translation>
<translation id="4281355161119203663">Ecosiaలో సైట్‌లు, యాప్‌లు, ఎక్స్‌టెన్షన్‌లకు సంబంధించిన అనుమతులను మీ తల్లి/తండ్రి ఆఫ్ చేశారు. ఈ <ph name="EXTENSION_TYPE_PARAMETER"/>ను జోడించడానికి అనుమతి లేదు.</translation>
<translation id="6235917057647038042">భవిష్యత్తులో Ecosia అప్‌డేట్‌లను పొందడానికి, మీకు macOS 10.13 లేదా ఆ తర్వాతి వెర్షన్ అవసరం అవుతుంది. ఈ కంప్యూటర్ macOS 10.12ను ఉపయోగిస్తోంది.</translation>
<translation id="8568283329061645092">మీరు మీ Google ఖాతాతో సైన్ ఇన్ చేసి ఉన్నప్పుడు, Chromium మీ పాస్‌వర్డ్‌లను చెక్ చేయగలుగుతుంది</translation>
<translation id="8574036838419011058">ఆన్‌లో ఉన్నప్పుడు, Chromium బ్యాక్‌గ్రౌండ్ యాక్టివిటీని, సున్నితమైన స్క్రోలింగ్, వీడియో ఫ్రేమ్ రేట్‌ల వంటి విజువల్ ఎఫెక్ట్‌లను పరిమితం చేయడం ద్వారా బ్యాటరీ పవర్‌ను ఆదా చేస్తుంది. <ph name="BEGIN_LINK"/>మరింత తెలుసుకోండి<ph name="END_LINK"/></translation>
<translation id="7129808598331559748">కాపీరైట్ <ph name="YEAR"/> Ecosia రచయితలు. అన్ని హ‌క్కులు రిజ‌ర్వ్ చేయ‌బ‌డ్డాయి.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>మేము ఈ డేటాను ఎలా ఉపయోగిస్తాము:<ph name="END_BOLD"/> మీ ఆసక్తులకు సంబంధించిన సమాచారాన్ని సైట్‌లు Ecosiaతో స్టోర్ చేయగలవు. ఉదాహరణకు, మారథాన్ కోసం షూస్ కొనడానికి మీరు ఒక సైట్‌ను సందర్శించినట్లయితే, మారథాన్‌లలో పరిగెత్తడం మీకు ఆసక్తి అని ఆ సైట్ స్టోర్ చేయవచ్చు. తర్వాత, రేస్ కోసం రిజిస్టర్ చేసుకోవడానికి మీరు వేరొక సైట్‌ను సందర్శిస్తే, మీ ఆసక్తుల ఆధారంగా ఆ సైట్ మీకు పరిగెత్తడానికి అవసరమైన షూస్ యాడ్‌ను చూపిస్తుంది.</translation>
<translation id="8109744984354428711">Ecosiaని ప్రారంభిస్తోంది...</translation>
<translation id="2402290209407843024">తెలియ‌ని ఎర్ర‌ర్‌ కారణంగా ఇన‌స్ట‌లేష‌న్‌ విఫలమైంది. దయచేసి Ecosiaను మళ్లీ డౌన్‌లోడ్ చేయండి.</translation>
<translation id="6665128960039431910">ఇది మీరు Ecosiaను ప్రారంభించేటప్పుడు లేదా ఓమ్నిబాక్స్ నుండి వెతికేటప్పుడు చూపబడే పేజీని కూడా నియంత్రిస్తుంది.</translation>
<translation id="2000339487270823788">ఇది మీ Ecosia</translation>
<translation id="7273750863406285983">ఈ సైట్ కోసం మీ కెమెరా మరియు మైక్రోఫోన్‌ను యాక్సెస్ చేయడానికి Ecosiaకు అనుమతి అవసరం</translation>
<translation id="5267683457871579197">EcosiaOS సిస్టమ్</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>ఏ డేటాను ఉపయోగిస్తారు:<ph name="END_BOLD"/> మీ బ్రౌజింగ్ హిస్టరీ, ఈ పరికరంలో Ecosiaను ఉపయోగించి మీరు సందర్శించిన సైట్‌ల రికార్డ్.</translation>
<translation id="8862326446509486874">సిస్టమ్-స్థాయిలో ఇన్‌స్టాల్‌ చేయ‌డానికి మీకు సరైన హక్కులు లేవు. నిర్వాహకుడి లాగా ఇన్‌స్టాలర్‌ను మ‌ళ్లీ రన్ చేయ‌డానికి ప్రయత్నించండి.</translation>
<translation id="8880203542552872219">అలా అయితే, Chromiumలో సేవ్ అయిన మీ పాస్‌వర్డ్ ‌ను దయచేసి ఎడిట్ చేయండి, అప్పుడు అది మీ కొత్త పాస్‌వర్డ్‌‌తో మ్యాచ్ అవుతుంది.</translation>
<translation id="6078545897140861225">ఇది మీరు Ecosiaను ప్రారంభించేటప్పుడు లేదా హోమ్ బటన్‌ను క్లిక్ చేసేటప్పుడు చూపబడే పేజీని కూడా నియంత్రిస్తుంది.</translation>
<translation id="3966234175958887595">Ecosia పాస్‌వర్డ్‌లను చూపడానికి ప్రయత్నిస్తోంది. దీన్ని అనుమతించడానికి మీ Windows పాస్‌వర్డ్‌ను టైప్ చేయండి.</translation>
<translation id="8931379085695076764">గత కొన్ని వారాల నుండి మీ బ్రౌజింగ్ హిస్టరీ ఆధారంగా Chromium మీ ఆసక్తులను అంచనా వేయగలదు. ఈ సమాచారం మీ పరికరంలో ఉంటుంది.</translation>
<translation id="6346154190168496057">Ecosiaని అప్‌డేట్ చేయడం సాధ్యం కాదు</translation>
<translation id="93440396576488794">Ecosia Enterprise లోగో</translation>
<translation id="8986207147630327271">మీరు ఈ బ్రౌజర్‌కు వర్క్ ప్రొఫైల్‌ను జోడిస్తున్నారు, ఇంకా మీ అడ్మినిస్ట్రేటర్‌కు వర్క్ ప్రొఫైల్‌పై కంట్రోల్ ఇస్తున్నారు.</translation>
<translation id="1597547208646178091">Ecosiaని సురక్షితం చేయడానికి, మేము కింది ఎక్స్‌టెన్షన్‌ను నిలిపివేసాము, ఇది <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>లో లిస్ట్‌ చేయబడలేదు మరియు మీకు తెలియకుండా జోడించబడి ఉండవచ్చు.</translation>
<translation id="2388751143175762498">Ecosiaకు సైన్ ఇన్ చేయండి</translation>
<translation id="7268098999602465369">Ecosia కాలం చెల్లినది</translation>
<translation id="6022879254514691681">{0,plural, =1{ఒక గంటలో Ecosia తిరిగి ప్రారంభించబడుతుంది}other{# గంటల్లో Ecosia తిరిగి ప్రారంభించబడుతుంది}}</translation>
<translation id="8963533629322868062">భవిష్యత్తులో Ecosia అప్‌డేట్‌లను పొందడానికి, మీకు Windows 10 లేదా ఆ తర్వాత వచ్చిన ఏదైనా వెర్షన్ అవసరం అవుతుంది. ఈ కంప్యూటర్ Windows 8.1ను ఉపయోగిస్తోంది.</translation>
<translation id="7774247008790177839">కొత్త Ecosia &amp;ట్యాబ్‌లో లింక్‌ని తెరువు</translation>
<translation id="911206726377975832">మీ బ్రౌజింగ్ డేటాను కూడా తొలగించాలా?</translation>
<translation id="7580831958727159171">ట్రయల్స్ సమయంలో, మీకు యాడ్‌లను చూపడానికి సైట్‌లు ఉపయోగించే ఆసక్తి ఉన్న అంశాలను మీరు చూడవచ్చు, తీసివేయవచ్చు. Ecosia మీ ఇటీవలి బ్రౌజింగ్ హిస్టరీ ఆధారంగా మీ ఆసక్తులను అంచనా వేస్తుంది.</translation>
<translation id="8901409988302458368"><ph name="TARGET_URL_HOSTNAME"/>‌ను యాక్సెస్ చేయడం కోసం ఒక ప్రత్యామ్నాయ బ్రౌజర్‌ను తెరిచే విధంగా Ecosiaను మీ సిస్టమ్ నిర్వాహకులు కాన్ఫిగర్ చేశారు.</translation>
<translation id="1523806373970723624">&amp;Ecosiaను అప్‌డేట్ చేయడానికి రీ-లాంచ్ చేయండి</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="6933283849886243832">Ecosiaకి ఇప్పుడు Windows XP లేదా Windows Vistaలో మద్దతు లేనందున ఇది సరిగ్గా పని చేయకపోవచ్చు</translation>
<translation id="942598560705308788">Chromium ద్వారా మేనేజ్ చేయబడే సర్టిఫికెట్‌లు</translation>
<translation id="6718055545215052843">భవిష్యత్తులో Ecosia అప్‌డేట్‌లను పొందడానికి, మీకు macOS 10.13 లేదా ఆ తర్వాతి వెర్షన్ అవసరం అవుతుంది. ఈ కంప్యూటర్ OS X 10.11ను ఉపయోగిస్తోంది.</translation>
<translation id="8078678931242443254">Ecosiaను ఎవరు ఉపయోగిస్తున్నారు?</translation>
<translation id="12795904718916112">Ecosia అత్యంత సురక్షితమైన సెక్యూరిటీని పొందండి</translation>
<translation id="9792300276217204">మీరు Chromiumను మూసివేసినప్పుడు ఎల్లప్పుడూ మీ పరికరంలోని సైట్ డేటాను క్లియర్ చేయండి</translation>
<translation id="6235001546696543832">Ecosia రచయితలు</translation>
</translationbundle>
