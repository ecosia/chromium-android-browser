<translation id="4395802781633621239">आफ्ना सबै डिभाइसमा आफ्ना पासवर्डलगायतका थप कुराहरू प्राप्त गर्न Ecosia मा साइन इन गर्नुहोस्। तपाईंले साइन इन गरेपछि यो पासवर्ड तपाईंको Ecosia खातामा सेभ गरिने छ।</translation>
<translation id="1330085168384841023">आफ्नो विन्डो सेयर गर्न सिस्टमका प्राथमिकताहरूमा गई Ecosia लाई स्क्रिन रेकर्ड गर्ने अनुमति दिनुहोस्।</translation>
<translation id="3708834841667355707">Ecosia ले साइटहरूलाई कम जानकारी प्रयोग गरेर उही स्तरको ब्राउजिङ अनुभव प्रदान गर्न सघाउने नयाँ सुविधाहरूको परीक्षण गरिरहेको छ</translation>
<translation id="319566061277127356">Ecosia मा आफ्नो नयाँ प्रोफाइल सेटअप गर्नुहोस्</translation>
<translation id="7433581196371819898">Ecosia ले यो एक्स्टेन्सनको स्रोत पुष्टि गर्न सक्दैन र यो असुरक्षित हुन सक्छ। यो एक्स्टेन्सनले अबदेखि तपाईंले खोल्ने साइटहरूमा रहेका व्यक्तिगत जानकारीलगायतका तपाईंको डेटा हेर्न र परिवर्तन गर्न नसकोस् भन्नाका लागि यसलाई Ecosia बाट हटाउनुहोस्।</translation>
<translation id="2198589091447191935">Ecosia अझ चाँडो चल्छ र JavaScript प्रयोग गर्ने सुविधाहरूले डिजाइन गरिएअनुसार काम गर्नु पर्ने हो (सिफारिस गरिएको)</translation>
<translation id="7105712012505419722">तपाईं एउटा व्यवस्थित खाताद्वारा साइन इन गर्दै हुनुहुन्छ र यसको व्यवस्थापकलाई आफ्नो Ecosia प्रोफाइल माथिको नियन्त्रण दिँदै हुनुहुन्छ। तपाईंको Ecosia डाटा, जस्तै एप्स, बुकमार्कहरू, इतिहास, पासवर्डहरू, र अन्य सेटिङहरू स्थायी रूपमा <ph name="USER_NAME"/> सँग गाँसिनेछन्। तपाईंले यो डाटा Ecosia खाताहरू ड्यासबोर्ड मार्फत मेटाउन सक्नुहुनेछ, तर तपाईं॥े यो डाटालाई अर्को खातासँग सम्बद्ध गर्न सक्नुहुन्न। <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">स्थापना गर्दै...</translation>
<translation id="7691143774653486474">स्थापनाकर्ता आर्किभलाई अनकम्प्रेस गर्न असफल भयो। कृपया Ecosia पुन: डाउनलोड गर्नुहोस्।</translation>
<translation id="2446603005062458629">Ecosia ले चाँडै नै विन्डोहरू बन्द गर्ने र डेटा मेटाउने छ</translation>
<translation id="4173512894976930765">साइटहरूले अपेक्षित रूपमा काम गर्ने छन्। तपाईंले Chrome का सबै विन्डो बन्द गर्नुभयो भने तपाईंलाई अधिकांश साइटहरूबाट साइन आउट गरिने छ तर तपाईं Chrome मा साइन इन अवस्थामा हुनुहुन्छ भने तपाईंलाई तपाईंको Google खाताबाट भने साइन आउट गरिने छैन।</translation>
<translation id="2745180350547322293">यो साइटले सुरक्षित कनेक्सन प्रयोग नगरिरहेको र यो फाइलमा छेडखानी गरिएको हुन सक्ने भएकाले Ecosia ले यो फाइल डाउनलोड गर्ने कार्य ब्लक गरेको छ</translation>
<translation id="6826163993811146231">{0,plural, =1{एक दिनभित्र Ecosia पुनः सुरु गर्नुहोस्}other{# दिनभित्र Ecosia पुनः सुरु गर्नुहोस्}}</translation>
<translation id="4205939740494406371">Chrome तपाईंका पासवर्डहरू जाँच्न सक्दैन। २४ घन्टापछि फेरि प्रयास गर्नुहोस् वा <ph name="BEGIN_LINK"/>आफ्नो Google खातामा गई आफ्ना पासवर्डहरू जाँच्नुहोस्<ph name="END_LINK"/>।</translation>
<translation id="4222932583846282852">रद्द गरिँदै...</translation>
<translation id="4224210481850767180">इन्स्टल गर्ने प्रक्रिया रद्द गरिएको छ।</translation>
<translation id="3554373328288278512">यो साइट चलाउन Ecosia लाई क्यामेरा तथा माइक्रोफोन प्रयोग गर्ने अनुमति दिनु पर्ने हुन्छ</translation>
<translation id="424864128008805179">Chrome बाट साइन आउट गर्ने हो?</translation>
<translation id="8384922154025337808">तपाइँको Ecosia लगतलाई यस खातामा लिङ्क गर्ने?</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>कस्ता खालका डेटा प्रयोग गरिन्छ:<ph name="END_BOLD"/> तपाईंको ब्राउजिङ इतिहास अर्थात् तपाईंले यो डिभाइसमा Ecosia प्रयोग गरी खोलेका साइटहरूको रेकर्ड।</translation>
<translation id="4281844954008187215">सेवाका सर्तहरू</translation>
<translation id="4293420128516039005">आफ्ना यन्त्रहरूभरि Chrome लाई सिंक तथा पर्सनलाइज गर्न साइन इन गर्नुहोस्</translation>
<translation id="6419542773162312746">एक्स्टेन्सनलाई Ecosia टुलबारमा साइट प्रयोग गर्ने अनुमतिसम्बन्धी अनुरोध देखाउने अनुमति दिनुहोस्</translation>
<translation id="8864449561723972619">Ecosia Dev (mDNS-In)</translation>
<translation id="4329315893554541805">पर्सनलाइजेसन र अन्य सुविधाहरू प्राप्त गर्न Chrome लाई वेब तथा एपसम्बन्धी गतिविधि र Google का लिंक गरिएका सेवाहरूमा समावेश गर्नुहोस्</translation>
<translation id="4334294535648607276">डाउनलोड सम्पन्न भयो</translation>
<translation id="4335235004908507846">Chrome ले तपाईंलाई डेटा चोरीका घटना, हानिकारक एक्स्टेन्सन र थप समस्याहरूबाट सुरक्षित रहन मद्दत गर्न सक्छ</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> लाई Ecosia मा थपिएको छ</translation>
<translation id="4348548358339558429">पर्सनलाइजेसन प्राप्त गर्न Chrome लाई वेब तथा एपसम्बन्धी गतिविधिमा समावेश गर्नुहोस्</translation>
<translation id="197803137365953132">यो फाइलले तपाईंको व्यक्तिगत तथा सामाजिक सञ्जाल खाताहरूमा हानि पुर्‍याउन सक्ने भएकाले Ecosia ले यो फाइल डाउनलोड गर्न रोक लगाएको छ</translation>
<translation id="4384570495110188418">तपाईं साइन इन नहुनुभएकाले Chrome ले तपाईंका पासवर्डहरूको जाँच गर्न सकेन</translation>
<translation id="4389991535395284064">तपाईं इन्कोग्निटो मोड प्रयोग गरेर साइटहरू ब्राउज गर्दै हुनुहुन्छ भने तपाईंले कुनै असुरक्षित कनेक्सन प्रयोग गरी साइट लोड गर्नुअघि Chrome ले तपाईंलाई चेतावनी दिने छ</translation>
<translation id="4427306783828095590">परिष्कृत सुरक्षा प्रयोग गरी फिसिङ तथा मालवेयरमाथि अझ राम्रोसँग रोक लगाउन सकिन्छ</translation>
<translation id="4434353761996769206">इन्स्टलरसम्बन्धी त्रुटि भयो: <ph name="INSTALLER_ERROR"/></translation>
<translation id="2297526912548649074"><ph name="USER_EMAIL"/> मार्फत Ecosia मा साइन इन गर्नुहोस्</translation>
<translation id="9035946286843935549">Ecosia - नेटवर्क साइन इन - <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">Ecosia मा अर्को कारबाही जारी छ। कृपया पछि फेरि प्रयास गर्नुहोस्।</translation>
<translation id="4459234553906210702">तपाईंले खोल्ने साइटहरूले विज्ञापनको पर्फर्मेन्स मापन गर्ने सुविधाका सहायताले Chrome सँग साइटलाई त्यसका विज्ञापनहरूको पर्फर्मेन्स मापन गर्न सघाउने जानकारी माग्न सक्छन्। विज्ञापनको पर्फर्मेन्स मापन गर्ने सुविधाले विभिन्न साइटहरूका बिचमा सकेसम्म कम जानकारी ट्रान्स्फर गरेर ती साइटमा गरिने गतिविधि ट्र्याक गर्न दिँदैन।</translation>
<translation id="4501471624619070934">यो देशमा एक्सेसमाथि प्रतिबन्ध लगाइएको हुनाले इन्स्टल गर्न सकिएन।</translation>
<translation id="4567424176335768812">तपाइँ <ph name="USER_EMAIL_ADDRESS"/> को रूपमा साइन इन हुनुभएको छ। अब तपाइँले तपाइँका सबै साइन इन भएका यन्त्रहरूमा तपाइँका पृष्ठमञ्जूषाहरू, इतिहास, र अन्य सेटिङहरू पहुँच गर्न सक्नुहुन्छ।</translation>
<translation id="6533266716128249922">Ecosia को सूचनासम्बन्धी सेटिङहरूमा जानुहोस्</translation>
<translation id="7562371913339616107">तपाईंलाई अझ राम्रो ब्राउजिङ सुविधा प्रदान गर्न र स्रोतहरू खाली पार्न Ecosia ले यी ट्याब निष्क्रिय बनाउन सक्छ।</translation>
<translation id="488806616089631539">Ecosia ले पहुँच प्राप्त गरेपछि, वेबसाइटहरू तपाईंसँग पहुँच माग्न सक्ने छन्।</translation>
<translation id="3268039966078382323">Ecosia लाई नवीनतम संस्करणमा अद्यावधिक गर्न सकिएन, जसका कारण तपाईं नयाँ सुविधाहरू तथा सुरक्षासम्बन्धी समाधानहरू चलाउनबाट वञ्चित भइराख्नुभएको छ।</translation>
<translation id="4624065194742029982">Chrome को इन्कोग्निटो मोड</translation>
<translation id="4690206707618474800">ऐच्छिक: Ecosia लाई डाइग्नोस्टिक र प्रयोगसम्बन्धी डेटा स्वतः पठाएर EcosiaOS Flex को पर्फर्मेन्स र यसका सुविधाहरूको गुणस्तर सुधार्न सघाउनुहोस्।</translation>
<translation id="9125443060066914183">Ecosia लाई झन छिटो बनाउनको लागि, हामीले <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> मा सूचित नभएका र तपाइँलाई थाहा नहुँदै थपिएका केही विस्तारहरू असक्षम गर्‍यौँ।</translation>
<translation id="4680828127924988555">इन्स्टल गर्ने प्रक्रिया रद्द गर्नुहोस्</translation>
<translation id="8236553889322631924">अज्ञात स्रोतबाट डाउनलोड गरिएका एक्स्टेन्सन, एप र थिमहरूले तपाईंको डिभाइसमा हानि पुर्‍याउन सक्छन्। Ecosia त्यस्ता कुराहरू Ecosia वेब स्टोरबाट मात्र इन्स्टल गर्न सिफारिस गर्छ</translation>
<translation id="4710245680469034439">प्रकृति र कलाकारहरूका सङ्ग्रहलगायतका कुराका आधारमा बनाइएका थिमहरू प्रयोग गरी ब्राउजर पर्सनलाइज गर्नुहोस्</translation>
<translation id="4724676981607797757">प्रयोग गर्न नमिल्ने प्रोटोकलसम्बन्धी त्रुटि भएकाले इन्स्टल गर्न सकिएन।</translation>
<translation id="3305517118160815955">अनिर्दिष्ट त्रुटिको कारण स्थापना असफल भयो। यदि Ecosia अहिले चालू छ भने, कृपया यसलाई बन्द गरि पुन: प्रयास गर्नुहोस्।</translation>
<translation id="4747730611090640388">Chrome ले तपाईंका रुचिहरू अनुमान ‌गर्न सक्छ।  तपाईंले यसपछि खोल्ने साइटले Chrome सँग तपाईंलाई देखाइने विज्ञापनहरू पर्सनलाइज गर्ने प्रयोजनका लागि तपाईंका रुचिहरू हेर्ने अनुमति माग्न सक्छ।</translation>
<translation id="827222962844006655">Ecosia क्यानरी (mDNS-In)</translation>
<translation id="3543284013834505767">यसले Ecosia खोजमा प्रयोग गरिएकै स्पेल चेकर प्रयोग गर्दछ। तपाईंले ब्राउजरमा टाइप गर्ने पाठ Ecosia मा पठाइन्छ। तपाईं सेटिङमा गई जुनसुकै बेला उक्त व्यवहार परिवर्तन गर्न सक्नुहुन्छ।</translation>
<translation id="4793679854893018356">Chrome ले तपाईंलाई कसरी सुरक्षित राख्छ भन्ने कुरा जान्नुहोस्</translation>
<translation id="8957938953005153147">Ecosia ले हालका पासवर्डहरू बदल्न खोजिरहेको छ। यसो गर्ने अनुमति दिन Windows को पासवर्ड टाइप गर्नुहोस्।</translation>
<translation id="8144706290339578682">तपाईंको डोमेनका हकमा सिंक गर्ने सुविधा उपलब्ध नभएको हुनाले EcosiaOS Flex ले तपाईंको डेटा सिंक गर्न सकेन।</translation>
<translation id="7984841734836997333"><ph name="EXISTING_USER"/> ले पहिलेदेखि नै साइन इन गर्नुभएको छ।  छुट्टै ब्राउजर प्रयोग गर्न <ph name="USER_EMAIL_ADDRESS"/> मार्फत आफ्नै प्रोफाइल प्रयोग गरी Ecosia मा साइन इन गर्नुहोस्।</translation>
<translation id="4264506519284061030">तपाईंको सङ्गठनले तपाईंको कार्य प्रोफाइलमा बुकमार्क, हिस्ट्री र पासवर्डहरू जस्ता ब्राउजिङ डेटा हेर्न र व्यवस्थापन गर्न सक्छ। यसबाट व्यक्तिगत Ecosia प्रोफाइलमा रहेको ब्राउजिङ डेटा हेर्न सकिँदैन।</translation>
<translation id="8701027951719712428">तपाईंको कम्प्युटरमा macOS ११ वा सोभन्दा नयाँ संस्करण इन्स्टल गरिएको छ भने मात्र तपाईं भविष्यमा Ecosia का अपडेट प्राप्त गर्नुहुन्छ। यो कम्प्युटरमा macOS १०.१५ प्रयोग भइरहेको छ।</translation>
<translation id="4873783916118289636">Chrome मा भएका गोपनीयता र सुरक्षासम्बन्धी मुख्य नियन्त्रण सुविधाहरूको समीक्षा गर्नुहोस्</translation>
<translation id="8454595950895325762">Ecosia लाई पृष्ठभूमिमा चल्न दिनुहोस्</translation>
<translation id="489671036945006830">लिंकलाई Ecosia को नयाँ ट्याबमा खोल्नुहोस्</translation>
<translation id="6566258574866003581">Ecosia ले तपाईंलाई यो एक्स्टेन्सनको समीक्षा गर्न सिफारिस गर्छ</translation>
<translation id="4951177103388687412">ट्याब समूहहरूका सहायताले व्यवस्थित रहनुहोस् र केन्द्रित हुनुहोस्</translation>
