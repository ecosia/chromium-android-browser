<translation id="7849498640944199147"><ph name="ORIGIN"/> बाट आफ्नो Android फोनमा कुनै नम्बर पठाउन दुवै यन्त्रमा Ecosia मा साइन इन गर्नुहोस्।</translation>
<translation id="576192547306902465">यो एक्स्टेन्सनले गोपनीयतासम्बन्धी अभ्यासहरू (जस्तै, डेटा सङ्कलन तथा प्रयोग गर्ने तरिका) प्रकाशित गरेको छैन। Ecosia ले तपाईंलाई यो एक्स्टेन्सन हटाउन सिफारिस गर्छ।</translation>
<translation id="8986207147630327271">तपाईं यो ब्राउजरमा एउटा कार्य प्रोफाइल हाल्दै हुनुहुन्छ। तपाईंले यसो गर्नुभयो भने तपाईंका एड्मिन केवल उक्त कार्य प्रोफाइल नियन्त्रण गर्न सक्नुहुन्छ।</translation>
<translation id="8989968390305463310">तपाईंको ब्राउजिङ इतिहासका कारण तपाईंलाई देखाइने विज्ञापन र तलका अनुमानित रुचिहरू फरक पर्न सक्छन्। तपाईंको गोपनीयताको सुरक्षार्थ Chrome ले हरेक महिना क्रमिक रूपमा तपाईंका रुचिहरू स्वतः मेटाउँछ। तपाईंले आफ्ना रुचिहरू नहटाउन्जेल ती रुचि रिफ्रेस हुन सक्छन्।</translation>
<translation id="8999117580775242387">HTTPS उपलब्ध नहुँदा Chrome ले तपाईंलाई चेतावनी नदिइकनै असुरक्षित कनेक्सन प्रयोग गर्ने छ</translation>
<translation id="7348818664647668234">{0,plural, =0{Ecosia को अद्यावधिक उपलब्ध छ}=1{Ecosia को अद्यावधिक उपलब्ध छ}other{Ecosia को अद्यावधिक # दिनदेखि उपलब्ध छ}}</translation>
<translation id="4817309082638621362">एकभन्दा बढी सङ्गठनहरूले Ecosia व्यवस्थापन गर्छन्</translation>
<translation id="4638085384909702681">Ecosia लाई डिफल्ट ब्राउजर बनाउनुहोस्</translation>
<translation id="9047384314208087523">EcosiaOS Flex सिस्टम</translation>
<translation id="350189837353493413">Ecosia ले केही फाइलहरू ब्लक गर्नुको कारण जान्नुहोस्</translation>
<translation id="911206726377975832">साथै तपाईंको ब्राउजिङ डाटा पनि मेट्ने?</translation>
<translation id="9138603949443464873">आफूले गरेका परिवर्तनहरू लागू गर्न Chrome पुनः सुरु गर्नुहोस्</translation>
<translation id="9195993889682885387">गत केही हप्ताको तपाईंको ब्राउजिङ इतिहासका आधारमा Chrome ले तपाईंका रुचिहरू अनुमान ‌गर्न सक्छ। यो जानकारी तपाईंको डिभाइसमै भण्डारण गरिन्छ।</translation>
<translation id="5704599732514791330">सिंंक सुरु गर्न Ecosia लाई अपडेट गर्नुहोस्</translation>
<translation id="838842459108103907">Ecosia आफूले चाहे जस्तो बनाउनुहोस्</translation>
<translation id="92460355979482493">यो सेटिङ अन हुँदा Chrome ले पेजहरू प्रिलोड गर्छ। यसले गर्दा पेजहरू अझ छिटो ब्राउज गर्न तथा खोज्न सकिन्छ।</translation>
<translation id="3070276123152913305">EcosiaOS Flex रिस्टार्ट गर्नुहोस्</translation>
<translation id="4512092435423703529">आफूले प्रयोग गर्ने जुनसुकै यन्त्रबाट Ecosia मा रहेका आफ्ना डेटा हेर्न तथा प्रयोग गर्न सिंक गर्ने सुविधा अन गर्नुहोस्।</translation>
<translation id="7972668220031382654">यो फाइल जोखिमपूर्ण हुन सक्ने भएकाले Ecosia ले यो फाइल स्क्यान गर्न सिफारिस गर्छ।</translation>
<translation id="963650557422347554">यो सेटिङ अन हुँदा Chrome ले निर्वाध रूपमा स्क्रोल गर्ने सुविधा तथा भिडियोको फ्रेम रेटलगायतका ब्याकग्राउन्डमा हुने क्रियाकलाप र भिजुअल इफेक्टहरू सीमित पारेर ब्याट्रीको पावर जोगाउँछ।</translation>
<translation id="983803489796659991">अपडेट सर्भरमा यो एपको कुनै पनि ह्यास डेटा नभएकाले उक्त एप इन्स्टल गर्न सकिएन।</translation>
<translation id="989369509083708165">Google Chrome तपाईंको डिफल्ट ब्राउजर हो</translation>
<translation id="4614106433017753369">तपाईं <ph name="SHORTCUT"/> थिचेर Ecosia मा एक प्रोफाइलबाट अर्को प्रोफाइलमा जान सक्नुहुन्छ</translation>
</translationbundle>
