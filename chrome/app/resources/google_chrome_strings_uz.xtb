<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia Dev</translation>
<translation id="5357908757303442841">Bu qurilmadagi Ecosia Parollar menejerida</translation>
<translation id="8859253218356192164">EcosiaOS Flex tizimini ishlab chiqishda <ph name="BEGIN_LINK_CROS_OSS"/>ochiq kodli DT<ph name="END_LINK_CROS_OSS"/> vositalaridan foydalanilgan.</translation>
<translation id="6676384891291319759">Internetga ulanish</translation>
<translation id="4586967042094107073">Ecosia fonda ishlashiga ruxsat</translation>
