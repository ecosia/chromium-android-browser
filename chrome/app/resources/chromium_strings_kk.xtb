<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="kk">
<translation id="1026101648481255140">Орнатуды жалғастыру</translation>
<translation id="8933665254023068908">&amp;EcosiaOS жүйесін жаңарту үшін қайта іске қосу</translation>
<translation id="6566258574866003581">Ecosia осы кеңейтімді қарап шығуды ұсынады</translation>
<translation id="1042552502243217427">Сайт беттегі сілтемелерді құпия түрде алдын ала жүктеуді сұрағанда, Chromium браузері Google серверлерін пайдаланады. Осылайша жеке деректеріңіз алдын ала жүктелетін сайттан жасырылады, бірақ Google алдын ала жүктелетін сайттарды біледі.</translation>
<translation id="1065672644894730302">Реттеулерді оқу мүмкін емес.

Кейбір мүмкіндіктер қолжетімсіз болуы мүмкін және параметрлерге жасалған өзгертулер сақталмайды.</translation>
<translation id="8561406087076314604">Ата-анаңыз Ecosia браузері үшін "Сайттарға, қолданбаларға және кеңейтімдерге арналған рұқсаттар" параметрін өшірді</translation>
<translation id="1098170124587656448">Chromium деректердің қолды болуынан, сәйкес келмейтін кеңейтімдерден және тағы басқа мәселелерден қорғайды.</translation>
<translation id="3632544319066562282">Ecosia құпия сөздерді экспорттағысы келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="113122355610423240">Chromium әдепкі браузеріңіз болып табылады</translation>
<translation id="1131805035311359397">Құпия сөздеріңіздің ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK"/>Chromium браузеріне кіріңіз<ph name="END_LINK"/>.</translation>
<translation id="1224748120031661633">Ecosia мәзірін басыңыз.</translation>
<translation id="1184145431117212167">Орнатылмады, себебі сіздегі Windows нұсқасына қолдау көрсетілмейді.</translation>
<translation id="1185134272377778587">Chromium туралы ақпарат</translation>
<translation id="1330085168384841023">Терезені бөлісу үшін жүйе параметрлерінде Ecosia-ге экран жазуға рұқсат беріңіз.</translation>
<translation id="1203500561924088507">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME"/> пайдаланбас бұрын браузерді жауып, қайта ашуыңыз керек.</translation>
<translation id="7455175614937447568">Бұл қойынды әрекетсіз тұрған кезде, Ecosia жылдам жұмыс істеуі үшін, жад босатылды. Сіз бұл сайтты әрекетсіз тұру тізімінен әрдайым шығарып отыру опциясын таңдай аласыз.</translation>
<translation id="9068280473864300215">Ecosia жүктеп алуды блоктады, себебі бұл файл қауіпті.</translation>
<translation id="126567311906253476">Gmail не YouTube сияқты Google қызметтеріне <ph name="USER_EMAIL"/> көмегімен кірген кезде, Chromium-ге сол аккаунтпен автоматты түрде кіруге болады.</translation>
<translation id="1290883685122687410">Реттеу қатесі: <ph name="METAINSTALLER_EXIT_CODE"/>. <ph name="WINDOWS_ERROR"/></translation>
<translation id="319566061277127356">Жаңа Ecosia профилінің параметрлерін реттеу</translation>
<translation id="4019094010333463261">Bluetooth құрылғыларын табу үшін Ecosia-ге Bluetooth пайдалану рұқсаты қажет. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="5405885279794834338">Деректерді Ecosia-нен (<ph name="URL"/>) де жою</translation>
<translation id="727568860157522676">Ecosia жүйесіне кірдіңіз!</translation>
<translation id="1478370723027452770">Chrome for Testing бойынша анықтама алу</translation>
<translation id="1497802159252041924">Орнату қатесі: <ph name="INSTALL_ERROR"/></translation>
<translation id="1861504561909287316">Ecosia қойындысын бөлісу</translation>
<translation id="6896860023874996542">Ecosia браузеріне айналаңыздың 3D картасын жасау үшін камераны пайдалану рұқсаты керек.</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{Бұл кеңейтімге енді қолдау көрсетілмейді. Ecosia оны өшіруге кеңес береді.}other{Бұл кеңейтімдерге енді қолдау көрсетілмейді. Ecosia оларды өшіруге кеңес береді.}}</translation>
<translation id="1574377791422810894">Chromium-нің қауіпсіздік құралдары</translation>
<translation id="2200308425865645682">Ecosia браузері деректерді Ecosia аккаунтыңызға сақтау және барлық құрылғыңызда пайдалануға рұқсат беру үшін жеке басыңызды растауы қажет. Аккаунттан шықсаңыз, бұл деректер осы құрылғыда қалады.</translation>
<translation id="7304240387834227637">Ecosia браузері Password Manager-дегі деректеріңізді жоюға рұқсат сұрайды. Рұқсат беру үшін Windows құпия сөзін енгізіңіз.</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{Жаңартылған нұсқаны қолдану үшін әкімшіңіз Ecosia браузерін қайта іске қосуыңызды талап етеді.}=1{Жаңартылған нұсқаны қолдану үшін әкімшіңіз Ecosia браузерін қайта іске қосуыңызды талап етеді. Инкогнито терезесі қайта ашылмайды.}other{Жаңартылған нұсқаны қолдану үшін әкімшіңіз Ecosia браузерін қайта іске қосуыңызды талап етеді. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="1625909126243026060">Chromium-дегі құпиялық пен қауіпсіздікті басқарудың маңызды құралдарын қарап шығыңыз.</translation>
<translation id="931416298178634530">Егер осы аккаунтты бір рет қана пайдаланғыңыз келсе, Ecosia браузерінде <ph name="GUEST_LINK_BEGIN"/>Қонақ режимін<ph name="GUEST_LINK_END"/> қоса аласыз. Аккаунтты әлдекімге қосқыңыз келсе, <ph name="DEVICE_TYPE"/> құрылғысына <ph name="LINK_BEGIN"/>жаңа адам қосыңыз<ph name="LINK_END"/>.

Веб-сайттар мен қолданбаларға берілген рұқсаттар осы аккаунтқа пайдаланылуы мүмкін. Ecosia аккаунттарын <ph name="SETTINGS_LINK_BEGIN"/>Параметрлер<ph name="SETTINGS_LINK_END"/> бөлімінен басқаруға болады.</translation>
<translation id="1640672724030957280">Жүктеп алынып жатыр…</translation>
<translation id="1715127912119967311">Бұл функцияларды жақсарту үшін Chromium оларды қолдануыңыз туралы ақпаратты Google-ға жібереді. Бұл деректерді тексерушілер оқуы, өңдеуі және aннотация қосуы мүмкін.</translation>
<translation id="1722488837206509557">Бұл жағдайда қолжетімді құрылғылардың арасынан таңдап, оларда контент көрсетуге болады.</translation>
<translation id="1118786556671181978">Сайттардың жарнама көрсетуге пайдаланған қызық тақырыптарын көре және өшіре аласыз. Ecosia браузерді қолданудың соңғы тарихына сүйене отырып, сізге қызық болар деген тақырыптарды болжайды.</translation>
<translation id="2379593823746842972">Ecosia жақын арада браузерді пайдалану деректерін жояды</translation>
<translation id="1736443181683099871">Chromium браузері навигацияларды HTTPS кеңейтіміне жаңартып көреді.</translation>
<translation id="5490755016715767023">Ecosia <ph name="REMAINING_TIME"/> кейін қайта қосылады</translation>
<translation id="1749104137266986751">HTTPS қолжетімді болмаған кезде, Chromium сізге ескертпестен, қауіпті байланысты пайдаланады.</translation>
<translation id="8454595950895325762">Ecosia жүйесін фонда іске қосуға рұқсат беру</translation>
<translation id="9125443060066914183">Ecosia қауіпсіз ету үшін <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> ішінде көрсетілмеген және сізге білдірмей қосылған болуы мүмкін кейбір кеңейтімдерді өшірдік.</translation>
<translation id="6984747211123632080">Ecosia қайта орнату</translation>
<translation id="1251415775728969647">Ecosia <ph name="AUTHENTICATION_PURPOSE"/> қолданып көрейін деп жатыр</translation>
<translation id="1761584959558744002">Браузерді пайдалану деректерін Ecosia аккаунтында сақтай отырып, тек осы құрылғыдан жою үшін <ph name="BEGIN_LINK"/>Ecosia-де аккаунттан шығыңыз<ph name="END_LINK"/>.</translation>
<translation id="185970820835152459">Кірген Google аккаунттарыңызды басқара аласыз. Google аккаунттарыңыз Chromium браузері, Play Store, Gmail және тағы басқа қызметтерде пайдаланылады. Егер отбасы мүшесі сияқты әлдебіреудің аккаунтын қосқыңыз келсе, жаңа пайдаланушыны <ph name="DEVICE_TYPE"/> құрылғыңызға қосыңыз. <ph name="LINK_BEGIN"/>Толығырақ<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">Сайттар Chromium браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады. Мысалы, марафонға аяқ киім сатып алу үшін сайтқа кірсеңіз, сайт қызығушылығыңызды марафон жүгіру деп анықтауы мүмкін. Кейін жүгіру жарысына тіркелу үшін басқа сайтқа кірсеңіз, сол сайт қызығушылықтарыңыз негізінде кроссовка жарнамасын көрсетуі мүмкін.</translation>
<translation id="4239392394637574967">Бақыланатын аккаунт арқылы кіріп, оның әкімшісіне Ecosia профиліңізді басқару мүмкіндігін бердіңіз. Қолданбалар, бетбелгілер, журнал, құпия сөздер сияқты Ecosia деректеріңіз және басқа параметрлер біржола <ph name="USER_NAME"/> пайдаланушысына байланыстырылады. Бұл деректерді Ecosia аккаунт бақылау тақтасы арқылы жоя аласыз, бірақ бұл деректерді басқа аккаунтмен байланыстыра алмайсыз. Бар Ecosia деректерін бөлек ұстау үшін қосымша жаңа профиль жасай аласыз. <ph name="LEARN_MORE"/></translation>
<translation id="1906696617298807388">Мекенжай жолағында немесе іздеу өрісінде терген кезде, Chromium браузері элемент ұсыныстарын алу үшін тергеніңізді Google Drive қызметіне жібереді. Бұл Инкогнито режимінде өшірілген.</translation>
<translation id="1911763535808217981">Бұл функцияны өшіріп, Chromium браузеріне кірместен Gmail сияқты Google сайттарын пайдалана беруіңізге болады</translation>
<translation id="18064594488616674">Ecosia жауап бермейді. Қазір қайта іске қосасыз ба?</translation>
<translation id="8047394653992042491">Жаңарту күшіне енуі үшін EcosiaOS жүйесін өшіріп қосу керек.</translation>
<translation id="4988569127367972482">Ecosia жүктеп алуды блоктады, себебі бұл файл түрі әдетте жүктеп алынбайды және ол қауіпті болуы мүмкін.</translation>
<translation id="1953553007165777902">Жүктеп алынып жатыр… <ph name="MINUTE"/> минут қалды.</translation>
<translation id="1966382378801805537">Chromium әдепкі браузерді анықтай не орната алмайды</translation>
<translation id="6583697665130212310">Неліктен Ecosia кейбір файлдарды блоктайтыны туралы ақпарат жаңа қойындыдан ашылады.</translation>
<translation id="2008474315282236005">Құрылғыдан 1 элемент жойылады. Деректерді кейінірек алу үшін Chromium браузеріне <ph name="USER_EMAIL"/> болып кіріңіз.</translation>
<translation id="2018879682492276940">Орнатылмады. Қайталап көріңіз.</translation>
<translation id="2020032459870799438">Басқа құпия сөздеріңіздің ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK"/>Chromium браузеріне кіріңіз<ph name="END_LINK"/>.</translation>
<translation id="2049376729098081731">Google қызметтерінде жекелендірілген мүмкіндіктерді пайдалану үшін Chromium тарихын қосу-қоспау нұсқасын таңдаңыз.</translation>
<translation id="7112125772061727648">Ecosia жүктеп алуды блоктады, себебі бұл – алдамшы файл және ол құрылғыңызға күтпеген өзгерістер енгізуі мүмкін.</translation>
<translation id="2088953378266246249">Chromium-нің түбірлік сертификаттарды қалай басқаратыны туралы ақпарат</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{Ecosia 1 минут бойы пайдаланылмаса, ұйымыңыз браузерді пайдалану деректерін автоматты түрде жояды. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін. Қойындыларыңыз ашық болады.}other{Ecosia # минут бойы пайдаланылмаса, ұйымыңыз браузерді пайдалану деректерін автоматты түрде жояды. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін. Қойындыларыңыз ашық болады.}}</translation>
<translation id="2126108037660393668">Жүктеп алынған файл растаудан өтпеді.</translation>
<translation id="2745180350547322293">Ecosia жүктеп алуды блоктады, себебі сайтта қауіпсіз байланыс пайдаланылып жатқан жоқ және файл өзгертілген болуы мүмкін.</translation>
<translation id="8296229475165428335">Ecosia мәзірінен бетбелгілерді, оқу режимін және т.б. ашуға болады.</translation>
<translation id="838842459108103907">Ecosia-ді реттеу</translation>
<translation id="2174917724755363426">Орнату аяқталмады. Шынымен бас тартқыңыз келе ме?</translation>
<translation id="9035946286843935549">Ecosia – Желіге кіру - <ph name="PAGE_TITLE"/></translation>
<translation id="2190166659037789668">Жаңа нұсқаны тексеру қатесі: <ph name="UPDATE_CHECK_ERROR"/>.</translation>
<translation id="8196791276481156937">Аккаунтты Ecosia-нен өшіру</translation>
<translation id="2210682093923538346">Сайт қауіпті. Chromium хабарландыруларды өшірді.</translation>
<translation id="2240214816234246077">Жақында кірмедіңіз. Chromium <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> рұқсаттарын өшірді.</translation>
<translation id="6111519389633335269">Компьютерді бөлісетін болсаңыз, достарыңыз интернетке бөлек кіріп, Ecosia жүйесін қалауынша орната алады.</translation>
<translation id="2313870531055795960">URL мекенжайларын Chromium браузерінде сақталған қауіпсіз емес сайттар тізімімен салыстырып тексереді. Егер сайт құпия сөзіңізді ұрлағысы келсе немесе зиянды файлды жүктеп алсаңыз, Chromium браузері URL мекенжайларын, сондай-ақ бет контенті бөліктерін Safe Browsing қызметіне жіберуі мүмкін.</translation>
<translation id="2329088755516916767">Қосылса, Chromium беттерді алдын ала жүктейді, осылайша браузерді пайдалану және іздеу әрекеті тез жүреді.</translation>
<translation id="665177868576952817">Нөмірді осы жерден Android телефонына жіберу үшін екі құрылғыда да Ecosia браузеріне кіріңіз.</translation>
<translation id="2359808026110333948">Жалғастыру</translation>
<translation id="790624108224468719">"<ph name="EXTENSION_NAME"/>" кеңейтімін қолдану үшін Ecosia-ге кіруіңіз керек</translation>
<translation id="2056307067005384438">Бұл кеңейтімді <ph name="USER_EMAIL_ADDRESS"/> ретінде пайдалану үшін Ecosia-ге кіріңіз.</translation>
<translation id="592990842052138727">EcosiaOS деректеріңізді синхрондай алмады, себебі аккаунтыңызға кіру мәліметтері ескірген.</translation>
<translation id="2526043366208696235">{NUM_DEVICES,plural, =0{1 HID құрылғысын бір немесе бірнеше Ecosia кеңейтімі пайдаланды}=1{1 HID құрылғысын бір немесе бірнеше Ecosia кеңейтімі пайдаланып жатыр}other{# HID құрылғысын бір немесе бірнеше Ecosia кеңейтімі пайдаланып жатыр}}</translation>
<translation id="3554373328288278512">Ecosia бұл сайт үшін камера мен микрофонды пайдалануға рұқсат сұрайды.</translation>
<translation id="2440750600860946460"><ph name="BEGIN_LINK"/>Chromium-дегі құралдар<ph name="END_LINK"/> көмегімен браузерді қауіпсіз қолданып, барлығын басқаруға болады.</translation>
<translation id="2451727308784734061">Password Manager қызметіне жылдам өту үшін таңбашаны пайдаланыңыз. Таңбашаны компьютердің негізгі экранына немесе қолданбаларды іске қосу тақтасына жылжытуға болады.</translation>
<translation id="5736558630107498475">Ecosia жақын арада жабылады</translation>
<translation id="6495878830719404098">Ecosia аясында</translation>
<translation id="2485422356828889247">Жою</translation>
<translation id="2513154137948333830">Өшіріп қосу қажет: <ph name="INSTALL_SUCCESS"/></translation>
<translation id="8957938953005153147">Ecosia бұрыннан бар құпия сөздерді ауыстырғысы келеді. Бұған рұқсат беру үшін Windows құпия сөзін енгізіңіз.</translation>
<translation id="5549921590305750618">Файлдарды жүктеп алу үшін Ecosia браузеріне сақтау орнын пайдалану құқығы қажет</translation>
<translation id="9090890391337853620">Ecosia Helper</translation>
<translation id="6094573000614590044">Құпия сөздер мен басқа ақпаратты барлық құрылғыдан алу үшін Ecosia аккаунтына кіріңіз.</translation>
<translation id="5707346538075088068">Жұмыс профилінің әкімшісі осы профильді пайдалану кезінде құрылатын Ecosia браузерінің кез келген дерегін (бетбелгілер, тарих, құпия сөздер жасау және басқа параметрлер сияқты) жоя алады. <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosia-ді пайдалана беру</translation>
<translation id="259935314519650377">Жүктеп алынған орнату құралы кэштелмеді. Қате: <ph name="UNPACK_CACHING_ERROR_CODE"/>.</translation>
<translation id="2198589091447191935">Ecosia жылдам жұмыс істейді және JavaScript қолданатын функциялар тиісті түрде жұмыс істеуі керек (ұсынылады).</translation>
<translation id="7280797724682955539">Орнату барысында операциялық жүйе қатесі орын алды. Ecosia қайта жүктеңіз.</translation>
<translation id="6960183526681645011">Құрылғыңызды басқа адамдар да пайдаланатын болса, достарыңыз және отбасыңыздың мүшелері интернетке бөлек кіріп, Ecosia параметрлерін өздері қалағандай орната алады.</translation>
<translation id="2381210243314074423"><ph name="ACCOUNT_FIRST_NAME"/>, Ecosia браузеріне қош келдіңіз!</translation>
<translation id="385080958066798123">Ecosia қойындысы</translation>
<translation id="2718390899429598676">Қосымша қауіпсіздік үшін Chromium деректеріңізді шифрлайды.</translation>
<translation id="7347725536241560534">Ecosia-нен Ecosia аккаунтын өшіру үшін аккаунттан шығыңыз.</translation>
<translation id="2738871930057338499">Интернетке қосылу мүмкін емес. HTTP 403 бойынша тыйым салынған. Прокси конфигурациясын тексеріңіз.</translation>
<translation id="2770231113462710648">Әдепкі браузерді келесіге өзгерту:</translation>
<translation id="3077076541395306362">Бұл кеңейтімде зиянды бағдарлама бар болғандықтан, ол қауіпті. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Ecosia-нан жойыңыз.</translation>
<translation id="2799223571221894425">Қайта іске қосу</translation>
<translation id="3952510753191144456"><ph name="USER_EMAIL_ADDRESS"/> үшін жаңа Ecosia профилі жасалады.</translation>
<translation id="2846251086934905009">Орнату қатесі: орнату аяқталмады, оның орнына доғарылды.</translation>
<translation id="4199684616787081033">Ecosia жүйесінен алып тастау…</translation>
<translation id="2850691299438350830">Аккаунтқа кірген кезде, Chromium браузерінде қауіпсіздігіңізді қамтамасыз етеді және басқа Google қолданбаларында қауіпсіздік деңгейін арттыру үшін пайдаланылуы мүмкін.</translation>
<translation id="2885378588091291677">Тапсырмалар реттегіші</translation>
<translation id="7221868538334633215">&amp;Ecosia туралы</translation>
<translation id="2915996080311180594">Кейін қайта қосу</translation>
<translation id="2928420929544864228">Орнату аяқталды.</translation>
<translation id="2945997411976714835">Орнату қатесі: орнату процесі басталмады.</translation>
<translation id="7527831132809333552">Ecosia-ді ұйымыңыз басқарады</translation>
<translation id="2977470724722393594">Chromium жаңартылған</translation>
<translation id="2977506796191543575">Егер сайт құпия сөзіңізді ұрлағысы келсе немесе зиянды файлды жүктеп алсаңыз, Chromium браузері URL мекенжайларын, сондай-ақ бет контенті бөліктерін Safe Browsing қызметіне жіберуі мүмкін.</translation>
<translation id="7562371913339616107">Ecosia браузерді пайдалану мүмкіндігін жақсарту және ресурстарды босату үшін бұл қойындыларды әрекетсіз қыла алады.</translation>
<translation id="6154325450733409298"><ph name="URL"/> сілтемесі Ecosia-дегі жаңа қойындыдан ашылады.</translation>
<translation id="3032706164202344641">Chromium сіздің құпия сөздеріңізді тексере алмай жатыр. Кейінірек қайталап көріңіз.</translation>
<translation id="1762318218111418450">Ecosia жүйесіне қосылуда…</translation>
<translation id="3038232873781883849">Сәлден соң орнатыла бастайды…</translation>
<translation id="6967821869905227561">Басқа Ecosia профильдері</translation>
<translation id="9178613517891824246">Ecosia компаниясына жаңылыс туралы есептер және <ph name="UMA_LINK"/> жіберу арқылы Ecosia жақсартуға көмектесіңіз</translation>
<translation id="7655708678113012665">{NUM_DEVICES,plural, =0{1 USB құрылғысын бір немесе бірнеше Ecosia кеңейтімі пайдаланды}=1{1 USB құрылғысын бір немесе бірнеше Ecosia кеңейтімі пайдаланып жатыр}other{# USB құрылғысын бір немесе бірнеше Ecosia кеңейтімі пайдаланып жатыр}}</translation>
<translation id="3101560983689755071">Браузерді қолдану тарихы төменде берілгендей сіз көретін жарнамаларға және қызығушылықтарға әсер етеді. Құпиялығыңызды сақтау үшін Chromium қызығушылықтарды ай сайын автоматты түрде жойып отырады. Қызығушылықтарды өшірмесеңіз, олар жаңартыла беруі мүмкін.</translation>
<translation id="7691143774653486474">Орнату құралы мұрағаттан шығара алмады. Ecosia қолданбасын қайта жүктеңіз.</translation>
<translation id="1318059253725731825">Ecosia микрофоныңызды пайдалануда.</translation>
<translation id="51576365410323372">Бұл қойынды ресурстарды көп қолданып жатыр. Өнімділікті жақсарту үшін Ecosia-ге оны әрекетсіз қылуға рұқсат беріңіз.</translation>
<translation id="8282620071565190081">Ecosia қолданбасын қайта іске қосу</translation>
<translation id="5500958820122281144">Сілтемені Ecosia инкогнито терезесінде ашу</translation>
<translation id="3697186779259384993">Жаңа Ecosia профилін реттеңіз.</translation>
<translation id="3216284932113164802">Ecosia жаңылысты. Қазір қайта іске қосу керек пе?</translation>
<translation id="8696852719113991652">Ecosia-нен Ecosia аккаунтын өшіру үшін Ecosia-нен "Параметрлер" бетінде шығыңыз.</translation>
<translation id="7602423871874451395">Ecosia өзінің деректер каталогін оқи және оған жаза алмайды:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="905744008702074577">V8 — сайт өнімділігін арттыру үшін қолданылатын Ecosia-нің JavaScript және WebAssembly жүйесі.</translation>
<translation id="3283186697780795848">Chromium браузерінің <ph name="PRODUCT_VERSION"/> нұсқасы орнатылды.</translation>
<translation id="3286538390144397061">Қазір қайта іске қосу</translation>
<translation id="4735588186234302898">Ecosia API пернелері жоқ. Кейбір Ecosia функциялары өшіріледі.</translation>
<translation id="3296368748942286671">Chromium жабылғанда, фондық қолданбаларды пайдалануды жалғастыру</translation>
<translation id="686474599126256998">Аккаунтты пайдалану рұқсатын реттеп жатқанда, Ecosia-ді пайдалана берсеңіз болады. Реттеу аяқталғанша, кейбір ресурстарға кіре алмауыңыз мүмкін.</translation>
<translation id="3313189106987092621">Chromium кез келген сайтты қауіпті байланыс арқылы жүктеу алдында сізге ескертеді.</translation>
<translation id="5513857521842828996">Ecosia-де аккаунтқа кірген болсаңыз, барлық Ecosia терезесін жапқан кезде, Ecosia аккаунтын қоспағанда, сайттардың көпшілігінен шығарыласыз. Сайттар сізді есте сақтасын десеңіз, <ph name="SETTINGS_LINK"/>.</translation>
<translation id="812798451698099271">Бұл аккаунтқа Ecosia профилі тіркеліп қойған.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="4781882243268600858">Бұрыннан бар Ecosia профиліне ауыстырылсын ба?</translation>
<translation id="3412460710772753638">Осы құрылғыдағы Құпия сөз менеджерінде</translation>
<translation id="4170280082681554565">Ecosia профильдері арқылы Ecosia-дегі материалдарыңызды бөліп қоя аласыз. Достарға және отбасыңызға арнап немесе жұмысқа не көңіл көтеруге бөлек профиль жасаңыз.</translation>
<translation id="347328004046849135">Ұрланған құпия сөзбен кірген кезде, Chromium сізге хабарлайды.</translation>
<translation id="3474745554856756813">Құрылғыдан <ph name="ITEMS_COUNT"/> элемент жойылады. Деректерді кейінірек алу үшін Chromium браузеріне <ph name="USER_EMAIL"/> болып кіріңіз.</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> арқылы Ecosia профильдерін ауыстыруға болады.</translation>
<translation id="8534308095039131078">Барлық Ecosia терезелерін жауып, әрекетті қайталап көріңіз.</translation>
<translation id="7984841734836997333"><ph name="EXISTING_USER"/> әлдеқашан кірді.  Браузерді пайдалану тарихын бөлек сақтау үшін Ecosia-ге <ph name="USER_EMAIL_ADDRESS"/> ретінде жеке профиліңізбен кіріңіз.</translation>
<translation id="3533435340678213462">Құпиялығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Бұл ретте Chromium-ның ескергенін қаламаған қызығушылықтарды өшіруге болады.</translation>
<translation id="3567254597502212821">Браузерді қолдану тарихы, осы құрылғыда Chromium көмегімен кірген сайттардың жазбасы.</translation>
<translation id="3597003331831379823">Реттеуді кеңейтілген құқықтармен бастау мүмкін болмады. <ph name="METAINSTALLER_ERROR"/></translation>
<translation id="2128110540135015661">Бұл пайдаланушының браузерді пайдалану деректері құрылғыдан жойылады. Деректерді қалпына келтіру үшін Ecosia браузеріне <ph name="USER_EMAIL"/> болып кіріңіз.</translation>
<translation id="1323499021727766710">{COUNT,plural, =0{Ecosia браузерінің жаңа нұсқасы шықты. Ол браузерді өшіріп, қайта іске қосқанда орнатылады.}=1{Ecosia браузерінің жаңа нұсқасы шықты. Ол браузерді өшіріп, қайта іске қосқанда орнатылады. Инкогнито терезесі қайта ашылмайды.}other{Ecosia браузерінің жаңа нұсқасы шықты. Ол браузерді өшіріп, қайта іске қосқанда орнатылады. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="7849498640944199147">Нөмірді <ph name="ORIGIN"/> құрылғысынан Android телефонына жіберу үшін екі құрылғыда да Ecosia браузеріне кіріңіз.</translation>
<translation id="3667616615096815454">Орнату мүмкін болмады, себебі сервер қолданбаны анықтай алмады.</translation>
<translation id="7845247414826995986">Экранды бөлісу үшін жүйе параметрлерінде Ecosia-ге экран жазуға рұқсат беріңіз.</translation>
<translation id="3685209450716071127">Chromium сіздің құпия сөздеріңізді тексере алмай жатыр. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="5902103164685487225">Ecosia браузерінде жарнаманы жекелендіру туралы толық ақпарат</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{Жаңартылған нұсқасын қолдану үшін әкімші Ecosia-ді қайта іске қосуыңызды сұрайды.}=1{Жаңартылған нұсқасын қолдану үшін әкімші Ecosia-ді қайта іске қосуыңызды сұрайды. Инкогнито терезесі қайта ашылмайды.}other{Жаңартылған нұсқасын қолдану үшін әкімші Ecosia-ді қайта іске қосуыңызды сұрайды. # инкогнито терезесі қайта ашылмайды.}}</translation>
<translation id="489671036945006830">Сілтемені жаңа Ecosia қойындысында ашу</translation>
<translation id="3728124580182886854">Жекелендіру және басқа мақсаттарды орындау үшін Chromium мен басқа Google қызметтерін байланыстырыңыз.</translation>
<translation id="3140530394740845618">Ecosia профильдерін басқару</translation>
<translation id="3035352359183300151">Неліктен Ecosia кейбір жүктеп алынғандарды блоктайтыны туралы ақпарат алыңыз</translation>
<translation id="379589255253486813">Тексеруге қажетті нәрсе болса, Chromium сізге хабар береді</translation>
<translation id="3802055581630249637">Chromium сіз кіруіңіз мүмкін беттерді алдын ала жүктейді, сонда оларға кірген кезіңізде, тезірек жүктеледі.</translation>
<translation id="3959732324458144441">EcosiaOS жүйесі</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> – Ecosia</translation>
<translation id="386822487697155367">ChromiumOS туралы анықтама алу</translation>
<translation id="6391863622742187823"><ph name="ACCOUNT_EMAIL"/> аккаунтынан Ecosia браузерінің мәліметтерін алыңыз.</translation>
<translation id="8544776492099331022">Ecosia-ді реттеу және басқару. Назар аударуыңыз қажет. Толығырақ ақпарат алу үшін басыңыз.</translation>
<translation id="4871843754042758264">Ecosia ашу үшін атыңызды басып, шарлауды бастаңыз.</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> бұл Ecosia профиліне кіріп қойған. Браузерді пайдалану деректерін бөлек сақтау үшін Ecosia сізге жеке профиль жасай алады.</translation>
<translation id="8172133981892685841">Бұл кеңейтім Ecosia Web Store саясатына қайшы, сондықтан қауіпті болуы мүмкін. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Ecosia-нан жойыңыз.</translation>
<translation id="4070480171055648632">Аккаунтыңызды <ph name="MANAGER_NAME"/> басқарады. Әкімші осы Ecosia браузерінің профилі мен оның бетбелгілер, тарих және құпия сөздер сияқты деректерін көре және өзгерте алады.</translation>
<translation id="3941890832296813527">Орнату қатесі: орнату файлының атауы жарамсыз немесе оған қолдау көрсетілмейді.</translation>
<translation id="1047556320128249268">Ecosia құпия сөздерді көшіргісі келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="3962647064319009959">Chromium сізді қалай қорғайтыны туралы ақпарат алыңыз</translation>
<translation id="8603020525900853944">&amp;Ecosia for Testing туралы</translation>
<translation id="3997429360543082038">ChromiumOS туралы</translation>
<translation id="5311911269004680646">EcosiaOS жүйесі де <ph name="BEGIN_LINK_LINUX_OSS"/>Linux әзірлеу ортасы<ph name="END_LINK_LINUX_OSS"/> сияқты <ph name="BEGIN_LINK_CROS_OSS"/>ашық кодты бағдарламалық құрал<ph name="END_LINK_CROS_OSS"/> арқылы қолжетімді болады.</translation>
<translation id="4036079820698952681"><ph name="BEGIN_LINK"/>Ағымдағы параметрлерді<ph name="END_LINK"/> хабарлау арқылы Chromium браузерін жақсартуға көмектесіңіз</translation>
<translation id="4050175100176540509">Соңғы нұсқасында қауіпсіздік жақсартылып, жаңа мүмкіндіктер берілген.</translation>
<translation id="4055805654398742145">P&amp;assword Manager</translation>
<translation id="7757263274906217411">{COUNT,plural, =1{Ecosia 1 минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады. Браузерді пайдалану деректері жойылады. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін.}other{Ecosia # минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады. Браузерді пайдалану деректері жойылады. Оларға тарих, автотолтыру және жүктеп алынғандар кіруі мүмкін.}}</translation>
<translation id="4118474109249235144">Chromium-нің инкогнито режимі</translation>
<translation id="4122186850977583290">"Chromium туралы ақпарат" бетіне өту</translation>
<translation id="4148957013307229264">Орнатылуда…</translation>
<translation id="4264506519284061030">Ұйымыңыз жұмыс профиліңіздегі бетбелгілер, тарих және құпия сөздер сияқты браузерді пайдалану деректерін көріп, басқара алады. Ол жеке Ecosia профильдеріндегі браузерді пайдалану деректерін көре алмайды.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> –Желіге кіру – Ecosia</translation>
<translation id="7782767522222146179">Ecosia үшін тамаша қолданбалар, ойындар мен тақырыптарды таба аласыз.</translation>
<translation id="4216212958613226427">Бұл тіл Chromium интерфейсін көрсету үшін қолданылады.</translation>
<translation id="4222932583846282852">Бас тартылуда…</translation>
<translation id="4224210481850767180">Орнату тоқтатылды.</translation>
<translation id="8384922154025337808">Ecosia дерегіңізді осы аккаунтпен байланыстырасыз ба?</translation>
<translation id="4251772536351901305">Стандартты қорғанысқа қарағанда сайттардағы көбірек деректерді талдау арқылы қауіпті сайттар, тіпті Google-ға бұрын белгісіз болған сайттар туралы ескертеді. Chromium ескертулерін өткізіп жіберуді таңдауға болады.</translation>
<translation id="2672632089507560181">Ecosia-нен шығу</translation>
<translation id="4271805377592243930">Chromium жөнінде анықтама алу</translation>
<translation id="4281844954008187215">Қызмет көрсету шарттары</translation>
<translation id="3305517118160815955">Орнату анықталмаған қате себебінен сәтсіз аяқталды. Ағымда Ecosia жұмыс істеп тұрса, оны жауып, әрекетті қайталаңыз.</translation>
<translation id="4304713468139749426">Құпия сөздер реттегіші</translation>
<translation id="4334294535648607276">Жүктеп алынды.</translation>
<translation id="8411844745163855310">Бұл құрылғыны пайдаланбас бұрын, <ph name="MANAGER"/> домені келесі Қызмет көрсету шарттарын оқып, қабылдауыңызды талап етеді. Бұл шарттар EcosiaOS Шарттарын толықтырмайды, өзгертпейді және шектемейді.</translation>
<translation id="88039520238670574">Ecosia браузерінен бәрібір шығасыз ба?</translation>
<translation id="4586967042094107073">Ecosia браузеріне фондық режимде жұмыс істеуге рұқсат беру</translation>
<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Ecosia оны өшіруге кеңес береді. <ph name="BEGIN_LINK"/>Қолдау көрсетілетін кеңейтімдер туралы толық ақпарат алыңыз.<ph name="END_LINK"/>}other{Ecosia оларды өшіруге кеңес береді. <ph name="BEGIN_LINK"/>Қолдау көрсетілетін кеңейтімдер туралы толық ақпарат алыңыз.<ph name="END_LINK"/>}}</translation>
<translation id="4817913198787198451">Ecosia реттеу және басқару</translation>
<translation id="4427306783828095590">Жақсартылған қорғаныс фишинг пен зиянды бағдарламаларды бөгеуде көбірек істейді.</translation>
<translation id="4434353761996769206">Орнату құралының қатесі: <ph name="INSTALLER_ERROR"/></translation>
<translation id="6994161374830839635">Ecosia-ді <ph name="MANAGER"/> басқарады</translation>
<translation id="4447409407328223819">Chrome for Testing туралы</translation>
<translation id="4501471624619070934">Орнату мүмкін болмады, себебі бұл елде кіруге шектеу қойылған.</translation>
<translation id="576192547306902465">Бұл кеңейтім пайдаланушы деректерін қалай жинап, қолданатыны сияқты құпиялық шараларын жарияламаған. Ecosia оны өшіруге кеңес береді.</translation>
<translation id="1859120614572957305">Ecosia браузеріне қош келдіңіз! Жаңа браузер терезесі ашылды.</translation>
<translation id="378302976931789177">Ecosia-ге айналаңызды картаға түсіруге және қолыңызды бақылауға рұқсат қажет.</translation>
<translation id="8403827649521531901">Басқа Ecosia профилінде әлдеқашан <ph name="USER_EMAIL_ADDRESS"/> ретінде кіргенсіз.</translation>
<translation id="4544142686420020088">Chromium жаңартылған жоқ. Бірдеңе дұрыс болмады. <ph name="BEGIN_LINK"/>Chromium браузеріндегі жаңартуға қатысты мәселелерді түзетіңіз.<ph name="END_LINK"/></translation>
<translation id="2020747823154282691">Ecosia браузерді пайдалану мүмкіндігін жақсарту және тапсырмалардың орындалуын жылдамдату үшін бұл қойындыны әрекетсіз қыла алады.</translation>
<translation id="8685318202174822382">Жаңа Ecosia профилінде жалғастырылсын ба?</translation>
<translation id="4567424176335768812"><ph name="USER_EMAIL_ADDRESS"/> ретінде кіргенсіз. Енді барлық кірген құрылғыларда бетбелгілеріңізді, журналыңызды және басқа параметрлерді көре аласыз.</translation>
<translation id="361644486359722423">Ecosia жүктеп алуды блоктады, себебі Safe Browsing функциясы өшірілді және файлды растау мүмкін емес.</translation>
<translation id="4594305310729380060">Осы құрылғыдағы Құпия сөз менеджеріне</translation>
<translation id="2636091632287013185">Ecosia қолданбалары</translation>
<translation id="4613863813562375431">ChromiumOS нұсқасы</translation>
<translation id="2394629668475473296">Экранды бөлісу үшін жүйе параметрлерінде Ecosia-ге экран жазуға рұқсат беріңіз.</translation>
<translation id="4621240073146040695">Сәл қалды! Жаңартуды аяқтау үшін Chromium жүйесін қайта іске қосыңыз.</translation>
<translation id="1676748966275099244">Ескерту: Ecosia кеңейтімдердің браузерді қолдану тарихын жазуына кедергі бола алмайды. Бұл кеңейтімді Инкогнито режимінде өшіру үшін бұл опцияның белгісін алып тастаңыз.</translation>
<translation id="4673151026126227699">Chromium пайдалану есептерін де бөліссеңіз, бұл есептерде сіз кірген URL мекенжайлары қамтылады.</translation>
<translation id="1384607180773886645">Профиль басқа Ecosia процесімен (<ph name="PROCESS_ID"/>) басқа компьютерде (<ph name="HOST_NAME"/>) пайдаланылып жатыр. Бүлінбеуі үшін Ecosia профильді құлыптап қойды. Басқа процестер бұл профильді пайдаланып жатпаса, профильді құлыптан ашып, Ecosia қайта іске қосуыңызға болады.</translation>
<translation id="4680828127924988555">Орнатудан бас тарту</translation>
<translation id="7898621536417126731">Ecosia деректерінің кейбірі Ecosia аккаунтыңызға әлі сақталмаған. Шығу алдында бірнеше минут күтіп көріңіз. Қазір шықсаңыз, бұл деректер жойылады.</translation>
<translation id="4427878468534147875">Аккаунтқа кірсеңіз, Ecosia-нен Ecosia аккаунтыңыздағы құпия сөздер мен т.б. ақпаратты пайдалана аласыз. <ph name="SHORTCUT"/> тіркесімі арқылы Ecosia қызметтерінің параметрлерін өзгертуге болады.</translation>
<translation id="4727435569202742773">Бұрын әлдекім осы компьютерден Ecosia браузеріне <ph name="ACCOUNT_EMAIL_LAST"/> болып кірген. Ақпаратты бөлек ұстау үшін жаңа Ecosia пайдаланушысын жасаңыз.</translation>
<translation id="4724676981607797757">Орнатылмады, себебі қолдау көрсетілмейтін протокол қатесі пайда болды.</translation>
<translation id="864244542982029641">Ecosia браузерінен бәрібір шығасыз ба?</translation>
<translation id="1025044809499013222">Ecosia браузеріне қазір ғана қауіпсіздік бойынша арнайы жаңартылған нұсқа қолданылды. Оны қазір қайта ашсаңыз, қойындылар қалпына келтіріледі.</translation>
<translation id="824192326282906244">Таңдауыңызды кез келген уақытта Ecosia параметрлерінде өзгертуге болады. Сынақ нұсқалары жарнама көрсетудің ағымдағы әдісімен жұмыс істейді. Сондықтан өзгерістер бірден көрінбейді.</translation>
<translation id="4788777615168560705">Chromium сіздің құпия сөздеріңізді тексере алмай жатыр. 24 сағаттан кейін қайталап көріңіз немесе <ph name="BEGIN_LINK"/>құпия сөздерді Google аккаунтынан тексеріңіз<ph name="END_LINK"/>.</translation>
<translation id="3543284013834505767">Ecosia Search қызметіндегі емле тексеру құралы пайдаланылады. Браузерде терілген мәтін Ecosia-ға жіберіледі. Мұны параметрлерде өзгертуіңізге болады.</translation>
<translation id="7787479292144635608">Ecosia-ді аккаунтсыз қолдану</translation>
<translation id="4154538917942874814">mDNS трафигіне рұқсат беретін Ecosia кіріс ережесі.</translation>
<translation id="2159716220295742156">&amp;Ecosia-ді жаңарту үшін қайта іске қосу</translation>
<translation id="8701027951719712428">Ecosia-нің жаңа нұсқаларын алып тұру үшін macOS 11 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде macOS 10.15 нұсқасы орнатылған.</translation>
<translation id="2234042158691635795">Ecosia фондық режимде.</translation>
<translation id="3271929752667225813">Ecosia-ге кірудің диалогтік терезесін жабу үшін басыңыз.</translation>
<translation id="1869027055332251164">Қонақтар Ecosia қолданбасын ешқандай дерек қалдырмай пайдалана алады.</translation>
<translation id="6761747850241550887">Ecosia жүйесіне өзіңізді қосу</translation>
<translation id="3708834841667355707">Ecosia жаңа функцияларды зерттеп жатыр. Олардың көмегімен сайттарды аз ақпаратпен де бұрынғыдай пайдалана беруге болады.</translation>
<translation id="3376578942612115781">Ecosia аккаунтын қайта аутентификациялау қажет.</translation>
<translation id="5224391634244552924">Ешқандай құпия сөз сақталмаған. Құпия сөздер сақталған кезде, Chromium оларды тексере алады.</translation>
<translation id="2421263730139898714">Ecosia жүйесінен шығу</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> бұл Ecosia профиліне кіріп қойған. <ph name="USER_EMAIL_ADDRESS"/> үшін жаңа Ecosia профилі жасалады.</translation>
<translation id="5277894862589591112">Өзгерістер енуі үшін, Chromium браузерін қайта қосыңыз</translation>
<translation id="5294316920224716406">Инкогнито режимін пайдаланған кезде, Chromium сайтты қауіпті байланыс арқылы жүктеу алдында сізге ескертеді.</translation>
<translation id="5296845517486664001">Сынақ нұсқалары қосылғанда, Chromium сізді белсенді сынақ нұсқасына кездейсоқ орналастырса, браузерді қолдану тарихы төменде берілгендей сіз көретін жарнамалар мен қызығушылықтарға әсер етеді. Құпиялығыңызды сақтау үшін Chromium қызығушылықтарды ай сайын жойып отырады.</translation>
<translation id="2297526912548649074">Ecosia-ге <ph name="USER_EMAIL"/> ретінде кіру</translation>
<translation id="5352264705793813212">Chromium тексеруге қажетті қауіпсіздікке қатысты кейбір ұсыныстарды тапты</translation>
<translation id="5251710252516682805">Басқа Ecosia профильдері</translation>
<translation id="7105712012505419722">Бақыланатын аккаунт арқылы кірдіңіз және оның әкімшілік бөлігін Ecosia профилі арқылы басқару мүмкіндігін бердіңіз. Қолданбалар, бетбелгілер, журнал, құпия сөздер сияқты Ecosia деректеріңіз және басқа параметрлер біржола <ph name="USER_NAME"/> пайдаланушысына байланыстырылады. Бұл деректерді Ecosia аккаунт бақылау тақтасы арқылы жоя аласыз, бірақ бұл деректерді басқа аккаунтмен байланыстыра алмайсыз. <ph name="LEARN_MORE"/></translation>
<translation id="5368118228313795342">Қосымша код: <ph name="EXTRA_CODE"/>.</translation>
<translation id="5377622451696208284">Жекелендіру үшін Chromium-ді интернет пен қолданбаларды пайдалану тарихына қосыңыз.</translation>
<translation id="350189837353493413">Неліктен Ecosia кейбір файлдарды блоктайтыны туралы ақпарат алыңыз</translation>
<translation id="5386450000063123300">Chromium жаңартылуда (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">Chromium браузеріне кіруге рұқсат ету</translation>
<translation id="330264384086604869">Ecosia-нен жою</translation>
<translation id="5581150090232500900">Әдепкі браузер ретінде Ecosia қолданбасын орнату</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia бета нұсқасы</translation>
<translation id="3307959934543585795">Ecosia дұрыс жұмыс істемеуі мүмкін, себебі оған Linux жүйесінде қолдау көрсетілмейді.</translation>
<translation id="197803137365953132">Ecosia бұл файлды жүктеп алуға тыйым салды, себебі ол жеке және әлеуметтік желі аккаунттарыңызға қауіп төндіруі мүмкін</translation>
<translation id="6558895515431832002">Бұл сайтқа көрсету үшін Ecosia браузері орналасқан жеріңізді білуі керек</translation>
<translation id="5487574057737591516">Құпиялығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Егер Chromium браузері қателессе немесе белгілі бір жарнамаларды көргіңіз келмесе, қызығушылықты өшіре аласыз.</translation>
<translation id="5279514147510747661">Ecosia ең соңғы жүйе жаңартуларын орнатуда, күте тұрыңыз.</translation>
<translation id="5066194399237265772">Ecosia құпия сөздерді өзгерткісі келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="5527463683072221100">PDF-терді Chromium-де ашу</translation>
<translation id="7348818664647668234">{0,plural, =0{Ecosia браузерінің жаңартылған нұсқасы қолжетімді}=1{Ecosia браузерінің жаңартылған нұсқасы қолжетімді}other{Ecosia браузерінің жаңартылған нұсқасы # күннен бері қолжетімді}}</translation>
<translation id="5643865575100044307">Chromium браузерін жапқан кезде құрылғыңыздан сайт деректерін үнемі жою</translation>
<translation id="5982672133249369264">Ecosia браузерін қайта іске қосыңыз</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="5698481217667032250">Chromium жүйесін осы тілде көрсету</translation>
<translation id="569897634095159764">Интернетке қосылу мүмкін емес. Прокси-сервер үшін аутентификация қажет.</translation>
<translation id="5761096224651992291">Жақында кірмедіңіз. Chromium <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/>, <ph name="PERMISSION_3"/> рұқсаттарын өшірді.</translation>
<translation id="1818520302923047971">Ecosia-ді бейімдеңіз және басқарыңыз. Ecosia-ді әдепкі браузер етіп орнатыңыз.</translation>
<translation id="5809516625706423866">Интернетке қосылу мүмкін емес. HTTP 401 бойынша рұқсат берілмейді. Прокси конфигурациясын тексеріңіз.</translation>
<translation id="1027331268335328576">Ecosia жүйесіне қош келдіңіз</translation>
<translation id="2942675027725878581">Ecosia бұл элементтерде зиянды бағдарлама бар екенін анықтады:</translation>
<translation id="5889361821821684993">Браузеріңізде ең қауіпсіз параметрлер бар екеніне көз жеткізу үшін Chromium жүйелі түрде тексереді. Пікіріңіз керек болса, сізге хабар жібереміз.</translation>
<translation id="5895138241574237353">Қайта іске қосу</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> – Желіге кіру</translation>
<translation id="5924017743176219022">Интернетке қосылып жатыр…</translation>
<translation id="719484593754925816">Ecosia браузерді пайдалану мүмкіндігін жақсарту және ресурстарды босату үшін бұл қойындыны әрекетсіз қыла алады.</translation>
<translation id="5941711191222866238">Жию</translation>
<translation id="5972142260211327093">Chromium сізді белсенді сынақ нұсқасына кездейсоқ орналастырса, браузерді қолдану тарихы төменде берілгендей көретін жарнамалар мен қызығушылықтарға әсер етеді. Құпиялығыңызды сақтау үшін Chromium қызығушылықтарды ай сайын жойып отырады. Қызығушылықтарды өшірмесеңіз, олар жаңартыла береді.</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{Ecosia 1 минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады.}other{Ecosia # минут бойы пайдаланылмаса, ұйымыңыз оны автоматты түрде жабады.}}</translation>
<translation id="5704599732514791330">Ecosia браузерін жаңартып, синхрондауды бастаңыз</translation>
<translation id="5988505247484123880">Әдетте кіретін сайттарыңыз тәжірибені жекелендіру үшін сізді қызықтыратын нәрселерді есте сақтайды. Сондай-ақ сайттар Chromium браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады.</translation>
<translation id="6003112304606738118">Жүктеп алынып жатыр… <ph name="HOURS"/> сағат қалды.</translation>
<translation id="8347473600923066837">Жоғарғы оң жақтағы Ecosia мәзірінен бетбелгілерді, оқу режимін және т.б. ашуға болады.</translation>
<translation id="6040143037577758943">Жабу</translation>
<translation id="6058380562449900225">Деректеріңізді қорғау үшін Chromium-ге сіз соңғы уақытта кірмеген сайттар рұқсаттарын өшіруге рұқсат беріңіз. Хабарландырулар көрсетіле береді.</translation>
<translation id="7303930050538184306">&amp;Ecosia жүйесінде ашу</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> кеңейтімі Ecosia браузеріне енгізілді</translation>
<translation id="2905159584855395810">Ecosia жылдамдығын арттырыңыз</translation>
<translation id="608006075545470555">Осы браузерге жұмыс профилін қосу</translation>
<translation id="8296565077892323223">Ecosia браузерін реттеңіз және басқарыңыз. Жаңартылған нұсқа қолжетімді.</translation>
<translation id="6102072151902574948">Қосулы болғанда, Chromium браузері бірқалыпты айналдыру және бейненің кадр жиілігі сияқты фондық әрекеттерді және визуалдық әсерлерді шектеу арқылы батарея қуатын сақтайды.</translation>
<translation id="8419312540998601274">Қосулы • Ecosia бұл кеңейтімнің қайдан келгенін анықтай алмайды.</translation>
<translation id="6419542773162312746">Кеңейтімге Ecosia құралдар тақтасында сайтқа кіру сұрауларын көрсетуге рұқсат беру</translation>
<translation id="4021894801595982809">Ecosia бұл құпия сөзді Ecosia аккаунтыңызда сақтайды. Оны есте сақтаудың қажеті жоқ.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> қауіпті болғандықтан, Ecosia оны бөгеді.</translation>
<translation id="2446603005062458629">Ecosia жақын арада жабылып, деректерді жояды</translation>
<translation id="6134968993075716475">"Қауіпсіз шолу" функциясы өшірулі. Chromium браузері оны қосуды ұсынады.</translation>
<translation id="4032832945953542360">Осы жерде Ecosia профильдерін ауыстыра аласыз.</translation>
<translation id="615103374448673771">Егер cookie файлдарына рұқсат берсеңіз, Chromium оларды алдын ала жүктеу кезінде пайдалануы мүмкін.</translation>
<translation id="5032126307005935789">Бұл файл қауіпті болуы мүмкін.<ph name="LINE_BREAK"/>Құпия сөзді көрсетсеңіз, Ecosia бұл жүктеп алу әрекетін тексере алады. Файл туралы ақпарат Ecosia Safe Browsing қызметіне жіберіледі, бірақ файл контенті мен құпия сөз құрылғыңызда қалады.</translation>
<translation id="6182736845697986886">Орнатылмады, себебі жаңарту серверінде ішкі қате пайда болды.</translation>
<translation id="2346323077583431428"><ph name="TARGET_DEVICE_NAME"/> құрылғысындағы Ecosia браузеріне кіргеніңізді тексеріп, қайта жіберіп көріңіз.</translation>
<translation id="2995860351618948435">Бұл компьютерде жаңа Ecosia нұсқасы бұрыннан бар. Бағдарламалық жасақтама жұмыс істемесе, Ecosia жойып, әрекетті қайталап көріңіз.</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia браузері қазір қайта іске қосылады}=1{Ecosia браузері 1 секундтан кейін қайта іске қосылады}other{Ecosia браузері # секундтан кейін қайта іске қосылады}}</translation>
<translation id="1809194740315140401">Ecosia файлдарды жүктеп алу үшін жадты пайдалануға рұқсат сұрайды.</translation>
<translation id="6245734527075554892">URL мекенжайларын Chromium браузерінде сақталған қауіпсіз емес сайттар тізімімен салыстырып тексереді.</translation>
<translation id="4662363689050405237">Әдепкі браузер ретінде Ecosia орнату</translation>
<translation id="6266342355635466082">Chromium жаңа нұсқалардың бар-жоғын тексере алмайды. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="6268381023930128611">Chromium жүйесінен шығасыз ба?</translation>
<translation id="4618410489751241263">Бұл қойындылар тым көп ресурстар қолданып жатыр. Өнімділікті жақсарту үшін Ecosia-ге оларды әрекетсіз қылуға рұқсат беріңіз.</translation>
<translation id="6416551953415159186">Ecosia профилін реттеу</translation>
<translation id="6290827346642914212">Chromium профиліне ат қойыңыз</translation>
<translation id="4882579364090762302">Кеңейтімді қолдану үшін Ecosia-ге кіруіңіз керек</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/> қауіпті болуы мүмкін болғандықтан, Ecosia оны бөгеді.</translation>
<translation id="4943938785458240142">Ecosia камераңызды пайдалануда.</translation>
<translation id="6327105987658262776">Ешқандай жаңарту жоқ.</translation>
<translation id="6450895420388847775">Ecosia браузерінде басқа операция орындалуда. Әрекетті кейінірек қайталаңыз.</translation>
<translation id="464306605599005355">Енді Ecosia қолданбасын Ecosia аккаунтымен және ортақ компьютерлерде пайдалану жеңілірек.</translation>
<translation id="6735145163744656874">Ecosia браузерді пайдалану мүмкіндігін жақсарту және тапсырмалардың орындалуын жылдамдату үшін бұл қойындыларды әрекетсіз қыла алады.</translation>
<translation id="1284343625991453987">Ecosia пернелер тіркесімі</translation>
<translation id="7051119589302096163">Ecosia жүктеп алуды блоктады, себебі бұл файл әдетте жүктеп алынбайды және ол қауіпті болуы мүмкін.</translation>
<translation id="7908111389403807005">Ecosia жою қажет пе?</translation>
<translation id="6375219077595103062">Password Manager таңбашасын қосу</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>Бұл дерек қалай пайдаланылады:<ph name="END_BOLD"/> Ecosia қызығушылықтарыңызды болжайды. Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Ecosia браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады.</translation>
<translation id="7578952608547569314">Компьютер экранындағы Ecosia логотипі.</translation>
<translation id="3939060118711873999">Ecosia — веб-беттер мен қолданбаларды өте жылдам ашатын веб-браузер. Ол жылдам, тұрақты және пайдалануға оңай. Ecosia жүйесіне ендірілген зиянды бағдарлама және фишинг қорғанысымен интернетті уайымсыз пайдалана беруіңізге болады.</translation>
<translation id="5404489723475681578">EcosiaOS жүйесін өшіріп қосу</translation>
<translation id="6443470774889161065">Chromium сіз кіруіңіз мүмкін көбірек бетті алдын ала жүктейді, сонда оларға кірген кезіңізде, тезірек жүктеледі.</translation>
<translation id="7877883466657693294">Өшірулі • Ecosia бұл кеңейтімнің қайдан келгенін анықтай алмайды.</translation>
<translation id="4410570812343670816">Ecosia профильдеріне қош келдіңіз!</translation>
<translation id="4371259280767924562">Аккаунтты Ecosia-нен өшіру</translation>
<translation id="524314285625975879">Сонымен қатар Ecosia іске қосылғанда қайсы бет көрсетілуін бақылайды.</translation>
<translation id="648319183876919572">Күшейтілген Safe Browsing-нің қауіпті веб-сайттар мен файлдардан қорғау қабілеті жоғарырақ.</translation>
<translation id="6496553866814956056">Ecosia жою</translation>
<translation id="788366290112401490">Перне тіркесімдері Ecosia-нен ашылады.</translation>
<translation id="1773882594264682232">Аккаунтқа кірсеңіз, Ecosia-нен Ecosia аккаунтыңыздағы құпия сөздер мен т.б. ақпаратты пайдалана аласыз. Мұны кез келген уақытта "Параметрлер" бөлімінде өзгерте аласыз.</translation>
<translation id="2280934980919215876">Ұйымыңыз Ecosia-ді <ph name="TIMEOUT_DURATION"/> бойы пайдаланбаған кезде жабады. Браузерді пайдалану деректері жойылды. Оларға тарих, автотолтыру мәліметтері және жүктеп алынғандар кіруі мүмкін.</translation>
<translation id="8608092457636055141">Әр профильде бетбелгілер, тарих, құпия сөздер және тағы басқа Ecosia ақпараты бар.</translation>
<translation id="6563921047760808519"><ph name="BEGIN_LINK"/>Chromium-нің деректеріңізді құпия сақтау жолы<ph name="END_LINK"/> туралы толық ақпарат</translation>
<translation id="3592624492063123732">Басқа Ecosia профиліндегі құпия сөздерді көру үшін ауысуға болады</translation>
<translation id="6570579332384693436">Емле қателерін түзету үшін Chromium браузері мәтін жолына терілген сөздерді Google-ға жібереді</translation>
<translation id="6533266716128249922">Ecosia хабарландыру параметрлері бөліміне өту</translation>
<translation id="1722634673917783018">Өзгертулеріңіз Ecosia келесі рет қайта іске қосылғанда күшіне енеді.</translation>
<translation id="2537426042760364251">Ecosia айналаңыздың 3D картасын жасау үшін камераны пайдалануға рұқсат сұрайды.</translation>
<translation id="6663852025006259149">Сайттар сіз күткендей жұмыс істеуі мүмкін, бірақ сіз Chromium-нің барлық терезесін жапқаннан кейін сізді есте сақтамайды</translation>
<translation id="6669284030132180248">Бетбелгілерді Google аккаунтыңызда да сақтасаңыз, Chromium-дe өнім бағаларын бақылап, баға төмендеген кезде, хабарландыру аласыз.</translation>
<translation id="6676384891291319759">Интернетке кіру</translation>
<translation id="8067423333018528301">Кіру кезіндегі қате себебінен EcosiaOS деректеріңізді синхрондай алмады.</translation>
<translation id="6692797197837897398">Chromium қандай жарнама көрсетілетінін басқаруыңызға мүмкіндік береді және қандай сайттар жекелендірілген жарнамалар көрсеткен кезде, сізден ақпарат алатынын шектейді.</translation>
<translation id="2173571365716863400">Ecosia бұл сайт үшін микрофонды пайдалануға рұқсат сұрайды.</translation>
<translation id="6712881677154121168">Жүктеп алу қатесі: <ph name="DOWNLOAD_ERROR"/>.</translation>
<translation id="6648664289472946060">Профиліңізді пайдалану мүмкін емес, себебі ол жаңарақ Ecosia нұсқасынан.

Кейбір мүмкіндіктер қолжетімсіз болуы мүмкін. Басқа профиль каталогін көрсетіңіз немесе жаңарақ Ecosia нұсқасын пайдаланыңыз.</translation>
<translation id="6729124504294600478">Жекелендіру мен басқа функцияларды алу үшін Chromium-ді интернет пен қолданбаларды пайдалану тарихы мен байланысқан Google қызметтеріне қосыңыз.</translation>
<translation id="4870057811531036437">Ecosia компьютердегі барлық пайдаланушылар үшін әлдеқашан орнатылған.</translation>
<translation id="4512092435423703529">Ecosia функцияларын кез келген құрылғыдан пайдаланғыңыз келсе, аккаунтыңызға кіріңіз, содан кейін синхрондау функциясын қосыңыз.</translation>
<translation id="674245979920622322">Жақында кірмедіңіз. Chromium <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> рұқсаттарын және тағы <ph name="COUNT"/> рұқсатты өшірді.</translation>
<translation id="7972668220031382654">Ecosia бұл файлды сканерлеуді ұсынады, себебі ол қауіпті болуы мүмкін.</translation>
<translation id="2441303983090031276">EcosiaOS қосымша <ph name="BEGIN_LINK_CROS_OSS"/>ашық кодты бағдарламалық құрал<ph name="END_LINK_CROS_OSS"/> арқылы қолжетімді болады.</translation>
<translation id="1263466865695943046">Құпия сөздеріңіз ұрланған жағдайда, Ecosia бұл туралы хабарлайды.</translation>
<translation id="684888714667046800">Интернетке қосылу мүмкін емес. Брандмауэр пайдалансаңыз, <ph name="PRODUCT_EXE_NAME"/> өнімінің рұқсат тізімінде екеніне көз жеткізіңіз.</translation>
<translation id="4600924482853773728">Ecosia – <ph name="PAGE_TITLE"/></translation>
<translation id="1490060441084292633">Ecosia "<ph name="EXTENSION_NAME"/>" кеңейтімінде зиянды бағдарлама бар екенін анықтады.</translation>
<translation id="6929417474050522668">Сынақ нұсқалары қосылғанда, жарнама өлшеу функциясы сіз кіретін сайттарға өз жарнамаларының өнімділігін өлшеуге көмектесетін ақпаратты Chromium браузерінен сұратуға мүмкіндік береді. Сайттар бір-біріне барынша аз ақпарат жіберетіндіктен, сайтаралық бақылау шектеледі.</translation>
<translation id="6940431691900807093">Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Chromium браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады. Chromium браузері 3 қызығушылыққа дейін бөлісуі мүмкін.</translation>
<translation id="8283315171506895091">Сілтемені Ecosia инкогнито терезесінде ашу</translation>
<translation id="6978145336957848883">Құпия сөзіңіз оңай болса, оны табу да оңай. Chromium браузеріне <ph name="BEGIN_LINK"/>күрделі құпия сөздер жасауға және сақтауға<ph name="END_LINK"/> мүмкіндік беріңіз.</translation>
<translation id="6981396265751285733">Қосулы болса, Chromium белсенді емес қойындылардағы жадты босатады. Мұның нәтижесінде белсенді қойындылар мен басқа қолданбаларға қосымша компьютер ресурстары үлестіріліп, Chromium жылдам жұмыс істейді. Белсенді емес қойындыларды ашқанда, олар автоматты түрде қайтадан белсенді болады.</translation>
<translation id="2149148292984034533">EcosiaOS шарттары</translation>
<translation id="1831192335802727557">Ecosia браузеріне бұл сайтта микрофонды пайдалану үшін рұқсат керек</translation>
<translation id="7011190694940573312">Орнатылмады, себебі операциялық жүйенің бұл нұсқасына қолдау көрсетілмейді.</translation>
<translation id="7024536598735240744">Пакеттен шығару қатесі: <ph name="UNPACK_ERROR"/>.</translation>
<translation id="7025789849649390912">Орнату тоқтап қалды.</translation>
<translation id="762525592078244189">Ecosia браузерін өз талғамыңызға сай реттеңіз</translation>
<translation id="5598074261782651109">Ecosia жаңарту</translation>
<translation id="2838372953389311551">Егер суреттің пайдалы сипаттамасы болмаса, Ecosia оны өзі ұсынып көреді. Сипаттамалар жасау үшін суреттер Ecosia-ға жіберіледі.</translation>
<translation id="550507036977517224">Ecosia for Testing қызметін бейімдеу</translation>
<translation id="9091453616111683919">Ecosia-нен <ph name="EXTENSION_NAME"/> кеңейтімін жою</translation>
<translation id="5137471865755621561">Ұйымыңыз Ecosia деректерін <ph name="TIMEOUT_DURATION"/> бойы пайдаланбаған кезде жояды. Оларға тарих, автотолтыру мәліметтері және жүктеп алынғандар кіруі мүмкін.</translation>
<translation id="219546601381787154">Ecosia бұл сайт үшін камераны пайдалануға рұқсат сұрайды.</translation>
<translation id="2542649989941327712">Ecosia браузері қосылмады. Қайталап көріңіз.</translation>
<translation id="7197677400338048821">Chromium сіздің құпия сөздеріңізді тексере алмай жатыр. 24 сағаттан кейін қайталап көріңіз.</translation>
<translation id="3784023996375784431">Хабарларда, құжаттарда және басқа қолданбаларда сілтемелерді басып, Ecosia браузерін кез келген уақытта пайдаланыңыз.</translation>
<translation id="7311066525704006840">Тапсырмалар реттегіші – Ecosia</translation>
<translation id="3816260943154642689">Ecosia болжамымен анықталған қызығушылықтарыңыз</translation>
<translation id="1720431815870023289">{NUM_EXTENSIONS,plural, =1{Ecosia мұны өшіруге кеңес береді.}other{Ecosia бұларды өшіруге кеңес береді.}}</translation>
<translation id="7309928523159922338">Жарнама өлшеу функциясы сіз кіретін сайттарға өз жарнамаларының өнімділігін өлшеуге көмектесетін ақпаратты Chromium браузерінен сұратуға мүмкіндік береді. Сайттар бір-біріне барынша аз ақпарат жіберетіндіктен, сайтаралық бақылау шектеледі.</translation>
<translation id="731795002583552498">Chromium браузерін жаңарту</translation>
<translation id="6673288084648462613">Реттеулер файлы бұзылған немесе жарамсыз.

Ecosia параметрлеріңізді қалпына келтіре алмайды.</translation>
<translation id="7339898014177206373">Жаңа терезе</translation>
<translation id="4960252760049500399">Мұнда веб-беттер, бетбелгілер және басқа Ecosia материалдары тұрады.</translation>
<translation id="7158975242722498086">Жүйе әкімшісі Ecosia браузерін <ph name="TARGET_URL_HOSTNAME"/> бетіне кіргенде <ph name="ALTERNATIVE_BROWSER_NAME"/> браузері ашылатын етіп конфигурациялады.</translation>
<translation id="6632508343667825745">Ecosia бұл файлды жүктеп алуға тыйым салды, себебі ол жеке және әлеуметтік желі аккаунттарыңызға (соның ішінде <ph name="USER_EMAIL"/> поштаңызға) қауіп төндіруі мүмкін</translation>
<translation id="6180968682827452331">Бұл кеңейтімге енді қолдау көрсетілмейді. Ecosia оны өшіруге кеңес береді.</translation>
<translation id="5622136942112821750">Ecosia профильдері арқылы Ecosia-дегі барлық материалыңызды бөле аласыз. Осылайша оларды жұмыс немесе көңіл көтеру топтарына оңай іріктеуге болады.</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia әзірлеуші нұсқасы</translation>
<translation id="5055330219314726197">Ecosia браузеріне бұл сайтта камераны пайдалану үшін рұқсат керек</translation>
<translation id="7458892263350425044">Микрофонды пайдалану үшін <ph name="BEGIN_LINK"/>жүйе параметрлерінде<ph name="END_LINK"/> Chromium-ге рұқсат беріңіз.</translation>
<translation id="1975037445584526511">Ecosia-нің жаңа нұсқаларын алып тұру үшін Windows 10 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде Windows 7 нұсқасы орнатылған.</translation>
<translation id="7467949745582939695">Chromium қайта іске қосылсын ба?</translation>
<translation id="80155189677487610">Ашылып тұрғанмен бірдей Ecosia нұсқасын орнату мүмкін емес. Ecosia қолданбасын жауып, әрекетті қайталаңыз.</translation>
<translation id="751935028865900641">Сайттар ойдағыдай жұмыс істеуі керек. Chromium-де аккаунтқа кірген болсаңыз, барлық Chromium терезесін жапқан кезде, Google аккаунтын қоспағанда, сайттардың көпшілігінен шығарыласыз.</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia браузері 1 минуттан кейін қайта іске қосылады}other{Ecosia браузері # минуттан кейін қайта іске қосылады}}</translation>
<translation id="8228132389897276908">Терезені бөлісу үшін жүйе параметрлерінде Ecosia-ге экран жазуға рұқсат беріңіз.</translation>
<translation id="7582945390259497898">Chromium браузері қызығушылықтарыңызды болжай алады. Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Chromium браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады.</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME"/> орнату құралы</translation>
<translation id="7585391435984513350">Жақында кірмедіңіз. Chromium <ph name="PERMISSION"/> рұқсатын өшірді.</translation>
<translation id="4061472199368124600">Ecosia камераңыз бен микрофоныңызды пайдалануда.</translation>
<translation id="170259281605734125">Ecosia жақсара түсті</translation>
<translation id="7649070708921625228">Анықтама</translation>
<translation id="675365189802108507">Бұл функциялар туралы қосымша ақпарат Ecosia параметрлерінде берілген.</translation>
<translation id="1508200558303644420">Ecosia әдепкі браузеріңіз емес</translation>
<translation id="7174674455569790401">Ecosia браузерін барлық құрылғыларда синхрондап, параметрлерін жекелендіріңіз</translation>
<translation id="7699779824407626136">Chromium жаңарту</translation>
<translation id="7745317241717453663">Шолу деректері бұл құрылғыдан жойылады. Деректерді кейінірек алу үшін Chromium жүйесіне <ph name="USER_EMAIL"/> болып кіріңіз.</translation>
<translation id="7747138024166251722">Орнату құралы уақытша каталогті жасай алмады. Дисктегі бос орынды және бағдарламалық жасақтама рұқсатын тексеріңіз.</translation>
<translation id="6161025257729272170">Ecosia жылдамдығын арттырыңыз</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia Canary</translation>
<translation id="7803986347287457849">Интернет трафигіңізді пайдалана алатын адамдар қандай сайттарға кіретініңізді көрмейтіндей етіңіз. Chromium браузері DNS жүйесіндегі сайттың IP мекенжайын іздеу үшін қауіпсіз байланысты пайдаланады.</translation>
<translation id="8301840715671593762">Осы құрылғыда бұл аккаунтқа Ecosia профилі тіркеліп қойған.</translation>
<translation id="7845233973568007926">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME"/> пайдаланбас бұрын компьютерді өшіріп қосуыңыз керек.</translation>
<translation id="7859018312476869945">Мекенжай жолағында немесе іздеу өрісінде терген кезде, Chromium браузері жақсырақ ұсыныстар алу үшін тергеніңізді әдепкі іздеу жүйесіне жібереді. Бұл Инкогнито режимінде өшірілген.</translation>
<translation id="3268039966078382323">Ecosia браузерінің ең соңғы нұсқасы орнатылмады, сондықтан жаңа мүмкіндіктер мен қауіпсіздікке қатысты түзетілген функцияларды пайдалана алмайсыз.</translation>
<translation id="7872446069773932638">Жүктеп алынып жатыр… <ph name="SECONDS"/> секунд қалды.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Дерек қалай басқарылады:<ph name="END_BOLD"/> құпиялығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Бұл ретте Ecosia-ның ескергенін қаламаған қызығушылықтарды өшіруге болады.</translation>
<translation id="4638085384909702681">Ecosia-ді әдепкі браузер етіп орнату</translation>
<translation id="7934340546140346950">Мүмкін болса, Chromium қауіпті байланыстарды HTTPS кеңейтіміне автоматты түрде жаңартады.</translation>
<translation id="2412381038247037703">Ecosia жүйесіне <ph name="USER_EMAIL_ADDRESS"/> ретінде кірдіңіз. Қайта кіру үшін бірдей аккаунтты пайдаланыңыз.</translation>
<translation id="7975919845073681630">Бұл – Chromium браузерінің қайта орнатылған нұсқасы және әдепкі браузер бола алмайды.</translation>
<translation id="851583113375911087">Белгісіз дереккөздерден алынған кеңейтім, қолданба, тақырыптар құрылғыңызға зиянын тигізуі мүмкін. Ecosia оларды тек <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> дүкенінен орнатуды ұсынады.</translation>
<translation id="488806616089631539">Ecosia браузерінің кіру рұқсаты болса, веб-сайттар сізден кіру рұқсатын сұрайды.</translation>
<translation id="80471789339884597">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME"/> пайдаланбас бұрын барлық браузерді жауып, қайта ашуыңыз керек.</translation>
<translation id="8086881907087796310">Орнатылмады, себебі компьютер минималды жабдық талаптарына жауап бермейді.</translation>
<translation id="1528748166720431933"><ph name="PAGE_TITLE"/> – Ecosia for Testing</translation>
<translation id="5661123757512626239">Ecosia бұл сайт үшін локацияны пайдалануға рұқсат сұрайды.</translation>
<translation id="143614250230771428">EcosiaOS деректеріңізді синхрондай алмады, себебі синхрондау функциясы доменіңіз үшін қолжетімді емес.</translation>
<translation id="813913629614996137">Дайындауда…</translation>
<translation id="588828970866589779">Ecosia-нің JavaScript және WebAssembly жүйелерінде қосымша қорғанысты қосу</translation>
<translation id="6491651957026506753">Бұл файл қауіпті болғандықтан, Ecosia оны бөгеді.</translation>
<translation id="8223363452568144035">Камераны пайдалану үшін <ph name="BEGIN_LINK"/>жүйе параметрлерінде<ph name="END_LINK"/> Chromium-ге рұқсат беріңіз.</translation>
<translation id="7433581196371819898">Ecosia бұл кеңейтімнің қайдан келгенін анықтай алмайды. Ол қауіпті болуы мүмкін. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Ecosia-нан жойыңыз.</translation>
<translation id="2046160555506209000">Егер суреттің пайдалы сипаттамасы болмаса, Ecosia оны өзі ұсынып көреді. Сипаттамалар жасау үшін суреттер Ecosia-ға жіберіледі. Бұл функцияны кез келген уақытта параметрлерден өшіріп қоюға болады.</translation>
<translation id="3260765223735049374">Ecosia-ге жаңа профильмен кіру қажет пе?</translation>
<translation id="8266560134891435528">Аккаунтқа кірмегендіктен, Chromium сіздің құпия сөздеріңізді тексере алмайды.</translation>
<translation id="8286943863733751221"><ph name="BEGIN_LINK"/>Chromium сізге<ph name="END_LINK"/> қауіпті сайттар мен жүктеп алу әрекеттері туралы ескертеді</translation>
<translation id="5994043198751001258">Ұйымыңыз Ecosia-ді <ph name="TIMEOUT_DURATION"/> бойы пайдаланбаған кезде жабады.</translation>
<translation id="8330519371938183845">Chromium браузерін барлық құрылғыларда синхрондап, параметрлерін жекелендіру үшін аккаунтыңызға кіріңіз</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> бұрын Ecosia браузерін пайдаланған</translation>
<translation id="4337034173783952373">Ecosia браузерінің материалдарын барлық құрылғыда пайдалану үшін аккаунтқа кіріп, синхрондау параметрін қосыңыз.</translation>
<translation id="8655983536493871574">Ecosia-нің жаңа нұсқаларын алып тұру үшін Windows 10 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде Windows 8 нұсқасы орнатылған.</translation>
<translation id="8355171755788522183">Copyright <ph name="YEAR"/> Ecosia. Барлық құқықтары қорғалған.</translation>
<translation id="4395802781633621239">Құпия сөздер мен басқа ақпаратты барлық құрылғыдан алу үшін Ecosia аккаунтына кіріңіз. Аккаунтқа кіргеннен кейін, бұл құпия сөз Ecosia аккаунтыңызға сақталады.</translation>
<translation id="8268239447047453615">Содан кейін Ecosia-ді өшіріп қосуыңыз қажет.</translation>
<translation id="5167067155585861308">Ecosia оны өшіруге кеңес береді. <ph name="BEGIN_LINK"/>Қолдау көрсетілетін кеңейтімдер туралы толық ақпарат алыңыз.<ph name="END_LINK"/></translation>
<translation id="8863497461138396324">Бұл кеңейтімді әзірлеушісі жариялаудан бас тартқан, сондықтан ол қауіпті болуы мүмкін. Сіз кірген сайттардағы деректеріңізді, оның ішінде жеке ақпаратыңызды бұдан былай көрмеуі және өзгерте алмауы үшін, оны Ecosia-нан жойыңыз.</translation>
<translation id="6826163993811146231">{0,plural, =1{Ecosia браузерін бір күннің ішінде қайта іске қосыңыз}other{Ecosia браузерін # күннің ішінде қайта іске қосыңыз}}</translation>
<translation id="4033006861724039519">Орнатқыш мұрағаты бүлінген немесе жарамсыз. Ecosia қайтадан жүктеңіз.</translation>
<translation id="2829233304432701500">Ecosia браузері Windows 10 жүйесін не одан кейінгі нұсқасын қажет етеді.</translation>
<translation id="8975930032513941502">Міндетті емес: диагностика және пайдалану туралы деректі Ecosia-ға автоматты түрде жіберу арқылы EcosiaOS функциялары мен жұмыс өнімділігін жақсартуға көмектесіңіз.</translation>
<translation id="2695952268686253864">Ecosia ескірген</translation>
<translation id="8522801943730206384">Құпия сөздер сақталған кезде, Chromium оларды тексере алады.</translation>
<translation id="8550334526674375523">Бұл жұмыс профилі жеке профиліңізден толық ажыратылған.</translation>
<translation id="8555465886620020932">Қызмет қатесі: <ph name="SERVICE_ERROR"/>.</translation>
<translation id="8568283329061645092">Google аккаунтыңызбен кіргенде, Chromium сіздің құпия сөздеріңізді тексере алады.</translation>
<translation id="4817309082638621362">Ecosia-ді бірнеше ұйым басқарады</translation>
<translation id="7129808598331559748">Copyright <ph name="YEAR"/> The Ecosia Authors. Барлық құқықтар қорғалған.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>Бұл дерек қалай пайдаланылады:<ph name="END_BOLD"/> сайттар Ecosia браузерінде қызығушылықтарыңыз туралы ақпаратты сақтай алады. Мысалы, марафонға аяқ киім сатып алу үшін сайтқа кірсеңіз, сайт қызығушылығыңызды марафон жүгіру деп анықтауы мүмкін. Кейін жүгіру жарысына тіркелу үшін басқа сайтқа кірсеңіз, сол сайт қызығушылықтарыңыз негізінде кроссовка жарнамасын көрсетуі мүмкін.</translation>
<translation id="8109744984354428711">Ecosia іске қосылуда…</translation>
<translation id="2402290209407843024">Орнату анықталмаған қате себебінен сәтсіз аяқталды. Ecosia браузерін қайта жүктеңіз.</translation>
<translation id="8648201657708811153">Google Chrome for Testing браузерін әдепкі браузер қылу мүмкін емес.</translation>
<translation id="6665128960039431910">Сонымен қатар ол Ecosia іске қосқаныңызда немесе Omnibox ішінен іздегеніңізде қайсы бет көрсетілетінін бақылайды.</translation>
<translation id="2000339487270823788">Сізге арналған Ecosia.</translation>
<translation id="7045045549868370797">Ecosia-ге кіру қажет пе?</translation>
<translation id="878572486461146056">Орнату қатесі: желі әкімшісі орнатуға рұқсат бермейтін топтық саясатты қолданды: <ph name="INSTALL_ERROR"/></translation>
<translation id="7273750863406285983">Ecosia браузеріне бұл сайтта камераны және микрофонды пайдалану үшін рұқсат керек</translation>
<translation id="1485302026917450654">Ecosia-ге кіру қажет пе?</translation>
<translation id="8826492472752484139">"Password Manager" түймесін басыңыз.</translation>
<translation id="5267683457871579197">EcosiaOS жүйесі</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>Қандай дерек пайдаланылады:<ph name="END_BOLD"/> браузерді қолдану тарихы, осы құрылғыда Ecosia көмегімен кірген сайттардың жазбасы.</translation>
<translation id="8862326446509486874">Жүйе деңгейінде орнату үшін тиісті құқықтарыңыз жоқ. Әкімші ретінде орнату құралын қайта іске қосып көріңіз.</translation>
<translation id="8880203542552872219">Егер өзгертсеңіз, Chromium браузерінде сақталған құпия сөзді де жаңасына өзгертіңіз.</translation>
<translation id="3966234175958887595">Ecosia құпия сөздерді көрсетуге әрекет етуде. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="8931379085695076764">Chromium қызығушылықтарыңызды соңғы бірнеше аптадағы браузерді қолдану тарихы негізінде болжайды. Бұл ақпарат құрылғыңызда қалады.</translation>
<translation id="6346154190168496057">Ecosia браузерін жаңарту мүмкін емес</translation>
<translation id="93440396576488794">Ecosia Enterprise логотипі</translation>
<translation id="8986207147630327271">Браузерге жұмыс профилін қосудасыз және әкімшіңізге жұмыс профилін басқаруды тапсырудасыз.</translation>
<translation id="2985399486579137606">Ecosia профильдерін басқару</translation>
<translation id="1597547208646178091">Ecosia браузерін қауіпсіз ету үшін, <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> тізімінде жоқ келесі кеңейтім өшірілді, ол сізге ескертілмей қосылған болуы мүмкін.</translation>
<translation id="2388751143175762498">Ecosia жүйесіне кіру</translation>
<translation id="231621248561775155">Ecosia бұл мұрағаттау файлын жүктеп алуға тыйым салды, себебі онда зиянды бағдарламаны жасыруы мүмкін басқа файлдар бар</translation>
<translation id="9062666675513499497">Басқа Google қызметтеріне кірген кезде, Chromium-ге де кіресіз</translation>
<translation id="5312730628132049495">Ecosia-ге кіріңіз. Аккаунтқа тек бір рет кіргіңіз келсе, <ph name="GUEST_LINK_BEGIN"/>құрылғыны қонақ ретінде пайдалануға<ph name="GUEST_LINK_END"/> болады</translation>
<translation id="5061261337583604526">Ecosia автоматты түрде жабылған</translation>
<translation id="7268098999602465369">Ecosia ескірген</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia браузері бір сағаттан кейін қайта іске қосылады}other{Ecosia браузері # сағаттан кейін қайта іске қосылады}}</translation>
<translation id="8963533629322868062">Ecosia-нің жаңа нұсқаларын алып тұру үшін Windows 10 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде Windows 8.1 нұсқасы орнатылған.</translation>
<translation id="7774247008790177839">Сілтемені жаңа Ecosia қойындысында ашу</translation>
<translation id="911206726377975832">Сонымен қатар шолу деректеріңізді жоясыз ба?</translation>
<translation id="7580831958727159171">Сынақ мерзімі кезінде сайттардың жарнама көрсетуге пайдаланған қызық тақырыптарын көре және өшіре аласыз. Ecosia браузерді қолданудың соңғы тарихына сүйене отырып, сізге қызық болар деген тақырыптарды болжайды.</translation>
<translation id="8901409988302458368">Жүйе әкімшісі Ecosia браузерін <ph name="TARGET_URL_HOSTNAME"/> сілтемесіне қосымша браузер арқылы кіре алатындай етіп конфигурациялады.</translation>
