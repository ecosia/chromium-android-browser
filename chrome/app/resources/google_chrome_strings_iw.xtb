<translation id="4154538917942874814">‏כלל נכנס עבור Ecosia על מנת לאפשר תנועת mDNS.</translation>
<translation id="8542320769345885402">‏מנהל הסיסמאות של Ecosia</translation>
<translation id="6273793429163604305">למקומות…</translation>
<translation id="675229436434399924">‏אפליקציות לגרסת הפיתוח של Ecosia</translation>
<translation id="4870057811531036437">‏Ecosia כבר מותקן במחשב ונגיש לכל המשתמשים.</translation>
<translation id="330264384086604869">‏הסרה מ-Ecosia</translation>
<translation id="6327105987658262776">אין עדכונים זמינים.</translation>
<translation id="6412673304250309937">‏המערכת בודקת כתובות URL ששמורות ב-Chrome ומכילות רשימות של אתרים לא בטוחים. אם אתר מסוים מנסה לגנוב סיסמה או אם המערכת מזהה הורדה של קובץ מזיק, Chrome עשוי גם לשלוח כתובות URL לבדיקה באמצעות 'גלישה בטוחה'. הנתונים שנשלחים לבדיקה כוללים ביטים מהתוכן של הדף.</translation>
<translation id="4781882243268600858">‏לעבור לפרופיל Ecosia קיים?</translation>
<translation id="2537426042760364251">‏נדרשת הרשאת גישה למצלמה ב-Ecosia כדי ליצור מפה תלת-ממדית של הסביבה שלך</translation>
<translation id="3879865245128287988">‏<ph name="PAGE_TITLE"/> - Ecosia בגרסת פיתוח</translation>
<translation id="5357908757303442841">‏שמורה במנהל הסיסמאות של Ecosia במכשיר הזה</translation>
<translation id="8859253218356192164">‏השימוש ב-EcosiaOS Flex מתאפשר בזכות <ph name="BEGIN_LINK_CROS_OSS"/>תוכנת קוד פתוח<ph name="END_LINK_CROS_OSS"/> נוספת.</translation>
<translation id="6676384891291319759">גישה אל האינטרנט</translation>
<translation id="4586967042094107073">‏Ecosia יכול לפעול ברקע</translation>
<translation id="2173571365716863400">‏נדרשת הרשאת גישה למיקרופון ב-Ecosia עבור האתר הזה</translation>
<translation id="6161025257729272170">‏שיפור המהירות ב-Ecosia</translation>
<translation id="9165312115453649251">‏מערכת EcosiaOS Flex</translation>
<translation id="8685318202174822382">‏להמשיך בפרופיל Ecosia חדש?</translation>
<translation id="6750954913813541382">‏כדי לתקן שגיאות כתיב, הטקסט שהוקלד על ידך בדפדפן נשלח אל Google על ידי Chrome</translation>
<translation id="88039520238670574">‏לסגור את Ecosia בכל זאת?</translation>
<translation id="8583650869792032882">‏כלל נכנס עבור הגרסה הניסיונית של Ecosia על מנת לאפשר תנועת mDNS.</translation>
<translation id="6881299373831449287">‏מתבצע עדכון של Chrome</translation>
<translation id="6800892712521842441">‏אפליקציות לגרסת הבטא של Ecosia</translation>
<translation id="5267683457871579197">‏מערכת EcosiaOS</translation>
<translation id="8963533629322868062">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.1.</translation>
<translation id="2128110540135015661">‏נתוני הגלישה של האדם הזה יימחקו מהמכשיר. כדי לשחזר את הנתונים, יש להיכנס ל-Ecosia בתור<ph name="USER_EMAIL"/>.</translation>
<translation id="2434044214904689670">‏כלל נכנס לגרסת הבטא של Ecosia כדי לאפשר תנועת mDNS.</translation>
<translation id="7482156490649194631">‏Ecosia עודכן, אך לא השתמשת בו לפחות 30 ימים.</translation>
<translation id="7025789849649390912">ההתקנה נעצרה.</translation>
<translation id="4032832945953542360">‏כאן ניתן לעבור בין פרופילים של Ecosia</translation>
<translation id="931416298178634530">‏אם ברצונך להשתמש בחשבון הזה באופן חד-פעמי, אפשר להשתמש <ph name="GUEST_LINK_BEGIN"/>במצב אורח<ph name="GUEST_LINK_END"/> בדפדפן Ecosia. כדי להוסיף חשבון של מישהו אחר, <ph name="LINK_BEGIN"/>יש להוסיף משתמש חדש<ph name="LINK_END"/> אל <ph name="DEVICE_TYPE"/>.

יכול להיות שהרשאות שכבר נתת לאתרים ולאפליקציות יחולו על החשבון הזה. יש לך גם אפשרות לנהל את חשבונות Ecosia <ph name="SETTINGS_LINK_BEGIN"/>בהגדרות<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="4281355161119203663">‏אחד מההורים השבית ב-Ecosia את ההגדרה "הרשאות לאתרים, אפליקציות ותוספים". לא ניתן להוסיף את ה<ph name="EXTENSION_TYPE_PARAMETER"/>.</translation>
<translation id="7085332316435785646">‏בוחרים אם לכלול את ההיסטוריה ב-Chrome להתאמה אישית מדויקת יותר בשירותי Google</translation>
<translation id="7088681679121566888">‏Chrome מעודכן</translation>
<translation id="1318059253725731825">‏Ecosia משתמש במיקרופון שלך.</translation>
<translation id="8933665254023068908">‏הפעלה מחדש לצורך עדכון ‎&amp;EcosiaOS</translation>
<translation id="7311066525704006840">‏מנהל המשימות - Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{‏יש עדכון חדש בשביל Ecosia והמערכת תחיל אותו ברגע שתבוצע הפעלה מחדש.}=1{‏יש עדכון חדש בשביל Ecosia והמערכת תחיל אותו ברגע שתבוצע הפעלה מחדש. החלון האנונימי לא ייפתח מחדש.}one{‏יש עדכון חדש בשביל Ecosia והמערכת תחיל אותו ברגע שתבוצע הפעלה מחדש. # החלונות האנונימיים לא ייפתחו מחדש.}two{‏יש עדכון חדש בשביל Ecosia והמערכת תחיל אותו ברגע שתבוצע הפעלה מחדש. # החלונות האנונימיים לא ייפתחו מחדש.}other{‏יש עדכון חדש בשביל Ecosia והמערכת תחיל אותו ברגע שתבוצע הפעלה מחדש. # החלונות האנונימיים לא ייפתחו מחדש.}}</translation>
<translation id="7155997830309522122">‏אם שינית את הסיסמה הזו, יש לערוך את הסיסמה השמורה ב-Chrome כך שהיא תתאים לסיסמה החדשה שלך.</translation>
<translation id="1027331268335328576">‏ברוך הבא ל-Ecosia</translation>
<translation id="675365189802108507">‏מידע נוסף לגבי התכונות האלה זמין בהגדרות של Ecosia.</translation>
<translation id="4239392394637574967">‏בחרת להיכנס לחשבון מנוהל, ויינתן למנהל המערכת שלו שליטה על הפרופיל שלך ב-Ecosia. הנתונים שלך ב-Ecosia, כגון אפליקציות, סימניות, היסטוריה, סיסמאות והגדרות אחרות ייקשרו באופן קבוע ל-<ph name="USER_NAME"/>. ניתן למחוק את הנתונים האלה באמצעות מרכז השליטה של חשבונות Ecosia, אבל לא ניתן יהיה לשייך את הנתונים האלה לחשבון אחר. <ph name="LEARN_MORE"/></translation>
<translation id="7295052994004373688">‏זו השפה שבה מוצג ממשק המשתמש של Google Chrome</translation>
<translation id="7296210096911315575">מידע חשוב על בטיחות ועל אופן השימוש</translation>
<translation id="5549921590305750618">‏Ecosia זקוק לגישה לאחסון כדי להוריד קבצים</translation>
<translation id="7339898014177206373">חלון חדש</translation>
<translation id="5337919616446681032">‏אם ברצונך להשתמש בחשבון הזה באופן חד-פעמי, אפשר להשתמש במצב אורח בדפדפן Ecosia. כדי להוסיף חשבון של מישהו אחר, <ph name="LINK_BEGIN"/>יש להוסיף משתמש חדש<ph name="LINK_END"/> אל <ph name="DEVICE_TYPE"/>.

יכול להיות שהרשאות שכבר נתת לאתרים ולאפליקציות יחולו על החשבון הזה. יש לך גם אפשרות לנהל את חשבונות Ecosia <ph name="SETTINGS_LINK_BEGIN"/>בהגדרות<ph name="SETTINGS_LINK_END"/>.</translation>
<translation id="2412381038247037703">‏התחברת ל-Ecosia כ-<ph name="USER_EMAIL_ADDRESS"/>. יש להשתמש באותו חשבון כדי להיכנס שוב.</translation>
<translation id="5669097765101132299">‏הקובץ הזה מסוכן ולכן הוא נחסם על ידי Ecosia</translation>
<translation id="3307959934543585795">‏יכול להיות ש-Ecosia לא יפעל כראוי כי הוא כבר לא נתמך בגרסה הזו של Linux</translation>
<translation id="12795904718916112">‏רוצה להשיג את רמת האבטחה הגבוהה ביותר של Ecosia?</translation>
<translation id="7486227612705979895">‏Chrome ייגש ל-Drive שלך כדי להציג הצעות בשורת כתובת האתר</translation>
<translation id="932641430818191661">‏גרסת הפיתוח של Ecosia</translation>
<translation id="7583399374488819119">מנהל ההתקנה של <ph name="COMPANY_NAME"/></translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="1027331268335328576">‏ברוך בואך אל Ecosia</translation>
<translation id="8411844745163855310">‏לפי הדרישה של <ph name="MANAGER"/>, יש לקרוא ולאשר את התנאים וההגבלות הבאים לפני השימוש במכשיר הזה. תנאים אלה לא מרחיבים, משנים או מגבילים את התנאים לשימוש ב-EcosiaOS.</translation>
<translation id="1263466865695943046">‏Ecosia מודיע לך אם הסיסמאות שלך נמצאות בסיכון</translation>
<translation id="7158975242722498086">‏לפי הגדרת מנהל המערכת, Ecosia יפתח את <ph name="ALTERNATIVE_BROWSER_NAME"/> כדי לגשת אל <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="7649070708921625228">עזרה</translation>
<translation id="93440396576488794">‏לוגו של Ecosia Enterprise</translation>
<translation id="7655455401911432608">‏היסטוריית הגלישה – תיעוד האתרים שביקרת בהם באמצעות Chrome במכשיר הזה.</translation>
<translation id="7747138024166251722">המתקין לא הצליח ליצור ספרייה זמנית. יש לבדוק את המקום הפנוי בדיסק ואת האישור להתקנת תוכנה.</translation>
<translation id="4871843754042758264">‏אפשר ללחוץ על השם שלך כדי לפתוח את Ecosia ולהתחיל לגלוש.</translation>
<translation id="2046160555506209000">‏אם אין לתמונה תיאור מועיל, Ecosia ינסה לספק לך תיאור. כדי ליצור תיאורים, התמונות נשלחות אל Ecosia. אפשר להשבית את האפשרות הזו בכל זמן דרך ההגדרות.</translation>
<translation id="8447746441670667471">‏גרסה חדשה של Ecosia זמינה כעת.</translation>
<translation id="5661123757512626239">‏נדרשת הרשאת מיקום ב-Ecosia עבור האתר הזה</translation>
<translation id="7722016758804384514">‏נראה שהפרופיל נמצא בשימוש על ידי תהליך אחר של Ecosia‏ (<ph name="PROCESS_ID"/>) במחשב אחר (<ph name="HOST_NAME"/>)‏. Ecosia נעל את הפרופיל כדי שלא ייפגם. אם ברור לך שאף תהליך אחר אינו משתמש בפרופיל זה, באפשרותך לבטל את נעילת הפרופיל ולהפעיל את Ecosia מחדש.</translation>
<translation id="1047556320128249268">‏Ecosia מנסה להעתיק את הסיסמאות. כדי לאפשר את הפעולה הזו, יש להקליד את הסיסמה שלך ל-Windows.</translation>
<translation id="4199684616787081033">‏הסרה מ-Ecosia...</translation>
<translation id="2402290209407843024">‏ההתקנה נכשלה בשל שגיאה לא מזוהה. צריך להוריד שוב את Ecosia.</translation>
<translation id="7845233973568007926">תודה שהתקנת. עליך להפעיל מחדש את המחשב לפני השימוש ב-<ph name="BUNDLE_NAME"/>.</translation>
<translation id="7872446069773932638">מתבצעת הורדה… יש עוד <ph name="SECONDS"/> שנ'</translation>
<translation id="2381210243314074423">‏ברוך בואך אל Ecosia, <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">‏כשמשתפים מחשב, חברים ובני משפחה יכולים לגלוש בנפרד ולהגדיר את Ecosia בדיוק כפי שהם רוצים.</translation>
<translation id="4727435569202742773">‏מישהו נכנס בעבר ל-Ecosia מהמחשב הזה כ-<ph name="ACCOUNT_EMAIL_LAST"/>. יש ליצור משתמש חדש ל-Ecosia כדי לשמור על הפרדת המידע שלך.</translation>
<translation id="7917876797003313048">‏יש לך אפשרות לנהל את חשבונות Google שאליהם נכנסת. כדי ליהנות מחיבור לחשבון בדפדפן Chrome, בחנות Play, ב-‏Gmail ובשירותים נוספים, עליך להיכנס עם חשבונות Google שלך. כדי להוסיף חשבון של מישהו אחר, כמו חבר/ה בקבוצה המשפחתית, יש להוסיף משתמש חדש ל-<ph name="DEVICE_TYPE"/>. <ph name="LINK_BEGIN"/>מידע נוסף<ph name="LINK_END"/></translation>
<translation id="8633885040939757689">‏Ecosia מנסה להעתיק את הסיסמאות.</translation>
<translation id="4278262067490419012">‏צריך להפעיל מחדש את EcosiaOS Flex כדי להחיל את העדכון.</translation>
<translation id="7962368738413920945">‏סביר להניח שאתרים יפעלו כצפוי, אבל ההעדפות שלך באתרים האלו יימחקו לאחר סגירת כל החלונות ב-Chrome</translation>
<translation id="5781596646235827063">‏המחשב הזה כבר לא יקבל עדכונים ל-Ecosia, מאחר שכבר אין תמיכה במערכות Windows XP ו-Windows Vista</translation>
<translation id="7783708361278795460">‏נשמרה במנהל הסיסמאות של Ecosia במכשיר הזה</translation>
<translation id="6984747211123632080">‏התקנת Ecosia מחדש</translation>
<translation id="2838372953389311551">‏אם אין לתמונה תיאור מועיל, Ecosia ינסה לספק לך תיאור. כדי ליצור תיאורים, התמונות נשלחות אל Ecosia.</translation>
<translation id="80471789339884597">תודה שהתקנת. עליך להפעיל מחדש את כל הדפדפנים לפני השימוש ב-<ph name="BUNDLE_NAME"/>.</translation>
<translation id="8275632261262434570">EcosiaOS Flex</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="7221868538334633215">‏מידע על Ecosia&amp;</translation>
<translation id="813913629614996137">מתבצע אתחול...</translation>
<translation id="4061472199368124600">‏Ecosia משתמש במצלמה ובמיקרופון שלך.</translation>
<translation id="8270775718612349140">‏אישורים שמנוהלים על ידי Chrome</translation>
<translation id="3966234175958887595">‏Ecosia מנסה להציג סיסמאות. יש להקליד את הסיסמה שלך ל-Windows כדי לאפשר זאת.</translation>
<translation id="2290912123073552463">‏אחד מההורים השבית ב-Ecosia את ההגדרה "הרשאות לאתרים, אפליקציות ותוספים". לא ניתן להפעיל את <ph name="EXTENSION_TYPE_PARAMETER"/>.</translation>
<translation id="3216284932113164802">‏אופס! Ecosia קרס. להפעיל מחדש עכשיו?</translation>
<translation id="8341646175450781745">‏כשההגדרה מופעלת, Chrome מפנה מקום בזיכרון שמוקצה לכרטיסיות לא פעילות. כך, לכרטיסיות הפעילות ולאפליקציות אחרות יש יותר משאבים מהמחשב ו-Chrome פועל מהר. כשחוזרים לכרטיסיות הלא פעילות, הן מופעלות מחדש באופן אוטומטי. אפשר <ph name="BEGIN_LINK"/>לקבל מידע נוסף<ph name="END_LINK"/> או <ph name="BEGIN_LINK_2"/>לשלוח משוב<ph name="END_LINK_2"/></translation>
<translation id="6491651957026506753">‏Ecosia‏ חסם את הקובץ הזה כי הוא מסוכן.</translation>
<translation id="1851101453239911251">‏<ph name="BEGIN_BOLD"/>איך אנחנו משתמשים בנתונים האלה:<ph name="END_BOLD"/> אתרים יכולים לשמור מידע ב-Ecosia לגבי תחומי העניין שלך. לדוגמה, אם ביקרת באתר כדי לקנות נעליים למרתון, האתר עשוי להגדיר 'ריצת מרתון' כתחום עניין שלך. לאחר מכן, בביקור באתר שונה, למשל כדי להירשם למרוץ, יכול להיות שתוצג לך מודעה לנעלי ריצה על סמך תחומי העניין שלך.</translation>
<translation id="8355171755788522183">‏Copyright <ph name="YEAR"/> Ecosia.‎ כל הזכויות שמורות.</translation>
<translation id="5610400309434105339">‏<ph name="BEGIN_BOLD"/>איך אנחנו משתמשים בנתונים האלה:<ph name="END_BOLD"/> Ecosia יכול להעריך מהם תחומי העניין שלך. לאחר מכן, אתר שבו ביקרת יכול לשלוח בקשה ל-Ecosia כדי לגלות מהם תחומי העניין שלך ולהתאים אישית את המודעות שמוצגות לך.</translation>
<translation id="5883025779824839861">‏המשך השימוש ב-Ecosia</translation>
<translation id="8394720698884623075">‏המערכת בודקת כתובות URL בעזרת רשימה של אתרים לא בטוחים ששמורה ב-Chrome</translation>
<translation id="4409756430498035341">‏Ecosia רוצה לייצא את הסיסמאות שלך.</translation>
<translation id="5902103164685487225">‏מידע נוסף על ההתאמה האישית של המודעות ב-Ecosia</translation>
<translation id="592990842052138727">‏לא בוצע סנכרון של הנתונים ב-EcosiaOS כי פרטי הכניסה לחשבון לא מעודכנים.</translation>
<translation id="665177868576952817">‏כדי לשלוח מספר מכאן לטלפון Android, יש להיכנס ל-Ecosia בשני המכשירים.</translation>
<translation id="4070480171055648632">‏החשבון שלך מנוהל על ידי <ph name="MANAGER_NAME"/>. האדמין שלך יכול לראות ולערוך את הפרופיל הזה של דפדפן Ecosia ואת הנתונים שלו, כמו סימניות, היסטוריה וסיסמאות.</translation>
<translation id="1025044809499013222">‏בוצע עדכון אבטחה מיוחד של Ecosia. עכשיו עליך להפעיל מחדש את Ecosia ואנחנו נשחזר את הכרטיסיות.</translation>
<translation id="7864624828358709494">‏בקובץ הזה יש תוכנה זדונית ולכן הוא נחסם על ידי Ecosia</translation>
<translation id="3816260943154642689">‏תחומי העניין שלך בהתאם להערכה של Ecosia</translation>
<translation id="8023973672752791660">‏כלל נכנס לגרסת הפיתוח של Ecosia כדי לאפשר תנועת mDNS.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="8550334526674375523">פרופיל העבודה שלך נפרד לחלוטין מהפרופיל האישי שלך.</translation>
<translation id="7185777478310554774">‏גרסה חדשה של Ecosia זמינה, והיא מהירה יותר מאי פעם.</translation>
<translation id="5622136942112821750">‏בעזרת פרופילים ב-Ecosia, אפשר להפריד בין הפריטים ששומרים ב-Ecosia. באופן הזה קל יותר להפריד בין עבודה לפנאי.</translation>
<translation id="18064594488616674">‏Ecosia אינו מגיב. להפעיל מחדש עכשיו?</translation>
<translation id="6896860023874996542">‏Ecosia זקוק להרשאת גישה למצלמה כדי ליצור מפה תלת-ממדית של הסביבה שלך</translation>
<translation id="7558678848273505235">{0,plural, =1{‏Ecosia יופעל מחדש בעוד דקה}one{‏Ecosia יופעל מחדש בעוד # דקות}two{‏Ecosia יופעל מחדש בעוד # דקות}other{‏Ecosia יופעל מחדש בעוד # דקות}}</translation>
<translation id="8641606876632989680">‏אם מערכת Chrome תזהה שנכנסת עם סיסמה שנחשפה, היא תתריע לך על כך</translation>
<translation id="8649026945479135076">‏באתרים רבים נהוג לשמור את תחומי העניין שלך כדי להתאים אישית את חוויית הגלישה בהם. בנוסף, אתרים יכולים לשמור מידע ב-Chrome לגבי תחומי העניין שלך.</translation>
<translation id="9090890391337853620">Ecosia Helper</translation>
<translation id="524314285625975879">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Ecosia.</translation>
<translation id="4997668724897475215">‏ההמלצה של Ecosia היא לסרוק את הקובץ הזה כי הוא עלול להיות מסוכן</translation>
<translation id="4170280082681554565">‏בעזרת פרופילים ב-Ecosia, אפשר להפריד בין הפריטים ששומרים ב-Ecosia. יוצרים פרופילים המיועדים לחברים ולבני משפחה או פרופילים נפרדים לעבודה ולבילויים בשעות הפנאי.</translation>
<translation id="8712767363896337380">‏העדכון כמעט הושלם. כדי להשלים את העדכון, עליך להפעיל את Chrome מחדש.</translation>
<translation id="873133009373065397">‏Google Chrome אינו יכול לקבוע או להגדיר את דפדפן ברירת המחדל</translation>
<translation id="1975037445584526511">‏כדי לקבל עדכונים של Ecosia בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 7.</translation>
<translation id="2695952268686253864">‏Ecosia אינו מעודכן</translation>
<translation id="8825634023950448068">‏כדי להגן על הפרטיות שלך, תחומי עניין שהוגדרו לפני יותר מ-4 שבועות נמחקים אוטומטית. עם המשך הגלישה, תחום עניין כלשהו עשוי להופיע שוב ברשימה. אם ב-Chrome הוגדר תחום עניין שגוי או שאינך רוצה לראות מודעות מסוימות, יש לך אפשרות להסיר תחומי עניין.</translation>
<translation id="5066194399237265772">‏Ecosia מנסה לערוך את הסיסמאות. כדי לאפשר את הפעולה הזו, יש להקליד את הסיסמה שלך ל-Windows.</translation>
<translation id="6078545897140861225">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Ecosia או לוחצים על הלחצן 'דף הבית'.</translation>
<translation id="1401515072108809622">‏Ecosia לא פעיל</translation>
<translation id="8862326446509486874">אין לך זכויות שמתאימות להתקנה ברמת המערכת. יש לנסות להפעיל שוב את המתקין כמנהל מערכת.</translation>
<translation id="8282620071565190081">‏הפעלה מחדש של Ecosia</translation>
<translation id="7849498640944199147">‏כדי לשלוח מספר מ-<ph name="ORIGIN"/> לטלפון Android, יש להיכנס אל Ecosia בשני המכשירים.</translation>
<translation id="7910693244647744044">‏הפעלת בחשבון שלך את הגרסה המשופרת של הגלישה הבטוחה. עכשיו אפשר להפעיל אותה ב-Ecosia.</translation>
<translation id="8986207147630327271">בחרת להוסיף פרופיל עבודה לדפדפן זה ולתת למנהל המערכת שליטה רק על פרופיל העבודה.</translation>
<translation id="8989968390305463310">‏היסטוריית הגלישה שלך משפיעה על המודעות שמוצגות לך ועל תחומי העניין המשוערים שמופיעים בהמשך. כדי להגן על הפרטיות שלך, מתבצעת ב-Chrome מחיקה אוטומטית של תחומי העניין שלך על בסיס מתחלף מדי חודש. תחומי עניין שלא הוסרו עוברים רענון.</translation>
<translation id="7348818664647668234">{0,plural, =0{‏יש עדכון זמין ל-Ecosia}=1{‏יש עדכון זמין ל-Ecosia}one{‏עדכון ל-Ecosia זמין כבר # ימים}two{‏עדכון ל-Ecosia זמין כבר # ימים}other{‏עדכון ל-Ecosia זמין כבר # ימים}}</translation>
<translation id="9003498785844995646">‏כשהתכונה מופעלת, Chrome חוסך בחיי הסוללה על ידי הגבלת הפעילות ברקע והאפקטים החזותיים, כמו גלילה חלקה וקצב פריימים של סרטונים. אפשר <ph name="BEGIN_LINK"/>לקבל מידע נוסף<ph name="END_LINK"/> או <ph name="BEGIN_LINK_2"/>לשלוח משוב<ph name="END_LINK_2"/></translation>
<translation id="9047384314208087523">‏מערכת EcosiaOS Flex</translation>
<translation id="5675757883980078189">‏כדי להשתמש ב-Ecosia יש צורך ב-Windows מגירסה 7 ואילך.</translation>
<translation id="911206726377975832">למחוק גם את נתוני הגלישה שלך?</translation>
<translation id="9138603949443464873">‏כדי להחיל את השינויים שביצעת, יש להפעיל מחדש את Chrome</translation>
<translation id="9195993889682885387">‏Chrome יכול להעריך מהם תחומי העניין שלך על סמך היסטוריית הגלישה שלך מהשבועות האחרונים. המידע הזה נשאר במכשיר שלך.</translation>
<translation id="5704599732514791330">‏יש לעדכן את Ecosia כדי להתחיל את הסנכרון</translation>
<translation id="838842459108103907">‏התאמה אישית של Ecosia</translation>
<translation id="3070276123152913305">‏הפעלה מחדש של EcosiaOS Flex</translation>
<translation id="4512092435423703529">‏כדי לקבל גישה אל הפריטים שלך ב-Ecosia בכל המכשירים, יש להיכנס לחשבון ולהפעיל את הסנכרון.</translation>
<translation id="7972668220031382654">‏ההמלצה של Ecosia היא לסרוק את הקובץ הזה כי הוא עלול להיות מסוכן.</translation>
<translation id="989369509083708165">‏Google Chrome הוא דפדפן ברירת המחדל</translation>
<translation id="4614106433017753369">‏ניתן לעבור בין פרופילים של Ecosia באמצעות <ph name="SHORTCUT"/></translation>
</translationbundle>
