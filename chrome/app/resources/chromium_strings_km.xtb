<translation id="1625909126243026060">ពិនិត្យមើល​ការគ្រប់គ្រង​សុវត្ថិភាព និងឯកជនភាព​សំខាន់ៗនៅក្នុង Chromium</translation>
<translation id="931416298178634530">ប្រសិនបើអ្នកចង់ប្រើគណនីនេះតែម្ដងគត់ អ្នកអាចប្រើ<ph name="GUEST_LINK_BEGIN"/>មុខងារភ្ញៀវ<ph name="GUEST_LINK_END"/>នៅក្នុងកម្មវិធីរុករកតាមអ៊ីនធឺណិត Ecosia។ ប្រសិនបើអ្នកចង់បញ្ចូលគណនីសម្រាប់អ្នកផ្សេងទៀត សូម<ph name="LINK_BEGIN"/>បញ្ចូលមនុស្សថ្មី<ph name="LINK_END"/>ទៅក្នុង <ph name="DEVICE_TYPE"/> របស់អ្នក។

ការអនុញ្ញាត​ដែលអ្នកបានផ្ដល់​ឱ្យគេហទំព័រ និងកម្មវិធីរួចហើយ​អាចអនុវត្តចំពោះ​គណនីនេះ។ អ្នកអាចគ្រប់គ្រងគណនី Ecosia របស់អ្នកបាននៅក្នុង<ph name="SETTINGS_LINK_BEGIN"/>ការកំណត់<ph name="SETTINGS_LINK_END"/>។</translation>
<translation id="1640672724030957280">កំពុងទាញ​យក...</translation>
<translation id="1715127912119967311">ដើម្បីជួយ​កែលម្អ​មុខងារ​ទាំងនេះ Chromium បញ្ជូន​អន្តរកម្ម​របស់អ្នក​ជាមួយ​មុខងារ​ទាំងនេះ​ទៅ Google។ ទិន្នន័យនេះ​អាចត្រូវបាន​អាន ដំណើរការ និង​ធ្វើចំណារ​ដោយ​អ្នកត្រួតពិនិត្យ​ជាមនុស្ស។</translation>
<translation id="1722488837206509557">ការធ្វើបែបនេះ​នឹងអាច​ឱ្យអ្នក​ជ្រើសរើស​ពីឧបករណ៍​ដែលអាច​ប្រើបាន និង​បង្ហាញ​ខ្លឹមសារ​នៅលើ​ឧបករណ៍​ទាំងនោះ។</translation>
<translation id="1118786556671181978">អ្នក​អាច​មើលឃើញ និង​លុប​ចេញ​នូវ​ប្រធានបទ​ជា​ទី​ចាប់​អារម្មណ៍​ដែល​គេហទំព័រ​ប្រើប្រាស់​សម្រាប់​បង្ហាញ​ការ​ផ្សាយ​ពាណិជ្ជកម្ម​ដល់​អ្នក។ Ecosia ប៉ាន់ស្មានចំណាប់អារម្មណ៍របស់អ្នក ដោយផ្អែកលើប្រវត្តិ​រុករក​តាមអ៊ីនធឺណិតថ្មីៗរបស់អ្នក។</translation>
<translation id="2379593823746842972">Ecosia នឹង​លុប​ទិន្នន័យរុករកក្នុង​ពេល​ឆាប់ៗ​នេះ</translation>
<translation id="1736443181683099871">Chromium នឹងព្យាយាម​ដំឡើងកម្រិត​ការរុករក​ទៅ HTTPS</translation>
<translation id="5490755016715767023">Ecosia នឹងចាប់ផ្តើមឡើងវិញក្នុងរយៈពេល <ph name="REMAINING_TIME"/></translation>
