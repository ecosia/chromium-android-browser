<translation id="6896860023874996542">Ecosia ត្រូវការការអនុញ្ញាតចូលប្រើកាមេរ៉ារបស់អ្នក ដើម្បីបង្កើតផែនទី 3D នៃមជ្ឈដ្ឋានជុំវិញរបស់អ្នក</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{លែងអាចប្រើកម្មវិធីបន្ថែម​នេះបានទៀតហើយ។ Ecosia ណែនាំឱ្យអ្នកដកកម្មវិធីបន្ថែម​នេះចេញ។}other{លែងអាចប្រើកម្មវិធីបន្ថែម​ទាំងនេះបានទៀតហើយ។ Ecosia ណែនាំឱ្យអ្នកដកកម្មវិធីបន្ថែម​ទាំងនេះចេញ។}}</translation>
