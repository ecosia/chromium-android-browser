<!DOCTYPE translationbundle>
<translationbundle lang="km">
<translation id="1026101648481255140">បន្តការដំឡើង</translation>
<translation id="8933665254023068908">ចាប់ផ្តើម​ឡើងវិញ​ដើម្បីដំឡើងកំណែ &amp;EcosiaOS</translation>
<translation id="6566258574866003581">Ecosia ណែនាំឱ្យអ្នកពិនិត្យមើលកម្មវិធីបន្ថែម​នេះ</translation>
<translation id="1042552502243217427">នៅ​ពេល​គេហទំព័រ​ស្នើសុំ​ផ្ទុកតំណ​ជា​មុន​ក្នុងលក្ខណៈ​ឯកជន​នៅ​លើ​ទំព័រ​របស់​គេហទំព័រនេះ Chromium ប្រើ​ម៉ាស៊ីនមេ Google។ ការធ្វើ​បែបនេះ​លាក់​អត្តសញ្ញាណ​របស់​អ្នក​ពី​គេហទំព័រ​ដែល​បាន​ផ្ទុក​ជា​មុន ប៉ុន្តែ​ Google សិក្សា​អំពី​គេហទំព័រ​អ្វីខ្លះដែលត្រូវបាន​ផ្ទុក​ជា​មុន។</translation>
<translation id="1065672644894730302">ចំណូលចិត្តរបស់អ្នកមិនអាចអានបានទេ។

លក្ខណៈពិសេសមួយចំនួនប្រហែលជាមិនមាន ហើយការប្តូរទៅចំណូលចិត្តនឹងមិនត្រូវបានរក្សាទុកទេ។</translation>
<translation id="8561406087076314604">មាតាបិតា​របស់អ្នក​បានបិទ "ការអនុញ្ញាត​សម្រាប់​គេហទំព័រ កម្មវិធី និង​កម្មវិធី​បន្ថែម" ចំពោះ Ecosia</translation>
<translation id="1098170124587656448">Chromium អាច​ជួយរក្សាសុវត្ថិភាពរបស់អ្នកពី​ការបែកធ្លាយ​ទិន្នន័យ កម្មវិធីបន្ថែម​ដែលមានបញ្ហា និង​អ្វីៗជាច្រើនទៀត</translation>
<translation id="3632544319066562282">Ecosia ចង់​នាំ​ចេញពាក្យ​សម្ងាត់​របស់អ្នក។ សូមវាយ​បញ្ចូលពាក្យ​សម្ងាត់ Windows របស់អ្នក​ដើម្បីអនុញ្ញាត​ការនាំចេញ​នេះ។</translation>
<translation id="113122355610423240">Chromium គឺជា​កម្មវិធីរុករក​តាមអ៊ីនធឺណិត​លំនាំដើម​របស់​អ្នក</translation>
<translation id="1131805035311359397">ដើម្បីពិនិត្យមើលថា​តើពាក្យសម្ងាត់​របស់អ្នក​មានសុវត្ថិភាពពី​ការបែកធ្លាយ​ទិន្នន័យ និងបញ្ហាសុវត្ថិភាព​ផ្សេងទៀតឬអត់ សូម​<ph name="BEGIN_LINK"/>ចូល Chromium<ph name="END_LINK"/>។</translation>
<translation id="1224748120031661633">ចុច​ម៉ឺនុយ Ecosia</translation>
<translation id="1184145431117212167">ការដំឡើងមិនបានសម្រេចទេ ដោយសារកំណែ Windows របស់អ្នកមិនអាចប្រើបាន។</translation>
<translation id="1185134272377778587">អំពី Chromium</translation>
<translation id="1330085168384841023">ដើម្បី​បង្ហាញ​វិនដូ​របស់អ្នក សូម​អនុញ្ញាតឱ្យ Ecosia ថតវីដេអូ​អេក្រង់​នៅក្នុង "ចំណូលចិត្ត​ប្រព័ន្ធ"។</translation>
<translation id="1203500561924088507">សូមអរគុណសម្រាប់ការដំឡើង។ អ្នកត្រូវតែចាប់ផ្ដើមកម្មវិធីរុករកតាមអ៊ីនធឺណិតរបស់អ្នកឡើងវិញ មុនពេលប្រើ <ph name="BUNDLE_NAME"/>។</translation>
<translation id="7455175614937447568">នៅពេលផ្ទាំងនេះអសកម្ម អង្គចងចាំត្រូវបានសម្អាត ដើម្បីរក្សា Ecosia ឱ្យដើរលឿន។ អ្នកអាចជ្រើសរើសដកគេហទំព័រនេះចេញពីភាពអសកម្មបានជានិច្ច។</translation>
<translation id="9068280473864300215">Ecosia បានទប់ស្កាត់​ការទាញយកនេះ ដោយសារ​ឯកសារនេះ​មានគ្រោះថ្នាក់</translation>
<translation id="126567311906253476">នៅពេល​ចូល​សេវាកម្ម Google ដូចជា Gmail ឬ YouTube ដោយប្រើ <ph name="USER_EMAIL"/> អ្នកអាច​ចូល Chromium ដោយ​ស្វ័យប្រវត្តិ ដោយប្រើ​គណនី​តែមួយ</translation>
