<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="th">
<translation id="4033006861724039519">การเก็บข้อมูลของโปรแกรมติดตั้งเสียหายหรือไม่ถูกต้อง โปรดดาวน์โหลด Ecosia อีกครั้ง</translation>
<translation id="1026101648481255140">ดำเนินการติดตั้งต่อ</translation>
<translation id="8296565077892323223">ปรับแต่งและควบคุม Ecosia มีการอัปเดต</translation>
<translation id="2804130178228362015">มีซอฟต์แวร์อันตรายในคอมพิวเตอร์ของคุณ Ecosia ช่วยนำซอฟต์แวร์ดังกล่าวออก คืนการตั้งค่า และปิดใช้ส่วนขยายให้คุณได้ เพื่อให้เบราว์เซอร์กลับมาทำงานเป็นปกติอีกครั้ง</translation>
<translation id="1065672644894730302">ค่ากำหนดของคุณไม่สามารถอ่านได้ ฟีเจอร์บางอย่างอาจใช้ไม่ได้และการเปลี่ยนแปลงค่ากำหนดจะไม่ได้รับการบันทึก</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> ใช้ Ecosia อยู่ก่อนหน้านี้</translation>
<translation id="2000339487270823788">นี่คือ Ecosia ของคุณ</translation>
<translation id="8078678931242443254">ใครกำลังใช้ Ecosia อยู่</translation>
<translation id="6346154190168496057">อัปเดต Ecosia ไม่ได้</translation>
<translation id="1152920704813762236">เกี่ยวกับ Chrome OS</translation>
<translation id="7303930050538184306">เ&amp;ปิดใน Ecosia</translation>
<translation id="1203500561924088507">ขอขอบคุณที่ติดตั้ง คุณต้องรีสตาร์ทเบราว์เซอร์ก่อนใช้ <ph name="BUNDLE_NAME"/></translation>
<translation id="6650631555168164414">ใช้งาน Ecosia อย่างเต็มประสิทธิภาพ</translation>
<translation id="1523806373970723624">เปิดอีกครั้งเพื่ออัปเดต Ecosia</translation>
<translation id="5279514147510747661">โปรดรอขณะที่ Ecosia ติดตั้งการอัปเดตระบบล่าสุด</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> กำหนดว่าคุณต้องอ่านและยอมรับข้อกำหนดในการให้บริการต่อไปนี้ก่อนใช้อุปกรณ์นี้ ข้อกำหนดเหล่านี้ไม่ขยาย แก้ไข หรือจำกัดข้อกำหนดของ Ecosia OS Flex</translation>
<translation id="8067423333018528301">Ecosia OS ซิงค์ข้อมูลไม่ได้เนื่องจากเกิดข้อผิดพลาดในการลงชื่อเข้าใช้</translation>
<translation id="2926455547526018397">Ecosia เบต้า</translation>
<translation id="2995860351618948435">คอมพิวเตอร์เครื่องนี้มี Ecosia รุ่นใหม่กว่าแล้ว หากซอฟต์แวร์ไม่ทำงาน โปรดถอนการติดตั้ง Ecosia แล้วลองใหม่อีกครั้ง</translation>
<translation id="824192326282906244">คุณเปลี่ยนใจได้ทุกเมื่อในการตั้งค่า Ecosia การทดลองใช้จะทำงานพร้อมกับวิธีแสดงโฆษณาปัจจุบัน คุณจึงจะไม่เห็นการเปลี่ยนแปลงโดยทันที</translation>
<translation id="4696685525015809740">แอป Ecosia Canary</translation>
<translation id="3697186779259384993">ปรับแต่งโปรไฟล์ Ecosia ใหม่</translation>
<translation id="4062366803229254216">Ecosia ต้องการสิทธิ์เข้าถึงบลูทูธเพื่อจับคู่ต่อ <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="2441303983090031276">Ecosia OS เกิดขึ้นได้ด้วยการสนับสนุนจาก<ph name="BEGIN_LINK_CROS_OSS"/>ซอฟต์แวร์โอเพนซอร์ส<ph name="END_LINK_CROS_OSS"/>อื่นเพิ่มเติม</translation>
<translation id="5598074261782651109">อัปเดต Ecosia</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> ลงชื่อเข้าใช้โปรไฟล์ Ecosia นี้แล้ว การดำเนินการนี้จะสร้างโปรไฟล์ Ecosia ใหม่สำหรับ <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="4943938785458240142">Ecosia ใช้กล้องของคุณอยู่</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> เป็นอันตราย Ecosia จึงบล็อกไว้</translation>
<translation id="1597911401261118146"><ph name="BEGIN_LINK"/>ลงชื่อเข้าใช้ Chrome<ph name="END_LINK"/> เพื่อตรวจสอบว่ารหัสผ่านของคุณไม่ได้รับผลกระทบจากการละเมิดข้อมูลและปัญหาด้านความปลอดภัยอื่นๆ</translation>
<translation id="5591151834004774364">Ecosia บล็อกไฟล์ที่เก็บถาวรนี้เนื่องจากอาจซ่อนมัลแวร์ไว้</translation>
<translation id="1597547208646178091">เพื่อให้ Ecosia ปลอดภัยขึ้น เราได้ปิดส่วนขยายต่อไปนี้ซึ่งไม่ได้แสดงอยู่ใน <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> และอาจมีการเพิ่มเข้ามาโดยที่คุณไม่รู้ตัว</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>วิธีที่คุณจัดการข้อมูลของตัวเองได้:<ph name="END_BOLD"/> เราลบความสนใจที่เก่ากว่า 4 สัปดาห์โดยอัตโนมัติเพื่อปกป้องความเป็นส่วนตัวของคุณ ความสนใจอาจกลับมาปรากฏในรายการอีกเมื่อคุณท่องเว็บต่อ หรือคุณจะนำความสนใจที่ไม่ต้องการให้ Ecosia พิจารณาออกก็ได้</translation>
<translation id="1628000112320670027">รับความช่วยเหลือเกี่ยวกับ Chrome</translation>
<translation id="1640672724030957280">กำลังดาวน์โหลด...</translation>
<translation id="1662146548738125461">เกี่ยวกับ Chrome OS Flex</translation>
<translation id="5500958820122281144">เปิดลิงก์ในหน้าต่างที่ไม่ระบุตัวตนของ Ecosia</translation>
<translation id="7602423871874451395">Ecosia ไม่สามารถอ่านและเขียนข้อมูลในไดเรกทอรีข้อมูล: <ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{ผู้ดูแลระบบได้กำหนดค่าให้ Ecosia ปิดหากไม่มีการใช้งานเกิน 1 นาที}other{ผู้ดูแลระบบได้กำหนดค่าให้ Ecosia ปิดหากไม่มีการใช้งานเกิน # นาที}}</translation>
<translation id="3939060118711873999">Ecosia คือเว็บเบราว์เซอร์ที่แสดงหน้าเว็บและแอปพลิเคชันต่างๆ ได้รวดเร็วในพริบตา โดยทำงานได้เร็ว มีเสถียรภาพ และใช้งานง่าย ช่วยให้คุณเรียกดูเว็บได้อย่างปลอดภัยมากขึ้นด้วยการป้องกันมัลแวร์และฟิชชิงซึ่งมีอยู่ใน Ecosia</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia จะเปิดขึ้นมาใหม่ใน 1 ชั่วโมง}other{Ecosia จะเปิดขึ้นมาใหม่ใน # ชั่วโมง}}</translation>
<translation id="4021894801595982809">Ecosia จะบันทึกรหัสผ่านนี้ในบัญชี Ecosia คุณจะได้ไม่ต้องจำรหัสผ่านเอง</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">ตรวจสอบว่าคุณลงชื่อเข้าใช้ Ecosia ใน <ph name="TARGET_DEVICE_NAME"/> แล้วลองส่งอีกครั้ง</translation>
<translation id="1812689907177901597">เมื่อปิดการตั้งค่านี้ คุณจะลงชื่อเข้าใช้เว็บไซต์ของ Google อย่างเช่น Gmail ได้โดยไม่ต้องลงชื่อเข้าใช้ Chrome</translation>
<translation id="5055330219314726197">Ecosia ต้องการสิทธิ์เข้าถึงกล้องถ่ายรูปของคุณสำหรับเว็บไซต์นี้</translation>
<translation id="1508200558303644420">Ecosia ไม่ใช่เบราว์เซอร์เริ่มต้น</translation>
<translation id="8135642897811755229">Ecosia เบต้า (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia ล้าสมัย</translation>
<translation id="1919130412786645364">อนุญาตให้ลงชื่อเข้าใช้ Chrome</translation>
<translation id="6235917057647038042">คุณจะต้องใช้ macOS 10.13 ขึ้นไปเพื่อรับการอัปเดต Ecosia ในอนาคต คอมพิวเตอร์เครื่องนี้ใช้ macOS 10.12</translation>
<translation id="1953553007165777902">กำลังดาวน์โหลด... เหลืออีก <ph name="MINUTE"/> นาที</translation>
<translation id="8608092457636055141">แต่ละโปรไฟล์จะเก็บข้อมูล Ecosia ของตัวเอง เช่น บุ๊กมาร์ก ประวัติการเข้าชม รหัสผ่าน และอื่นๆ</translation>
<translation id="2018879682492276940">การติดตั้งไม่สำเร็จ โปรดลองอีกครั้ง</translation>
<translation id="7375011918167125899">บัญชีอื่นได้ลงชื่อเข้าใช้อยู่แล้ว หากต้องการแยกการท่องเว็บของคุณไว้ต่างหาก Ecosia สร้างโปรไฟล์ให้คุณโดยเฉพาะได้</translation>
<translation id="207902854391093810">เมื่อเริ่มการทดสอบ การวัดผลโฆษณาจะให้เว็บไซต์ที่คุณเข้าชมสามารถขอข้อมูลจาก Chrome เพื่อช่วยวัดประสิทธิภาพโฆษณาของเว็บไซต์ดังกล่าวได้ การวัดผลโฆษณาจะจำกัดการติดตามข้ามเว็บไซต์โดยโอนข้อมูลระหว่างเว็บไซต์ให้น้อยที่สุด</translation>
<translation id="8655983536493871574">คุณจะต้องใช้ Windows 10 ขึ้นไปเพื่อรับการอัปเดต Ecosia ในอนาคต คอมพิวเตอร์เครื่องนี้ใช้ Windows 8</translation>
<translation id="3590393640971125498">ข้อกำหนดของ Ecosia OS Flex</translation>
<translation id="864244542982029641">ปิด Ecosia ใช่ไหม</translation>
<translation id="3791194915692553395">Ecosia OS Flex เกิดขึ้นได้ด้วยการสนับสนุนจาก<ph name="BEGIN_LINK_CROS_OSS"/>ซอฟต์แวร์โอเพนซอร์ส<ph name="END_LINK_CROS_OSS"/>เพิ่มเติม เช่นเดียวกับ<ph name="BEGIN_LINK_LINUX_OSS"/>สภาพแวดล้อมในการพัฒนาซอฟต์แวร์ Linux<ph name="END_LINK_LINUX_OSS"/></translation>
<translation id="2120620239521071941">การดำเนินการนี้จะลบ <ph name="ITEMS_COUNT"/> รายการออกจากอุปกรณ์นี้ หากต้องการดึงข้อมูลภายหลัง ให้ลงชื่อเข้าใช้ Chrome ด้วย <ph name="USER_EMAIL"/></translation>
<translation id="2159716220295742156">เปิดอีกครั้งเพื่ออัปเดต Ecosia</translation>
<translation id="2123055963409958220">ช่วยให้ Chrome ดียิ่งขึ้นด้วยการรายงาน<ph name="BEGIN_LINK"/>การตั้งค่าปัจจุบัน<ph name="END_LINK"/></translation>
<translation id="2131230230468101642">เราลบความสนใจที่เก่ากว่า 4 สัปดาห์โดยอัตโนมัติเพื่อปกป้องความเป็นส่วนตัวของคุณ ความสนใจอาจกลับมาปรากฏในรายการอีกเมื่อคุณท่องเว็บต่อ หรือคุณจะนำความสนใจที่ไม่ต้องการให้ Chrome พิจารณาออกก็ได้</translation>
<translation id="5404489723475681578">รีสตาร์ท Ecosia OS</translation>
<translation id="5982672133249369264">โปรดรีสตาร์ท Ecosia ตอนนี้เลย</translation>
<translation id="2174917724755363426">การติดตั้งไม่สมบูรณ์ คุณแน่ใจไหมว่าต้องการยกเลิก</translation>
<translation id="223889379102603431">ข้อมูลเกี่ยวกับวิธีที่ Chrome จัดการใบรับรองรูท</translation>
<translation id="4337034173783952373">หากต้องการเข้าถึงข้อมูลของคุณในเบราว์เซอร์ Ecosia ในอุปกรณ์ทั้งหมด ให้ลงชื่อเข้าใช้แล้วเปิดการซิงค์</translation>
<translation id="4735588186234302898">คีย์ API ของ Ecosia หายไป การทำงานบางอย่างของ Ecosia จะถูกปิดใช้งาน</translation>
<translation id="7908111389403807005">คุณแน่ใจหรือไม่ว่าต้องการยกเลิกการติดตั้ง Ecosia</translation>
<translation id="2309047409763057870">นี่เป็นการติดตั้ง Google Chrome แบบสำรอง และไม่สามารถใช้เป็นเบราว์เซอร์เริ่มต้นของคุณ</translation>
<translation id="7613817989637275906">Ecosia พบว่าส่วนขยายเหล่านี้มีมัลแวร์</translation>
<translation id="7273750863406285983">Ecosia ต้องการสิทธิ์เข้าถึงไมโครโฟนและกล้องถ่ายรูปของคุณสำหรับเว็บไซต์นี้</translation>
<translation id="234869673307233423">Chrome ตรวจสอบรหัสผ่านของคุณไม่ได้ โปรดลองอีกครั้งภายหลัง</translation>
<translation id="5707346538075088068">ผู้ดูแลโปรไฟล์งานนำข้อมูล Ecosia ที่สร้างขึ้นในช่วงที่มีการใช้โปรไฟล์นี้ออกได้ (เช่น การสร้างบุ๊กมาร์ก ประวัติการเข้าชม รหัสผ่าน และการตั้งค่าอื่นๆ) <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">ต่อไป</translation>
<translation id="3959732324458144441">ระบบ Ecosia OS</translation>
<translation id="3632544319066562282">Ecosia ต้องการส่งออกรหัสผ่านของคุณ พิมพ์รหัสผ่าน Windows เพื่ออนุญาตให้ดำเนินการ</translation>
<translation id="2485422356828889247">ถอนการติดตั้ง</translation>
<translation id="2534507159460261402">Google Pay (คัดลอกไปยัง Chrome)</translation>
<translation id="2559253115192232574">ภายหลัง เว็บไซต์ที่คุณเข้าชมอาจขอข้อมูลความสนใจจาก Chrome เพื่อปรับการแสดงโฆษณาให้เหมาะกับคุณ Chrome สามารถแชร์ความสนใจได้สูงสุด 3 รายการ</translation>
<translation id="2563121210305478421">เปิด Chrome อีกครั้ง</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> ลงชื่อเข้าใช้โปรไฟล์ Ecosia นี้แล้ว หากต้องการแยกการท่องเว็บของคุณไว้ต่างหาก Ecosia สร้างโปรไฟล์ให้คุณโดยเฉพาะได้</translation>
<translation id="80155189677487610">ไม่สามารถติดตั้ง Ecosia รุ่นเดียวกับที่กำลังเรียกใช้อยู่ได้ โปรดปิด Ecosia แล้วลองใหม่อีกครั้ง</translation>
<translation id="2586406160782125153">การดำเนินการนี้จะลบข้อมูลการท่องเว็บออกจากอุปกรณ์นี้ หากต้องการดึงข้อมูลภายหลัง ให้ลงชื่อเข้าใช้ Chrome ด้วย <ph name="USER_EMAIL"/></translation>
<translation id="6391863622742187823">ดึงข้อมูลของคุณในเบราว์เซอร์ Ecosia จาก <ph name="ACCOUNT_EMAIL"/></translation>
<translation id="2622559029861875898">Chrome ตรวจหาอัปเดตไม่ได้ โปรดลองตรวจสอบการเชื่อมต่ออินเทอร์เน็ต</translation>
<translation id="1761341660094265938">Ecosia OS</translation>
<translation id="7774247008790177839">เปิดลิงก์ใน Ecosia แท็บใหม่</translation>
<translation id="9178613517891824246">ช่วยทำให้ Ecosia ดียิ่งขึ้นโดยการส่งรายงานข้อขัดข้องและ <ph name="UMA_LINK"/> ไปยัง Ecosia</translation>
<translation id="815199437159352723">ส่วนขยายนี้ได้เปลี่ยนหน้าที่จะแสดงเมื่อคุณเริ่มต้น Ecosia</translation>
<translation id="1676748966275099244">คำเตือน: Ecosia ไม่สามารถป้องกันไม่ให้ส่วนขยายบันทึกประวัติการท่องเว็บ หากต้องการปิดใช้ส่วนขยายนี้ในโหมดไม่ระบุตัวตน ให้ยกเลิกการเลือกตัวเลือกนี้</translation>
<translation id="1831192335802727557">Ecosia ต้องการสิทธิ์เข้าถึงไมโครโฟนของคุณสำหรับเว็บไซต์นี้</translation>
<translation id="2770231113462710648">เปลี่ยนเบราว์เซอร์ที่เป็นค่าเริ่มต้นเป็น:</translation>
<translation id="2775140325783767197">Chrome ตรวจสอบรหัสผ่านของคุณไม่ได้ โปรดลองตรวจสอบการเชื่อมต่ออินเทอร์เน็ต</translation>
<translation id="2799223571221894425">เปิดใหม่</translation>
<translation id="2847461019998147611">แสดง Google Chrome ในภาษานี้</translation>
<translation id="8109744984354428711">กำลังเปิด Ecosia...</translation>
<translation id="812798451698099271">มีโปรไฟล์ Ecosia ที่ใช้บัญชีนี้อยู่แล้ว</translation>
<translation id="2861074815332034794">กำลังอัปเดต Chrome (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="727568860157522676">คุณได้ลงชื่อเข้าใช้ Ecosia แล้ว!</translation>
<translation id="2885378588091291677">ตัวจัดการงาน</translation>
<translation id="2888126860611144412">เกี่ยวกับ Chrome</translation>
<translation id="2915996080311180594">รีสตาร์ทภายหลัง</translation>
<translation id="2926676257163822632">รหัสผ่านที่ไม่รัดกุมนั้นคาดเดาได้ง่าย ให้ Chrome <ph name="BEGIN_LINK"/>สร้างและจดจำรหัสผ่านที่รัดกุมให้คุณ<ph name="END_LINK"/></translation>
<translation id="219546601381787154">Ecosia ต้องการสิทธิ์เข้าถึงกล้องสำหรับเว็บไซต์นี้</translation>
<translation id="2928420929544864228">การติดตั้งเสร็จสมบูรณ์</translation>
<translation id="2929907241665500097">Chrome ไม่ได้อัปเดตเนื่องจากเกิดข้อผิดพลาด <ph name="BEGIN_LINK"/>โปรดแก้ปัญหาการอัปเดต Chrome และการอัปเดตที่ไม่สำเร็จ<ph name="END_LINK"/></translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - หน้าลงชื่อเข้าใช้ของเครือข่าย - Ecosia</translation>
<translation id="5622643576877267490">เปิดอีกครั้งเพื่ออัปเดต &amp;Ecosia OS Flex</translation>
<translation id="303514781271618814">Chrome กำลังสำรวจฟีเจอร์ใหม่ๆ ที่ทำให้เว็บไซต์มอบประสบการณ์การท่องเว็บที่เหมือนกันได้โดยใช้อินเทอร์เน็ตน้อยลง</translation>
<translation id="2234042158691635795">Ecosia กำลังอยู่ในโหมดทำงานในพื้นหลัง</translation>
<translation id="3038232873781883849">กำลังรอติดตั้ง...</translation>
<translation id="3059710691562604940">Google Safe Browsing ปิดอยู่ Chrome ขอแนะนำให้เปิด</translation>
<translation id="385080958066798123">แท็บ Ecosia</translation>
<translation id="3080151273017101988">เรียกใช้แอปพลิเคชันเบื้องหลังต่อไปเมื่อ Google Chrome ถูกปิดลง</translation>
<translation id="6876820794875877783">Ecosia มีรุ่นใหม่ที่ปลอดภัยกว่าให้ใช้งานแล้ว</translation>
<translation id="3100998948628680988">ตั้งชื่อโปรไฟล์ Chrome ของคุณ</translation>
<translation id="3114643501466072395"><ph name="BEGIN_LINK"/>ลงชื่อเข้าใช้ Chrome<ph name="END_LINK"/> เพื่อตรวจสอบว่ารหัสผ่านรายการอื่นไม่ได้รับผลกระทบจากการละเมิดข้อมูลและปัญหาด้านความปลอดภัยอื่นๆ</translation>
<translation id="1722634673917783018">การเปลี่ยนแปลงของคุณจะมีผลในครั้งถัดไปที่คุณเปิด Ecosia</translation>
<translation id="2636091632287013185">แอป Ecosia</translation>
<translation id="7580831958727159171">ในระหว่างการทดลองใช้ คุณสามารถดูและลบหัวข้อที่สนใจซึ่งเว็บไซต์ใช้เพื่อแสดงโฆษณาแก่คุณได้ Ecosia คาดคะเนความสนใจของคุณโดยอิงจากประวัติการท่องเว็บล่าสุด</translation>
<translation id="2899530016847324742">{NUM_DEVICES,plural, =1{Ecosia เชื่อมต่อกับอุปกรณ์ HID}other{Ecosia เชื่อมต่อกับอุปกรณ์ HID}}</translation>
<translation id="3245429137663807393">หากคุณแชร์รายงานการใช้งาน Chrome ด้วย รายงานดังกล่าวจะรวม URL ที่คุณเข้าชม</translation>
<translation id="2388751143175762498">ลงชื่อเข้าใช้ Ecosia</translation>
<translation id="3286538390144397061">รีสตาร์ทเดี๋ยวนี้</translation>
<translation id="9090890391337853620">ตัวช่วยเหลือของ Ecosia</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia จะเปิดขึ้นมาใหม่ตอนนี้}=1{Ecosia จะเปิดขึ้นมาใหม่ใน 1 วินาที}other{Ecosia จะเปิดขึ้นมาใหม่ใน # วินาที}}</translation>
<translation id="7280797724682955539">มีข้อผิดพลาดของระบบปฏิบัติการเกิดขึ้นในระหว่างการติดตั้ง โปรดดาวน์โหลด Ecosia อีกครั้ง</translation>
<translation id="2298752889004612764">โหมดประหยัดหน่วยความจำช่วยให้ Ecosia ทำงานได้เร็วขึ้น</translation>
<translation id="3428747202529429621">รักษาความปลอดภัยของคุณใน Chrome และอาจใช้เพื่อปรับปรุงความปลอดภัยในแอปอื่นๆ ของ Google เมื่อลงชื่อเข้าใช้</translation>
<translation id="3434246496373299699">Chrome จะตรวจสอบรหัสผ่านได้เมื่อคุณลงชื่อเข้าใช้ด้วยบัญชี Google</translation>
<translation id="1762318218111418450">กำลังเพิ่มลงใน Ecosia...</translation>
<translation id="6761747850241550887">เพิ่มตัวคุณเองใน Ecosia</translation>
<translation id="2149148292984034533">ข้อกำหนดของ Ecosia OS</translation>
<translation id="3674955518940155608">ล้างข้อมูลจาก Ecosia (<ph name="URL"/>) ด้วย</translation>
<translation id="6558895515431832002">Ecosia ต้องการสิทธิ์เข้าถึงตำแหน่งของคุณเพื่อแชร์ตำแหน่งกับเว็บไซต์นี้</translation>
<translation id="3533694711092285624">ไม่มีรหัสผ่านที่บันทึกไว้ Chrome จะตรวจสอบรหัสผ่านได้เมื่อคุณบันทึกรหัสผ่านไว้</translation>
<translation id="3541482654983822893">Chrome ตรวจสอบรหัสผ่านของคุณไม่ได้ โปรดรอ 24 ชั่วโมงแล้วลองอีกครั้ง</translation>
<translation id="8901409988302458368">ผู้ดูแลระบบของคุณกำหนดค่าให้ Ecosia เปิดเบราว์เซอร์สำรองเพื่อเข้าถึง <ph name="TARGET_URL_HOSTNAME"/></translation>
<translation id="3579965087968408543">ล้างข้อมูลเว็บไซต์จากอุปกรณ์เสมอเมื่อปิด Chrome</translation>
<translation id="7174674455569790401">ซิงค์และปรับเปลี่ยน Ecosia ในอุปกรณ์ต่างๆ</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{ผู้ดูแลระบบต้องการให้คุณเปิด Ecosia ขึ้นมาใหม่เพื่อใช้การอัปเดต}=1{ผู้ดูแลระบบต้องการให้คุณเปิด Ecosia ขึ้นมาใหม่เพื่อใช้การอัปเดต หน้าต่างที่ไม่ระบุตัวตนจะไม่เปิดให้อีก}other{ผู้ดูแลระบบต้องการให้คุณเปิด Ecosia ขึ้นมาใหม่เพื่อใช้การอัปเดต หน้าต่างที่ไม่ระบุตัวตนจำนวน # หน้าต่างจะไม่เปิดให้อีก}}</translation>
<translation id="464306605599005355">ตอนนี้การใช้ Ecosia กับบัญชี Ecosia ของคุณและบนคอมพิวเตอร์ที่ใช้ร่วมกันทำได้ง่ายกว่าเดิม</translation>
<translation id="1490060441084292633">Ecosia พบว่า "<ph name="EXTENSION_NAME"/>" มีมัลแวร์</translation>
<translation id="5311911269004680646">Ecosia OS เกิดขึ้นได้ด้วยการสนับสนุนจาก<ph name="BEGIN_LINK_CROS_OSS"/>ซอฟต์แวร์โอเพนซอร์ส<ph name="END_LINK_CROS_OSS"/>อื่นเพิ่มเติม ตลอดจน<ph name="BEGIN_LINK_LINUX_OSS"/>สภาพแวดล้อมในการพัฒนาซอฟต์แวร์ Linux<ph name="END_LINK_LINUX_OSS"/></translation>
<translation id="3716540481907974026">เวอร์ชัน Chrome OS Flex</translation>
<translation id="3718181793972440140">การดำเนินการนี้จะลบ 1 รายการออกจากอุปกรณ์นี้ หากต้องการดึงข้อมูลภายหลัง ให้ลงชื่อเข้าใช้ Chrome ด้วย <ph name="USER_EMAIL"/></translation>
<translation id="9032120646440147804">ส่วนขยาย "<ph name="EXTENSION_NAME"/>" ได้เปลี่ยนหน้าที่จะแสดงเมื่อคุณเริ่มต้น Ecosia</translation>
<translation id="3744202345691150878">รับความช่วยเหลือเกี่ยวกับ Chrome OS</translation>
<translation id="4600924482853773728">Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="4969069484658032230">Ecosia OS Flex ซิงค์ข้อมูลไม่ได้เนื่องจากเกิดข้อผิดพลาดในการลงชื่อเข้าใช้</translation>
<translation id="1761341660094265938">Ecosia OS</translation>
<translation id="3952510753191144456">การดำเนินการนี้จะสร้างโปรไฟล์ Ecosia ใหม่สำหรับ <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="8534308095039131078">โปรดปิดหน้าต่าง Ecosia ทั้งหมดและลองใหม่อีกครั้ง</translation>
<translation id="3865754807470779944">ติดตั้ง Chrome เวอร์ชัน <ph name="PRODUCT_VERSION"/> ไว้แล้ว</translation>
<translation id="8283315171506895091">เปิดลิงก์ในหน้าต่างที่ไม่ระบุตัวตนของ Ecosia</translation>
<translation id="6496553866814956056">ยกเลิกการติดตั้ง Ecosia</translation>
<translation id="1118786556671181978">คุณสามารถดูและลบหัวข้อที่สนใจซึ่งเว็บไซต์ใช้เพื่อแสดงโฆษณาแก่คุณ Ecosia คาดคะเนความสนใจของคุณโดยอิงจากประวัติการท่องเว็บล่าสุด</translation>
<translation id="8047394653992042491">ต้องรีสตาร์ท Ecosia OS เพื่อใช้การอัปเดต</translation>
<translation id="4050175100176540509">การปรับปรุงด้านความปลอดภัยที่สำคัญและฟีเจอร์ใหม่ๆ พร้อมให้บริการในเวอร์ชันล่าสุด</translation>
<translation id="4817913198787198451">กำหนดค่าและควบคุม Ecosia</translation>
<translation id="3708834841667355707">Ecosia กำลังพัฒนาฟีเจอร์ใหม่ๆ ที่จะช่วยให้เว็บไซต์มอบประสบการณ์การท่องเว็บได้เหมือนเดิมแต่ใช้ข้อมูลของคุณน้อยลง</translation>
<translation id="319566061277127356">ตั้งค่าโปรไฟล์ Ecosia ใหม่</translation>
<translation id="7105712012505419722">คุณกำลังลงชื่อเข้าใช้ด้วยบัญชีที่จัดการ และให้การควบคุมระดับผู้ดูแลระบบของบัญชีดังกล่าวเหนือโปรไฟล์ Ecosia ของคุณ ข้อมูล Ecosia เช่น แอป บุ๊กมาร์ก ประวัติการเข้าชม รหัสผ่าน และการตั้งค่าอื่นๆ จะเชื่อมโยงอย่างถาวรกับ <ph name="USER_NAME"/> คุณจะสามารถลบข้อมูลนี้ผ่านทางแผงควบคุมบัญชี Ecosia แต่คุณจะไม่สามารถเชื่อมโยงข้อมูลนี้กับบัญชีอื่น <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">กำลังติดตั้ง...</translation>
<translation id="7691143774653486474">โปรแกรมติดตั้งยกเลิกการบีบอัดการเก็บข้อมูลไม่ได้ โปรดดาวน์โหลด Ecosia อีกครั้ง</translation>
<translation id="6826163993811146231">{0,plural, =1{เปิด Ecosia ขึ้นมาใหม่ภายใน 1 วัน}other{เปิด Ecosia ขึ้นมาใหม่ภายใน # วัน}}</translation>
<translation id="4205939740494406371">Chrome ตรวจสอบรหัสผ่านของคุณไม่ได้ โปรดรอ 24 ชั่วโมงแล้วลองอีกครั้งหรือ<ph name="BEGIN_LINK"/>ตรวจสอบรหัสผ่านในบัญชี Google<ph name="END_LINK"/></translation>
<translation id="4222932583846282852">กำลังยกเลิก...</translation>
<translation id="3554373328288278512">Ecosia ต้องการสิทธิ์เข้าถึงกล้องและไมโครโฟนสำหรับเว็บไซต์นี้</translation>
<translation id="424864128008805179">ต้องการออกจากระบบ Chrome ไหม</translation>
<translation id="8384922154025337808">เชื่อมโยงข้อมูล Ecosia กับบัญชีนี้ไหม</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>ข้อมูลใดบ้างที่มีการนำไปใช้:<ph name="END_BOLD"/> ประวัติการท่องเว็บของคุณ บันทึกรายการเว็บไซต์ที่คุณเข้าชมโดยใช้ Ecosia ในอุปกรณ์นี้</translation>
<translation id="4281844954008187215">ข้อกำหนดในการให้บริการ</translation>
<translation id="4293420128516039005">ลงชื่อเข้าใช้เพื่อซิงค์และปรับเปลี่ยน Chrome ในอุปกรณ์ต่างๆ</translation>
<translation id="6419542773162312746">อนุญาตให้ส่วนขยายแสดงคำขอเข้าถึงในแถบเครื่องมือ Ecosia</translation>
<translation id="8864449561723972619">Ecosia Dev (mDNS-In)</translation>
<translation id="4334294535648607276">ดาวน์โหลดเสร็จสมบูรณ์</translation>
<translation id="4335235004908507846">Chrome ช่วยให้คุณปลอดภัยจากการละเมิดข้อมูล ส่วนขยายที่ไม่ปลอดภัย และอื่นๆ ได้</translation>
<translation id="2227704215309956084">เพิ่ม <ph name="EXTENSION_NAME"/> ลงใน Ecosia แล้ว</translation>
<translation id="4384570495110188418">Chrome ตรวจสอบรหัสผ่านไม่ได้เพราะคุณไม่ได้ลงชื่อเข้าใช้</translation>
<translation id="4427306783828095590">การปกป้องที่ปรับปรุงแล้วทำได้มากกว่าบล็อกฟิชชิงและมัลแวร์</translation>
<translation id="9035946286843935549">Ecosia - หน้าลงชื่อเข้าใช้ของเครือข่าย - <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">Ecosia กำลังดำเนินการอย่างอื่นอยู่ โปรดลองอีกครั้งในภายหลัง</translation>
<translation id="4459234553906210702">การวัดผลโฆษณาจะให้เว็บไซต์ที่คุณเข้าชมสามารถขอข้อมูลจาก Chrome เพื่อช่วยในการวัดประสิทธิภาพโฆษณาเว็บไซต์ดังกล่าวได้ การวัดผลโฆษณาจะจำกัดการติดตามข้ามเว็บไซต์โดยโอนข้อมูลระหว่างเว็บไซต์ให้น้อยที่สุด</translation>
<translation id="6107290018380796650">Ecosia ทำให้คุณสามารถคลิกที่หมายเลขโทรศัพท์บนเว็บแล้วโทรหาด้วย Skype!</translation>
<translation id="4567424176335768812">คุณกำลังลงชื่อเข้าใช้เป็น <ph name="USER_EMAIL_ADDRESS"/> ตอนนี้คุณสามารถเข้าถึงบุ๊กมาร์ก ประวัติการเข้าชม และการตั้งค่าอื่นๆ บนอุปกรณ์ทั้งหมดที่ลงชื่อเข้าใช้</translation>
<translation id="6533266716128249922">ไปที่การตั้งค่าการแจ้งเตือน Ecosia</translation>
<translation id="488806616089631539">เมื่อ Ecosia มีสิทธิ์การเข้าถึงแล้ว เว็บไซต์จะขอสิทธิ์การเข้าถึงจากคุณได้</translation>
<translation id="3268039966078382323">Ecosia อัปเดตเป็นเวอร์ชันล่าสุดไม่ได้ คุณจึงไม่ได้รับฟีเจอร์ใหม่และการแก้ไขด้านความปลอดภัย</translation>
<translation id="4690206707618474800">ไม่บังคับ: ช่วยปรับปรุงฟีเจอร์และประสิทธิภาพของ Ecosia OS Flex ด้วยการส่งข้อมูลการวินิจฉัยและการใช้งานให้ Ecosia โดยอัตโนมัติ</translation>
<translation id="9125443060066914183">เพื่อให้ Ecosia ปลอดภัยขึ้น เราปิดส่วนขยายบางรายการที่ไม่ได้ระบุไว้ใน <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> และอาจถูกเพิ่มเข้ามาโดยที่คุณไม่รู้ตัว</translation>
<translation id="4680828127924988555">ยกเลิกการติดตั้ง</translation>
<translation id="8236553889322631924">ส่วนขยาย แอป และธีมจากแหล่งที่มาที่ไม่รู้จักอาจเป็นอันตรายต่ออุปกรณ์ของคุณ ขอแนะนำให้ติดตั้ง Ecosia จาก Ecosia เว็บสโตร์เท่านั้น</translation>
<translation id="3305517118160815955">การติดตั้งล้มเหลวเนื่องจากมีข้อผิดพลาดที่ไม่ได้ระบุ หาก Ecosia ทำงานอยู่ในขณะนี้ โปรดปิดและลองอีกครั้ง</translation>
<translation id="4747730611090640388">Chrome สามารถคาดคะเนความสนใจของคุณได้  ภายหลัง เว็บไซต์ที่คุณเข้าชมอาจขอข้อมูลความสนใจจาก Chrome เพื่อปรับการแสดงโฆษณาให้เหมาะกับคุณ</translation>
<translation id="827222962844006655">Ecosia Canary (mDNS-In)</translation>
<translation id="2243562167758283214">ไฟล์นี้อาจเป็นอันตราย Ecosia จึงบล็อกไว้</translation>
<translation id="3543284013834505767">การดำเนินการนี้จะใช้โปรแกรมตรวจตัวสะกดแบบเดียวกับใน Ecosia Search ข้อความที่คุณพิมพ์ในเบราว์เซอร์จะส่งไปยัง Ecosia คุณปรับเปลี่ยนลักษณะการทำงานนี้ได้ทุกเมื่อในการตั้งค่า</translation>
<translation id="8144706290339578682">Ecosia OS Flex ซิงค์ข้อมูลไม่ได้เนื่องจากการซิงค์ใช้ไม่ได้กับโดเมนของคุณ</translation>
<translation id="4873783916118289636">ตรวจสอบการควบคุมที่สำคัญด้านความเป็นส่วนตัวและความปลอดภัยใน Chrome</translation>
<translation id="8454595950895325762">ให้ Ecosia ทำงานในเบื้องหลัง</translation>
<translation id="489671036945006830">เปิดลิงก์ใน Ecosia แท็บใหม่</translation>
<translation id="5581150090232500900">ตั้ง Ecosia เป็นเบราว์เซอร์เริ่มต้นของคุณ</translation>
<translation id="6495878830719404098">ใน Ecosia</translation>
<translation id="6113625922434842626">Ecosia OS Flex ซิงค์ข้อมูลไม่ได้เนื่องจากรายละเอียดการลงชื่อเข้าใช้บัญชีไม่เป็นปัจจุบัน</translation>
<translation id="4410570812343670816">ยินดีต้อนรับสู่โปรไฟล์ Ecosia</translation>
<translation id="4970880042055371251">เวอร์ชัน Chrome OS</translation>
<translation id="796435732739009892">Ecosia บล็อกไฟล์นี้เนื่องจากไฟล์ประเภทนี้เป็นอันตราย</translation>
<translation id="8570641140903702642">Ecosia Canary</translation>
<translation id="6718055545215052843">คุณจะต้องใช้ macOS 10.13 ขึ้นไปเพื่อรับการอัปเดต Ecosia ในอนาคต คอมพิวเตอร์เครื่องนี้ใช้ OS X 10.11</translation>
<translation id="5098668839038261629">หากเปิดใช้ คุณจะออกจากระบบของ Chrome ด้วย</translation>
<translation id="7782767522222146179">พบกับแอป เกม ส่วนขยาย และธีมเด็ดๆ สำหรับ Ecosia</translation>
<translation id="6416551953415159186">ปรับแต่งโปรไฟล์ Ecosia ของคุณ</translation>
<translation id="1859120614572957305">ยินดีต้อนรับสู่ Ecosia เปิดหน้าต่างเบราวเซอร์ใหม่แล้ว</translation>
<translation id="6648664289472946060">โปรไฟล์ของคุณไม่สามารถใช้ได้เพราะมาจากรุ่นที่ใหม่กว่าของ Ecosia ฟีเจอร์บางอย่างอาจจะไม่พร้อมใช้งาน โปรดระบุไดเรกทอรีของโปรไฟล์อื่นหรือใช้ Ecosia รุ่นที่ใหม่กว่า</translation>
<translation id="6960183526681645011">เพื่อนและครอบครัวสามารถท่องเว็บแยกกันและตั้งค่า Ecosia ตามที่ตนต้องการในกรณีที่ใช้อุปกรณ์ร่วมกัน</translation>
<translation id="1869027055332251164">ผู้เยี่ยมชมสามารถใช้ Ecosia ได้โดยไม่ทิ้งร่องรอยไว้</translation>
<translation id="143614250230771428">Ecosia OS ซิงค์ข้อมูลไม่ได้เนื่องจากการซิงค์ไม่พร้อมใช้งานสำหรับโดเมนของคุณ</translation>
<translation id="1809194740315140401">Ecosia ต้องการสิทธิ์เข้าถึงพื้นที่เก็บข้อมูลเพื่อดาวน์โหลดไฟล์</translation>
<translation id="8975930032513941502">ไม่บังคับ: ช่วยปรับปรุงฟีเจอร์และประสิทธิภาพของ Ecosia OS โดยการส่งข้อมูลการวินิจฉัยและการใช้งานให้ Ecosia โดยอัตโนมัติ</translation>
<translation id="5357889879764279201">รับความช่วยเหลือเกี่ยวกับ Chrome OS Flex</translation>
<translation id="6665128960039431910">อีกทั้งยังควบคุมหน้าที่จะแสดงเมื่อคุณเปิด Ecosia หรือทำการค้นหาจากแถบอเนกประสงค์ด้วย</translation>
<translation id="1861504561909287316">แชร์แท็บ Ecosia</translation>
<translation id="5412485296464121825">เว็บไซต์สามารถจัดเก็บข้อมูลเกี่ยวกับความสนใจไว้กับ Chrome ตัวอย่างเช่น หากคุณเข้าชมเว็บไซต์เพื่อซื้อรองเท้าวิ่งมาราธอน เว็บไซต์นี้อาจระบุว่าคุณสนใจการวิ่งมาราธอน ภายหลัง เมื่อคุณเข้าชมเว็บไซต์อื่นเพื่อลงทะเบียนแข่งมาราธอน เว็บไซต์นี้ก็อาจแสดงโฆษณารองเท้าวิ่งโดยอิงจากความสนใจดังกล่าว</translation>
<translation id="6673288084648462613">ไฟล์ค่ากำหนดของคุณขัดข้องหรือไม่ถูกต้อง Ecosia ไม่สามารถกู้คืนการตั้งค่าของคุณได้</translation>
<translation id="5524761631371622910">เมื่อเริ่มการทดสอบและหาก Chrome สุ่มคุณไปไว้ในการทดสอบที่ดำเนินอยู่ ประวัติการท่องเว็บจะส่งผลต่อโฆษณาที่คุณเห็นและความสนใจที่ระบบคาดคะเนไว้ดังที่แสดงอยู่ด้านล่างนี้ Chrome ลบความสนใจเป็นประจำทุกเดือนเพื่อปกป้องความเป็นส่วนตัวของคุณ</translation>
<translation id="2905159584855395810">ทำให้ Ecosia เร็วขึ้น</translation>
<translation id="2549591663512786020">Ecosia กำลังพยายามแสดงรหัสผ่าน</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/> อาจเป็นอันตราย Ecosia จึงบล็อกไว้</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{ผู้ดูแลระบบขอให้คุณเปิด Ecosia ขึ้นมาใหม่เพื่อใช้การอัปเดตนี้}=1{ผู้ดูแลระบบขอให้คุณเปิด Ecosia ขึ้นมาใหม่เพื่อใช้การอัปเดตนี้ หน้าต่างที่ไม่ระบุตัวตนจะไม่เปิดให้อีก}other{ผู้ดูแลระบบขอให้คุณเปิด Ecosia ขึ้นมาใหม่เพื่อใช้การอัปเดตนี้ หน้าต่างที่ไม่ระบุตัวตนจำนวน # หน้าต่างจะไม่เปิดให้อีก}}</translation>
<translation id="8544776492099331022">ปรับแต่งและควบคุม Ecosia มีสิ่งที่คุณจำเป็นต้องทราบ โปรดคลิกเพื่อดูรายละเอียด</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="5789438819244101666">{SECONDS,plural, =1{Ecosia จะรีสตาร์ทใน 1 วินาที}other{Ecosia จะรีสตาร์ทใน # วินาที}}</translation>
<translation id="5727531838415286053">หาก Chrome สุ่มคุณไปไว้ในการทดสอบที่ดำเนินอยู่ ประวัติการท่องเว็บจะส่งผลต่อโฆษณาที่คุณเห็นและความสนใจที่ระบบคาดคะเนไว้ดังที่แสดงอยู่ด้านล่างนี้ Chrome ลบความสนใจเป็นประจำทุกเดือนเพื่อปกป้องความเป็นส่วนตัวของคุณ ระบบจะรีเฟรชความสนใจหากคุณไม่นำออก</translation>
<translation id="5736850870166430177">หากเว็บไซต์พยายามขโมยรหัสผ่าน หรือคุณดาวน์โหลดไฟล์ที่เป็นอันตราย Chrome อาจส่ง URL รวมถึงเนื้อหาบางส่วนในหน้าไปยัง Google Safe Browsing ด้วย</translation>
<translation id="8301840715671593762">มีโปรไฟล์ Ecosia ที่ใช้บัญชีนี้ในอุปกรณ์นี้อยู่แล้ว</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia Canary</translation>
<translation id="2542649989941327712">เปิด Ecosia ไม่ได้ โปรดลองอีกครั้ง</translation>
<translation id="6338684070520405381">Ecosia กำลังพยายามแก้ไขรหัสผ่าน</translation>
<translation id="5895138241574237353">ปิดแล้วเปิดอีกครั้ง</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - หน้าลงชื่อเข้าใช้ของเครือข่าย</translation>
<translation id="5924017743176219022">กำลังเชื่อมต่ออินเทอร์เน็ต...</translation>
<translation id="4960252760049500399">เว็บของคุณ บุ๊กมาร์ก และสิ่งอื่นๆ ใน Ecosia พร้อมใช้แล้วที่นี่</translation>
<translation id="5941711191222866238">ย่อเล็กสุด</translation>
<translation id="4662363689050405237">ทำให้ Ecosia เป็นเบราว์เซอร์เริ่มต้น</translation>
<translation id="6003112304606738118">กำลังดาวน์โหลด... เหลืออีก <ph name="HOURS"/> ชั่วโมง</translation>
<translation id="3138995062177413515">{0,plural, =0{Ecosia จะปิดลงในตอนนี้}=1{Ecosia จะปิดลงใน 1 วินาที}other{Ecosia จะปิดลงใน # วินาที}}</translation>
<translation id="6040143037577758943">ปิด</translation>
<translation id="6070348360322141662">Google Chrome จะเข้ารหัสลับข้อมูลของคุณเพื่อเพิ่มความปลอดภัยให้มากยิ่งขึ้น</translation>
<translation id="608006075545470555">เพิ่มโปรไฟล์งานลงในเบราว์เซอร์นี้</translation>
<translation id="170259281605734125">Ecosia ดีขึ้นกว่าเดิม</translation>
<translation id="6145313976051292476">เปิด PDF ใน Chrome</translation>
<translation id="6039735020616040749">โหมดประหยัดหน่วยความจําช่วยให้ Ecosia ทํางานได้เร็วขึ้น</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - Ecosia</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia เบต้า</translation>
<translation id="4154538917942874814">กฎขาเข้าสำหรับ Ecosia เพื่ออนุญาตการเข้าชมแบบ mDNS</translation>
<translation id="8542320769345885402">เครื่องมือจัดการรหัสผ่านบน Ecosia</translation>
<translation id="6273793429163604305">เข้าที่...</translation>
<translation id="675229436434399924">แอป Ecosia Dev</translation>
<translation id="4870057811531036437">มีการติดตั้ง Ecosia สำหรับผู้ใช้ทุกคนบนคอมพิวเตอร์ของคุณแล้ว</translation>
<translation id="330264384086604869">ลบจาก Ecosia</translation>
<translation id="6327105987658262776">ไม่มีอัปเดตพร้อมใช้งาน</translation>
<translation id="6412673304250309937">ตรวจสอบ URL กับรายการเว็บไซต์ที่ไม่ปลอดภัยซึ่งจัดเก็บไว้ใน Chrome หากเว็บไซต์พยายามขโมยรหัสผ่าน หรือคุณดาวน์โหลดไฟล์ที่เป็นอันตราย Chrome อาจส่ง URL รวมถึงเนื้อหาบางส่วนในหน้าไปยัง Google Safe Browsing ด้วย</translation>
<translation id="4781882243268600858">เปลี่ยนไปใช้โปรไฟล์ Ecosia ที่มีอยู่ไหม</translation>
<translation id="2537426042760364251">Ecosia ต้องการสิทธิ์เข้าถึงกล้องเพื่อสร้างแผนที่ 3 มิติของสิ่งที่อยู่รอบตัวคุณ</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - Ecosia Dev</translation>
<translation id="5357908757303442841">เครื่องมือจัดการรหัสผ่านบน Ecosia ในอุปกรณ์นี้</translation>
<translation id="8859253218356192164">Ecosia OS Flex เกิดขึ้นได้ด้วยการสนับสนุนจาก<ph name="BEGIN_LINK_CROS_OSS"/>ซอฟต์แวร์โอเพนซอร์ส<ph name="END_LINK_CROS_OSS"/>เพิ่มเติม</translation>
<translation id="6676384891291319759">เข้าถึงอินเทอร์เน็ต</translation>
<translation id="4586967042094107073">ให้ Ecosia ทำงานในพื้นหลัง</translation>
<translation id="2173571365716863400">Ecosia ต้องการสิทธิ์เข้าถึงไมโครโฟนสำหรับเว็บไซต์นี้</translation>
<translation id="6161025257729272170">ทำให้ Ecosia เร็วขึ้น</translation>
<translation id="9165312115453649251">ระบบ Ecosia OS Flex</translation>
<translation id="8685318202174822382">ดำเนินการต่อในโปรไฟล์ Ecosia ใหม่ไหม</translation>
<translation id="6750954913813541382">Chrome จะส่งข้อความที่คุณพิมพ์ในเบราว์เซอร์ไปยัง Google เพื่อแก้ไขข้อผิดพลาดของการสะกดคำ</translation>
<translation id="88039520238670574">ออกจาก Ecosia ใช่ไหม</translation>
<translation id="8583650869792032882">กฎขาเข้าสำหรับ Ecosia Canary เพื่ออนุญาตการเข้าชมแบบ mDNS</translation>
<translation id="6881299373831449287">กำลังอัปเดต Chrome</translation>
<translation id="6800892712521842441">แอป Ecosia เบต้า</translation>
<translation id="5267683457871579197">ระบบ Ecosia OS</translation>
<translation id="8963533629322868062">คุณจะต้องใช้ Windows 10 ขึ้นไปเพื่อรับการอัปเดต Ecosia ในอนาคต คอมพิวเตอร์เครื่องนี้ใช้ Windows 8.1</translation>
<translation id="2128110540135015661">ระบบจะลบข้อมูลการท่องเว็บของบุคคลนี้ออกจากอุปกรณ์เครื่องนี้ หากต้องการกู้ข้อมูลคืน ให้ลงชื่อเข้าใช้ Ecosia ในชื่อ <ph name="USER_EMAIL"/></translation>
<translation id="2434044214904689670">กฎขาเข้าสำหรับ Ecosia เบต้าเพื่ออนุญาตการเข้าชมแบบ mDNS</translation>
<translation id="7482156490649194631">อัปเดต Ecosia แล้ว แต่คุณไม่ได้ใช้งานมาไม่ต่ำกว่า 30 วันแล้ว</translation>
<translation id="7025789849649390912">หยุดการติดตั้งแล้ว</translation>
<translation id="4032832945953542360">คุณสลับไปมาระหว่างโปรไฟล์ Ecosia ได้ที่นี่</translation>
<translation id="931416298178634530">หากต้องการใช้บัญชีนี้เพียงครั้งเดียว คุณสามารถใช้<ph name="GUEST_LINK_BEGIN"/>โหมดผู้มาเยือน<ph name="GUEST_LINK_END"/>ในเบราว์เซอร์ Ecosia ได้ หากต้องการเพิ่มบัญชีสำหรับผู้อื่น ให้<ph name="LINK_BEGIN"/>เพิ่มบุคคลใหม่<ph name="LINK_END"/>ลงใน <ph name="DEVICE_TYPE"/>

สิทธิ์ที่คุณให้กับเว็บไซต์และแอปต่างๆ ไว้แล้วอาจมีผลกับบัญชีนี้ คุณจัดการบัญชี Ecosia ใน<ph name="SETTINGS_LINK_BEGIN"/>การตั้งค่า<ph name="SETTINGS_LINK_END"/>ได้</translation>
<translation id="4281355161119203663">ผู้ปกครองได้ปิด "สิทธิ์สำหรับเว็บไซต์ แอป และส่วนขยาย" ใน Ecosia ไม่อนุญาตให้เพิ่ม<ph name="EXTENSION_TYPE_PARAMETER"/>นี้</translation>
<translation id="7085332316435785646">เลือกว่าจะรวมประวัติการเข้าชม Chrome เพื่อรับประสบการณ์ที่ปรับเปลี่ยนในแบบของคุณมากขึ้นในบริการของ Google หรือไม่</translation>
<translation id="7088681679121566888">Chrome เป็นเวอร์ชันล่าสุดแล้ว</translation>
<translation id="1318059253725731825">Ecosia ใช้ไมโครโฟนอยู่</translation>
<translation id="8933665254023068908">เปิดอีกครั้งเพื่ออัปเดต &amp;Ecosia OS</translation>
<translation id="7311066525704006840">ตัวจัดการงาน - Ecosia</translation>
<translation id="3212611709533299048">{COUNT,plural, =0{อัปเดตใหม่ของ Ecosia พร้อมให้ใช้งานแล้วและระบบจะใช้อัปเดตดังกล่าวเมื่อคุณเปิด Ecosia ขึ้นมาใหม่}=1{อัปเดตใหม่ของ Ecosia พร้อมให้ใช้งานแล้วและระบบจะใช้อัปเดตดังกล่าวเมื่อคุณเปิด Ecosia ขึ้นมาใหม่ หน้าต่างที่ไม่ระบุตัวตนจะไม่เปิดให้อีก}other{อัปเดตใหม่ของ Ecosia พร้อมให้ใช้งานแล้วและระบบจะใช้อัปเดตดังกล่าวเมื่อคุณเปิด Ecosia ขึ้นมาใหม่ หน้าต่างที่ไม่ระบุตัวตนจำนวน # หน้าต่างจะไม่เปิดให้อีก}}</translation>
<translation id="7155997830309522122">หากเปลี่ยนแล้ว โปรดแก้ไขรหัสผ่านที่บันทึกไว้ใน Chrome ให้ตรงกับรหัสผ่านใหม่</translation>
<translation id="1027331268335328576">ยินดีต้อนรับสู่ Ecosia</translation>
<translation id="675365189802108507">คุณดูข้อมูลเพิ่มเติมเกี่ยวกับฟีเจอร์เหล่านี้ได้ในการตั้งค่า Ecosia</translation>
<translation id="4239392394637574967">คุณกำลังลงชื่อเข้าใช้ด้วยบัญชีที่จัดการ และให้การควบคุมระดับผู้ดูแลระบบของบัญชีดังกล่าวเหนือโปรไฟล์ Ecosia ของคุณ ข้อมูล Ecosia เช่น แอป บุ๊กมาร์ก ประวัติการเข้าชม รหัสผ่าน และการตั้งค่าอื่นๆ จะเชื่อมโยงอย่างถาวรกับ <ph name="USER_NAME"/> คุณจะสามารถลบข้อมูลนี้ผ่านทางแผงควบคุมบัญชี Ecosia แต่คุณจะไม่สามารถเชื่อมโยงข้อมูลนี้กับบัญชีอื่น คุณสามารถเลือกที่จะสร้างโปรไฟล์ใหม่เพื่อแยกเก็บข้อมูล Ecosia ที่มีอยู่ของคุณ <ph name="LEARN_MORE"/></translation>
<translation id="7295052994004373688">นี่เป็นภาษาที่ใช้ในการแสดง UI ของ Google Chrome</translation>
<translation id="7296210096911315575">ข้อมูลสำคัญเกี่ยวกับการใช้งานและความปลอดภัย</translation>
<translation id="5549921590305750618">Ecosia ต้องการสิทธิ์เข้าถึงพื้นที่เก็บข้อมูลเพื่อดาวน์โหลดไฟล์</translation>
<translation id="7339898014177206373">หน้าต่างใหม่</translation>
<translation id="5337919616446681032">หากต้องการใช้บัญชีนี้เพียงครั้งเดียว คุณสามารถใช้โหมดผู้มาเยือนในเบราว์เซอร์ Ecosia ได้ หากต้องการเพิ่มบัญชีสำหรับผู้อื่น ให้<ph name="LINK_BEGIN"/>เพิ่มบุคคลใหม่<ph name="LINK_END"/>ลงใน <ph name="DEVICE_TYPE"/>

สิทธิ์ที่คุณให้กับเว็บไซต์และแอปต่างๆ ไว้แล้วอาจมีผลกับบัญชีนี้ คุณจัดการบัญชี Ecosia ใน<ph name="SETTINGS_LINK_BEGIN"/>การตั้งค่า<ph name="SETTINGS_LINK_END"/>ได้</translation>
<translation id="2412381038247037703">คุณเคยลงชื่อเข้าใช้ Ecosia ในชื่อ <ph name="USER_EMAIL_ADDRESS"/> โปรดใช้บัญชีเดิมเพื่อลงชื่อเข้าใช้อีกครั้ง</translation>
<translation id="5669097765101132299">Ecosia บล็อกไฟล์นี้เนื่องจากเป็นอันตราย</translation>
<translation id="3307959934543585795">Ecosia อาจทำงานไม่ถูกต้องเพราะไม่รองรับใน Linux Distribution นี้แล้ว</translation>
<translation id="12795904718916112">รับการรักษาความปลอดภัยที่เข้มงวดที่สุดของ Ecosia</translation>
<translation id="7486227612705979895">Chrome จะเข้าถึงไดรฟ์ของคุณเพื่อแสดงคำแนะนำในแถบที่อยู่</translation>
<translation id="932641430818191661">Ecosia Dev</translation>
<translation id="7583399374488819119">โปรแกรมติดตั้ง <ph name="COMPANY_NAME"/></translation>
<translation id="8275632261262434570">Ecosia OS Flex</translation>
<translation id="1027331268335328576">ยินดีต้อนรับสู่ Ecosia</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> กำหนดว่าคุณต้องอ่านและยอมรับข้อกำหนดในการให้บริการต่อไปนี้ก่อนใช้อุปกรณ์นี้ ข้อกำหนดเหล่านี้ไม่ได้ขยาย แก้ไข หรือจำกัดข้อกำหนดของ Ecosia OS</translation>
<translation id="1263466865695943046">Ecosia จะแจ้งให้ทราบหากมีคนล่วงรู้รหัสผ่านของคุณ</translation>
<translation id="7158975242722498086">ผู้ดูแลระบบได้กำหนดค่าให้ Ecosia เปิด <ph name="ALTERNATIVE_BROWSER_NAME"/> เพื่อเข้าถึง <ph name="TARGET_URL_HOSTNAME"/></translation>
<translation id="7649070708921625228">ความช่วยเหลือ</translation>
<translation id="93440396576488794">โลโก้ Ecosia Enterprise</translation>
<translation id="7655455401911432608">ประวัติการท่องเว็บ ซึ่งเป็นบันทึกรายการเว็บไซต์ที่คุณเข้าชมโดยใช้ Chrome ในอุปกรณ์นี้</translation>
<translation id="7747138024166251722">โปรแกรมติดตั้งสร้างไดเรกทอรีชั่วคราวไม่ได้ โปรดตรวจสอบพื้นที่ดิสก์ว่างและการอนุญาตให้ติดตั้งซอฟต์แวร์</translation>
<translation id="4871843754042758264">คลิกชื่อของคุณเพื่อเปิด Ecosia และเริ่มท่องเว็บ</translation>
<translation id="2046160555506209000">หากรูปภาพไม่มีคำอธิบายที่เป็นประโยชน์ Ecosia จะพยายามใส่คำอธิบายให้คุณ รูปภาพจะส่งมายัง Ecosia เพื่อสร้างคำอธิบาย คุณปิดการดำเนินการนี้ได้ทุกเมื่อในการตั้งค่า</translation>
<translation id="8447746441670667471">Ecosia เวอร์ชันใหม่มีให้ได้ลองใช้กันแล้ว</translation>
<translation id="5661123757512626239">Ecosia ต้องการสิทธิ์เข้าถึงตำแหน่งสำหรับเว็บไซต์นี้</translation>
<translation id="7722016758804384514">ดูเหมือนว่าโปรไฟล์กำลังถูกใช้งานโดยกระบวนการอื่นของ Ecosia (<ph name="PROCESS_ID"/>) บนคอมพิวเตอร์อีกเครื่อง (<ph name="HOST_NAME"/>)  Ecosia ล็อกโปรไฟล์ไว้เพื่อไม่ให้โปรไฟล์เกิดความเสียหาย  หากคุณมั่นใจว่าไม่มีกระบวนการอื่นใดกำลังใช้โปรไฟล์นี้อยู่ คุณสามารถปลดล็อกโปรไฟล์และเปิด Ecosia ใหม่</translation>
<translation id="1047556320128249268">Ecosia กำลังพยายามคัดลอกรหัสผ่าน โปรดพิมพ์รหัสผ่าน Windows ของคุณเพื่ออนุญาต</translation>
<translation id="4199684616787081033">นำออกจาก Ecosia...</translation>
<translation id="2402290209407843024">การติดตั้งล้มเหลวเนื่องจากเกิดข้อผิดพลาดที่ไม่ระบุ โปรดดาวน์โหลด Ecosia อีกครั้ง</translation>
<translation id="7845233973568007926">ขอขอบคุณที่ติดตั้ง คุณต้องรีสตาร์ทคอมพิวเตอร์ก่อนใช้ <ph name="BUNDLE_NAME"/></translation>
<translation id="7872446069773932638">กำลังดาวน์โหลด... เหลืออีก <ph name="SECONDS"/> วินาที</translation>
<translation id="2381210243314074423">ยินดีต้อนรับสู่ Ecosia คุณ <ph name="ACCOUNT_FIRST_NAME"/></translation>
<translation id="6111519389633335269">ถ้าคุณให้ผู้อื่นใช้คอมพิวเตอร์ร่วมด้วย เพื่อนๆ และครอบครัวของคุณสามารถท่องเว็บแยกกันได้และตั้งค่า Ecosia ได้ตามที่พวกเขาต้องการ</translation>
<translation id="4727435569202742773">ก่อนหน้านี้มีผู้ลงชื่อเข้าใช้ Ecosia ในคอมพิวเตอร์นี้ด้วยชื่อ <ph name="ACCOUNT_EMAIL_LAST"/> โปรดสร้างผู้ใช้ Ecosia ใหม่เพื่อเก็บข้อมูลแยก</translation>
<translation id="7917876797003313048">คุณจัดการบัญชี Google ที่ลงชื่อเข้าใช้ได้ บัญชี Google ใช้สำหรับเบราว์เซอร์ Chrome, Play Store, Gmail และอื่นๆ หากต้องการเพิ่มบัญชีให้คนอื่น เช่น สมาชิกในครอบครัว ให้เพิ่มบุคคลใหม่ลงใน <ph name="DEVICE_TYPE"/> แทน <ph name="LINK_BEGIN"/>ดูข้อมูลเพิ่มเติม<ph name="LINK_END"/></translation>
<translation id="8633885040939757689">Ecosia กำลังพยายามคัดลอกรหัสผ่าน</translation>
<translation id="4278262067490419012">Ecosia OS Flex ต้องรีสตาร์ทเพื่อใช้การอัปเดต</translation>
<translation id="7962368738413920945">เว็บไซต์อาจทำงานได้ตามที่ต้องการแต่จะไม่จดจำคุณหลังจากที่ปิดหน้าต่าง Chrome ทั้งหมด</translation>
<translation id="5781596646235827063">คอมพิวเตอร์เครื่องนี้จะไม่ได้รับการอัปเดต Ecosia อีกต่อไปเพราะระบบไม่รองรับ Windows XP และ Windows Vista แล้ว</translation>
<translation id="7783708361278795460">ที่เครื่องมือจัดการรหัสผ่านบน Ecosia ในอุปกรณ์นี้</translation>
<translation id="6984747211123632080">ติดตั้ง Ecosia ใหม่</translation>
<translation id="2838372953389311551">หากรูปภาพไม่มีคำอธิบายที่เป็นประโยชน์ Ecosia จะพยายามใส่คำอธิบายให้คุณ รูปภาพจะส่งมายัง Ecosia เพื่อสร้างคำอธิบาย</translation>
<translation id="80471789339884597">ขอขอบคุณที่ติดตั้ง คุณต้องรีสตาร์ทเบราว์เซอร์ทั้งหมดก่อนใช้ <ph name="BUNDLE_NAME"/></translation>
<translation id="8275632261262434570">Ecosia OS Flex</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="7221868538334633215">เกี่ยวกับ &amp;Ecosia</translation>
<translation id="813913629614996137">กำลังเริ่มดำเนินการ...</translation>
<translation id="4061472199368124600">Ecosia ใช้กล้องและไมโครโฟนของคุณอยู่</translation>
<translation id="8270775718612349140">ใบรับรองที่จัดการโดย Chrome</translation>
<translation id="3966234175958887595">Ecosia กำลังพยายามแสดงรหัสผ่าน พิมพ์รหัสผ่าน Windows ของคุณเพื่อแสดงรหัสผ่าน</translation>
<translation id="2290912123073552463">ผู้ปกครองได้ปิด "สิทธิ์สำหรับเว็บไซต์ แอป และส่วนขยาย" ใน Ecosia ไม่อนุญาตให้เปิดใช้<ph name="EXTENSION_TYPE_PARAMETER"/>นี้</translation>
<translation id="3216284932113164802">อ๊ะ! Ecosia ขัดข้อง เปิดใหม่ตอนนี้หรือไม่</translation>
<translation id="8341646175450781745">เมื่อเปิดใช้โหมดนี้ Chrome จะเพิ่มหน่วยความจําจากแท็บที่ไม่ได้ใช้งาน ซึ่งทําให้แท็บที่ใช้งานอยู่และแอปอื่นๆ มีทรัพยากรสําหรับคอมพิวเตอร์เพิ่มขึ้นและช่วยให้ Chrome ทํางานได้เร็ว แท็บที่ไม่มีการใช้งานจะกลับมาทํางานโดยอัตโนมัติเมื่อคุณไปที่แท็บเหล่านั้น <ph name="BEGIN_LINK"/>ดูข้อมูลเพิ่มเติม<ph name="END_LINK"/>หรือ<ph name="BEGIN_LINK_2"/>ส่งความคิดเห็น<ph name="END_LINK_2"/></translation>
<translation id="6491651957026506753">ไฟล์นี้อันตราย Ecosia จึงบล็อกไว้</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>วิธีที่เราใช้ข้อมูลนี้:<ph name="END_BOLD"/> เว็บไซต์สามารถจัดเก็บข้อมูลเกี่ยวกับความสนใจไว้กับ Ecosia ตัวอย่างเช่น หากคุณเข้าชมเว็บไซต์เพื่อซื้อรองเท้าวิ่งมาราธอน เว็บไซต์นี้อาจระบุว่าคุณสนใจการวิ่งมาราธอน ภายหลัง เมื่อคุณเข้าชมเว็บไซต์อื่นเพื่อลงทะเบียนแข่งมาราธอน เว็บไซต์นี้ก็อาจแสดงโฆษณารองเท้าวิ่งโดยอิงจากความสนใจดังกล่าว</translation>
<translation id="8355171755788522183">ลิขสิทธิ์ <ph name="YEAR"/> Ecosia สงวนลิขสิทธิ์</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>วิธีที่เราใช้ข้อมูลนี้:<ph name="END_BOLD"/> Ecosia ใช้ข้อมูลเพื่อคาดเดาความสนใจของคุณ จากนั้น เว็บไซต์ที่คุณเข้าชมจะขอให้ Ecosia ดูความสนใจของคุณเพื่อปรับเปลี่ยนการแสดงโฆษณาให้เหมาะสมตามความสนใจ</translation>
<translation id="5883025779824839861">ใช้ Ecosia ต่อ</translation>
<translation id="8394720698884623075">ตรวจสอบ URL กับรายการเว็บไซต์ที่ไม่ปลอดภัยซึ่งจัดเก็บไว้ใน Chrome</translation>
<translation id="4409756430498035341">Ecosia ต้องการส่งออกรหัสผ่านของคุณ</translation>
<translation id="5902103164685487225">ดูข้อมูลเพิ่มเติมเกี่ยวกับการปรับโฆษณาตามโปรไฟล์ของผู้ใช้ใน Ecosia</translation>
<translation id="592990842052138727">Ecosia OS ซิงค์ข้อมูลไม่ได้เนื่องจากรายละเอียดการลงชื่อเข้าใช้บัญชีของคุณไม่ใช่ข้อมูลปัจจุบัน</translation>
<translation id="665177868576952817">หากต้องการส่งหมายเลขจากที่นี่ไปยังโทรศัพท์ Android ให้ลงชื่อเข้าใช้ Ecosia ในอุปกรณ์ทั้งสองเครื่อง</translation>
<translation id="4070480171055648632">บัญชีของคุณจัดการโดย <ph name="MANAGER_NAME"/> ผู้ดูแลระบบสามารถดูและแก้ไขโปรไฟล์เบราว์เซอร์ Ecosia นี้ รวมถึงข้อมูลในโปรไฟล์อย่างเช่นบุ๊กมาร์ก ประวัติการเข้าชม และรหัสผ่านได้</translation>
<translation id="1025044809499013222">ระบบเพิ่งนำการอัปเดตความปลอดภัยพิเศษไปใช้กับ Ecosia รีสตาร์ทเลย แล้วเราจะคืนค่าแท็บให้คุณ</translation>
<translation id="7864624828358709494">Ecosia บล็อกไฟล์นี้เนื่องจากมีมัลแวร์</translation>
<translation id="3816260943154642689">ความสนใจของคุณที่ได้รับการคาดคะเนโดย Ecosia</translation>
<translation id="8023973672752791660">กฎขาเข้าสำหรับ Ecosia Dev เพื่ออนุญาตการเข้าชมแบบ mDNS</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="8550334526674375523">โปรไฟล์งานนี้แยกออกจากโปรไฟล์ส่วนตัวโดยสิ้นเชิง</translation>
<translation id="7185777478310554774">มี Ecosia รุ่นใหม่ให้ใช้งานแล้วและเร็วกว่าเดิม</translation>
<translation id="5622136942112821750">โปรไฟล์ Ecosia ช่วยให้คุณแยกข้อมูลต่างๆ ใน Ecosia ได้ ซึ่งทำให้แยกการทำงานออกจากความบันเทิงได้ง่ายขึ้น</translation>
<translation id="18064594488616674">Ecosia ไม่ตอบสนอง เปิดใช้งานใหม่ตอนนี้หรือไม่</translation>
<translation id="6896860023874996542">Ecosia ต้องการสิทธิ์เข้าถึงกล้องเพื่อสร้างแผนที่ 3 มิติของสิ่งที่อยู่รอบตัวคุณ</translation>
<translation id="7558678848273505235">{0,plural, =1{Ecosia จะเปิดขึ้นมาใหม่ใน 1 นาที}other{Ecosia จะเปิดขึ้นมาใหม่ใน # นาที}}</translation>
<translation id="8641606876632989680">Chrome จะแจ้งให้คุณทราบเมื่อคุณลงชื่อเข้าใช้ด้วยรหัสผ่านที่ไม่รัดกุม</translation>
<translation id="8649026945479135076">โดยทั่วไป เว็บไซต์ที่คุณเข้าชมจะจดจำสิ่งที่คุณสนใจเพื่อปรับประสบการณ์การใช้งานให้เหมาะกับคุณ เว็บไซต์ยังสามารถจัดเก็บข้อมูลเกี่ยวกับความสนใจไว้กับ Chrome ได้ด้วย</translation>
<translation id="9090890391337853620">ตัวช่วยเหลือของ Ecosia</translation>
<translation id="524314285625975879">อีกทั้งยังควบคุมหน้าที่จะแสดงเมื่อคุณเปิด Ecosia ด้วย</translation>
<translation id="4997668724897475215">Ecosia แนะนำให้สแกนไฟล์นี้เนื่องจากอาจเป็นอันตราย</translation>
<translation id="4170280082681554565">โปรไฟล์ Ecosia ช่วยให้คุณแยกข้อมูลต่างๆ ใน Ecosia ออกจากกัน สร้างโปรไฟล์สำหรับเพื่อนและครอบครัว หรือแยกการทำงานออกจากความบันเทิง</translation>
<translation id="8712767363896337380">ใกล้จะอัปเดตเสร็จแล้ว เปิด Chrome อีกครั้งเพื่อให้การอัปเดตเสร็จสมบูรณ์</translation>
<translation id="873133009373065397">Google Chrome ไม่สามารถกำหนดหรือตั้งค่าเบราว์เซอร์เริ่มต้น</translation>
<translation id="1975037445584526511">คุณจะต้องใช้ Windows 10 ขึ้นไปเพื่อรับการอัปเดต Ecosia ในอนาคต คอมพิวเตอร์เครื่องนี้ใช้ Windows 7</translation>
<translation id="2695952268686253864">Ecosia ล้าสมัย</translation>
<translation id="8825634023950448068">เราลบความสนใจที่เก่ากว่า 4 สัปดาห์โดยอัตโนมัติเพื่อปกป้องความเป็นส่วนตัวของคุณ ความสนใจอาจกลับมาปรากฏในรายการอีกเมื่อคุณท่องเว็บต่อ และหาก Chrome คาดคะเนผิดหรือคุณไม่ต้องการเห็นโฆษณาบางรายการ คุณนำความสนใจออกได้</translation>
<translation id="5066194399237265772">Ecosia กำลังพยายามแก้ไขรหัสผ่าน โปรดพิมพ์รหัสผ่าน Windows ของคุณเพื่ออนุญาต</translation>
<translation id="6078545897140861225">อีกทั้งยังควบคุมหน้าที่จะแสดงเมื่อคุณเปิด Ecosia หรือคลิกปุ่ม "หน้าแรก"</translation>
<translation id="1401515072108809622">Ecosia ไม่ทำงาน</translation>
<translation id="8862326446509486874">คุณไม่มีสิทธิ์ในการติดตั้งระดับระบบ ทดลองใช้งานโปรแกรมติดตั้งอีกครั้งโดยกำหนดให้เป็นผู้ดูแลระบบ</translation>
<translation id="8282620071565190081">เปิด Ecosia ขึ้นใหม่</translation>
<translation id="7849498640944199147">หากต้องการส่งหมายเลขจาก <ph name="ORIGIN"/> ไปยังโทรศัพท์ Android ให้ลงชื่อเข้าใช้ Ecosia ในอุปกรณ์ทั้งสองเครื่อง</translation>
<translation id="7910693244647744044">คุณเปิด Ecosia Safe Browsing เวอร์ชันปรับปรุงในบัญชีแล้ว เริ่มใช้ใน Ecosia กันเลย</translation>
<translation id="8986207147630327271">คุณกำลังเพิ่มโปรไฟล์งานลงในเบราว์เซอร์นี้และให้ผู้ดูแลระบบเป็นผู้ควบคุมเฉพาะโปรไฟล์งานดังกล่าว</translation>
<translation id="8989968390305463310">ประวัติการท่องเว็บส่งผลต่อโฆษณาที่คุณเห็นและความสนใจที่ระบบคาดคะเนไว้ดังที่แสดงอยู่ด้านล่างนี้ Chrome ลบความสนใจโดยอัตโนมัติเป็นประจำทุกเดือนเพื่อปกป้องความเป็นส่วนตัวของคุณ ระบบจะรีเฟรชความสนใจหากคุณไม่นำออก</translation>
<translation id="7348818664647668234">{0,plural, =0{มีอัปเดต Ecosia พร้อมให้ใช้งาน}=1{มีอัปเดต Ecosia พร้อมให้ใช้งาน}other{อัปเดต Ecosia พร้อมให้ใช้งานมาแล้ว # วัน}}</translation>
<translation id="9003498785844995646">เมื่อเปิดไว้ Chrome จะช่วยสงวนพลังงานแบตเตอรี่โดยการจำกัดกิจกรรมในเบื้องหลังและเอฟเฟกต์ภาพ เช่น การเลื่อนอย่างราบรื่นและอัตราเฟรมของวิดีโอ <ph name="BEGIN_LINK"/>ดูข้อมูลเพิ่มเติม<ph name="END_LINK"/>หรือ<ph name="BEGIN_LINK_2"/>ส่งความคิดเห็น<ph name="END_LINK_2"/></translation>
<translation id="9047384314208087523">ระบบ Ecosia OS Flex</translation>
<translation id="5675757883980078189">Ecosia ต้องใช้ Windows 7 ขึ้นไป</translation>
<translation id="911206726377975832">ลบข้อมูลการท่องเว็บด้วยหรือไม่</translation>
<translation id="9138603949443464873">เปิด Chrome ขึ้นมาใหม่เพื่อให้การเปลี่ยนแปลงมีผล</translation>
<translation id="9195993889682885387">Chrome สามารถคาดคะเนความสนใจโดยพิจารณาจากประวัติการท่องเว็บเมื่อ 2-3 สัปดาห์ที่ผ่านมา ข้อมูลนี้อยู่ในอุปกรณ์ของคุณ</translation>
<translation id="5704599732514791330">อัปเดต Ecosia เพื่อเริ่มการซิงค์</translation>
<translation id="838842459108103907">ปรับแต่ง Ecosia</translation>
<translation id="3070276123152913305">รีสตาร์ท Ecosia OS Flex</translation>
<translation id="4512092435423703529">หากต้องการเข้าถึงข้อมูล Ecosia ในอุปกรณ์ทั้งหมด ให้ลงชื่อเข้าใช้แล้วเปิดการซิงค์</translation>
<translation id="7972668220031382654">Ecosia แนะนำให้สแกนไฟล์นี้เนื่องจากอาจเป็นอันตราย</translation>
<translation id="989369509083708165">Google Chrome เป็นเบราว์เซอร์เริ่มต้นของคุณ</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> จะสลับไปมาระหว่างโปรไฟล์ Ecosia ได้</translation>
</translationbundle>
