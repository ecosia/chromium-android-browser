<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="th">
<translation id="4033006861724039519">การเก็บข้อมูลของโปรแกรมติดตั้งเสียหายหรือไม่ถูกต้อง โปรดดาวน์โหลด Ecosia อีกครั้ง</translation>
<translation id="1026101648481255140">ดำเนินการติดตั้งต่อ</translation>
<translation id="8296565077892323223">ปรับแต่งและควบคุม Ecosia มีการอัปเดต</translation>
<translation id="1761584959558744002">หากต้องการลบข้อมูลการท่องเว็บออกจากอุปกรณ์นี้เท่านั้น แต่ยังเก็บข้อมูลดังกล่าวไว้ในบัญชี Ecosia ให้<ph name="BEGIN_LINK"/>ออกจากระบบ Ecosia<ph name="END_LINK"/></translation>
<translation id="3271929752667225813">คลิกเพื่อปิดกล่องโต้ตอบการลงชื่อเข้าใช้ Ecosia</translation>
<translation id="2056307067005384438">หากต้องการใช้ส่วนขยายนี้ด้วย <ph name="USER_EMAIL_ADDRESS"/> ให้ลงชื่อเข้าใช้ Ecosia</translation>
<translation id="1065672644894730302">ค่ากำหนดของคุณไม่สามารถอ่านได้ ฟีเจอร์บางอย่างอาจใช้ไม่ได้และการเปลี่ยนแปลงค่ากำหนดจะไม่ได้รับการบันทึก</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> ใช้ Ecosia อยู่ก่อนหน้านี้</translation>
<translation id="2000339487270823788">นี่คือ Ecosia ของคุณ</translation>
<translation id="8078678931242443254">ใครกำลังใช้ Ecosia อยู่</translation>
<translation id="6346154190168496057">อัปเดต Ecosia ไม่ได้</translation>
<translation id="5312730628132049495">ลงชื่อเข้าใช้ Ecosia หากต้องการลงชื่อเข้าใช้บัญชีเพียงครั้งเดียว คุณสามารถ<ph name="GUEST_LINK_BEGIN"/>ใช้อุปกรณ์ในฐานะผู้มาเยือน<ph name="GUEST_LINK_END"/>ได้</translation>
<translation id="1152920704813762236">เกี่ยวกับ ChromeOS</translation>
<translation id="7303930050538184306">เ&amp;ปิดใน Ecosia</translation>
<translation id="1184145431117212167">ติดตั้งไม่สำเร็จเนื่องจากระบบไม่รองรับ Windows เวอร์ชันที่คุณใช้</translation>
<translation id="4988569127367972482">Ecosia บล็อกการดาวน์โหลดนี้เนื่องจากไฟล์ประเภทนี้ไม่ได้มีการดาวน์โหลดกันโดยทั่วไปและอาจเป็นอันตราย</translation>
<translation id="1203500561924088507">ขอขอบคุณที่ติดตั้ง คุณต้องรีสตาร์ทเบราว์เซอร์ก่อนใช้ <ph name="BUNDLE_NAME"/></translation>
<translation id="4517165228415697265">Ecosia แนะนำให้ตั้ง Ecosia เป็นค่าเริ่มต้น</translation>
<translation id="1265739287306757398">ดูวิธีการ</translation>
<translation id="1523806373970723624">เปิดอีกครั้งเพื่ออัปเดต Ecosia</translation>
<translation id="1290883685122687410">ข้อผิดพลาดในการตั้งค่า: <ph name="METAINSTALLER_EXIT_CODE"/> <ph name="WINDOWS_ERROR"/></translation>
<translation id="5279514147510747661">โปรดรอขณะที่ Ecosia ติดตั้งการอัปเดตระบบล่าสุด</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> กำหนดว่าคุณต้องอ่านและยอมรับข้อกำหนดในการให้บริการต่อไปนี้ก่อนใช้อุปกรณ์นี้ ข้อกำหนดเหล่านี้ไม่ขยาย แก้ไข หรือจำกัดข้อกำหนดของ Ecosia OS Flex</translation>
<translation id="3592624492063123732">คุณสามารถสลับเพื่อดูรหัสผ่านจากโปรไฟล์ Ecosia อื่นได้</translation>
<translation id="8067423333018528301">Ecosia OS ซิงค์ข้อมูลไม่ได้เนื่องจากเกิดข้อผิดพลาดในการลงชื่อเข้าใช้</translation>
<translation id="2926455547526018397">Ecosia เบต้า</translation>
<translation id="2995860351618948435">คอมพิวเตอร์เครื่องนี้มี Ecosia รุ่นใหม่กว่าแล้ว หากซอฟต์แวร์ไม่ทำงาน โปรดถอนการติดตั้ง Ecosia แล้วลองใหม่อีกครั้ง</translation>
<translation id="824192326282906244">คุณเปลี่ยนใจได้ทุกเมื่อในการตั้งค่า Ecosia การทดลองใช้จะทำงานพร้อมกับวิธีแสดงโฆษณาปัจจุบัน คุณจึงจะไม่เห็นการเปลี่ยนแปลงโดยทันที</translation>
<translation id="3621704124701415791">Ecosia มี Ecosia แปลภาษาในตัว คุณจึงแปลได้ทุกเมื่อที่ต้องการ</translation>
<translation id="5043324171996581320">{COUNT,plural, =0{Ecosia อัปเดตเสร็จแล้ว คุณจะใช้เวอร์ชันล่าสุดได้ทันทีที่เปิดอีกครั้ง หลังจากนั้น แท็บปัจจุบันจะเปิดขึ้นอีกครั้ง}=1{Ecosia อัปเดตเสร็จแล้ว คุณจะใช้เวอร์ชันล่าสุดได้ทันทีที่เปิดอีกครั้ง หลังจากนั้น แท็บปัจจุบันจะเปิดขึ้นอีกครั้ง หน้าต่างที่ไม่ระบุตัวตนจะไม่เปิดขึ้นอีก}other{Ecosia อัปเดตเสร็จแล้ว คุณจะใช้เวอร์ชันล่าสุดได้ทันทีที่เปิดอีกครั้ง หลังจากนั้น แท็บปัจจุบันจะเปิดขึ้นอีกครั้ง หน้าต่างที่ไม่ระบุตัวตนจำนวน # หน้าต่างจะไม่เปิดขึ้นอีก}}</translation>
<translation id="4696685525015809740">แอป Ecosia Canary</translation>
<translation id="7045045549868370797">ลงชื่อเข้าใช้ Ecosia ไหม</translation>
<translation id="1691902349688685912">เปิดอีกครั้งเพื่อให้การอัปเดต Ecosia เสร็จสิ้น</translation>
<translation id="1497802159252041924">ข้อผิดพลาดในการติดตั้ง: <ph name="INSTALL_ERROR"/></translation>
<translation id="3697186779259384993">ปรับแต่งโปรไฟล์ Ecosia ใหม่</translation>
<translation id="2441303983090031276">Ecosia OS เกิดขึ้นได้ด้วยการสนับสนุนจาก<ph name="BEGIN_LINK_CROS_OSS"/>ซอฟต์แวร์โอเพนซอร์ส<ph name="END_LINK_CROS_OSS"/>อื่นเพิ่มเติม</translation>
<translation id="5598074261782651109">อัปเดต Ecosia</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> ลงชื่อเข้าใช้โปรไฟล์ Ecosia นี้แล้ว การดำเนินการนี้จะสร้างโปรไฟล์ Ecosia ใหม่สำหรับ <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="4943938785458240142">Ecosia ใช้กล้องของคุณอยู่</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/> เป็นอันตราย Ecosia จึงบล็อกไว้</translation>
<translation id="1597911401261118146"><ph name="BEGIN_LINK"/>ลงชื่อเข้าใช้ Chrome<ph name="END_LINK"/> เพื่อตรวจสอบว่ารหัสผ่านของคุณไม่ได้รับผลกระทบจากการละเมิดข้อมูลและปัญหาด้านความปลอดภัยอื่นๆ</translation>
<translation id="1597547208646178091">เพื่อให้ Ecosia ปลอดภัยขึ้น เราได้ปิดส่วนขยายต่อไปนี้ซึ่งไม่ได้แสดงอยู่ใน <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> และอาจมีการเพิ่มเข้ามาโดยที่คุณไม่รู้ตัว</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>วิธีที่คุณจัดการข้อมูลของตัวเองได้:<ph name="END_BOLD"/> เราลบความสนใจที่เก่ากว่า 4 สัปดาห์โดยอัตโนมัติเพื่อปกป้องความเป็นส่วนตัวของคุณ ความสนใจอาจกลับมาปรากฏในรายการอีกเมื่อคุณท่องเว็บต่อ หรือคุณจะนำความสนใจที่ไม่ต้องการให้ Ecosia พิจารณาออกก็ได้</translation>
<translation id="1628000112320670027">รับความช่วยเหลือเกี่ยวกับ Chrome</translation>
<translation id="1640672724030957280">กำลังดาวน์โหลด...</translation>
<translation id="1662146548738125461">เกี่ยวกับ Chrome OS Flex</translation>
<translation id="5500958820122281144">เปิดลิงก์ในหน้าต่างที่ไม่ระบุตัวตนของ Ecosia</translation>
<translation id="7602423871874451395">Ecosia ไม่สามารถอ่านและเขียนข้อมูลในไดเรกทอรีข้อมูล: <ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="2020747823154282691">Ecosia สามารถทำให้แท็บนี้ไม่ทำงานเพื่อปรับปรุงประสบการณ์การท่องเว็บและทำให้ทุกอย่างทำงานได้เร็วขึ้น</translation>
<translation id="3939060118711873999">Ecosia คือเว็บเบราว์เซอร์ที่แสดงหน้าเว็บและแอปพลิเคชันต่างๆ ได้รวดเร็วในพริบตา โดยทำงานได้เร็ว มีเสถียรภาพ และใช้งานง่าย ช่วยให้คุณเรียกดูเว็บได้อย่างปลอดภัยมากขึ้นด้วยการป้องกันมัลแวร์และฟิชชิงซึ่งมีอยู่ใน Ecosia</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia จะเปิดขึ้นมาใหม่ใน 1 ชั่วโมง}other{Ecosia จะเปิดขึ้นมาใหม่ใน # ชั่วโมง}}</translation>
<translation id="1722488837206509557">สิทธิ์นี้จะช่วยให้คุณสามารถเลือกจากอุปกรณ์ที่พร้อมใช้งานและแสดงเนื้อหาบนอุปกรณ์เหล่านั้น</translation>
<translation id="4021894801595982809">Ecosia จะบันทึกรหัสผ่านนี้ในบัญชี Ecosia คุณจะได้ไม่ต้องจำรหัสผ่านเอง</translation>
<translation id="2346323077583431428">ตรวจสอบว่าคุณลงชื่อเข้าใช้ Ecosia ใน <ph name="TARGET_DEVICE_NAME"/> แล้วลองส่งอีกครั้ง</translation>
<translation id="788366290112401490">แป้นพิมพ์ลัดที่เปิดใน Ecosia</translation>
<translation id="6180968682827452331">ระบบไม่รองรับส่วนขยายนี้แล้ว Ecosia แนะนำให้คุณนำออกแทน</translation>
<translation id="1812689907177901597">เมื่อปิดการตั้งค่านี้ คุณจะลงชื่อเข้าใช้เว็บไซต์ของ Google อย่างเช่น Gmail ได้โดยไม่ต้องลงชื่อเข้าใช้ Chrome</translation>
<translation id="5055330219314726197">Ecosia ต้องการสิทธิ์เข้าถึงกล้องถ่ายรูปของคุณสำหรับเว็บไซต์นี้</translation>
<translation id="1508200558303644420">Ecosia ไม่ใช่เบราว์เซอร์เริ่มต้น</translation>
<translation id="8135642897811755229">Ecosia เบต้า (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia ล้าสมัย</translation>
<translation id="8228132389897276908">หากต้องการแชร์หน้าต่าง ให้อนุญาตการบันทึกหน้าจอสำหรับ Ecosia ใน "ค่ากำหนดของระบบ"</translation>
<translation id="1919130412786645364">อนุญาตให้ลงชื่อเข้าใช้ Chrome</translation>
<translation id="1953553007165777902">กำลังดาวน์โหลด... เหลืออีก <ph name="MINUTE"/> นาที</translation>
<translation id="8116259102110666562">Ecosia ทำงานได้กับทุกแพลตฟอร์มเพื่อมอบประสบการณ์การใช้งานที่คุ้นเคยไม่ว่าคุณจะใช้อุปกรณ์ใดก็ตาม</translation>
<translation id="2001586581944147178">ทำให้ผู้ที่มีสิทธิ์เข้าถึงการเข้าใช้อินเทอร์เน็ตของคุณดูว่าคุณเข้าชมเว็บไซต์ไหนบ้างได้ยากขึ้น Chrome ใช้การเชื่อมต่อที่ปลอดภัยเพื่อค้นหาที่อยู่ IP ของเว็บไซต์ใน DNS (ระบบชื่อโดเมน)</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{ระบบไม่รองรับส่วนขยายนี้อีกต่อไป Ecosia ขอแนะนำให้คุณนำออก}other{ระบบไม่รองรับส่วนขยายเหล่านี้อีกต่อไป Ecosia ขอแนะนําให้คุณนําออก}}</translation>
<translation id="8608092457636055141">แต่ละโปรไฟล์จะเก็บข้อมูล Ecosia ของตัวเอง เช่น บุ๊กมาร์ก ประวัติการเข้าชม รหัสผ่าน และอื่นๆ</translation>
<translation id="2018879682492276940">การติดตั้งไม่สำเร็จ โปรดลองอีกครั้ง</translation>
<translation id="686474599126256998">ขณะที่เรากำลังตั้งค่าสิทธิ์เข้าถึงบัญชี คุณจะยังคงใช้ Ecosia ได้ แต่อาจเข้าถึงทรัพยากรบางอย่างไม่ได้จนกว่าการตั้งค่าจะเสร็จสมบูรณ์</translation>
<translation id="2034233344106846793">Chrome จะอัปเกรดการเชื่อมต่อที่ไม่ปลอดภัยเป็น HTTPS โดยอัตโนมัติเมื่อทำได้</translation>
<translation id="207902854391093810">เมื่อเริ่มการทดสอบ การวัดผลโฆษณาจะให้เว็บไซต์ที่คุณเข้าชมสามารถขอข้อมูลจาก Chrome เพื่อช่วยวัดประสิทธิภาพโฆษณาของเว็บไซต์ดังกล่าวได้ การวัดผลโฆษณาจะจำกัดการติดตามข้ามเว็บไซต์โดยโอนข้อมูลระหว่างเว็บไซต์ให้น้อยที่สุด</translation>
<translation id="8655983536493871574">คุณจะต้องใช้ Windows 10 ขึ้นไปเพื่อรับการอัปเดต Ecosia ในอนาคต คอมพิวเตอร์เครื่องนี้ใช้ Windows 8</translation>
<translation id="3590393640971125498">ข้อกำหนดของ Ecosia OS Flex</translation>
<translation id="864244542982029641">ปิด Ecosia ใช่ไหม</translation>
<translation id="3791194915692553395">Ecosia OS Flex เกิดขึ้นได้ด้วยการสนับสนุนจาก<ph name="BEGIN_LINK_CROS_OSS"/>ซอฟต์แวร์โอเพนซอร์ส<ph name="END_LINK_CROS_OSS"/>เพิ่มเติม เช่นเดียวกับ<ph name="BEGIN_LINK_LINUX_OSS"/>สภาพแวดล้อมในการพัฒนาซอฟต์แวร์ Linux<ph name="END_LINK_LINUX_OSS"/></translation>
<translation id="2120620239521071941">การดำเนินการนี้จะลบ <ph name="ITEMS_COUNT"/> รายการออกจากอุปกรณ์นี้ หากต้องการดึงข้อมูลภายหลัง ให้ลงชื่อเข้าใช้ Chrome ด้วย <ph name="USER_EMAIL"/></translation>
<translation id="2159716220295742156">เปิดอีกครั้งเพื่ออัปเดต Ecosia</translation>
<translation id="2123055963409958220">ช่วยให้ Chrome ดียิ่งขึ้นด้วยการรายงาน<ph name="BEGIN_LINK"/>การตั้งค่าปัจจุบัน<ph name="END_LINK"/></translation>
<translation id="2126108037660393668">ไฟล์ที่ดาวน์โหลดไม่ผ่านการยืนยัน</translation>
<translation id="2985399486579137606">จัดการโปรไฟล์ Ecosia</translation>
<translation id="2131230230468101642">เราลบความสนใจที่เก่ากว่า 4 สัปดาห์โดยอัตโนมัติเพื่อปกป้องความเป็นส่วนตัวของคุณ ความสนใจอาจกลับมาปรากฏในรายการอีกเมื่อคุณท่องเว็บต่อ หรือคุณจะนำความสนใจที่ไม่ต้องการให้ Chrome พิจารณาออกก็ได้</translation>
<translation id="5404489723475681578">รีสตาร์ท Ecosia OS</translation>
<translation id="5982672133249369264">โปรดรีสตาร์ท Ecosia ตอนนี้เลย</translation>
<translation id="2174917724755363426">การติดตั้งไม่สมบูรณ์ คุณแน่ใจไหมว่าต้องการยกเลิก</translation>
<translation id="2190166659037789668">ข้อผิดพลาดในการตรวจสอบการอัปเดต: <ph name="UPDATE_CHECK_ERROR"/></translation>
<translation id="2199691482078155239">Chrome ให้คุณควบคุมโฆษณาที่เห็นได้มากขึ้น และจำกัดว่าเว็บไซต์จะรู้อะไรเกี่ยวกับคุณได้บ้างเมื่อแสดงโฆษณาที่ปรับตามโปรไฟล์ของผู้ใช้</translation>
<translation id="7347725536241560534">หากต้องการนำบัญชี Ecosia ออกจาก Ecosia ให้ออกจากระบบ</translation>
<translation id="223889379102603431">ข้อมูลเกี่ยวกับวิธีที่ Chrome จัดการใบรับรองรูท</translation>
<translation id="4337034173783952373">หากต้องการเข้าถึงข้อมูลของคุณในเบราว์เซอร์ Ecosia ในอุปกรณ์ทั้งหมด ให้ลงชื่อเข้าใช้แล้วเปิดการซิงค์</translation>
<translation id="4735588186234302898">คีย์ API ของ Ecosia หายไป การทำงานบางอย่างของ Ecosia จะถูกปิดใช้งาน</translation>
<translation id="7908111389403807005">คุณแน่ใจหรือไม่ว่าต้องการยกเลิกการติดตั้ง Ecosia</translation>
<translation id="2309047409763057870">นี่เป็นการติดตั้ง Google Chrome แบบสำรอง และไม่สามารถใช้เป็นเบราว์เซอร์เริ่มต้นของคุณ</translation>
<translation id="7613817989637275906">Ecosia พบว่าส่วนขยายเหล่านี้มีมัลแวร์</translation>
<translation id="7273750863406285983">Ecosia ต้องการสิทธิ์เข้าถึงไมโครโฟนและกล้องถ่ายรูปของคุณสำหรับเว็บไซต์นี้</translation>
<translation id="234869673307233423">Chrome ตรวจสอบรหัสผ่านของคุณไม่ได้ โปรดลองอีกครั้งภายหลัง</translation>
<translation id="5707346538075088068">ผู้ดูแลโปรไฟล์งานนำข้อมูล Ecosia ที่สร้างขึ้นในช่วงที่มีการใช้โปรไฟล์นี้ออกได้ (เช่น การสร้างบุ๊กมาร์ก ประวัติการเข้าชม รหัสผ่าน และการตั้งค่าอื่นๆ) <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">ต่อไป</translation>
