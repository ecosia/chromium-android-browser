<translation id="2888126860611144412">O Chromeu</translation>
<translation id="29082080693925013">Da ostanete organizirani, možete zakačiti često posjećene web lokacije i organizirati kartice u grupe</translation>
<translation id="2915996080311180594">Ponovo pokreni kasnije</translation>
