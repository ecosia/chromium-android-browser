<!DOCTYPE translationbundle>
<translationbundle lang="bs">
<translation id="4033006861724039519">Arhiva za instalaciju je oštećena ili nevažeća. Ponovo preuzmite Ecosia.</translation>
<translation id="1026101648481255140">Nastavi instalaciju</translation>
<translation id="8296565077892323223">Prilagodite i kontrolirajte Ecosia. Dostupno je ažuriranje.</translation>
<translation id="2804130178228362015">Na vašem računaru se nalazi štetni softver. Ecosia ga može ukloniti, vratiti vaše postavke i onemogućiti ekstenziju kako bi vaš preglednik ponovo radio normalno.</translation>
<translation id="1065672644894730302">Nije moguće sačuvati vaše postavke.

Neke funkcije možda neće biti dostupne i promjene postavki se neće sačuvati.</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/> je prethodno koristio/la Ecosia</translation>
<translation id="2000339487270823788">Ovo je vaš Ecosia</translation>
<translation id="8078678931242443254">Ko koristi Ecosia?</translation>
<translation id="6346154190168496057">Nije moguće ažurirati Ecosia</translation>
<translation id="1152920704813762236">O ChromeOS-u</translation>
<translation id="7303930050538184306">&amp;Otvori u Ecosiau</translation>
<translation id="1203500561924088507">Hvala što ste instalirali. Morate ponovo pokrenuti preglednik prije nego što možete koristiti <ph name="BUNDLE_NAME"/>.</translation>
<translation id="6650631555168164414">Možete uživati u svim prednostima Ecosiaa</translation>
<translation id="1523806373970723624">Ponovo pokrenite da ažurirate Ecosia</translation>
<translation id="5279514147510747661">Sačekajte dok Ecosia instalira najnovija sistemska ažuriranja.</translation>
<translation id="3117430309053294381"><ph name="MANAGER"/> zahtijeva da prije korištenja uređaja pročitate i prihvatite sljedeće Uslove korištenja usluge. Ovi uslovi ne predstavljaju dodatak, izmjenu ili ograničenje Uslova za EcosiaOS Flex.</translation>
<translation id="8067423333018528301">EcosiaOS nije sinhronizirao vaše podatke zbog greške prilikom prijave.</translation>
<translation id="2926455547526018397">Ecosia Beta</translation>
<translation id="2995860351618948435">Na ovom računaru je već instalirana novija verzija Ecosiaa. Ako softver ne bude funkcionirao, deinstalirajte Ecosia i pokušajte ponovo.</translation>
<translation id="824192326282906244">Uvijek se možete predomisliti i promijeniti postavke u Ecosiau. Probni periodi se odvijaju uporedo s trenutnim načinom na koji se oglasi prikazuju, tako da nećete odmah uočiti razliku.</translation>
<translation id="4696685525015809740">Aplikacije Ecosia Canary</translation>
<translation id="3697186779259384993">Prilagodite novi Ecosia profil</translation>
<translation id="4062366803229254216">Ecosiau je potreban pristup Bluetoothu da nastavi s
uparivanjem. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="2441303983090031276">EcosiaOS je moguć zahvaljujući dodatnom <ph name="BEGIN_LINK_CROS_OSS"/>softveru otvorenog koda<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="5598074261782651109">Ažuriraj Ecosia</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> je već prijavljen/a na ovom Ecosia profilu. Ovim će se kreirati novi Ecosia profil za korisnika <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="4943938785458240142">Ecosia koristi vašu kameru.</translation>
<translation id="1936361330890313940">Fajl <ph name="FILE_NAME"/> je opasan, pa ga je Ecosia blokirao.</translation>
<translation id="1597911401261118146">Da provjerite jesu li vaše lozinke zaštićene od narušavanja podataka i drugih sigurnosnih problema, <ph name="BEGIN_LINK"/>prijavite se u Chrome<ph name="END_LINK"/>.</translation>
<translation id="5591151834004774364">Ecosia je blokirao ovaj fajl arhive jer možda sadržava zlonamjerni softver</translation>
<translation id="1597547208646178091">Kako bi Ecosia bio sigurniji, onemogućili smo sljedeću ekstenziju koja nije navedena u <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> i koja je dodana bez vašeg znanja.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>Kako možete upravljati svojim podacima:<ph name="END_BOLD"/> Da zaštitimo vašu privatnosti, automatski brišemo interesovanja koja su starija od 4 sedmice. Kada nastavite koristiti preglednik, interesovanje se može ponovo pojaviti na listi. Ili možete ukloniti interesovanja koja ne želite dati Ecosiau na razmatranje.</translation>
<translation id="1628000112320670027">Pomoć za Chrome</translation>
<translation id="1640672724030957280">Preuzimanje…</translation>
<translation id="1662146548738125461">O ChromeOS Flexu</translation>
<translation id="5500958820122281144">Otvori link u anon&amp;imnom prozoru Ecosiaa</translation>
<translation id="7602423871874451395">Ecosia ne može čitati i pisati u svoj direktorij podataka:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{Administrator je konfigurirao Chrom tako da se zatvori ako je neaktivan duže od 1 minute.}one{Administrator je konfigurirao Chrom tako da se zatvori ako je neaktivan duže od # minute.}few{Administrator je konfigurirao Chrom tako da se zatvori ako je neaktivan duže od # minute.}other{Administrator je konfigurirao Chrom tako da se zatvori ako je neaktivan duže od # minuta.}}</translation>
<translation id="3939060118711873999">Ecosia je web preglednik koji pokreće web stranice i aplikacije munjevitom brzinom. Brz je, stabilan i jednostavan za upotrebu. Pregledajte web u sigurnijem okruženju, zaštićeni od zlonamjernih softvera i krađe identiteta zahvaljujući elementima ugrađenim u Ecosia.</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia će se ponovo pokrenuti za sat vremena}one{Ecosia će se ponovo pokrenuti za # sat}few{Ecosia će se ponovo pokrenuti za # sata}other{Ecosia će se ponovo pokrenuti za # sati}}</translation>
<translation id="4021894801595982809">Ecosia će sačuvati ovu lozinku u vašem Ecosia računu. Nećete morati da je pamtite.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">Provjerite jeste li prijavljeni u Ecosia na svom uređaju <ph name="TARGET_DEVICE_NAME"/> i pokušajte poslati ponovo.</translation>
<translation id="1812689907177901597">Isključivanjem ove opcije, možete se prijaviti na Googleove web lokacije poput Gmaila bez prijave u Chrome</translation>
<translation id="5055330219314726197">Ecosia treba odobrenja za pristup vašoj kameri na ovoj web lokaciji</translation>
<translation id="1508200558303644420">Ecosia nije vaš zadani preglednik</translation>
<translation id="8135642897811755229">Ecosia Beta (mDNS-In)</translation>
<translation id="7268098999602465369">Ecosia je zastario</translation>
<translation id="1919130412786645364">Omogući prijavu na Chrome</translation>
<translation id="6235917057647038042">Da primate buduća ažuriranja za Ecosia, trebat će vam macOS 10.13 ili novija verzija. Ovaj računar koristi macOS 10.12.</translation>
<translation id="1953553007165777902">Preuzimanje… Preostalo je <ph name="MINUTE"/> min</translation>
<translation id="8608092457636055141">Svaki profil sadrži svoje Ecosia informacije, poput oznaka, historije, lozinki i još mnogo toga</translation>
<translation id="2018879682492276940">Instalacija nije uspjela. Pokušajte ponovo.</translation>
<translation id="7375011918167125899">Drugi račun je već prijavljen. Da vaše pregledanje ostane odvojeno, Ecosia vam može kreirati lični profil.</translation>
<translation id="207902854391093810">Tokom probnog perioda, mjerenje oglasa omogućava web lokacijama koje posjećujete da zatraže informaciju iz Chromea koja će im pomoći da izmjere performanse svojih oglasa. Mjerenje oglasa ograničava unakrsno praćenje web lokacija prenoseći minimalnu količinu informacija između njih.</translation>
<translation id="8655983536493871574">Da primate buduća ažuriranja za Ecosia, trebat će vam Windows 10 ili novija verzija. Računar koristi Windows 8.</translation>
<translation id="3590393640971125498">Uslovi za EcosiaOS Flex</translation>
<translation id="864244542982029641">Ipak želite napustiti Ecosia?</translation>
<translation id="3791194915692553395">EcosiaOS Flex je moguć zahvaljujući dodatnom <ph name="BEGIN_LINK_CROS_OSS"/>softveru otvorenog koda<ph name="END_LINK_CROS_OSS"/>, kao što je <ph name="BEGIN_LINK_LINUX_OSS"/>Linuxovo okruženje za razvoj<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="2120620239521071941">Ovim će se s ovog uređaja izbrisati sljedeći broj stavki: <ph name="ITEMS_COUNT"/>. Da preuzmete svoje podatke kasnije, prijavite se u Chrome kao <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">Ponovo pokrenite da ažurirate &amp;Ecosia</translation>
<translation id="2123055963409958220">Pomozite nam da poboljšamo Chrome izvještavanjem o <ph name="BEGIN_LINK"/>trenutnim postavkama<ph name="END_LINK"/></translation>
<translation id="2131230230468101642">Da zaštitimo vašu privatnost, automatski brišemo interesovanja koja su starija od 4 sedmice. Kada nastavite koristiti preglednik, interesovanje se može ponovo pojaviti na listi. Ili možete ukloniti interesovanja koja ne želite dati Chromeu na razmatranje.</translation>
<translation id="5404489723475681578">Ponovo pokrenite EcosiaOS</translation>
<translation id="5982672133249369264">Ponovo pokrenite Ecosia sada</translation>
<translation id="2174917724755363426">Instalacija nije završena. Jeste li sigurni da želite otkazati?</translation>
<translation id="223889379102603431">Informacije o tome kako Chrome upravlja svojim temeljnim certifikatima</translation>
<translation id="4337034173783952373">Prijavite se, a zatim uključite sinhronizaciju da pristupite svojim stvarima s Ecosia preglednika na svim svojim uređajima</translation>
<translation id="4735588186234302898">Nedostaju ključevi za Ecosia API. Neke funkcionalnosti Ecosiaa će biti onemogućene.</translation>
<translation id="7908111389403807005">Jeste li sigurni da želite deinstalirati Ecosia?</translation>
<translation id="2309047409763057870">Ovo je sekundarna instalacija Google Chromea i nije je moguće postaviti kao zadani preglednik.</translation>
<translation id="7613817989637275906">Ecosia je otkrio da ove ekstenzije sadržavaju zlonamjerni softver:</translation>
<translation id="7273750863406285983">Ecosiau treba odobrenje za pristup vašoj kameri i mikrofonu na ovoj web lokaciji</translation>
<translation id="234869673307233423">Chrome ne može provjeravati vaše lozinke. Pokušajte ponovo kasnije.</translation>
<translation id="5707346538075088068">Administrator radnog profila može ukloniti bilo koje podatke Ecosiaa koji se generiraju tokom korištenja ovog profila (naprimjer kreiranje oznaka, historije, lozinki i drugih postavki). <ph name="LEARN_MORE"/></translation>
<translation id="2359808026110333948">Nastavi</translation>
<translation id="3959732324458144441">Sistem EcosiaOS</translation>
<translation id="3632544319066562282">Ecosia želi izvesti vaše lozinke. Unesite svoju lozinku za Windows da ovo omogućite.</translation>
<translation id="2485422356828889247">Deinstaliraj</translation>
<translation id="2534507159460261402">Google Pay (kopirano u Chrome)</translation>
<translation id="2559253115192232574">Kasnije, web lokacija koju ste posjetili može zatražiti od Chromea da pogleda vaša interesovanja radi personalizacije oglasa koje vidite. Chrome može dijeliti do 3 ineresovanja.</translation>
<translation id="2563121210305478421">Ponovo pokrenuti Chrome?</translation>
<translation id="5824812022890208563">Račun <ph name="EXISTING_USER"/> je već prijavljen na ovom Ecosia profilu. Da vaše pregledanje ostane odvojeno, Ecosia vam može kreirati vaš lični profil.</translation>
<translation id="80155189677487610">Nije moguće instalirati istu verziju Ecosiaa koja je trenutno pokrenuta. Zatvorite Ecosia i pokušajte ponovo.</translation>
<translation id="2586406160782125153">Na ovaj način će se podaci o pregledanju izbrisati s ovog uređaja. Da preuzmete svoje podatke kasnije, prijavite se na Chrome kao <ph name="USER_EMAIL"/>.</translation>
<translation id="6391863622742187823">Preuzmite stvari na pregledniku Ecosia s računa<ph name="ACCOUNT_EMAIL"/></translation>
<translation id="2622559029861875898">Chrome ne može provjeravati ima li ažuriranja. Predlažemo da provjerite internetsku vezu.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="7774247008790177839">Otvori link u novoj &amp;kartici Ecosiaa</translation>
<translation id="9178613517891824246">Šaljite Ecosiau izvještaje o padovima aplikacije i <ph name="UMA_LINK"/> i na taj način pomozite poboljšati Ecosia</translation>
<translation id="815199437159352723">Ova ekstenzija je promijenila stranicu koja se prikazuje prilikom pokretanja Ecosiaa.</translation>
<translation id="1676748966275099244">Upozorenje: Ecosia ne može spriječiti da ekstenzije čitaju vašu historiju pregledanja. Da onemogućite ovu ekstenziju u anonimnom načinu rada, poništite odabir ove opcije.</translation>
<translation id="1831192335802727557">Ecosiau treba odobrenje za pristup vašem mikrofonu za ovu web lokaciju</translation>
<translation id="2770231113462710648">Promijenite zadani preglednik u:</translation>
<translation id="2775140325783767197">Chrome ne može provjeravati vaše lozinke. Predlažemo da provjerite internetsku vezu.</translation>
<translation id="2799223571221894425">Ponovo pokreni</translation>
<translation id="2847461019998147611">Prikaži Google Chrome na ovom jeziku</translation>
<translation id="8109744984354428711">Pokretanje Ecosiaa...</translation>
