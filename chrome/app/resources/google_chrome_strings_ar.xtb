<translation id="7655708678113012665">{NUM_DEVICES,plural, =0{‏كانت إضافة واحدة أو أكثر من إضافات Ecosia تصل إلى جهاز USB واحد}=1{‏تصل إضافة واحدة أو أكثر من إضافات Ecosia إلى جهاز USB واحد}two{‏تصل إضافة واحدة أو أكثر من إضافات Ecosia إلى جهازَي USB}few{‏تصل إضافة واحدة أو أكثر من إضافات Ecosia إلى # أجهزة USB}many{‏تصل إضافة واحدة أو أكثر من إضافات Ecosia إلى # جهاز USB}other{‏تصل إضافة واحدة أو أكثر من إضافات Ecosia إلى # جهاز USB}}</translation>
