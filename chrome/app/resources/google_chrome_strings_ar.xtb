<translation id="2234042158691635795">‏Ecosia في وضع الخلفية.</translation>
<translation id="3038232873781883849">في انتظار التثبيت...</translation>
<translation id="3059710691562604940">‏تم إيقاف "التصفّح الآمن" ويقترح متصفّح Chrome تفعيله.</translation>
<translation id="385080958066798123">‏علامة تبويب Ecosia</translation>
<translation id="3080151273017101988">‏استمرار تشغيل تطبيقات الخلفية عند إغلاق Google Chrome</translation>
<translation id="6876820794875877783">‏يتوفر إصدار جديد وأكثر أمانًا لمتصفح Ecosia.</translation>
<translation id="3100998948628680988">‏تسمية ملفك الشخصى على Chrome</translation>
<translation id="3114643501466072395">‏للتحقُّق مما إذا كانت كلمات المرور الأخرى آمنة من عمليات اختراق البيانات ومشاكل الأمان الأخرى، يُرجى <ph name="BEGIN_LINK"/>تسجيل الدخول إلى متصفِّح Chrome<ph name="END_LINK"/>.</translation>
<translation id="1722634673917783018">‏ستسري التغييرات في المرة التالية التي تعيد فيها تشغيل Ecosia.</translation>
<translation id="2636091632287013185">‏تطبيقات Ecosia</translation>
<translation id="7580831958727159171">‏أثناء التجارب، يمكنك الاطِّلاع على المواضيع محل الاهتمام التي استخدمتها المواقع الإلكترونية لعرض الإعلانات لك ويمكنك إزالة هذه المواضيع. ويقدِّر Ecosia المواضيع محل الاهتمام بناءً على سجل التصفّح الأخير.</translation>
<translation id="2899530016847324742">{NUM_DEVICES,plural, =1{‏‫Ecosia متصل بجهاز HID.}zero{‏‫Ecosia متصل بأجهزة HID.}two{‏‫Ecosia متصل بأجهزة HID.}few{‏‫Ecosia متصل بأجهزة HID.}many{‏‫Ecosia متصل بأجهزة HID.}other{‏‫Ecosia متصل بأجهزة HID.}}</translation>
<translation id="3245429137663807393">‏في حال مشاركة تقارير استخدام Chrome أيضًا، ستتضمّن هذه التقارير عناوين URL التي تزورها</translation>
<translation id="2388751143175762498">‏تسجيل الدخول إلى Ecosia</translation>
<translation id="3286538390144397061">إعادة التشغيل الآن</translation>
<translation id="9090890391337853620">‏مساعد Ecosia</translation>
<translation id="5690368185132749068">{0,plural, =0{‏ستتم إعادة تشغيل Ecosia الآن}=1{‏ستتم إعادة تشغيل Ecosia في غضون ثانية واحدة}two{‏ستتم إعادة تشغيل Ecosia في غضون ثانيتين}few{‏ستتم إعادة تشغيل Ecosia في غضون # ثوان}many{‏ستتم إعادة تشغيل Ecosia في غضون # ثانيةً}other{‏ستتم إعادة تشغيل Ecosia في غضون # ثانية}}</translation>
<translation id="7280797724682955539">‏حدث خطأ في نظام التشغيل أثناء عملية التثبيت. يُرجى تنزيل Ecosia مرة أخرى.</translation>
<translation id="2298752889004612764">‏زيادة سرعة أداء Ecosia من خلال ميزة "توفير الذاكرة"</translation>
<translation id="3428747202529429621">‏يوفّر لك هذا الوضع حماية في Chrome، ويمكن استخدامه لتحسين مستوى أمانك في تطبيقات Google الأخرى عندما تكون مسجلًا دخولك.</translation>
<translation id="3434246496373299699">‏لا يستطيع Chrome التحقّق من كلمات المرور إلا عند تسجيل الدخول باستخدام حسابك على Google.</translation>
<translation id="1762318218111418450">‏جارٍ الإضافة إلى Ecosia...</translation>
<translation id="6761747850241550887">‏إضافة نفسك إلى Ecosia</translation>
<translation id="2149148292984034533">‏بنود نظام التشغيل Ecosia</translation>
<translation id="3674955518940155608">‏محو البيانات من Ecosia أيضًا (<ph name="URL"/>)</translation>
<translation id="6558895515431832002">‏يحتاج Ecosia للوصول إلى موقعك الجغرافي لمشاركته مع الموقع الإلكتروني هذا.</translation>
<translation id="3533694711092285624">‏ما مِن كلمات مرور محفوظة. لا يستطيع متصفّح Chrome التحقّق من كلمات المرور إلا عند حفظها.</translation>
<translation id="3541482654983822893">‏يتعذّر على Chrome التحقُّق من كلمات المرور. يُرجى إعادة المحاولة بعد 24 ساعة.</translation>
<translation id="8901409988302458368">‏ضَبَط مشرف النظام Ecosia لفتح متصفِّح بديل للوصول إلى <ph name="TARGET_URL_HOSTNAME"/>.</translation>
<translation id="3579965087968408543">‏محو بيانات الموقع الإلكتروني من جهازك دائمًا عند إغلاق Chrome</translation>
<translation id="7174674455569790401">‏يمكنك مزامنة Ecosia وتخصيصه على جميع أجهزتك.</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق تحديث.}=1{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق تحديث. لن تتم إعادة فتح نافذة التصفح المتخفي.}two{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق تحديث. لن تتم إعادة فتح نافذتَي التصفح المتخفي.}few{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق تحديث. لن تتم إعادة فتح نوافذ التصفّح المتخفي البالغ عددها #.}many{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق تحديث. لن تتم إعادة فتح نوافذ التصفّح المتخفي البالغ عددها #.}other{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق تحديث. لن تتم إعادة فتح نوافذ التصفّح المتخفي البالغ عددها #.}}</translation>
<translation id="464306605599005355">‏الآن أصبح استخدام Ecosia مع حسابك في Ecosia وفي أجهزة الكمبيوتر المشتركة أكثر سهولة.</translation>
<translation id="1490060441084292633">‏رصد Ecosia أنّ الإضافة "<ph name="EXTENSION_NAME"/>" تحتوي على برامج ضارة.</translation>
<translation id="5311911269004680646">‏أصبح نظام التشغيل Ecosia متاحًا من خلال <ph name="BEGIN_LINK_CROS_OSS"/>برنامج إضافي مفتوح المصدر<ph name="END_LINK_CROS_OSS"/>، كما هو الحال في <ph name="BEGIN_LINK_LINUX_OSS"/>بيئة تطوير Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="3716540481907974026">‏إصدار نظام التشغيل ChromeOS Flex</translation>
<translation id="3718181793972440140">‏سيعمل هذا على حذف عنصر واحد من هذا الجهاز. لاسترداد بياناتك لاحقًا، سجّل الدخول إلى Chrome كـ <ph name="USER_EMAIL"/>.</translation>
<translation id="9032120646440147804">‏غيّرت الإضافة "<ph name="EXTENSION_NAME"/>" الصفحة التي تظهر عند بدء Ecosia.</translation>
<translation id="3744202345691150878">‏الحصول على مساعدة بشأن نظام التشغيل Chrome</translation>
<translation id="4600924482853773728">Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="4969069484658032230">‏تعذَّر على EcosiaOS Flex مزامنة البيانات بسبب حدوث خطأ أثناء تسجيل الدخول.</translation>
<translation id="1761341660094265938">‏نظام التشغيل Ecosia من Ecosia</translation>
<translation id="3952510753191144456">‏سيؤدي هذا الإجراء إلى إنشاء ملف شخصي جديد على Ecosia لحساب <ph name="USER_EMAIL_ADDRESS"/>.</translation>
<translation id="8534308095039131078">‏يُرجى إغلاق كل نوافذ Ecosia وإعادة المحاولة.</translation>
<translation id="3865754807470779944">‏الإصدار المُثبّت من Chrome: <ph name="PRODUCT_VERSION"/></translation>
<translation id="8283315171506895091">‏فتح الرابط في نافذة تصفح متخفٍ في Ecosia</translation>
<translation id="6496553866814956056">‏إزالة Ecosia</translation>
<translation id="1118786556671181978">‏يمكنك الاطّلاع على المواضيع التي تهمّك وتستخدمها المواقع الإلكترونية لعرض الإعلانات لك، وبإمكانك كذلك إزالة ما تشاء من هذه المواضيع. ويعمل Ecosia على تقديم تقديرات حول اهتماماتك بناءً على سجل التصفّح الأخير.</translation>
<translation id="8047394653992042491">‏يجب إعادة تشغيل نظام التشغيل Ecosia لتثبيت التحديث.</translation>
<translation id="4050175100176540509">تحسينات الأمان المهمة والميزات الجديدة متاحة في أحدث إصدار.</translation>
<translation id="4817913198787198451">‏تخصيص Ecosia والتحكم فيه</translation>
<translation id="3708834841667355707">‏يعمل Ecosia على استكشاف ميزات جديدة تتيح للمواقع الإلكترونية توفير تجربة التصفّح ذاتها باستخدام قدر أقل من المعلومات.</translation>
<translation id="319566061277127356">‏إعداد ملفك الشخصي الجديد على متصفِّح Ecosia</translation>
<translation id="7105712012505419722">‏إنك تسجل الدخول باستخدام حساب مُدار وتمنح المشرف إمكانية التحكم في ملفك الشخصي في Ecosia. وسيتم ربط بيانات Ecosia التابعة لك، مثل التطبيقات والإشارات المرجعية والسجلّ وكلمات المرور والإعدادات الأخرى بالمستخدم <ph name="USER_NAME"/>. وستتمكن من حذف هذه البيانات عبر لوحة تحكم حسابات Ecosia، ولكنك لن تتمكن من إقران هذه البيانات بحساب آخر. <ph name="LEARN_MORE"/></translation>
<translation id="4148957013307229264">جارٍ التثبيت...</translation>
<translation id="7691143774653486474">‏فشلت أداة المثبِّت في فك ضغط الأرشيف. يُرجى تنزيل Ecosia مرة أخرى.</translation>
<translation id="6826163993811146231">{0,plural, =1{‏يجب إعادة تشغيل Ecosia في غضون يوم واحد}zero{‏يجب إعادة تشغيل Ecosia في غضون # يوم}two{‏يجب إعادة تشغيل Ecosia في غضون يومين}few{‏يجب إعادة تشغيل Ecosia في غضون # أيام}many{‏يجب إعادة تشغيل Ecosia في غضون # يومًا}other{‏يجب إعادة تشغيل Ecosia في غضون # يوم}}</translation>
<translation id="4205939740494406371">‏يتعذّر على Chrome التحقُّق من كلمات المرور. يُرجى إعادة المحاولة بعد 24 ساعة أو <ph name="BEGIN_LINK"/>التحقُّق من كلمات المرور في حسابك على Google<ph name="END_LINK"/>.</translation>
<translation id="4222932583846282852">جارٍ الإلغاء...</translation>
<translation id="3554373328288278512">‏يحتاج Ecosia إلى إذن للوصول إلى الكاميرا والميكروفون من أجل هذا الموقع الإلكتروني.</translation>
<translation id="424864128008805179">‏هل تريد تسجيل الخروج من Chrome؟</translation>
<translation id="8384922154025337808">‏هل ترغب في ربط بياناتك في Ecosia بهذا الحساب؟</translation>
<translation id="4565616259974605182">‏<ph name="BEGIN_BOLD"/>البيانات المستخدَمة:<ph name="END_BOLD"/> سجلّ تصفُّحك، بالإضافة إلى سجلّ بالمواقع الإلكترونية التي زرتها باستخدام Ecosia على هذا الجهاز</translation>
<translation id="4281844954008187215">بنود الخدمة</translation>
<translation id="4293420128516039005">‏يمكنك تسجيل الدخول لمزامنة Chrome وتخصيصه على جميع أجهزتك.</translation>
<translation id="6419542773162312746">‏السماح للإضافة بعرض طلبات الوصول في شريط أدوات Ecosia</translation>
<translation id="8864449561723972619">‏إصدار مطوّري البرامج من Ecosia ‏(mDNS-In)</translation>
<translation id="4334294535648607276">اكتمل التنزيل.</translation>
<translation id="4335235004908507846">‏يستطيع Chrome مساعدتك في الحفاظ على أمان معلوماتك من عمليات اختراق البيانات والإضافات الضارة وغيرها من المشاكل.</translation>
<translation id="2227704215309956084">‏تمت إضافة <ph name="EXTENSION_NAME"/> إلى Ecosia</translation>
<translation id="4384570495110188418">‏يتعذّر على Chrome التحقّق من كلمات المرور لأنك لم تسجّل الدخول.</translation>
<translation id="4427306783828095590">يؤدي تفعيل إعداد "الحماية المُحسَّنة" إلى حظر التصيّد الاحتيالي والبرامج الضارّة.</translation>
<translation id="9035946286843935549">‏Ecosia - تسجيل الدخول إلى الشبكة - <ph name="PAGE_TITLE"/></translation>
<translation id="6450895420388847775">‏عملية أخرى على Ecosia قيد التقدم. يُرجى المحاولة مرة أخرى لاحقًا.</translation>
<translation id="4459234553906210702">‏يسمح Ad measurement للمواقع الإلكترونية التي تنتقل إليها بطلب معلومات من Chrome تساعد الموقع الإلكتروني في قياس أداء الإعلانات التي يعرضها. ويحدّ Ad measurement من عملية تتبّع البيانات ونشاط التصفّح على المواقع الإلكترونية، وذلك من خلال نقل أقل قدر ممكن من المعلومات بينها.</translation>
<translation id="6107290018380796650">‏يتيح لك Ecosia النقر على رقم هاتف على الويب والاتصال به باستخدام Skype!</translation>
<translation id="4567424176335768812">لقد سجلت دخولك باعتبارك <ph name="USER_EMAIL_ADDRESS"/>. ويُمكنك الآن الاستمتاع بالدخول إلى الإشارات المرجعية، والسجلّ، والإعدادات الأخرى على جميع الأجهزة التي تسجّل الدخول إليها.</translation>
<translation id="6533266716128249922">‏الانتقال إلى إعدادات الإشعارات في Ecosia</translation>
<translation id="488806616089631539">‏بعد حصول Ecosia على إمكانية الوصول، ستتمكن المواقع الإلكترونية من مطالبتك بإمكانية الوصول.</translation>
<translation id="3268039966078382323">‏تعذّرت إعادة التحميل Ecosia إلى آخر إصدار، لذلك قد تفوتك الميزات وعمليات إصلاح الأمان الجديدة.</translation>
<translation id="4690206707618474800">‏اختياري: يمكنك المساعدة في تحسين ميزات نظام التشغيل EcosiaOS Flex وأدائه من خلال إرسال بيانات التشخيص والاستخدام تلقائيًا إلى Ecosia.</translation>
<translation id="9125443060066914183">‏لجعل Ecosia أكثر أمانًا، تم إيقاف بعض الإضافات غير المدرجة في <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/> والتي ربما تمت إضافتها بدون علمك.</translation>
<translation id="4680828127924988555">إلغاء التثبيت</translation>
<translation id="8236553889322631924">‏إنّ الإضافات والتطبيقات والمظاهر الواردة من مصادر غير معروفة يمكن أن تتسبّب في إلحاق الضرر بجهازك. ينصح Ecosia بإجراء عملية التثبيت من خلال سوق Ecosia الإلكتروني فقط.</translation>
<translation id="3305517118160815955">‏فشلت عملية التثبيت بسبب خطأ غير محدد. إذا كان Ecosia في حالة التشغيل حاليًا، يُرجى إغلاقه وإعادة المحاولة.</translation>
<translation id="4747730611090640388">‏يمكن أن يقدِّر Chrome اهتماماتك.  وبعد ذلك، يمكن للموقع الإلكتروني الذي تنتقل إليه أن يطلب من Chrome معرفة اهتماماتك من أجل تخصيص الإعلانات التي تظهر لك.</translation>
<translation id="827222962844006655">Ecosia Canary (mDNS-In)</translation>
<translation id="2243562167758283214">‏قد يكون هذا الملف ضارًا، لذلك فقد حظره Ecosia.</translation>
<translation id="3543284013834505767">‏يستخدم ذلك المدقق الإملائي نفسه الذي يتم استخدامه في "بحث Ecosia". ويتم إرسال النص الذي تكتبه في المتصفّح إلى Ecosia. يمكنك دائمًا تغيير هذا السلوك في الإعدادات.</translation>
<translation id="8144706290339578682">‏تعذَّر على EcosiaOS Flex مزامنة البيانات لأنّ ميزة المزامنة غير متاحة لنطاقك.</translation>
<translation id="4873783916118289636">‏يمكنك مراجعة العناصر الرئيسية للتحكّم في الخصوصية والأمان في Chrome.</translation>
<translation id="8454595950895325762">‏دع Ecosia يعمل في الخلفية</translation>
<translation id="489671036945006830">‏فتح الرابط في علامة تبويب جديدة في Ecosia</translation>
<translation id="5581150090232500900">‏تحديد Ecosia المتصفح التلقائي</translation>
<translation id="6495878830719404098">‏في Ecosia</translation>
<translation id="6113625922434842626">‏تعذَّر على EcosiaOS Flex مزامنة البيانات لأنّ تفاصيل الحساب المُستخدَم في تسجيل الدخول قديمة.</translation>
<translation id="4410570812343670816">‏مرحبًا بك في الملفات الشخصية على Ecosia</translation>
<translation id="4970880042055371251">‏إصدار نظام التشغيل Chrome</translation>
<translation id="796435732739009892">‏حَظَر Ecosia هذا الملف لأنّه ملف خطير.</translation>
<translation id="8570641140903702642">Ecosia Canary</translation>
<translation id="6718055545215052843">‏للحصول على تحديثات Ecosia في المستقبل، يجب استخدام جهاز يعمل بنظام التشغيل macOS 10.13 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل OS X 10.11.</translation>
<translation id="5098668839038261629">‏عند تفعيل هذا الخيار، سيتم تسجيل خروجك أيضًا من Chrome.</translation>
<translation id="7782767522222146179">‏يمكنك اكتشاف تطبيقات، وألعاب، وإضافات، ومظاهر رائعة لمتصفح Ecosia.</translation>
<translation id="6416551953415159186">‏تخصيص ملفك الشخصي في Ecosia</translation>
<translation id="1859120614572957305">‏مرحبًا بك في Ecosia. تم فتح نافذة متصفّح جديدة.</translation>
<translation id="6648664289472946060">‏لا يمكن استخدام ملفك الشخصي نظرًا لأنه من إصدار أحدث من Ecosia.

قد تكون بعض الميزات غير متاحة. يُرجى تحديد دليل ملف شخصي مختلف أو استخدام إصدار أحدث من Ecosia.</translation>
<translation id="6960183526681645011">‏في حال مشاركة جهاز مع الأصدقاء والعائلة، يمكنهم الحصول على تجربة تصفّح منفصلة وإعداد Ecosia على النحو المفضّل لديهم.</translation>
<translation id="1869027055332251164">‏يمكن للضيف استخدام Ecosia بدون أن يترك أي أثر وراءه.</translation>
<translation id="143614250230771428">‏تعذّر على نظام التشغيل Ecosia مزامنة البيانات لأن المزامنة غير متاحة لنطاقك.</translation>
<translation id="1809194740315140401">‏يحتاج Ecosia إلى إذن للوصول إلى مساحة التخزين من أجل تنزيل الملفات.</translation>
<translation id="8975930032513941502">‏إجراء اختياري: يمكنك المساعدة في تحسين ميزات نظام التشغيل Ecosia وأدائه من خلال إرسال بيانات التشخيص والاستخدام تلقائيًا إلى Ecosia.</translation>
<translation id="5357889879764279201">‏الحصول على مساعدة في نظام التشغيل ChromeOS Flex</translation>
<translation id="6665128960039431910">‏كما أنها تتحكم في الصفحة التي تظهر عند تشغيل Ecosia أو إجراء بحث من المربع متعدد الاستخدامات.</translation>
<translation id="1861504561909287316">‏مشاركة علامة تبويب Ecosia</translation>
<translation id="5412485296464121825">‏يمكن أن تخزّن المواقع الإلكترونية معلومات عن اهتماماتك في متصفّح Chrome. على سبيل المثال، إذا انتقلت إلى موقع إلكتروني لشراء حذاء لاستخدامه في سباق ماراثون، قد يحدّد هذا الموقع الإلكتروني حسب تقديره أنك مهتم بسباقات الماراثون. وبعد ذلك، إذا انتقلت إلى موقع إلكتروني آخر للتسجيل في سباق ماراثون، يمكن أن يعرض لك هذا الموقع الإلكتروني إعلانًا عن الأحذية المخصّصة للجري بناءً على اهتماماتك.</translation>
<translation id="6673288084648462613">‏ملف الإعدادات المفضّلة تالف أو غير صالح. يتعذر على Ecosia استرداد إعداداتك.</translation>
<translation id="5524761631371622910">‏عندما تكون التجارب مفعَّلة، وفي حال أضافك Chrome عشوائيًا إلى تجربة نشطة، سيؤثر سجلّ تصفّحك في الإعلانات التي تظهر لك والاهتمامات التي يتم تقديرها على النحو الموضّح أدناه. ولحماية خصوصيتك، يحذف Chrome اهتماماتك بشكل متواصل مرة واحدة على الأقل شهريًا.</translation>
<translation id="2905159584855395810">‏زيادة سرعة أداء Ecosia</translation>
<translation id="2549591663512786020">‏يحاول Ecosia إظهار كلمات المرور.</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="3625533701824359646">‏قد يكون ملف <ph name="FILE_NAME"/> ضارًا، لذلك فقد حظره Ecosia.</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق هذا التحديث.}=1{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق هذا التحديث. لن تتم إعادة فتح نافذة التصفح المتخفي.}two{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق هذا التحديث. لن تتم إعادة فتح نافذتَي التصفح المتخفي.}few{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق هذا التحديث. لن تتم إعادة فتح نوافذ التصفّح المتخفي البالغ عددها #.}many{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق هذا التحديث. لن تتم إعادة فتح نوافذ التصفّح المتخفي البالغ عددها #.}other{‏يطلب المشرف إعادة تشغيل Ecosia لتطبيق هذا التحديث. لن تتم إعادة فتح نوافذ التصفّح المتخفي البالغ عددها #.}}</translation>
<translation id="8544776492099331022">‏تخصيص Ecosia والتحكم فيه معلومات مهمة - انقر للحصول على التفاصيل.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="5789438819244101666">{SECONDS,plural, =1{‏ستتم إعادة تشغيل Ecosia خلال ثانية واحدة}zero{‏ستتم إعادة تشغيل Ecosia خلال # ثانية}two{‏ستتم إعادة تشغيل Ecosia خلال ثانيتين (#)}few{‏ستتم إعادة تشغيل Ecosia خلال # ثوانٍ}many{‏ستتم إعادة تشغيل Ecosia خلال # ثانيةً}other{‏ستتم إعادة تشغيل Ecosia خلال # ثانية}}</translation>
<translation id="5727531838415286053">‏في حال أضافك Chrome عشوائيًا إلى تجربة نشطة، سيؤثر سجلّ تصفّحك في الإعلانات التي تظهر لك والاهتمامات التي يتم تقديرها على النحو الموضّح أدناه. ولحماية خصوصيتك، يحذف Chrome اهتماماتك بشكل متواصل مرة واحدة على الأقل شهريًا. يتم تحديث الاهتمامات ما لم تزِلها.</translation>
<translation id="5736850870166430177">‏إذا حاول موقع إلكتروني سرقة كلمة المرور أو إذا نزّلت ملفًا ضارًا، قد يرسِل متصفِّح Chrome أيضًا عناوين URL تتضمّن أجزاءً من محتوى الصفحة إلى خدمة "التصفُّح الآمن".</translation>
