<translation id="7602423871874451395">‏يتعذر على Ecosia القراءة والكتابة في دليل البيانات الخاص به:

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="1914619467562029368">{COUNT,plural, =1{‏ضبط المشرف إعدادات Ecosia ليغلق تلقائيًا في حال لم يتم استخدامه لأكثر من دقيقة واحدة.}zero{‏ضبط المشرف إعدادات Ecosia ليغلق تلقائيًا في حال لم يتم استخدامه لأكثر من # دقيقة.}two{‏ضبط المشرف إعدادات Ecosia ليغلق تلقائيًا في حال لم يتم استخدامه لأكثر من دقيقتَين.}few{‏ضبط المشرف إعدادات Ecosia ليغلق تلقائيًا في حال لم يتم استخدامه لأكثر من # دقائق.}many{‏ضبط المشرف إعدادات Ecosia ليغلق تلقائيًا في حال لم يتم استخدامه لأكثر من # دقيقة.}other{‏ضبط المشرف إعدادات Ecosia ليغلق تلقائيًا في حال لم يتم استخدامه لأكثر من # دقيقة.}}</translation>
<translation id="3939060118711873999">‏إن Ecosia هو متصفح ويب يشغّل صفحات الويب والتطبيقات بسرعة خاطفة. فهذا المتصفح سريع ويتميز بالثبات وسهولة الاستخدام، ويمكنك من خلاله تصفح الويب بقدر أكبر من الأمان من خلال وجود حماية مضمنة داخله ضد البرامج الضارة والتصيّد.</translation>
<translation id="6022879254514691681">{0,plural, =1{‏ستتم إعادة تشغيل Ecosia في غضون ساعة واحدة}zero{‏ستتم إعادة تشغيل Ecosia في غضون # ساعة}two{‏ستتم إعادة تشغيل Ecosia في غضون ساعتين}few{‏ستتم إعادة تشغيل Ecosia في غضون # ساعات}many{‏ستتم إعادة تشغيل Ecosia في غضون # ساعةً}other{‏ستتم إعادة تشغيل Ecosia في غضون # ساعة}}</translation>
<translation id="4021894801595982809">‏سيحفظ Ecosia كلمة المرور هذه في حسابك على Ecosia ولن تحتاج إلى تذكُّرها.</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="2346323077583431428">‏يُرجى التأكُّد من تسجيل الدخول إلى متصفِّح Ecosia على جهازك <ph name="TARGET_DEVICE_NAME"/> ثم محاولة الإرسال مرة أخرى.</translation>
<translation id="1812689907177901597">‏من خلال إيقاف هذا الإعداد، يمكنك تسجيل الدخول إلى "مواقع Google" مثل Gmail بدون الحاجة إلى تسجيل الدخول إلى Chrome</translation>
<translation id="5055330219314726197">‏يحتاج Ecosia إلى إذن للوصول إلى الكاميرا من أجل الموقع الإلكتروني هذا.</translation>
<translation id="1508200558303644420">‏Ecosia ليس متصفحك التلقائي.</translation>
<translation id="8135642897811755229">‏الإصدار التجريبي من Ecosia‏ (mDNS-In)</translation>
<translation id="7268098999602465369">‏إصدار Ecosia قديم</translation>
<translation id="1919130412786645364">‏السماح بتسجيل الدخول إلى Chrome</translation>
<translation id="6235917057647038042">‏للحصول على تحديثات Ecosia في المستقبل، يجب استخدام جهاز يعمل بنظام التشغيل macOS 10.13 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل macOS 10.12.</translation>
<translation id="1953553007165777902">جارٍ التنزيل… عدد الدقائق المتبقّية: <ph name="MINUTE"/></translation>
<translation id="8608092457636055141">‏يحتفظ كل ملف شخصي بالمعلومات الخاصة به على Ecosia، مثل الإشارات المرجعية والسجلّ وكلمات المرور وغير ذلك.</translation>
<translation id="2018879682492276940">تعذّر التثبيت. يُرجى إعادة المحاولة.</translation>
<translation id="7375011918167125899">‏سبق وتم تسجيل الدخول باستخدام حساب آخر. للحصول على تجربة تصفُّح منفصلة، يمكن لمتصفِّح Ecosia إنشاء ملف شخصي خاص بك.</translation>
<translation id="207902854391093810">‏عندما تكون التجارب مفعَّلة، يسمح Ad measurement للمواقع الإلكترونية التي تنتقل إليها بطلب معلومات من Chrome تساعد الموقع الإلكتروني في قياس أداء الإعلانات التي يعرضها. ويحدّ Ad measurement من عملية تتبّع البيانات ونشاط التصفّح على المواقع الإلكترونية، وذلك من خلال نقل أقل قدر ممكن من المعلومات بينها.</translation>
<translation id="8655983536493871574">‏للحصول على تحديثات Ecosia في المستقبل، يجب استخدام كمبيوتر يعمل بنظام التشغيل Windows 10 أو إصدار أحدث. يعمل هذا الكمبيوتر بنظام التشغيل Windows 8.</translation>
<translation id="3590393640971125498">‏أحكام نظام التشغيل EcosiaOS Flex</translation>
<translation id="864244542982029641">‏هل تريد الخروج من Ecosia على أي حال؟</translation>
<translation id="3791194915692553395">‏أصبح نظام التشغيل EcosiaOS Flex متاحًا من خلال <ph name="BEGIN_LINK_CROS_OSS"/>برنامج إضافي مفتوح المصدر<ph name="END_LINK_CROS_OSS"/>، كما هو الحال في <ph name="BEGIN_LINK_LINUX_OSS"/>بيئة تطوير نظام التشغيل Linux<ph name="END_LINK_LINUX_OSS"/>.</translation>
<translation id="2120620239521071941">‏سيعمل هذا على حذف <ph name="ITEMS_COUNT"/> من العناصر من هذا الجهاز. لاسترداد بياناتك لاحقًا، سجّل الدخول إلى Chrome كـ <ph name="USER_EMAIL"/>.</translation>
<translation id="2159716220295742156">‏إعادة تشغيل متصفِّح Ecosia لتحديثه</translation>
<translation id="2123055963409958220">‏يمكنك المساعدة في تحسين Chrome بالإبلاغ عن <ph name="BEGIN_LINK"/>الإعدادات الحالية<ph name="END_LINK"/></translation>
<translation id="2131230230468101642">‏لحماية خصوصيتك، نحذف تلقائيًا اهتماماتك التي يمر عليها أكثر من أربعة أسابيع. وفي حال بحثت عن أحد الاهتمامات مرّة آخرى، سيظهر في القائمة من جديد. يمكنك إزالة الاهتمامات التي لا تريد أن يضيفها Chrome إلى قائمة اهتماماتك.</translation>
<translation id="5404489723475681578">‏إعادة تشغيل نظام التشغيل Ecosia</translation>
<translation id="5982672133249369264">‏يُرجى إعادة تشغيل Ecosia الآن</translation>
<translation id="2174917724755363426">لم يكتمل التثبيت. هل تريد فعلاً الإلغاء؟</translation>
<translation id="223889379102603431">‏معلومات حول الآلية التي يُدير بها متصفّح Chrome شهادات الجذر الخاصة به</translation>
<translation id="4337034173783952373">‏للوصول إلى بياناتك في متصفّح Ecosia من جميع أجهزتك، سجِّل الدخول وفعِّل المزامنة.</translation>
<translation id="4735588186234302898">‏مفاتيح واجهة برمجة تطبيقات Ecosia مفقودة. وسيترتب على ذلك توقف بعض وظائف Ecosia عن العمل.</translation>
<translation id="7908111389403807005">‏هل تريد فعلًا إزالة Ecosia؟</translation>
<translation id="2309047409763057870">‏هذا تثبيت ثانوي من Google Chrome، ولا يمكن جعله متصفحك التلقائي.</translation>
<translation id="7613817989637275906">‏رصد Ecosia أنّ هذه الإضافات تحتوي على برامج ضارة:</translation>
<translation id="7273750863406285983">‏يحتاج Ecosia إلى إذن للوصول إلى الكاميرا والميكروفون من أجل الموقع الإلكتروني هذا.</translation>
<translation id="234869673307233423">‏يتعذّر على Chrome التحقّق من كلمات المرور. يُرجى إعادة المحاولة.</translation>
<translation id="5707346538075088068">‏يمكن لمشرف الملف الشخصي للعمل إزالة أي بيانات مرتبطة بمتصفِّح Ecosia والتي يتم إنشاؤها أثناء استخدام هذا الملف الشخصي (مثل إنشاء الإشارات المرجعية والسجلّ وكلمات المرور والإعدادات الأخرى).<ph name="LEARN_MORE"/></translation>
