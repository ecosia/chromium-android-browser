<translation id="3997429360543082038">ChromiumOS-ის შესახებ</translation>
<translation id="5311911269004680646">EcosiaOS და <ph name="BEGIN_LINK_LINUX_OSS"/>Linux-ის შემუშავების გარემო <ph name="END_LINK_LINUX_OSS"/> მუშაობს <ph name="BEGIN_LINK_CROS_OSS"/>ღია კოდის დამატებითი პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS"/> დამსახურებით.</translation>
<translation id="4036079820698952681">ხელი შეუწყვეთ Chromium-ის გაუმჯობესებას <ph name="BEGIN_LINK"/>მიმდინარე პარამეტრების<ph name="END_LINK"/> გამოგზავნის მეშვეობით</translation>
<translation id="4050175100176540509">უსაფრთხოების მნიშვნელოვანი გაუმჯობესება და ახალი თვისებები ხელმისაწვდომია უახლეს ვერსიაში.</translation>
<translation id="4055805654398742145">პ&amp;აროლების მმართველი</translation>
<translation id="7757263274906217411">{COUNT,plural, =1{თქვენი ორგანიზაცია ავტომატურად ხურავს Ecosia-ს, როცა ის 1 წუთის განმავლობაში არ გამოიყენება. დათვალიერების მონაცემები წაიშლება. აღნიშნული, შესაძლოა, მოიცავდეს ისტორიას, ავტომატური შევსების მონაცემებსა და ჩამოტვირთვებს.}other{თქვენი ორგანიზაცია ავტომატურად ხურავს Ecosia-ს, როცა ის # წუთის განმავლობაში არ გამოიყენება. დათვალიერების მონაცემები წაიშლება. აღნიშნული, შესაძლოა, მოიცავდეს ისტორიას, ავტომატური შევსების მონაცემებსა და ჩამოტვირთვებს.}}</translation>
<translation id="4118474109249235144">Chromium-ის ინკოგნიტო რეჟიმი</translation>
<translation id="4122186850977583290">Chromium-ის შესახებ ინფორმაციის გვერდზე გადასვლა</translation>
<translation id="4148957013307229264">ინსტალაცია…</translation>
<translation id="4264506519284061030">თქვენს ორგანიზაციას შეუძლია თქვენ მიერ ვების დათვალიერების მონაცემების ნახვა და მართვა თქვენს სამსახურის პროფილში (მაგალითად, თქვენი სანიშნეების, ისტორიისა და პაროლების). ის ვერ შეძლებს თქვენი პერსონალური Ecosia პროფილებით ვების დათვალიერების მონაცემების ნახვას.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> — ქსელში შესვლა — Ecosia</translation>
<translation id="7782767522222146179">აღმოაჩინეთ შესანიშნავი აპები, თამაშები, გაფართოებები და თემები Ecosia-ისთვის.</translation>
<translation id="4216212958613226427">ეს ენა გამოიყენება Chromium-ის სამომხმარებლო ინტერფეისისთვის</translation>
<translation id="4222932583846282852">მიმდინარეობს გაუქმება…</translation>
<translation id="4224210481850767180">ინსტალაცია გაუქმდა.</translation>
<translation id="8384922154025337808">დავუკავშიროთ თქვენი Ecosia მონაცემები ამ ანგარიშის?</translation>
<translation id="4251772536351901305">გაგაფრთხილებთ სახიფათო საიტების შესახებ (თუნდაც Google-ისთვის იქამდე უცნობის შესახებ) საიტებიდან იმაზე მეტი მონაცემის სკანირების მეშვეობით, ვიდრე სტანდარტული დაცვის შემთხვევაში. სურვილისამებრ, შეგიძლიათ გამოტოვოთ Chromium-ის გაფრთხილებები.</translation>
<translation id="2672632089507560181">Ecosia-იდან გასვლა</translation>
<translation id="4271805377592243930">Chromium-თან დაკავშირებული დახმარების მიღება</translation>
<translation id="4281844954008187215">მომსახურების პირობები</translation>
<translation id="3305517118160815955">ინსტალაცია ვერ განხორციელდა განუსაზღვრელი შეცდომის გამო. თუ Ecosia ამჟამად გაშვებულია, დახურეთ იგი და ხელახლა სცადეთ.</translation>
<translation id="4304713468139749426">პაროლების მმართველი</translation>
<translation id="4334294535648607276">ჩამოტვირთვა დასრულდა.</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> მოითხოვს, რომ ამ მოწყობილობის გამოყენებამდე წაიკითხოთ ქვემოთ მოცემული მომსახურების პირობები და დაეთანხმოთ მათ. აღნიშნული პირობები არ არის EcosiaOS-ის წესების დამატება, ასევე, არ ცვლის და არც ზღუდავს მათ.</translation>
<translation id="88039520238670574">მაინც გსურთ Ecosia-იდან გასვლა?</translation>
<translation id="4586967042094107073">Ecosia-ისთვის ფონურ რეჟიმში მუშაობის დაშვება</translation>
<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Ecosia გირჩევთ მის ამოშლას. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი მხარდაჭერილი გაფართოებების შესახებ<ph name="END_LINK"/>}other{Ecosia გირჩევთ მათ ამოშლას. <ph name="BEGIN_LINK"/>შეიტყვეთ მეტი მხარდაჭერილი გაფართოებების შესახებ<ph name="END_LINK"/>}}</translation>
<translation id="4817913198787198451">Ecosia-ის მორგება და კონტროლი</translation>
<translation id="4427306783828095590">გაძლიერებული დაცვა გთავაზობთ ფიშინგისა და მავნე პროგრამებისგან დაცვის მეტ საშუალებას</translation>
<translation id="4434353761996769206">ინსტალატორის შეცდომა: <ph name="INSTALLER_ERROR"/></translation>
<translation id="6994161374830839635"><ph name="MANAGER"/> მართავს Ecosia-ს</translation>
<translation id="4447409407328223819">Chrome for Testing-ის შესახებ</translation>
<translation id="4501471624619070934">ინსტალაცია ვერ მოხერხდა, რადგან წვდომა შეზღუდულია ამ ქვეყანაში</translation>
<translation id="576192547306902465">ამ გაფართოებას არ გამოუქვეყნებია კონფიდენციალური ინფორმაციის გამოყენების პრაქტიკა, მაგალითად, მონაცემების შეგროვებისა და გამოყენების წესები. Ecosia გირჩევთ მის ამოშლას.</translation>
<translation id="1859120614572957305">მოგესალმებით Ecosia-ში; გახსნილია ბრაუზერის ახალი ფანჯარა</translation>
<translation id="378302976931789177">თქვენი გარემოს მოსანიშნად და თქვენი ხელებისთვის თვალის მიდევნებისთვის Ecosia საჭრიროებს ნებართვას</translation>
<translation id="8403827649521531901">თქვენ უკვე შესული ხართ Ecosia-ის სხვა პროფილში როგორც <ph name="USER_EMAIL_ADDRESS"/></translation>
<translation id="4544142686420020088">Chromium-ის განახლება ვერ მოხერხდა შეფერხების გამო. <ph name="BEGIN_LINK"/>შეასწორეთ Chromium-ის განახლებასთან დაკავშირებული პრობლემები და განუხორციელებელი განახლებები.<ph name="END_LINK"/></translation>
<translation id="2020747823154282691">Ecosia-ს შეუძლია, ეს ჩანართი უმოქმედო რეჟიმში გადაიტანოს, რათა გააუმჯობესოს თქვენი დათვალიერების გამოცდილება და მოქმედებების შესრულება ააჩქაროს.</translation>
<translation id="8685318202174822382">გსურთ ახალ Ecosia პროფილში გაგრძელება?</translation>
<translation id="4567424176335768812">თქვენ შესული ხართ, როგორც <ph name="USER_EMAIL_ADDRESS"/>. ახლა შეგიძლიათ გახსნათ თქვენი სანიშნეები, ისტორია და სხვა პარამეტრები ყველა მოწყობილობიდან, რომელშიც შესული ხართ.</translation>
<translation id="361644486359722423">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან Safe Browsing გამორთეთ და ფაილის შემოწმება ვერ ხერხდება</translation>
<translation id="4594305310729380060">პაროლების მმართველში ამ მოწყობილობაზე</translation>
<translation id="2636091632287013185">Ecosia პროგრამები</translation>
<translation id="4613863813562375431">ChromiumOS-ის ვერსია</translation>
<translation id="2394629668475473296">ეკრანის გასაზიარებლად დაუშვით ეკრანის ჩაწერა Ecosia-ისთვის სისტემის პრეფერენციებში</translation>
<translation id="4621240073146040695">განახლება თითქმის მზად არის! დასასრულებლად, ხელახლა გაუშვით Chromium.</translation>
<translation id="1676748966275099244">გაფრთხილება: Ecosia ვერ შეუშლის ხელს გაფართოებებს დათვალიერების ისტორიის შენახვაში. ინკოგნიტო რეჟიმში ამ გაფართოების გასათიშად მოხსენით მონიშვნა ამ ვარიანტზე.</translation>
<translation id="4673151026126227699">თუ Chromium-ის მოხმარების ანგარიშებსაც გააზიარებთ, მათ თქვენ მიერ მონახულებულ URL-ებიც დაერთვება</translation>
<translation id="1384607180773886645">როგორც ჩანს, პროფილი გამოიყენება სხვა Ecosia პროცესის მიერ (<ph name="PROCESS_ID"/>) სხვა კომპიუტერში (<ph name="HOST_NAME"/>). Ecosia-მა დაბლოკა პროფილი, რათა არ დაზიანდეს. თუ დარწმუნებული ხართ, რომ სხვა პროცესები არ იყენებენ ამ პროფილს, შეგიძლიათ განბლოკოთ პროფილი და ხელახლა გაუშვათ Ecosia.</translation>
<translation id="4680828127924988555">ინსტალაციის გაუქმება</translation>
<translation id="7898621536417126731">თქვენი Ecosia-ის ზოგიერთი მონაცემი ჯერ არ შენახულა თქვენს Ecosia ანგარიშში. სისტემიდან გასვლამდე მოითმინეთ რამდენიმე წუთი. ახლა გასვლის შემთხვევაში, აღნიშნული მონაცემები წაიშლება.</translation>
<translation id="4427878468534147875">როცა შესული ხართ, Ecosia-ში შეგიძლიათ გამოიყენოთ თქვენი პაროლები და სხვა კონტენტი თქვენი Ecosia ანგარიშიდან. <ph name="SHORTCUT"/> შეცვლის თქვენი Ecosia სერვისების პარამეტრებს.</translation>
<translation id="4727435569202742773">Ecosia-ში უკვე განხორციელდა შესვლა ამ კომპიუტერიდან, როგორც <ph name="ACCOUNT_EMAIL_LAST"/>. გთხოვთ, შექმნათ Ecosia-ის ახალი მომხმარებელი თქვენი ინფორმაციის ცალკე შესანახად.</translation>
<translation id="4724676981607797757">ინსტალაცია ვერ მოხერხდა მხარდაუჭერელი პროტოკოლის შეცდომის გამო.</translation>
<translation id="864244542982029641">მაინც გსურთ Ecosia-იდან გასვლა?</translation>
<translation id="1025044809499013222">Ecosia-ს ეს-ესაა მიესადაგა უსაფრთხოების საგანგებო განახლება. გადატვირთეთ ის ახლავე (თქვენი ჩანართები აღდგება).</translation>
<translation id="824192326282906244">აზრის შეცვლას ნებისმიერ დროს შეძლებთ Ecosia-ის პარამეტრებიდან. ცდები განხორციელდება რეკლამის ჩვენების ამჟამინდელი მექანიზმების მოქმედების პარალელურად, ამიტომ ცვლილებებს მომენტალურად არ შეამჩნევთ.</translation>
<translation id="4788777615168560705">Chromium ვერ ახერხებს პაროლების შემოწმებას. ცადეთ 24 საათში ან <ph name="BEGIN_LINK"/>შეამოწმეთ პაროლები თქვენს Google ანგარიშში<ph name="END_LINK"/>.</translation>
<translation id="3543284013834505767">ეს ფუნქცია იყენებს მართლწერის იმ შემმოწმებელს, რომელიც გამოიყენება Ecosia Search-ში. ბრაუზერში თქვენ მიერ აკრეფილი ტექსტი ეგზავნება Ecosia-ს. ამ ქცევის შეცვლა ნებისმიერ დროს შეგიძლიათ პარამეტრებიდან.</translation>
<translation id="7787479292144635608">Ecosia-ის გამოყენება ანგარიშის გარეშე</translation>
<translation id="4154538917942874814">Ecosia-ის შემავალი წესი დაუშვას mDNS მოძრაობა.</translation>
<translation id="2159716220295742156">ხელახლა გაშვება &amp;Ecosia-ის გასაახლებლად</translation>
<translation id="8701027951719712428">მომავალში Ecosia-ის განახლებების მისაღებად დაგჭირდებათ macOS 11 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს macOS 10.15-ს.</translation>
<translation id="2234042158691635795">Ecosia ფონურ რეჟიმშია.</translation>
<translation id="3271929752667225813">დააწკაპუნეთ Ecosia-ის შესვლის დიალოგის დასახურად</translation>
<translation id="1869027055332251164">სტუმრებს შეუძლიათ Ecosia-ის გამოყენება და მისი ყველა ფუნქციით სარგებლობა.</translation>
<translation id="6761747850241550887">საკუთარი თავის დამატება Ecosia-ში</translation>
<translation id="3708834841667355707">Ecosia მუშაობს ახალ ფუნქციებზე, რომელთა მეშვეობითაც საიტებს იგივე ფუნქციონალი შეუნარჩუნდება თქვენი ნაკლები ინფორმაციის გამოყენებით</translation>
<translation id="3376578942612115781">Ecosia ანგარიში საჭიროებს ხელახლა ავტორიზაციას</translation>
<translation id="5224391634244552924">შენახული პაროლები არ არის. პაროლების შემოწმებას Chromium შეძლებს მათი შენახვის შემდეგ.</translation>
<translation id="2421263730139898714">Ecosia-იდან გამოსვლა</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> უკვე შესულია ამ Ecosia პროფილში. ეს მოქმედება შექმნის ახალ Ecosia პროფილს <ph name="USER_EMAIL_ADDRESS"/>-ისთვის</translation>
<translation id="5277894862589591112">ცვლილებების მისასადაგებლად ხელახლა გაუშვით Chromium</translation>
<translation id="5294316920224716406">ვების ინკოგნიტო რეჟიმში დათვალიერებისას Chromium გაგაფრთხილებთ საიტის დაუცველი კავშირის გამოყენებით ჩატვირთვამდე</translation>
<translation id="5296845517486664001">როცა ცდები ჩართულია და თუ Chromium შემთხვევითობის პრინციპით მიგაღებინებთ მონაწილეობას მიმდინარე ცდაში, თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chromium წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით.</translation>
<translation id="2297526912548649074">Ecosia-ში შესვლა, როგორც <ph name="USER_EMAIL"/></translation>
<translation id="5352264705793813212">Chromium-მა თქვენთვის იპოვა უსაფრთხოებასთან დაკავშირებული რეკომენდაციები</translation>
<translation id="5251710252516682805">სხვა Ecosia პროფილები</translation>
<translation id="7105712012505419722">მართული ანგარიშით შედიხართ სისტემაში და ადმინისტრატორს თქვენს Ecosia-ის პროფილზე კონტროლს აძლევთ. თქვენი Ecosia ის მონაცემები როგორიცაა თქვენი აპლიკაციები, სანიშნები, ისტორიები, პაროლები, და სხვა პარამეტრები მუდმივად მიბმული გახდება <ph name="USER_NAME"/>-თან. ამ მონაცემების წაშლას Ecosia ანგარიშის საინფორმაციო დაფის გზით შეძლებთ, მაგრამ შეუძლებელი იქნება ამ მონაცემების სხვა ანგარიშთან გაერთიანება. <ph name="LEARN_MORE"/></translation>
<translation id="5368118228313795342">დამატებითი კოდი: <ph name="EXTRA_CODE"/>.</translation>
<translation id="5377622451696208284">პერსონალიზაციით რომ ისარგებლოთ, დაურთეთ Chromium ვებსა და აპებში აქტივობას</translation>
<translation id="350189837353493413">შეიტყვეთ, რატომ ბლოკავს Ecosia ზოგიერთ ფაილს</translation>
<translation id="5386450000063123300">მიმდინარეობს Chromium-ის განახლება (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">Chromium-ში შესვლის დაშვება</translation>
<translation id="330264384086604869">Ecosia-იდან ამოღება</translation>
<translation id="5581150090232500900">დააყენეთ Ecosia ნაგულისხმევ ბრაუზერად</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> — Ecosia Beta</translation>
<translation id="3307959934543585795">Ecosia-მა შეიძლება არასწორად იმუშაოს, რადგან ის აღარ არის მხარდაჭერილი ამ Linux დისტრიბუტივზე</translation>
<translation id="197803137365953132">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ფაილს შეუძლია თქვენი პირადი და სოციალური ქსელების ანგარიშების დაზიანება.</translation>
<translation id="6558895515431832002">Ecosia საჭიროებს თქვენს მდებარეობაზე წვდომის ნებართვას ამ საიტისთვის გასაზიარებლად</translation>
<translation id="5487574057737591516">თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. თუ Chromium შეცდომით გამოიცნობს თქვენს ინტერესს, ან რომელიმე ტიპის რეკლამის ნახვას არ მოისურვებთ, ინტერესის წაშლის საშუალება გექნებათ.</translation>
<translation id="5279514147510747661">დაელოდეთ, სანამ Ecosia დააინსტალირებს სისტემის უახლეს განახლებებს.</translation>
<translation id="5066194399237265772">Ecosia ცდილობს პაროლების რედაქტირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="5527463683072221100">PDF-ების გახსნა Chromium-ში</translation>
<translation id="7348818664647668234">{0,plural, =0{ხელმისაწვდომია Ecosia-ის განახლება}=1{ხელმისაწვდომია Ecosia-ის განახლება}other{უკვე # დღეა, რაც ხელმისაწვდომია Ecosia-ის განახლება}}</translation>
<translation id="5643865575100044307">Chromium-ის დახურვისას თქვენი მოწყობილობიდან საიტების მონაცემების ყოველთვის წაშლა</translation>
<translation id="5982672133249369264">გთხოვთ, ახლავე გადატვირთოთ Ecosia</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="5698481217667032250">Chromium-ის ამ ენაზე ჩვენება</translation>
<translation id="569897634095159764">ინტერნეტთან დაკავშირება ვერ ხერხდება. პროქსი-სერვერი საჭიროებს ავტორიზაციას.</translation>
<translation id="5761096224651992291">ბოლო დროს არ ყოფილხართ. Chromium-მა ამოშალა <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> და <ph name="PERMISSION_3"/></translation>
<translation id="1818520302923047971">მოირგეთ და მართეთ Ecosia. დააყენეთ Ecosia ნაგულისხმევად.</translation>
<translation id="5809516625706423866">ინტერნეტთან დაკავშირება ვერ ხერხდება. HTTP 401 — არ არის ავტორიზაცია. შეამოწმეთ პროქსი-სერვერის კონფიგურაცია.</translation>
<translation id="1027331268335328576">მოგესალმებათ Ecosia!</translation>
<translation id="2942675027725878581">Ecosia-მა აღმოაჩინა, რომ შემდეგი ერთეულები შეიცავს მავნე პროგრამას:</translation>
<translation id="5889361821821684993">Chromium რეგულარულად ამოწმებს, არის თუ არა თქვენს ბრაუზერში ყველაზე უსაფრთხო პარამეტრები. გაცნობებთ, თუ რაიმეს შემოწმება იქნება საჭირო.</translation>
<translation id="5895138241574237353">გადატვირთვა</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> — ქსელში შესვლა</translation>
<translation id="5924017743176219022">მიმდინარეობს ინტერნეტთან დაკავშირება...</translation>
<translation id="719484593754925816">Ecosia-ს შეუძლია, ეს ჩანართი უმოქმედო რეჟიმში გადაიტანოს, რათა გააუმჯობესოს თქვენი დათვალიერების გამოცდილება და გაასუფთაოს რესურსები.</translation>
<translation id="5941711191222866238">ჩაკეცვა</translation>
<translation id="5972142260211327093">თუ Chromium შემთხვევითობის პრინციპით მიგაღებინებთ მონაწილეობას მიმდინარე ცდაში, თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chromium წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით. ინტერესები გაახლდება, თუ რომელიმე მათგანს არ წაშლით.</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{თქვენი ორგანიზაცია ავტომატურად ხურავს Ecosia-ს, როცა ის 1 წუთის განმავლობაში არ გამოიყენება.}other{თქვენი ორგანიზაცია ავტომატურად ხურავს Ecosia-ს, როცა ის # წუთის განმავლობაში არ გამოიყენება.}}</translation>
<translation id="5704599732514791330">სინქრონიზაციის დასაწყებად, განაახლეთ Ecosia</translation>
<translation id="5988505247484123880">თქვენ მიერ მონახულებული საიტები, როგორც წესი, ინახავს თქვენს ინტერესებს ფუნქციების თქვენზე მორგების მიზნით. საიტებს Chromium-ის მეშვეობითაც შეუძლია თქვენს ინტერესებთან დაკავშირებული ინფორმაციის შენახვა.</translation>
<translation id="6003112304606738118">მიმდინარეობს ჩამოტვირთვა… დარჩენილია <ph name="HOURS"/> საათი</translation>
<translation id="8347473600923066837">Ecosia-ის მენიუდან, რომელიც მოცემულია ზედა მარჯვენა ნაწილში, შეგიძლიათ სანიშნეების, წაკითხვის რეჟიმისა და სხვა ერთეულების გახსნა</translation>
<translation id="6040143037577758943">დახურვა</translation>
<translation id="6058380562449900225">თქვენი მონაცემების დაცვის მიზნით, მიეცით საშუალება Chromium-ს გააუქმოს ნებართვები საიტებს, რომლებზეც ბოლო დროს არ გადასულხართ. აღნიშნული არ გათიშავს შეტყობინებების მიღების ფუნქციას.</translation>
<translation id="7303930050538184306">Ecosia-ში &amp;გახსნა</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/> დაემატა Ecosia-ს</translation>
<translation id="2905159584855395810">ააჩქარეთ Ecosia-ის მუშაობა</translation>
<translation id="608006075545470555">დაამატეთ სამსახურის პროფილი ამ ბრაუზერს</translation>
<translation id="8296565077892323223">მოირგეთ და გააკონტროლეთ Ecosia. ხელმისაწვდომია განახლება.</translation>
<translation id="6102072151902574948">ჩართვის შემთხვევაში, Chromium დაზოგავს ბატარეის მუხტს ვიზუალური ეფექტებისა (მაგალითად, ლივლივა გადაადგილებისა და ვიდეოკადრების სიხშირის) და ფონური აქტივობის შეზღუდვის გზით.</translation>
<translation id="8419312540998601274">ჩართული • Ecosia ვერ ადასტურებს ამ გაფართოების წარმომავლობას</translation>
<translation id="6419542773162312746">გაფართოებისთვის Ecosia-ის ხელსაწყოთა ზოლში წვდომის მოთხოვნების ჩვენების დაშვება</translation>
<translation id="4021894801595982809">Ecosia შეინახავს ამ პაროლს თქვენს Ecosia ანგარიშში. მისი დამახსოვრება აუცილებელი არ არის.</translation>
<translation id="1936361330890313940">Ecosia-მა დაბლოკა <ph name="FILE_NAME"/>, რადგან ის სახიფათოა.</translation>
<translation id="2446603005062458629">Ecosia მალე დაიხურება, ხოლო მონაცემები წაიშლება</translation>
<translation id="6134968993075716475">Safe Browsing გამორთულია. Chromium გირჩევთ მის ჩართვას.</translation>
<translation id="4032832945953542360">აქ შეგიძლიათ Ecosia პროფილებს შორის გადართვა</translation>
<translation id="615103374448673771">ქუქი-ჩანაწერების დაშვების შემთხვევაში, Chromium-მა, შესაძლოა, გამოიყენოს ისინი წინასწარ ჩატვირთვისთვის</translation>
<translation id="5032126307005935789">ეს ფაილი, შესაძლოა, სახიფათო იყოს<ph name="LINE_BREAK"/>Ecosia-ს შეუძლია, თქვენ ნაცვლად შეამოწმოს ეს ჩამოტვირთვა, თუ პაროლს მიუთითებთ. ფაილის შესახებ ინფორმაცია ეგზავნება Ecosia Safe Browsing-ს, თუმცა ფაილების შიგთავსი და პაროლი რჩება თქვენს მოწყობილობაზე.</translation>
<translation id="6182736845697986886">ინსტალაცია ვერ მოხერხდა განახლების სერვერის შიდა შეცდომის გამო.</translation>
<translation id="2346323077583431428">დარწმუნდით, რომ თქვენს <ph name="TARGET_DEVICE_NAME"/>-ზე შესული ხართ Ecosia-ში, შემდეგ კი ხელახლა ცადეთ გაგზავნა.</translation>
<translation id="2995860351618948435">ამ კომპიუტერს უკვე აქვს Ecosia.-ის უფრო ახალი ვერსია. იმ შემთხვევაში, თუ პროგრამა არ მუშაობს, გთხოვთ, განახორციელეთ Ecosia-ის დეინსტალაცია და სცადეთ ისევ.</translation>
<translation id="5690368185132749068">{0,plural, =0{Ecosia ახლა ხელახლა გაეშვება}=1{Ecosia ხელახლა გაეშვება 1 წამში}other{Ecosia ხელახლა გაეშვება # წამში}}</translation>
<translation id="1809194740315140401">ფაილების ჩამოსატვირთად Ecosia საჭიროებს მეხსიერებაზე წვდომის ნებართვას</translation>
<translation id="6245734527075554892">შეამოწმებს URL-ების თანხვედრას Chromium-ში შენახულ არაუსაფრთხო საიტების სიასთან</translation>
<translation id="4662363689050405237">Ecosia გახდეს ნაგულისხმევი ბრაუზერი</translation>
<translation id="6266342355635466082">Chromium ვერ ახერხებს განახლებების შემოწმებას. შეამოწმეთ კავშირი ინტერნეტთან.</translation>
<translation id="6268381023930128611">გსურთ Chromium-იდან გამოსვლა?</translation>
<translation id="4618410489751241263">ეს ჩანართები დამატებით რესურსებს მოიხმარს. ეფექტურობის გაზრდის მიზნით, ნება დართეთ Ecosia-ს, ჩანართები უმოქმედო რეჟიმში გადაიტანოს.</translation>
<translation id="6416551953415159186">თქვენი Ecosia პროფილის მორგება</translation>
<translation id="6290827346642914212">დაასათაურეთ თქვენი Chromium პროფილი</translation>
<translation id="4882579364090762302">გაფართოების გამოსაყენებლად შედით Ecosia-ში</translation>
<translation id="3625533701824359646">Ecosia-მა დაბლოკა <ph name="FILE_NAME"/>, რადგან ის შეიძლება სახიფათო იყოს.</translation>
<translation id="4943938785458240142">Ecosia იყენებს თქვენს კამერას.</translation>
<translation id="6327105987658262776">განახლებები ხელმისაწვდომი არ არის.</translation>
<translation id="6450895420388847775">Ecosia-ში სხვა ოპერაცია მიმდინარეობს. გთხოვთ, ცადოთ მოგვიანებით.</translation>
<translation id="464306605599005355">ყველა საერთო მოხმარების კომპიუტერზე ადვილი გახდა Ecosia ანგარიშით Ecosia-ის გამოყენება.</translation>
<translation id="6735145163744656874">Ecosia-ს შეუძლია, თქვენი ჩანართები უმოქმედო რეჟიმში გადაიტანოს, რათა გააუმჯობესოს თქვენი დათვალიერების გამოცდილება და უზრუნველყოს სისწრაფე.</translation>
<translation id="1284343625991453987">Ecosia-ის მალსახმობი</translation>
<translation id="7051119589302096163">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან ამ ფაილს, როგორც წესი, არ ტვირთავენ ხოლმე და ის, შესაძლოა, სახიფათო იყოს</translation>
<translation id="7908111389403807005">ნამდვილად გსურთ მოახდინოთ Ecosia-ის დეინსტალაცია?</translation>
<translation id="6375219077595103062">დაამატეთ პაროლების მმართველის მალსახმობი</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>ამ მონაცემთა გამოყენების წესი:<ph name="END_BOLD"/> Ecosia-ს შეუძლია თქვენი ინტერესების პროგნოზირება. მოგვიანებით, თქვენ მიერ მონახულებულ საიტს საშუალება ექნება, Ecosia-ს სთხოვოს თქვენი ინტერესების ჩვენება, თქვენთვის ხილული რეკლამის პერსონალიზების მიზნით.</translation>
<translation id="7578952608547569314">Ecosia-ის ლოგო კომპიუტერის ეკრანზე.</translation>
<translation id="3939060118711873999">Ecosia არის ვებ ბრაუზერი, რომელიც ვებგვერდებს და აპლიკაციებს ელვისებური სისწრაფით ხსნის. ის არის სწრაფი, სტაბილური და გამოსაყენებლად მარტივი. დაათვალიერეთ ვები უფრო უსაფრთხოდ Ecosia-ში ჩაშენებული საზიანო პროგრამული უზრუნველყოფისა და თაღლითობისგან დაცვის საშუალებით.</translation>
<translation id="5404489723475681578">გადატვირთეთ EcosiaOS</translation>
<translation id="6443470774889161065">Chromium წინასწარ ჩატვირთავს უფრო მეტ გვერდს, რომელთა ნახვასაც, სავარაუდოდ, დააპირებთ — ამგვარად, ამ გვერდებზე გადასვლისას, ისინი უფრო სწრაფად ჩაიტვირთება</translation>
<translation id="7877883466657693294">გამორთული • Ecosia ვერ ადასტურებს ამ გაფართოების წარმომავლობას</translation>
<translation id="4410570812343670816">მოგესალმებათ Ecosia პროფილები</translation>
<translation id="4371259280767924562">ანგარიშის ამოშლა Ecosia-იდან</translation>
<translation id="524314285625975879">იგი ასევე აკონტროლებს, თუ რომელი გვერდი გამოჩნდება Ecosia-ის გაშვებისას.</translation>
<translation id="648319183876919572">გაძლიერებული Safe Browsing მეტად გიცავთ სახიფათო ვებსაიტებისა და ჩამოტვირთვებისგან</translation>
<translation id="6496553866814956056">Ecosia-ის დეინსტალაცია</translation>
<translation id="788366290112401490">მალსახმობები იხსნება Ecosia-ში</translation>
<translation id="1773882594264682232">როცა შესული ხართ, Ecosia-ში შეგიძლიათ გამოიყენოთ თქვენი პაროლები და სხვა კონტენტი თქვენი Ecosia ანგარიშიდან. ამის შეცვლა შეგიძლიათ ნებისმიერ დროს, მდებარეობის პარამეტრებიდან.</translation>
<translation id="2280934980919215876">თქვენი ორგანიზაცია ხურავს Ecosia-ს, როცა ის <ph name="TIMEOUT_DURATION"/> არ გამოიყენება. დათვალიერების მონაცემები წაიშალა. აღნიშნული, შესაძლოა, მოიცავდეს ისტორიას, ავტომატური შევსების მონაცემებსა და ჩამოტვირთვებს.</translation>
<translation id="8608092457636055141">თითოეულ პროფილში ინახება საკუთარი Ecosia ინფორმაცია, როგორიცაა სანიშნეები, ისტორია, პაროლები და სხვა</translation>
<translation id="6563921047760808519">შეიტყვეთ მეტი იმის შესახებ, თუ <ph name="BEGIN_LINK"/>როგორ ინარჩუნებს Chromium თქვენი მონაცემების კონფიდენციალურობას<ph name="END_LINK"/></translation>
<translation id="3592624492063123732">ახლა შეგიძლიათ გადართვა, პაროლები სხვა Ecosia პროფილიდან რომ ნახოთ</translation>
<translation id="6570579332384693436">მართლწერის შეცდომების გასასწორებლად, Chromium თქვენ მიერ ტექსტის ველში აკრეფილ ტექსტებს Google-ს უგზავნის</translation>
<translation id="6533266716128249922">Ecosia-ის შეტყობინების პარამეტრებზე გადასვლა</translation>
<translation id="1722634673917783018">თქვენი ცვლილებები გააქტიურდება Ecosia-ის შემდეგი გაშვებისას.</translation>
<translation id="2537426042760364251">თქვენი შემოგარენის 3-განზომილებიანი რუკის შესაქმნელად Ecosia საჭიროებს მეხსიერებაზე წვდომის ნებართვას</translation>
<translation id="6663852025006259149">საიტები, სავარაუდოდ, მოლოდინისამებრ იმუშავებს, თუმცა ისინი არ დაგიმახსოვრებთ, როცა Chromium-ის ყველა ფანჯარას დახურავთ</translation>
<translation id="6669284030132180248">თუ თქვენს სანიშნეებს Google ანგარიშშიც ინახავთ, შეგიძლიათ თვალი მიადევნოთ პროდუქტების ფასებს Chromium-ში და შეიტყოთ, როცა ფასი დაიკლებს</translation>
<translation id="6676384891291319759">წვდომა ინტერნეტზე</translation>
<translation id="8067423333018528301">EcosiaOS-მა ვერ დაასინქრონა თქვენი მონაცემები შესვლის შეცდომის გამო.</translation>
<translation id="6692797197837897398">Chromium გაძლევთ მეტ კონტროლს თქვენთვის ხილულ რეკლამაზე. ის, ასევე, ზღუდავს იმას, თუ რომელ საიტებს შეუძლია თქვენ შესახებ ინფორმაციის მიღება, როცა მათ მიერ თქვენთვის ნაჩვენებია პერსონალიზებული რეკლამა.</translation>
<translation id="2173571365716863400">Ecosia საჭიროებს მიკროფონზე წვდომის ნებართვას ამ საიტისთვის</translation>
<translation id="6712881677154121168">შეცდომა ჩამოტვირთვისას: <ph name="DOWNLOAD_ERROR"/></translation>
<translation id="6648664289472946060">თქვენი პროფილის გამოყენება შეუძლებელია, რადგან ის Ecosia-ის უახლესი ვერსიიდანაა.

ზოგიერთი ფუნქცია შეიძლება მიუწვდომელი იყოს. გთხოვთ მიუთითოთ სხვადასხვა პროფილის დირექტორია ან გამოიყენეთ Ecosia-ის ახალი ვერსია.</translation>
<translation id="6729124504294600478">პერსონალიზაციის და სხვა ფუნქციებით რომ ისარგებლოთ, დაურთეთ Chromium როგორც ვებსა და აპებში აქტივობას, ისე მიბმულ Google სერვისებს</translation>
<translation id="4870057811531036437">Ecosia უკვე დაინსტალირებულია თქვენი კომპიუტერის ყველა მომხმარებლისთვის.</translation>
<translation id="4512092435423703529">თქვენს Ecosia კონტენტზე თქვენი ნებისმიერი მოწყობილობიდან წვდომისთვის შედით სისტემაში, შემდეგ კი ჩართეთ სინქრონიზაცია.</translation>
<translation id="674245979920622322">ბოლო დროს არ ყოფილხართ. Chromium-მა ამოშალა <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> და კიდევ <ph name="COUNT"/></translation>
<translation id="7972668220031382654">Ecosia გირჩევთ, დაასკანიროთ ეს ფაილი, რადგან ის შეიძლება სახიფათო იყოს.</translation>
<translation id="2441303983090031276">EcosiaOS-ს უზრუნველყოფს დამატებითი <ph name="BEGIN_LINK_CROS_OSS"/>ღია წყაროს პროგრამული უზრუნველყოფა<ph name="END_LINK_CROS_OSS"/>.</translation>
<translation id="1263466865695943046">Ecosia გაცნობებთ, თუ თქვენს პაროლებს ვინმე გატეხავს</translation>
<translation id="684888714667046800">ინტერნეტთან დაკავშირება ვერ ხერხდება. თუ ქსელის დაცვას იყენებთ, დარწმუნდით, რომ <ph name="PRODUCT_EXE_NAME"/> დაშვებულთა სიაშია.</translation>
<translation id="4600924482853773728">Ecosia — <ph name="PAGE_TITLE"/></translation>
<translation id="1490060441084292633">Ecosia-მა აღმოაჩინა, რომ „<ph name="EXTENSION_NAME"/>“ შეიცავს მავნე პროგრამას</translation>
<translation id="6929417474050522668">როცა ცდები ჩართულია, რეკლამის ეფექტურობის გაზომვის მეშვეობით, თქვენ მიერ მონახულებულ საიტებს საშუალება ექნება, Chromium-ისგან მოითხოვონ გარკვეული ინფორმაცია, რომელიც ამა თუ იმ საიტს თავისი რეკლამის ეფექტურობის განსაზღვრაში დაეხმარება. რეკლამის ეფექტურობის გაზომვისას საიტებს შორის თვალის მიდევნების მექანიზმები შეზღუდულია, რაც ნიშნავს, რომ საიტებს შორის მინიმალური ინფორმაცია გადაიცემა.</translation>
<translation id="6940431691900807093">მოგვიანებით, თქვენ მიერ მონახულებულ საიტს საშუალება ექნება, Chromium-ს სთხოვოს თქვენი ინტერესების ჩვენება, თქვენთვის ხილული რეკლამის პერსონალიზების მიზნით. Chromium-ს შეუძლია 3-მდე ინტერესის გაზიარება.</translation>
<translation id="8283315171506895091">ბმულის გახსნა Ecosia-ის ინკო&amp;გნიტო ფანჯარაში</translation>
<translation id="6978145336957848883">სუსტი პაროლები ადვილი გამოსაცნობია, ამიტომ მიეცით საშუალება Chromium-ს, <ph name="BEGIN_LINK"/>თქვენთვის შექმნას და დაიმახსოვროს ძლიერი პაროლები<ph name="END_LINK"/>.</translation>
<translation id="6981396265751285733">ჩართვის შემთხვევაში, Chromium გამოათავისუფლებს მეხსიერებას არააქტიური ჩანართებიდან. აქტიურ ჩანართებსა და სხვა აპებს კომპიუტერის მეტი რესურსის გამოყენების საშუალება მიეცემა, რაც დააჩქარებს Chromium-საც. თქვენი არააქტიური ჩანართები ავტომატურად გააქტიურდება, როცა მათ დაუბრუნდებით.</translation>
