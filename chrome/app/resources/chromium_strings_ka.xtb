<translation id="8544776492099331022">მოირგეთ და გააკონტროლეთ Ecosia. საჭიროა თქვენი ყურადღება — დააწკაპუნეთ დეტალური ინფორმაციისთვის.</translation>
<translation id="4871843754042758264">Ecosia ის გახსნისა და დათვალიერების დაწყებისათვის დააჭირეთ თქვენი სახელს.</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/> უკვე შესულია ამ Ecosia პროფილში. თქვენი დათვალიერების მონაცემები რომ განაცალკევოთ, Ecosia-ს შეუძლია თქვენთვის პერსონალური პროფილის შექმნა.</translation>
<translation id="4070480171055648632">თქვენს ანგარიშს მართავს <ph name="MANAGER_NAME"/>. თქვენს ადმინისტრატორს შეუძლია ამ Ecosia ბრაუზერის პროფილისა და მისი მონაცემების (მაგალითად, სანიშნეების, ისტორიისა და პაროლების) ნახვა და რედაქტირება.</translation>
<translation id="1047556320128249268">Ecosia ცდილობს პაროლების კოპირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="4997668724897475215">Ecosia გირჩევთ, დაასკანიროთ ეს ფაილი, რადგან ის შეიძლება სახიფათო იყოს</translation>
<translation id="3997429360543082038">ChromiumOS-ის შესახებ</translation>
<translation id="5311911269004680646">EcosiaOS და <ph name="BEGIN_LINK_LINUX_OSS"/>Linux-ის შემუშავების გარემო <ph name="END_LINK_LINUX_OSS"/> მუშაობს <ph name="BEGIN_LINK_CROS_OSS"/>ღია კოდის დამატებითი პროგრამული უზრუნველყოფის<ph name="END_LINK_CROS_OSS"/> დამსახურებით.</translation>
<translation id="4036079820698952681">ხელი შეუწყვეთ Chromium-ის გაუმჯობესებას <ph name="BEGIN_LINK"/>მიმდინარე პარამეტრების<ph name="END_LINK"/> გამოგზავნის მეშვეობით</translation>
<translation id="4050175100176540509">უსაფრთხოების მნიშვნელოვანი გაუმჯობესება და ახალი თვისებები ხელმისაწვდომია უახლეს ვერსიაში.</translation>
<translation id="4148957013307229264">ინსტალაცია…</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> — ქსელში შესვლა — Ecosia</translation>
<translation id="7782767522222146179">აღმოაჩინეთ შესანიშნავი აპები, თამაშები, გაფართოებები და თემები Ecosia-ისთვის.</translation>
<translation id="4216212958613226427">ეს ენა გამოიყენება Chromium-ის სამომხმარებლო ინტერფეისისთვის</translation>
<translation id="4222932583846282852">მიმდინარეობს გაუქმება…</translation>
<translation id="8384922154025337808">დავუკავშიროთ თქვენი Ecosia მონაცემები ამ ანგარიშის?</translation>
<translation id="4271805377592243930">Chromium-თან დაკავშირებული დახმარების მიღება</translation>
<translation id="3305517118160815955">ინსტალაცია ვერ განხორციელდა განუსაზღვრელი შეცდომის გამო. თუ Ecosia ამჟამად გაშვებულია, დახურეთ იგი და ხელახლა სცადეთ.</translation>
<translation id="4304713468139749426">პაროლების მმართველი</translation>
<translation id="4334294535648607276">ჩამოტვირთვა დასრულდა.</translation>
<translation id="8411844745163855310"><ph name="MANAGER"/> მოითხოვს, რომ ამ მოწყობილობის გამოყენებამდე წაიკითხოთ ქვემოთ მოცემული მომსახურების პირობები და დაეთანხმოთ მათ. აღნიშნული პირობები არ არის EcosiaOS-ის წესების დამატება, ასევე, არ ცვლის და არც ზღუდავს მათ.</translation>
<translation id="88039520238670574">მაინც გსურთ Ecosia-იდან გასვლა?</translation>
<translation id="4586967042094107073">Ecosia-ისთვის ფონურ რეჟიმში მუშაობის დაშვება</translation>
<translation id="4817913198787198451">Ecosia-ის მორგება და კონტროლი</translation>
<translation id="4427306783828095590">გაძლიერებული დაცვა გთავაზობთ ფიშინგისა და მავნე პროგრამებისგან დაცვის მეტ საშუალებას</translation>
<translation id="1859120614572957305">მოგესალმებით Ecosia-ში; გახსნილია ბრაუზერის ახალი ფანჯარა</translation>
<translation id="4544142686420020088">Chromium-ის განახლება ვერ მოხერხდა შეფერხების გამო. <ph name="BEGIN_LINK"/>შეასწორეთ Chromium-ის განახლებასთან დაკავშირებული პრობლემები და განუხორციელებელი განახლებები.<ph name="END_LINK"/></translation>
<translation id="8685318202174822382">გსურთ ახალ Ecosia პროფილში გაგრძელება?</translation>
<translation id="4567424176335768812">თქვენ შესული ხართ, როგორც <ph name="USER_EMAIL_ADDRESS"/>. ახლა შეგიძლიათ გახსნათ თქვენი სანიშნეები, ისტორია და სხვა პარამეტრები ყველა მოწყობილობიდან, რომელშიც შესული ხართ.</translation>
<translation id="4594305310729380060">პაროლების მმართველში ამ მოწყობილობაზე</translation>
<translation id="2636091632287013185">Ecosia პროგრამები</translation>
<translation id="4613863813562375431">ChromiumOS-ის ვერსია</translation>
<translation id="4621240073146040695">განახლება თითქმის მზად არის! დასასრულებლად, ხელახლა გაუშვით Chromium.</translation>
<translation id="1676748966275099244">გაფრთხილება: Ecosia ვერ შეუშლის ხელს გაფართოებებს დათვალიერების ისტორიის შენახვაში. ინკოგნიტო რეჟიმში ამ გაფართოების გასათიშად მოხსენით მონიშვნა ამ ვარიანტზე.</translation>
<translation id="4673151026126227699">თუ Chromium-ის მოხმარების ანგარიშებსაც გააზიარებთ, მათ თქვენ მიერ მონახულებულ URL-ებიც დაერთვება</translation>
<translation id="1384607180773886645">როგორც ჩანს, პროფილი გამოიყენება სხვა Ecosia პროცესის მიერ (<ph name="PROCESS_ID"/>) სხვა კომპიუტერში (<ph name="HOST_NAME"/>). Ecosia-მა დაბლოკა პროფილი, რათა არ დაზიანდეს. თუ დარწმუნებული ხართ, რომ სხვა პროცესები არ იყენებენ ამ პროფილს, შეგიძლიათ განბლოკოთ პროფილი და ხელახლა გაუშვათ Ecosia.</translation>
<translation id="4680828127924988555">ინსტალაციის გაუქმება</translation>
<translation id="4727435569202742773">Ecosia-ში უკვე განხორციელდა შესვლა ამ კომპიუტერიდან, როგორც <ph name="ACCOUNT_EMAIL_LAST"/>. გთხოვთ, შექმნათ Ecosia-ის ახალი მომხმარებელი თქვენი ინფორმაციის ცალკე შესანახად.</translation>
<translation id="864244542982029641">მაინც გსურთ Ecosia-იდან გასვლა?</translation>
<translation id="1025044809499013222">Ecosia-ს ეს-ესაა მიესადაგა უსაფრთხოების საგანგებო განახლება. გადატვირთეთ ის ახლავე (თქვენი ჩანართები აღდგება).</translation>
<translation id="824192326282906244">აზრის შეცვლას ნებისმიერ დროს შეძლებთ Ecosia-ის პარამეტრებიდან. ცდები განხორციელდება რეკლამის ჩვენების ამჟამინდელი მექანიზმების მოქმედების პარალელურად, ამიტომ ცვლილებებს მომენტალურად არ შეამჩნევთ.</translation>
<translation id="4788777615168560705">Chromium ვერ ახერხებს პაროლების შემოწმებას. ცადეთ 24 საათში ან <ph name="BEGIN_LINK"/>შეამოწმეთ პაროლები თქვენს Google ანგარიშში<ph name="END_LINK"/>.</translation>
<translation id="3543284013834505767">ეს ფუნქცია იყენებს მართლწერის იმ შემმოწმებელს, რომელიც გამოიყენება Ecosia Search-ში. ბრაუზერში თქვენ მიერ აკრეფილი ტექსტი ეგზავნება Ecosia-ს. ამ ქცევის შეცვლა ნებისმიერ დროს შეგიძლიათ პარამეტრებიდან.</translation>
<translation id="4154538917942874814">Ecosia-ის შემავალი წესი დაუშვას mDNS მოძრაობა.</translation>
<translation id="2159716220295742156">ხელახლა გაშვება &amp;Ecosia-ის გასაახლებლად</translation>
<translation id="2234042158691635795">Ecosia ფონურ რეჟიმშია.</translation>
<translation id="1869027055332251164">სტუმრებს შეუძლიათ Ecosia-ის გამოყენება და მისი ყველა ფუნქციით სარგებლობა.</translation>
<translation id="6761747850241550887">საკუთარი თავის დამატება Ecosia-ში</translation>
<translation id="3708834841667355707">Ecosia მუშაობს ახალ ფუნქციებზე, რომელთა მეშვეობითაც საიტებს იგივე ფუნქციონალი შეუნარჩუნდება თქვენი ნაკლები ინფორმაციის გამოყენებით</translation>
<translation id="5224391634244552924">შენახული პაროლები არ არის. პაროლების შემოწმებას Chromium შეძლებს მათი შენახვის შემდეგ.</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/> უკვე შესულია ამ Ecosia პროფილში. ეს მოქმედება შექმნის ახალ Ecosia პროფილს <ph name="USER_EMAIL_ADDRESS"/>-ისთვის</translation>
<translation id="5277894862589591112">ცვლილებების მისასადაგებლად ხელახლა გაუშვით Chromium</translation>
<translation id="5296845517486664001">როცა ცდები ჩართულია და თუ Chromium შემთხვევითობის პრინციპით მიგაღებინებთ მონაწილეობას მიმდინარე ცდაში, თქვენ მიერ ვების დათვალიერების ისტორია აისახება თქვენთვის ხილულ რეკლამასა და თქვენს ინტერესებზე, ქვემოთ პროგნოზირებულის შესაბამისად. თქვენი კონფიდენციალურობის დაცვის მიზნით, Chromium წაშლის თქვენს ინტერესებს ყოველთვიურად რიგითობის მიხედვით.</translation>
<translation id="7105712012505419722">მართული ანგარიშით შედიხართ სისტემაში და ადმინისტრატორს თქვენს Ecosia-ის პროფილზე კონტროლს აძლევთ. თქვენი Ecosia ის მონაცემები როგორიცაა თქვენი აპლიკაციები, სანიშნები, ისტორიები, პაროლები, და სხვა პარამეტრები მუდმივად მიბმული გახდება <ph name="USER_NAME"/>-თან. ამ მონაცემების წაშლას Ecosia ანგარიშის საინფორმაციო დაფის გზით შეძლებთ, მაგრამ შეუძლებელი იქნება ამ მონაცემების სხვა ანგარიშთან გაერთიანება. <ph name="LEARN_MORE"/></translation>
<translation id="5386450000063123300">მიმდინარეობს Chromium-ის განახლება (<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">Chromium-ში შესვლის დაშვება</translation>
<translation id="8447746441670667471">ხელმისაწვდომია Ecosia-ის ახალი ვერსია.</translation>
<translation id="330264384086604869">Ecosia-იდან ამოღება</translation>
<translation id="3138995062177413515">{0,plural, =0{Ecosia ახლა დაიხურება.}=1{Ecosia დაიხურება 1 წამში.}other{Ecosia დაიხურება # წამში.}}</translation>
<translation id="5581150090232500900">დააყენეთ Ecosia ნაგულისხმევ ბრაუზერად</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> — Ecosia Beta</translation>
<translation id="3307959934543585795">Ecosia-მა შეიძლება არასწორად იმუშაოს, რადგან ის აღარ არის მხარდაჭერილი ამ Linux დისტრიბუტივზე</translation>
<translation id="6558895515431832002">Ecosia საჭიროებს თქვენს მდებარეობაზე წვდომის ნებართვას ამ საიტისთვის გასაზიარებლად</translation>
<translation id="5487574057737591516">თქვენი კონფიდენციალურობის დაცვის მიზნით, ჩვენ ავტომატურად ვშლით თქვენს ინტერესებს, რომლებიც 4 კვირაზე ძველია. თქვენ მიერ ვების დათვალიერების პარალელურად, ესა თუ ეს ინტერესი შეიძლება ხელახლა გამოჩნდეს სიაში. თუ Chromium შეცდომით გამოიცნობს თქვენს ინტერესს, ან რომელიმე ტიპის რეკლამის ნახვას არ მოისურვებთ, ინტერესის წაშლის საშუალება გექნებათ.</translation>
<translation id="5279514147510747661">დაელოდეთ, სანამ Ecosia დააინსტალირებს სისტემის უახლეს განახლებებს.</translation>
<translation id="5066194399237265772">Ecosia ცდილობს პაროლების რედაქტირებას. აღნიშნულის დასაშვებად აკრიფეთ თქვენი Windows-ის პაროლი ამის დასაშვებად.</translation>
<translation id="5527463683072221100">PDF-ების გახსნა Chromium-ში</translation>
<translation id="5614091477838198795">როცა ეს ფუნქცია ჩართულია, თქვენ, ასევე, გახვალთ Chromium-იდან</translation>
