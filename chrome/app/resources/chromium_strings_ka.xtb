<translation id="8986207147630327271">თქვენ აპირებთ, ამ ბრაუზერს სამსახურის პროფილი დაამატოთ, რითაც თქვენს ადმინისტრატორს კონტროლს მხოლოდ სამსახურის პროფილზე მიანიჭებთ.</translation>
<translation id="2985399486579137606">Ecosia-ის პროფილების მართვა</translation>
<translation id="1597547208646178091">Ecosia-ის უსაფრთხოების გასაძლიერებლად, ჩვენ გავთიშეთ შემდეგი გაფართოება, რომელიც არ არის ხელმისაწვდომი <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>-ში და, შესაძლოა, თქვენი თანხმობის გარეშე დაემატა.</translation>
<translation id="2388751143175762498">შედით Ecosia-ში</translation>
<translation id="231621248561775155">Ecosia-მა დაბლოკა ეს ჩამოტვირთვა, რადგან არქივის ფაილი შეიცავს სხვა ფაილებს, რომლებშიც, შესაძლოა, მავნე პროგრამა იმალებოდეს</translation>
<translation id="9062666675513499497">შედით Chromium-ში, როცა Google-ის სხვა სერვისებში შედიხართ</translation>
<translation id="5312730628132049495">შედით Ecosia-ში. თუ ანგარიშში შესვლა მხოლოდ ერთჯერადად გსურთ, <ph name="GUEST_LINK_BEGIN"/>მოწყობილობის გამოყენება სტუმრის სტატუსით<ph name="GUEST_LINK_END"/> შეგიძლიათ.</translation>
<translation id="5061261337583604526">Ecosia ავტომატურად დაიხურა</translation>
<translation id="7268098999602465369">Ecosia მოძველდა</translation>
<translation id="6022879254514691681">{0,plural, =1{Ecosia ხელახლა გაეშვება 1 საათში}other{Ecosia ხელახლა გაეშვება # საათში}}</translation>
<translation id="8963533629322868062">Ecosia-ის მომავალი განახლებების მისაღებად დაგჭირდებათ Windows 10 ან უფრო ახალი ვერსია. ეს კომპიუტერი იყენებს Windows 8.1-ს.</translation>
<translation id="7774247008790177839">ბმულის გახსნა Ecosia-ის ახალ ჩა&amp;ნართში</translation>
<translation id="911206726377975832">ასევე წაშალოთ თქვენი დათვალიერების მონაცემები?</translation>
<translation id="7580831958727159171">ცდების მსვლელობისას შეძლებთ იმ ინტერესთა თემების ნახვასა და ამოშლას, რომლებსაც საიტები იყენებს თქვენთვის რეკლამის საჩვენებლად. თქვენს ინტერესებს Ecosia პროგნოზირებს თქვენ მიერ ვების დათვალიერების ბოლოდროინდელი ისტორიის საფუძველზე.</translation>
<translation id="8901409988302458368">თქვენი სისტემის ადმინისტრატორმა მოახდინა Ecosia-ის კონფიგურაცია იმგვარად, რომ <ph name="TARGET_URL_HOSTNAME"/>-ზე წვდომისთვის საჭიროა ალტერნატიული ბრაუზერის გახსნა.</translation>
<translation id="1523806373970723624">ხელახლა გაშვება &amp;Ecosia-ის გასაახლებლად</translation>
<translation id="2470806471563820591">Ecosia (mDNS-In)</translation>
<translation id="4767994371234572952">მოირგეთ Ecosia</translation>
<translation id="6933283849886243832">Ecosia-მა შეიძლება არასწორად იმუშაოს, რადგან ის აღარ არის მხარდაჭერილი Windows XP-სა და Windows Vista-ზე</translation>
<translation id="942598560705308788">Chromium-ის მიერ მართული სერტიფიკატები</translation>
<translation id="8078678931242443254">ვინ იყენებს Ecosia-ს?</translation>
<translation id="12795904718916112">ისარგებლეთ Ecosia-ის უსაფრთხოების ყველაზე ძლიერი ფუნქციებით</translation>
<translation id="983803489796659991">ინსტალაცია ვერ მოხერხდა, რადგან განახლების სერვერს არ აქვს ამ აპლიკაციის ჰეშ-მონაცემები.</translation>
<translation id="5612740201368556834">Ecosia-ის გამოყენება ანგარიშის გარეშე</translation>
<translation id="6235001546696543832">Ecosia-ის ავტორები</translation>
<translation id="992780518932311116">თქვენი მდებარეობა რომ გამოიყენოთ, გახსენით <ph name="BEGIN_LINK"/>სისტემის პარამეტრები<ph name="END_LINK"/> და მიანიჭეთ Chromium-ს წვდომა</translation>
</translationbundle>
