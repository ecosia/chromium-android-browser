<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE translationbundle>
<translationbundle lang="ko">
<translation id="1026101648481255140">설치 다시 시작</translation>
<translation id="8933665254023068908">다시 실행하여 EcosiaOS 업데이트</translation>
<translation id="6566258574866003581">Ecosia에서는 이 확장 프로그램을 검토할 것을 권장합니다.</translation>
<translation id="1042552502243217427">사이트에서 페이지에 있는 링크를 비공개로 미리 로드해 달라고 요청하면 Chromium은 Google 서버를 사용합니다. 이렇게 하면 미리 로드된 사이트에서 사용자의 신원을 숨길 수 있지만 Google은 어떤 사이트가 미리 로드되는지 학습하게 됩니다.</translation>
<translation id="1065672644894730302">환경설정을 읽을 수 없습니다.

일부 기능을 사용할 수 없으며 환경설정의 변경사항이 저장되지 않습니다.</translation>
<translation id="8561406087076314604">부모님이 Ecosia의 ‘사이트, 앱, 확장 프로그램에 대한 권한’을 사용 중지했습니다</translation>
<translation id="1098170124587656448">Chromium이 정보 유출, 유해한 확장 프로그램 등으로부터 사용자를 보호해 줍니다.</translation>
<translation id="3632544319066562282">Ecosia에서 비밀번호를 내보내려고 합니다. 허용하려면 Windows 비밀번호를 입력하세요.</translation>
<translation id="113122355610423240">Chromium이 기본 브라우저로 설정되어 있습니다.</translation>
<translation id="1131805035311359397">암호가 정보 유출 및 다른 보안 문제로부터 안전한지 확인하려면 <ph name="BEGIN_LINK"/>Chromium에 로그인<ph name="END_LINK"/>하세요.</translation>
<translation id="1224748120031661633">Ecosia 메뉴를 클릭합니다</translation>
<translation id="1184145431117212167">지원되지 않는 Windows 버전으로 인해 설치할 수 없습니다.</translation>
<translation id="1185134272377778587">Chromium 정보</translation>
<translation id="1330085168384841023">창을 공유하려면 시스템 환경설정에서 Ecosia의 화면 녹화를 허용하세요</translation>
<translation id="1203500561924088507">설치해 주셔서 감사합니다. <ph name="BUNDLE_NAME"/>을(를) 사용하려면 브라우저를 다시 시작해야 합니다.</translation>
<translation id="7455175614937447568">이 탭이 비활성 상태인 동안 Ecosia의 속도를 빠르게 유지하기 위해 메모리를 확보했습니다. 이 사이트가 비활성 상태가 되지 않도록 항상 제외할 수 있습니다.</translation>
<translation id="9068280473864300215">위험한 파일이므로 Ecosia에서 이 다운로드를 차단했습니다.</translation>
<translation id="126567311906253476"><ph name="USER_EMAIL"/> 계정으로 Gmail 또는 YouTube와 같은 Google 서비스에 로그인하면 동일한 계정으로 Chromium에 자동으로 로그인할 수 있습니다.</translation>
<translation id="1290883685122687410">설정 오류: <ph name="METAINSTALLER_EXIT_CODE"/>. <ph name="WINDOWS_ERROR"/></translation>
<translation id="319566061277127356">새 Ecosia 프로필 설정</translation>
<translation id="4019094010333463261">블루투스 기기를 탐색하려면 Ecosia에 블루투스 액세스 권한이 필요합니다. <ph name="IDS_SERIAL_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK"/></translation>
<translation id="5405885279794834338">Ecosia(<ph name="URL"/>)에서도 데이터 삭제</translation>
<translation id="727568860157522676">Ecosia에 로그인했습니다.</translation>
<translation id="1478370723027452770">Chrome for Testing 관련 지원받기</translation>
<translation id="1497802159252041924">설치 오류: <ph name="INSTALL_ERROR"/></translation>
<translation id="1861504561909287316">Ecosia 탭 공유</translation>
<translation id="6896860023874996542">Ecosia에서 주변 3D 지도를 만들려면 카메라 액세스 권한이 필요합니다.</translation>
<translation id="7886351766410889877">{NUM_EXTENSIONS,plural, =1{이 확장 프로그램은 더 이상 지원되지 않습니다. Ecosia에서는 삭제할 것을 권장합니다.}other{이 확장 프로그램은 더 이상 지원되지 않습니다. Ecosia에서는 삭제할 것을 권장합니다.}}</translation>
<translation id="1574377791422810894">Chromium의 안전 도구</translation>
<translation id="2200308425865645682">일부 데이터를 Ecosia 계정에 저장하고 모든 기기에서 사용하려면 Ecosia에서 본인 인증을 거쳐야 합니다. 로그아웃하면 해당 데이터가 이 기기에 유지됩니다</translation>
<translation id="7304240387834227637">Ecosia에서 비밀번호 관리자 데이터를 삭제하려고 합니다. 허용하려면 Windows 비밀번호를 입력하세요.</translation>
<translation id="4933729908795930260">{COUNT,plural, =0{관리자의 요구에 따라 업데이트를 적용하려면 Ecosia을 다시 실행해야 합니다.}=1{관리자의 요구에 따라 업데이트를 적용하려면 Ecosia을 다시 실행해야 합니다. 시크릿 창이 다시 열리지 않습니다.}other{관리자의 요구에 따라 업데이트를 적용하려면 Ecosia을 다시 실행해야 합니다. 시크릿 창 #개가 다시 열리지 않습니다.}}</translation>
<translation id="1625909126243026060">Chromium의 주요 개인 정보 보호 및 보안 제어 기능을 검토합니다.</translation>
<translation id="931416298178634530">이 계정을 한 번만 사용하려면 Ecosia 브라우저에서 <ph name="GUEST_LINK_BEGIN"/>게스트 모드<ph name="GUEST_LINK_END"/>를 사용하세요. 다른 사용자를 위해 계정을 추가하려면 <ph name="DEVICE_TYPE"/>에 <ph name="LINK_BEGIN"/>새 사용자를 추가<ph name="LINK_END"/>하세요.

이 계정에는 웹사이트와 앱에 이미 부여한 권한이 적용될 수 있습니다. <ph name="SETTINGS_LINK_BEGIN"/>설정<ph name="SETTINGS_LINK_END"/>에서 Ecosia 계정을 관리할 수 있습니다.</translation>
<translation id="1640672724030957280">다운로드 중...</translation>
<translation id="1715127912119967311">Chromium은 이러한 기능을 개선하도록 사용자와의 상호작용을 Google에 전송합니다. 검토자가 이 데이터를 읽고 처리하고 이 데이터에 주석을 달 수 있습니다.</translation>
<translation id="1722488837206509557">이렇게 하면 사용 가능한 기기 중에서 선택하고 해당 기기에 콘텐츠를 표시할 수 있습니다.</translation>
<translation id="1118786556671181978">사이트에서 광고 표시를 위해 사용하는 관심분야의 주제를 내가 확인하고 삭제할 수 있습니다. Ecosia에서는 사용자의 최근 방문 기록을 기반으로 관심분야를 추정합니다.</translation>
<translation id="2379593823746842972">Ecosia에서 곧 인터넷 사용 기록이 삭제됩니다</translation>
<translation id="1736443181683099871">Chromium에서 탐색을 HTTPS로 업그레이드하려고 시도합니다</translation>
<translation id="5490755016715767023"><ph name="REMAINING_TIME"/> 후에 Ecosia 다시 시작</translation>
<translation id="1749104137266986751">HTTPS를 사용할 수 없는 경우, Chromium에서 경고 없이 안전하지 않은 연결을 사용합니다.</translation>
<translation id="8454595950895325762">백그라운드에서 Ecosia을 실행</translation>
<translation id="9125443060066914183">Ecosia에서는 Ecosia의 보안을 강화하기 위해 <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>에 표시되지 않고 사용자 모르게 추가되었을 수 있는 일부 확장 프로그램의 사용을 중지했습니다.</translation>
<translation id="6984747211123632080">Ecosia 재설치</translation>
<translation id="1251415775728969647">Ecosia에서 <ph name="AUTHENTICATION_PURPOSE"/>을(를) 시도하는 중입니다.</translation>
<translation id="1761584959558744002">인터넷 사용 기록을 이 기기에서만 삭제하고 Ecosia 계정에서는 유지하려면 <ph name="BEGIN_LINK"/>Ecosia에서 로그아웃<ph name="END_LINK"/>하세요.</translation>
<translation id="185970820835152459">로그인된 Google 계정을 관리할 수 있습니다. Google 계정은 Chromium 브라우저, Play 스토어, Gmail 등에서 사용됩니다. 가족 구성원 등 다른 사람을 위해 계정을 추가하고 싶다면 대신 <ph name="DEVICE_TYPE"/>에 새 사용자를 추가하세요. <ph name="LINK_BEGIN"/>자세히 알아보기<ph name="LINK_END"/></translation>
<translation id="1863308913976887472">사이트에서는 Chromium에 내 관심분야에 관한 정보를 저장할 수 있습니다. 예를 들어 마라톤화를 구매하려고 사이트를 방문하면 사이트에서 내 관심분야를 마라톤으로 정의할 수 있습니다. 나중에 마라톤 대회에 등록하기 위해 다른 사이트에 방문하면 관심분야를 토대로 마라톤화 광고가 표시될 수 있습니다.</translation>
<translation id="4239392394637574967">관리 계정으로 로그인하고 Ecosia 프로필에 대한 관리자 제어권을 부여하려고 합니다. 앱, 북마크, 방문 기록, 비밀번호 및 기타 설정 등 Ecosia 데이터가 <ph name="USER_NAME"/> 계정에 영구적으로 연결됩니다. 이후 이 데이터를 Ecosia 계정 대시보드에서 삭제할 수는 있지만 다른 계정에 연결할 수는 없습니다. 기존 Ecosia 데이터를 유지하려면 새 프로필을 만드는 방법이 있습니다. <ph name="LEARN_MORE"/></translation>
<translation id="1906696617298807388">주소 표시줄이나 검색창에 입력하면 Chromium에서 입력 내용을 Google Drive로 전송하여 항목을 추천합니다. 시크릿 모드에서는 이 기능이 사용 중지되어 있습니다.</translation>
<translation id="1911763535808217981">이 기능을 사용 중지하면 Chromium에 로그인하지 않고도 Gmail 등의 Google 사이트에 로그인할 수 있습니다.</translation>
<translation id="18064594488616674">Ecosia이 응답하지 않습니다. 다시 시작하시겠습니까?</translation>
<translation id="8047394653992042491">업데이트를 적용하려면 EcosiaOS를 다시 시작해야 합니다.</translation>
<translation id="4988569127367972482">일반적으로 다운로드하지 않는 파일 형식이며 위험할 가능성이 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다.</translation>
<translation id="1953553007165777902">다운로드 중... <ph name="MINUTE"/>분 남음</translation>
<translation id="1966382378801805537">Chromium에서 기본 브라우저를 확인하거나 설정할 수 없습니다.</translation>
<translation id="6583697665130212310">Ecosia에서 일부 파일을 차단하는 이유 알아보기, 새 탭에서 열기</translation>
<translation id="2008474315282236005">항목 1개가 기기에서 삭제됩니다. 나중에 데이터를 가져오려면 Chromium에 <ph name="USER_EMAIL"/>(으)로 로그인하세요.</translation>
<translation id="2018879682492276940">설치할 수 없습니다. 다시 시도해 보세요.</translation>
<translation id="2020032459870799438">다른 암호가 정보 유출 및 다른 보안 문제로부터 안전한지 확인하려면 <ph name="BEGIN_LINK"/>Chromium에 로그인<ph name="END_LINK"/>하세요.</translation>
<translation id="2049376729098081731">보다 맞춤설정된 Google 서비스 환경을 사용하기 위해 Chromium 방문 기록을 포함할지 선택하세요.</translation>
<translation id="7112125772061727648">사기성 파일이며 기기에 예기치 않은 변경사항이 적용될 수 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다.</translation>
<translation id="2088953378266246249">Chromium의 루트 인증서 관리 방식에 관한 정보</translation>
<translation id="1876482900355946220">{COUNT,plural, =1{Ecosia을 1분 동안 사용하지 않으면 조직에서 인터넷 사용 기록을 자동으로 삭제합니다. 여기에는 방문 기록, 자동 완성, 다운로드가 포함될 수 있습니다. 탭이 열린 상태로 유지됩니다.}other{Ecosia을 #분 동안 사용하지 않으면 조직에서 인터넷 사용 기록을 자동으로 삭제합니다. 여기에는 방문 기록, 자동 완성, 다운로드가 포함될 수 있습니다. 탭이 열린 상태로 유지됩니다.}}</translation>
<translation id="2126108037660393668">다운로드한 파일을 확인할 수 없습니다.</translation>
<translation id="2745180350547322293">사이트에서 보안 연결을 사용하고 있지 않으며 파일이 조작되었을 가능성이 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다.</translation>
<translation id="8296229475165428335">Ecosia 메뉴에서 북마크, 읽기 모드 등을 열 수 있습니다.</translation>
<translation id="838842459108103907">Ecosia 맞춤설정</translation>
<translation id="2174917724755363426">설치가 완료되지 않았습니다. 취소하시겠습니까?</translation>
<translation id="9035946286843935549">Ecosia - 네트워크 로그인 - <ph name="PAGE_TITLE"/></translation>
<translation id="2190166659037789668">업데이트 확인 오류: <ph name="UPDATE_CHECK_ERROR"/></translation>
<translation id="8196791276481156937">Ecosia에서 계정 삭제</translation>
<translation id="2210682093923538346">위험한 사이트입니다. Chromium에서 알림을 삭제했습니다.</translation>
<translation id="2240214816234246077">최근에 사이트를 방문하지 않았습니다. Chromium에서 <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> 권한을 삭제했습니다.</translation>
<translation id="6111519389633335269">컴퓨터를 공유하는 경우 친구와 가족이 개별적으로 탐색하고 원하는 대로 Ecosia을 설정할 수 있습니다.</translation>
<translation id="2313870531055795960">Chromium에 저장된 안전하지 않은 사이트 목록을 사용하여 URL을 검사합니다. 사이트에서 사용자의 비밀번호를 도용하려고 하거나 사용자가 유해한 파일을 다운로드하는 경우, Chromium에서 페이지 콘텐츠 일부를 비롯한 URL을 세이프 브라우징 서비스에 보낼 수 있습니다.</translation>
<translation id="2329088755516916767">사용 설정하면 Chromium에서 페이지를 미리 로드하여 더 빠르게 탐색하고 검색할 수 있습니다.</translation>
<translation id="665177868576952817">여기에서 Android 휴대전화로 번호를 전송하려면 두 기기 모두에서 Ecosia에 로그인하세요.</translation>
<translation id="2359808026110333948">계속</translation>
<translation id="790624108224468719">"<ph name="EXTENSION_NAME"/>" 확장 프로그램에서 Ecosia 로그인을 요청합니다</translation>
<translation id="2056307067005384438"><ph name="USER_EMAIL_ADDRESS"/> 계정으로 이 확장 프로그램을 사용하려면 Ecosia에 로그인하세요.</translation>
<translation id="592990842052138727">계정의 로그인 세부정보가 오래되어 EcosiaOS에서 데이터를 동기화할 수 없습니다.</translation>
<translation id="2526043366208696235">{NUM_DEVICES,plural, =0{하나 이상의 Ecosia 확장 프로그램에서 HID 기기 1대에 액세스함}=1{하나 이상의 Ecosia 확장 프로그램에서 HID 기기 1대에 액세스 중}other{하나 이상의 Ecosia 확장 프로그램에서 HID 기기 #대에 액세스 중}}</translation>
<translation id="3554373328288278512">Ecosia에서 사이트에 대한 카메라 및 마이크 권한이 필요합니다.</translation>
<translation id="2440750600860946460"><ph name="BEGIN_LINK"/>Chromium의 도구<ph name="END_LINK"/>로 안전하게 탐색하고 관리할 수 있습니다.</translation>
<translation id="2451727308784734061">바로가기를 사용하여 비밀번호 관리자로 빠르게 이동하세요. 바로가기는 컴퓨터의 홈 화면이나 앱 런처로 이동할 수 있습니다.</translation>
<translation id="5736558630107498475">Ecosia이 곧 종료됩니다</translation>
<translation id="6495878830719404098">Ecosia에서</translation>
<translation id="2485422356828889247">제거</translation>
<translation id="2513154137948333830">재부팅 필요: <ph name="INSTALL_SUCCESS"/></translation>
<translation id="8957938953005153147">Ecosia에서 기존 비밀번호를 바꾸려고 합니다. 허용하려면 Windows 비밀번호를 입력하세요.</translation>
<translation id="5549921590305750618">파일을 다운로드하려면 Ecosia에 저장소 액세스 권한이 있어야 합니다</translation>
<translation id="9090890391337853620">Ecosia 도우미</translation>
<translation id="6094573000614590044">모든 기기에서 비밀번호 등을 사용하려면 Ecosia에 로그인하세요</translation>
<translation id="5707346538075088068">북마크, 방문 기록, 비밀번호, 기타 설정 생성 등 이 프로필을 사용하는 동안 생성된 모든 Ecosia 데이터는 직장 프로필 관리자가 삭제할 수 있습니다. <ph name="LEARN_MORE"/></translation>
<translation id="5883025779824839861">Ecosia 계속 사용</translation>
<translation id="259935314519650377">다운로드한 설치 프로그램을 캐시할 수 없습니다. 오류(<ph name="UNPACK_CACHING_ERROR_CODE"/>)가 발생했습니다.</translation>
<translation id="2198589091447191935">Ecosia이 더 빠르게 실행되며 JavaScript를 사용하는 기능이 의도한 대로 작동함(권장)</translation>
<translation id="7280797724682955539">설치 중 운영체제 오류가 발생했습니다. Ecosia을 다시 다운로드하세요.</translation>
<translation id="6960183526681645011">기기를 공유하는 경우 친구와 가족이 개별적으로 탐색하고 원하는 대로 Ecosia을 설정할 수 있습니다.</translation>
<translation id="2381210243314074423"><ph name="ACCOUNT_FIRST_NAME"/>님, Ecosia에 오신 것을 환영합니다</translation>
<translation id="385080958066798123">Ecosia 탭</translation>
<translation id="2718390899429598676">보안 강화를 위해 Chromium에서 사용자 데이터를 암호화합니다.</translation>
<translation id="7347725536241560534">Ecosia에서 Ecosia 계정을 삭제하려면 로그아웃하세요.</translation>
<translation id="2738871930057338499">인터넷에 연결할 수 없습니다(HTTP 403 Forbidden). 프록시 설정을 확인하시기 바랍니다.</translation>
<translation id="2770231113462710648">다음으로 기본 브라우저 변경:</translation>
<translation id="3077076541395306362">이 확장 프로그램에는 멀웨어가 포함되어 있으며, 안전하지 않습니다. 더 이상 개인 정보를 비롯한 방문 사이트의 데이터를 확인하고 변경할 수 없도록 Ecosia에서 이 확장 프로그램을 삭제하세요.</translation>
<translation id="2799223571221894425">다시 시작</translation>
<translation id="3952510753191144456"><ph name="USER_EMAIL_ADDRESS"/>님을 위한 새 Ecosia 프로필이 생성됩니다.</translation>
<translation id="2846251086934905009">설치 오류: 설치 프로그램이 완료되지 않았습니다. 설치가 중단되었습니다.</translation>
<translation id="4199684616787081033">Ecosia에서 제거...</translation>
<translation id="2850691299438350830">로그인 상태일 때 Chromium에서 사용자를 보호하고 기타 Google 앱에서 사용자의 보안을 강화하는 데 사용될 수 있습니다.</translation>
<translation id="2885378588091291677">작업 관리자</translation>
<translation id="7221868538334633215">Ecosia 정보</translation>
<translation id="2915996080311180594">나중에 다시 시작</translation>
<translation id="2928420929544864228">설치가 완료되었습니다.</translation>
<translation id="2945997411976714835">설치 오류: 설치 프로그램 프로세스를 시작할 수 없습니다.</translation>
<translation id="7527831132809333552">조직에서 Ecosia을 관리합니다.</translation>
<translation id="2977470724722393594">Chromium이 최신 버전임</translation>
<translation id="2977506796191543575">사이트에서 사용자의 비밀번호를 도용하려고 하거나 사용자가 유해한 파일을 다운로드하는 경우, Chromium에서 페이지 콘텐츠 일부를 비롯한 URL을 세이프 브라우징 서비스에 보낼 수 있습니다.</translation>
<translation id="7562371913339616107">Ecosia은 이러한 탭을 비활성화하여 탐색 환경을 개선하고 리소스를 확보할 수 있습니다.</translation>
<translation id="6154325450733409298">Ecosia의 새 탭에서 <ph name="URL"/> 주소가 열립니다.</translation>
<translation id="3032706164202344641">Chromium에서 비밀번호를 확인할 수 없습니다. 나중에 다시 시도하세요.</translation>
<translation id="1762318218111418450">Ecosia에 추가하는 중...</translation>
<translation id="3038232873781883849">설치 대기 중...</translation>
<translation id="6967821869905227561">기타 Ecosia 프로필</translation>
<translation id="9178613517891824246">비정상 종료 보고서와 <ph name="UMA_LINK"/>을(를) Ecosia로 전송하여 Ecosia 개선에 참여합니다.</translation>
<translation id="7655708678113012665">{NUM_DEVICES,plural, =0{하나 이상의 Ecosia 확장 프로그램에서 USB 기기 1대에 액세스함}=1{하나 이상의 Ecosia 확장 프로그램에서 USB 기기 1대에 액세스 중}other{하나 이상의 Ecosia 확장 프로그램에서 USB 기기 #대에 액세스 중}}</translation>
<translation id="3101560983689755071">방문 기록에 따라 표시되는 광고 및 아래의 예측 관심분야가 달라집니다. 개인 정보를 보호하기 위해 Chromium에서는 매월 최소 한 번씩 수시로 관심분야를 자동 삭제합니다. 관심분야는 직접 삭제하지 않는 한 새로고침될 수 있습니다.</translation>
<translation id="7691143774653486474">설치 프로그램이 보관 파일 압축 풀기에 실패했습니다. Ecosia을 다시 다운로드하세요.</translation>
<translation id="1318059253725731825">Ecosia이 마이크를 사용 중입니다.</translation>
<translation id="51576365410323372">이 탭은 추가 리소스를 사용하고 있습니다. 성능을 개선하려면 Ecosia에서 이 탭을 비활성화하도록 허용하세요.</translation>
<translation id="8282620071565190081">Ecosia 다시 시작</translation>
<translation id="5500958820122281144">Ecosia 시크릿 창에서 링크 열기(&amp;G)</translation>
<translation id="3697186779259384993">새로운 Ecosia 프로필 맞춤설정</translation>
<translation id="3216284932113164802">Ecosia이 다운되었습니다. 다시 시작하시겠습니까?</translation>
<translation id="8696852719113991652">Ecosia에서 Ecosia 계정을 삭제하려면 설정 페이지를 통해 Ecosia에서 로그아웃하세요</translation>
<translation id="7602423871874451395">Ecosia에서 데이터 디렉터리를 읽고 쓸 수 없습니다.

<ph name="USER_DATA_DIRECTORY"/></translation>
<translation id="905744008702074577">V8은 사이트 속도를 개선하는 데 사용되는 Ecosia의 JavaScript 및 WebAssembly 엔진입니다.</translation>
<translation id="3283186697780795848">Chromium 버전 <ph name="PRODUCT_VERSION"/>이(가)가 설치됩니다.</translation>
<translation id="3286538390144397061">지금 다시 시작</translation>
<translation id="4735588186234302898">Ecosia API 키가 누락되었습니다. Ecosia의 일부 기능이 사용 중지됩니다.</translation>
<translation id="3296368748942286671">Chromium 종료 후에도 백그라운드 앱을 계속 실행</translation>
<translation id="686474599126256998">계정 액세스를 설정하는 동안에도 Ecosia을 계속 사용할 수 있습니다. 설정이 완료될 때까지 일부 리소스에 액세스하지 못할 수도 있습니다</translation>
<translation id="3313189106987092621">Chromium에서 안전하지 않은 연결을 사용해 사이트를 로드하기 전에 경고를 표시합니다.</translation>
<translation id="5513857521842828996">Ecosia에 로그인한 경우 Ecosia 계정을 제외한 모든 Ecosia 창을 닫으면 대부분의 사이트에서 로그아웃됩니다. 사이트에서 나를 기억하도록 하려면 <ph name="SETTINGS_LINK"/>하세요.</translation>
<translation id="812798451698099271">이 계정을 사용하는 Ecosia 프로필이 이미 존재합니다.</translation>
<translation id="1761341660094265938">EcosiaOS</translation>
<translation id="4781882243268600858">기존 Ecosia 프로필로 전환하시겠습니까?</translation>
<translation id="3412460710772753638">기기의 비밀번호 관리자에 업데이트합니다.</translation>
<translation id="4170280082681554565">Ecosia 프로필을 사용하면 모든 Ecosia 데이터를 분리할 수 있습니다. 친구와 가족을 위한 프로필을 만들거나 업무용과 개인용 프로필을 구분하세요.</translation>
<translation id="347328004046849135">유출된 비밀번호로 로그인하면 Chromium에서 알림을 표시합니다.</translation>
<translation id="3474745554856756813">항목 <ph name="ITEMS_COUNT"/>개가 기기에서 삭제됩니다. 나중에 데이터를 가져오려면 Chromium에 <ph name="USER_EMAIL"/>(으)로 로그인하세요.</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> 바로가기를 사용하여 Ecosia 프로필 간에 전환하세요</translation>
<translation id="8534308095039131078">Ecosia 창을 모두 닫고 다시 시도해 보세요.</translation>
<translation id="7984841734836997333"><ph name="EXISTING_USER"/> 계정은 이미 로그인되어 있습니다.  방문 기록을 별도로 보관하려면 내 프로필에서 <ph name="USER_EMAIL_ADDRESS"/> 주소로 Ecosia에 로그인하세요.</translation>
<translation id="3533435340678213462">개인 정보를 보호하기 위해 Chromium에서는 4주가 지난 관심분야를 자동 삭제합니다. 인터넷 사용에 따라 특정 관심분야가 목록에 다시 표시될 수 있습니다. Chromium에서 고려하지 않았으면 하는 관심분야가 있으면 직접 삭제하세요.</translation>
<translation id="3567254597502212821">이 기기에서 Chromium을 사용해 방문한 사이트의 기록인 방문 기록이 사용됩니다.</translation>
<translation id="3597003331831379823">승격된 권한으로 설정을 실행할 수 없습니다. <ph name="METAINSTALLER_ERROR"/></translation>
<translation id="2128110540135015661">선택한 사용자의 인터넷 사용 기록이 이 기기에서 삭제됩니다. 데이터를 복구하려면 <ph name="USER_EMAIL"/>(으)로 Ecosia에 로그인하세요.</translation>
<translation id="1323499021727766710">{COUNT,plural, =0{새 Ecosia 업데이트가 있습니다. Ecosia을 다시 실행하면 업데이트가 바로 적용됩니다.}=1{새 Ecosia 업데이트가 있습니다. Ecosia을 다시 실행하면 업데이트가 바로 적용됩니다. 시크릿 창이 다시 열리지 않습니다.}other{새 Ecosia 업데이트가 있습니다. Ecosia을 다시 실행하면 업데이트가 바로 적용됩니다. 시크릿 창 #개가 다시 열리지 않습니다.}}</translation>
<translation id="7849498640944199147"><ph name="ORIGIN"/>에서 Android 휴대전화로 번호를 전송하려면 두 기기 모두에서 Ecosia에 로그인하세요.</translation>
<translation id="3667616615096815454">설치할 수 없습니다. 서버에서 애플리케이션을 알 수 없습니다.</translation>
<translation id="7845247414826995986">화면을 공유하려면 시스템 환경설정에서 Ecosia의 화면 녹화를 허용하세요</translation>
<translation id="3685209450716071127">Chromium에서 비밀번호를 확인할 수 없습니다. 인터넷 연결 상태를 확인하세요.</translation>
<translation id="5902103164685487225">Ecosia의 광고 개인 최적화에 관해 자세히 알아보기</translation>
<translation id="3479730782477097349">{COUNT,plural, =0{관리자가 이 업데이트를 적용하려면 사용자가 Ecosia을 다시 시작하도록 설정했습니다.}=1{관리자가 이 업데이트를 적용하려면 사용자가 Ecosia을 다시 시작하도록 설정했습니다. 시크릿 창이 다시 열리지 않습니다.}other{관리자가 이 업데이트를 적용하려면 사용자가 Ecosia을 다시 시작하도록 설정했습니다. 시크릿 창 #개가 다시 열리지 않습니다.}}</translation>
<translation id="489671036945006830">새 Ecosia 탭에서 링크 열기(&amp;T)</translation>
<translation id="3728124580182886854">맞춤설정 등의 목적으로 Chromium과 기타 Google 서비스를 연결합니다</translation>
<translation id="3140530394740845618">Ecosia 프로필 관리</translation>
<translation id="3035352359183300151">Ecosia에서 일부 다운로드를 차단하는 이유 알아보기</translation>
<translation id="379589255253486813">검토가 필요한 경우 Chromium에서 알려드립니다</translation>
<translation id="3802055581630249637">Chromium은 사용자가 방문할 가능성이 있는 페이지를 미리 로드하여 사용자가 방문할 때 페이지를 더 빠르게 로드합니다.</translation>
<translation id="3959732324458144441">EcosiaOS 시스템</translation>
<translation id="2722323139667924824"><ph name="PAGE_TITLE"/> - Ecosia</translation>
<translation id="386822487697155367">ChromiumOS 도움말 보기</translation>
<translation id="6391863622742187823"><ph name="ACCOUNT_EMAIL"/> 계정으로 Ecosia 브라우저 기능을 이용해 보세요</translation>
<translation id="8544776492099331022">Ecosia을 맞춤설정 및 제어합니다. 확인이 필요한 항목이 있습니다. 클릭하여 세부정보를 보세요.</translation>
<translation id="4871843754042758264">Ecosia을 열고 탐색을 시작하려면 내 이름을 클릭하세요.</translation>
<translation id="5824812022890208563"><ph name="EXISTING_USER"/>님이 이미 Ecosia 프로필에 로그인되어 있습니다. 인터넷 사용 기록을 별도로 보관하기 위해 Ecosia에서 나만의 프로필을 만들 수 있습니다.</translation>
<translation id="8172133981892685841">이 확장 프로그램은 Ecosia 웹 스토어 정책을 위반하며, 안전하지 않을 수 있습니다. 더 이상 개인 정보를 비롯한 방문 사이트의 데이터를 확인하고 변경할 수 없도록 Ecosia에서 이 확장 프로그램을 삭제하세요.</translation>
<translation id="4070480171055648632">내 계정은 <ph name="MANAGER_NAME"/>에서 관리합니다. 관리자가 이 Ecosia 브라우저 프로필과 북마크, 방문 기록, 비밀번호 등의 데이터를 보고 수정할 수 있습니다.</translation>
<translation id="3941890832296813527">설치 오류: 설치 프로그램 파일 이름이 잘못되었거나 지원되지 않습니다.</translation>
<translation id="1047556320128249268">Ecosia에서 비밀번호를 복사하려고 합니다. 허용하려면 Windows 비밀번호를 입력하세요.</translation>
<translation id="3962647064319009959">Chromium이 사용자를 안전하게 보호하는 방법 알아보기</translation>
<translation id="8603020525900853944">&amp;Ecosia for Testing 정보</translation>
<translation id="3997429360543082038">ChromiumOS 정보</translation>
<translation id="5311911269004680646"><ph name="BEGIN_LINK_LINUX_OSS"/>Linux 개발 환경<ph name="END_LINK_LINUX_OSS"/>과 마찬가지로, EcosiaOS는 추가 <ph name="BEGIN_LINK_CROS_OSS"/>오픈소스 소프트웨어<ph name="END_LINK_CROS_OSS"/>를 사용하여 개발되었습니다.</translation>
<translation id="4036079820698952681"><ph name="BEGIN_LINK"/>현재 설정<ph name="END_LINK"/>을 보고하여 Chromium 개선에 참여</translation>
<translation id="4050175100176540509">최신 버전에는 중요한 보안 개선사항 및 새로운 기능이 포함되어 있습니다.</translation>
<translation id="4055805654398742145">비밀번호 관리자(&amp;A)</translation>
<translation id="7757263274906217411">{COUNT,plural, =1{Ecosia을 1분 동안 사용하지 않으면 조직에서 자동으로 종료합니다. 인터넷 사용 기록이 삭제됩니다. 여기에는 방문 기록, 자동 완성, 다운로드가 포함될 수 있습니다.}other{Ecosia을 #분 동안 사용하지 않으면 조직에서 자동으로 종료합니다. 인터넷 사용 기록이 삭제됩니다. 여기에는 방문 기록, 자동 완성, 다운로드가 포함될 수 있습니다.}}</translation>
<translation id="4118474109249235144">Chromium 시크릿 모드</translation>
<translation id="4122186850977583290">Chromium 정보 페이지로 이동</translation>
<translation id="4148957013307229264">설치 중...</translation>
<translation id="4264506519284061030">조직에서 북마크, 방문 기록, 비밀번호와 같은 직장 프로필의 인터넷 사용 기록을 보고 관리할 수 있습니다. 개인 Ecosia 프로필의 인터넷 사용 기록은 확인할 수 없습니다.</translation>
<translation id="3907708440788567041"><ph name="PAGE_TITLE"/> - 네트워크 로그인 - Ecosia</translation>
<translation id="7782767522222146179">Ecosia에 유용한 앱, 게임, 확장 프로그램, 테마를 찾아보세요.</translation>
<translation id="4216212958613226427">Chromium UI가 이 언어로 표시됩니다.</translation>
<translation id="4222932583846282852">취소 중...</translation>
<translation id="4224210481850767180">설치가 취소되었습니다.</translation>
<translation id="8384922154025337808">Ecosia 데이터를 이 계정에 연결하시겠습니까?</translation>
<translation id="4251772536351901305">표준 보호 모드보다 더 많은 사이트에서 데이터를 분석하여 위험한 사이트에 관해 경고합니다. Google이 이전에 몰랐던 사이트도 여기에 포함됩니다. Chromium 경고를 건너뛸 수 있습니다.</translation>
<translation id="2672632089507560181">Ecosia에서 로그아웃</translation>
<translation id="4271805377592243930">Chromium 도움말 보기</translation>
<translation id="4281844954008187215">서비스 약관</translation>
<translation id="3305517118160815955">확인되지 않은 오류로 설치에 실패했습니다. Ecosia이 실행 중인 경우 종료한 후 다시 실행하세요.</translation>
<translation id="4304713468139749426">비밀번호 관리자</translation>
<translation id="4334294535648607276">다운로드가 완료되었습니다.</translation>
<translation id="8411844745163855310">기기를 사용하기 전에 <ph name="MANAGER"/>에서 다음 서비스 약관을 읽고 이에 동의해야 합니다. 이 약관은 EcosiaOS 약관을 확대, 수정 또는 제한하지 않습니다</translation>
<translation id="88039520238670574">Ecosia을 종료하시겠습니까?</translation>
<translation id="4586967042094107073">백그라운드에서 Ecosia을 실행</translation>
<translation id="804899663814036125">{NUM_EXTENSIONS,plural, =1{Ecosia에서 삭제할 것을 권장합니다. <ph name="BEGIN_LINK"/>지원되는 확장 프로그램에 대해 자세히 알아보기<ph name="END_LINK"/>}other{Ecosia에서 삭제할 것을 권장합니다. <ph name="BEGIN_LINK"/>지원되는 확장 프로그램에 대해 자세히 알아보기<ph name="END_LINK"/>}}</translation>
<translation id="4817913198787198451">Ecosia 맞춤설정 및 제어</translation>
<translation id="4427306783828095590">향상된 보호 기능이 피싱 및 멀웨어를 더욱 효과적으로 차단합니다.</translation>
<translation id="4434353761996769206">설치 프로그램 오류: <ph name="INSTALLER_ERROR"/></translation>
<translation id="6994161374830839635"><ph name="MANAGER"/>에서 Ecosia을 관리합니다.</translation>
<translation id="4447409407328223819">Chrome for Testing 정보</translation>
<translation id="4501471624619070934">이 국가에서는 액세스가 제한되므로 설치할 수 없습니다.</translation>
<translation id="576192547306902465">이 확장 프로그램은 데이터 수집 및 사용 방식과 같은 개인 정보 보호 관행을 게시하지 않았습니다. Ecosia에서 삭제할 것을 권장합니다.</translation>
<translation id="1859120614572957305">Ecosia에 오신 것을 환영합니다. 새 브라우저 창이 열렸습니다</translation>
<translation id="378302976931789177">Ecosia에서 주변 환경을 매핑하고 손을 추적하려면 권한이 필요합니다</translation>
<translation id="8403827649521531901">이미 다른 Ecosia 프로필에 <ph name="USER_EMAIL_ADDRESS"/> 계정으로 로그인되어 있습니다</translation>
<translation id="4544142686420020088">문제가 발생하여 Chromium을 업데이트할 수 없습니다. <ph name="BEGIN_LINK"/>Chromium 업데이트 문제 및 업데이트 실패 문제 해결하기<ph name="END_LINK"/></translation>
<translation id="2020747823154282691">Ecosia은 이 탭을 비활성화하여 탐색 환경을 개선하고 빠른 속도를 유지할 수 있습니다.</translation>
<translation id="8685318202174822382">새 Ecosia 프로필로 계속하시겠습니까?</translation>
<translation id="4567424176335768812"><ph name="USER_EMAIL_ADDRESS"/>(으)로 로그인되어 있습니다. 이제 로그인한 모든 기기에서 북마크, 방문 기록 및 기타 설정에 액세스할 수 있습니다.</translation>
<translation id="361644486359722423">사용자가 세이프 브라우징을 사용 중지했으며 파일을 확인할 수 없기 때문에 Ecosia에서 이 다운로드를 차단했습니다.</translation>
<translation id="4594305310729380060">기기의 비밀번호 관리자에 저장합니다.</translation>
<translation id="2636091632287013185">Ecosia 앱</translation>
<translation id="4613863813562375431">ChromiumOS 버전</translation>
<translation id="2394629668475473296">화면을 공유하려면 시스템 환경설정에서 Ecosia의 화면 녹화를 허용하세요</translation>
<translation id="4621240073146040695">업데이트가 거의 완료되었습니다. 업데이트를 완료하려면 Chromium을 다시 시작하세요.</translation>
<translation id="1676748966275099244">경고: Ecosia에서는 확장 프로그램에 인터넷 사용 기록이 저장될 수 있습니다. 시크릿 모드에서 이 확장 프로그램을 사용 중지하려면 옵션을 선택 해제하세요.</translation>
<translation id="4673151026126227699">Chromium 사용 보고서도 공유하면 내가 방문한 URL이 해당 보고서에 포함됩니다.</translation>
<translation id="1384607180773886645">다른 컴퓨터(<ph name="HOST_NAME"/>)의 다른 Ecosia 프로세스(<ph name="PROCESS_ID"/>)에서 프로필을 사용 중인 것 같습니다. 프로필이 손상되지 않도록 Ecosia에서 잠금 설정했습니다. 다른 프로세스에서 프로필을 사용 중이지 않은 것이 확실한 경우 프로필을 잠금 해제하고 Ecosia을 다시 시작하세요.</translation>
<translation id="4680828127924988555">설치 취소</translation>
<translation id="7898621536417126731">Ecosia 데이터 중 일부가 아직 Ecosia 계정에 저장되지 않았습니다. 잠시 기다렸다가 로그아웃하세요. 지금 로그아웃하면 이 데이터가 삭제됩니다</translation>
<translation id="4427878468534147875">로그인한 상태로 Ecosia에서 Ecosia 계정의 비밀번호 등을 사용할 수 있습니다. <ph name="SHORTCUT"/>에서 Ecosia 서비스 설정을 변경할 수 있습니다.</translation>
<translation id="4727435569202742773">다른 사용자가 이전에 이 컴퓨터에서 <ph name="ACCOUNT_EMAIL_LAST"/>(으)로 Ecosia에 로그인했습니다. 새로운 Ecosia 사용자를 만들어 정보를 별도로 관리하세요.</translation>
<translation id="4724676981607797757">지원되지 않는 프로토콜 오류로 인해 설치할 수 없습니다.</translation>
<translation id="864244542982029641">Ecosia을 종료하시겠습니까?</translation>
<translation id="1025044809499013222">Ecosia 특별 보안 업데이트를 방금 적용했습니다. 다시 시작하면 탭이 복원됩니다.</translation>
<translation id="824192326282906244">언제든지 Ecosia 설정에서 선택을 변경할 수 있습니다. 시험 버전은 현재의 광고 게재 방식을 기반으로 실행되므로 변경사항이 당장 적용되는 것은 아닙니다.</translation>
<translation id="4788777615168560705">Chromium에서 비밀번호를 확인할 수 없습니다. 24시간 후에 다시 시도해 보거나 <ph name="BEGIN_LINK"/>Google 계정에서 비밀번호를 확인<ph name="END_LINK"/>하세요.</translation>
<translation id="3543284013834505767">Ecosia 검색과 동일한 맞춤법 검사기가 사용됩니다. 브라우저에 입력되는 텍스트는 Ecosia로 전송됩니다. 설정에서 언제든지 이 동작을 변경할 수 있습니다.</translation>
<translation id="7787479292144635608">계정 없이 Ecosia 사용</translation>
<translation id="4154538917942874814">Ecosia이 mDNS 트래픽을 허용하는 인바운드 규칙입니다.</translation>
<translation id="2159716220295742156">다시 실행하여 Ecosia 업데이트</translation>
<translation id="8701027951719712428">향후 Ecosia 업데이트를 받으려면 macOS 11 이상이 필요합니다. 이 컴퓨터에서는 macOS 10.15를 사용 중입니다.</translation>
<translation id="2234042158691635795">Ecosia이 백그라운드 모드로 실행 중입니다.</translation>
<translation id="3271929752667225813">클릭하여 Ecosia 로그인 대화상자 닫기</translation>
<translation id="1869027055332251164">게스트로 사용 기록을 남기지 않고 Ecosia을 사용할 수 있습니다.</translation>
<translation id="6761747850241550887">Ecosia에 본인 추가</translation>
<translation id="3708834841667355707">Ecosia은 사이트에서 내 정보를 더 적게 사용하면서도 동일한 인터넷 사용 환경을 제공할 수 있는 새로운 기능을 모색하고 있습니다.</translation>
<translation id="3376578942612115781">Ecosia 계정에 재인증이 필요함</translation>
<translation id="5224391634244552924">저장된 비밀번호가 없습니다. 비밀번호를 저장하면 Chromium에서 확인할 수 있습니다.</translation>
<translation id="2421263730139898714">Ecosia에서 로그아웃</translation>
<translation id="847970842635669371"><ph name="EXISTING_USER"/>님이 이미 Ecosia 프로필에 로그인되어 있습니다. <ph name="USER_EMAIL_ADDRESS"/>님을 위한 새 Ecosia 프로필이 생성됩니다.</translation>
<translation id="5277894862589591112">변경사항을 적용하려면 Chromium을 다시 실행하세요.</translation>
<translation id="5294316920224716406">시크릿 모드로 탐색할 때 Chromium에서 안전하지 않은 연결을 사용해 사이트를 로드하기 전에 경고를 표시합니다.</translation>
<translation id="5296845517486664001">무료 체험이 사용 설정되어 있는 경우와 Chromium에서 임의로 나에게 현재 진행 중인 무료 체험을 적용한 경우, 표시되는 광고 및 아래의 예측 관심분야에 방문 기록이 영향을 미칩니다. 개인 정보를 보호하기 위해 Chromium에서는 매월 최소 한 번씩 수시로 관심분야를 삭제합니다.</translation>
<translation id="2297526912548649074"><ph name="USER_EMAIL"/> 계정으로 Ecosia에 로그인</translation>
<translation id="5352264705793813212">Chromium에서 발견한 보안 권장사항을 검토해 주세요</translation>
<translation id="5251710252516682805">기타 Ecosia 프로필</translation>
<translation id="7105712012505419722">관리 계정으로 로그인하고 Ecosia 프로필에 대한 관리자 제어권을 부여하려고 합니다. 앱, 북마크, 방문 기록, 비밀번호 및 기타 설정 등 Ecosia 데이터가 <ph name="USER_NAME"/> 계정에 영구적으로 연결됩니다. 이후 이 데이터를 Ecosia 계정 대시보드에서 삭제할 수는 있지만 다른 계정에 연결할 수는 없습니다. <ph name="LEARN_MORE"/></translation>
<translation id="5368118228313795342">추가 코드: <ph name="EXTRA_CODE"/>.</translation>
<translation id="5377622451696208284">맞춤설정을 사용하려면 웹 및 앱 활동에 Chromium을 포함하세요</translation>
<translation id="350189837353493413">Ecosia에서 일부 파일을 차단하는 이유 알아보기</translation>
<translation id="5386450000063123300">Chromium 업데이트 중(<ph name="PROGRESS_PERCENT"/>)</translation>
<translation id="538767207339317086">Chromium 로그인 허용</translation>
<translation id="330264384086604869">Ecosia에서 제거</translation>
<translation id="5581150090232500900">Ecosia을 기본 브라우저로 설정</translation>
<translation id="1361296321590354837"><ph name="PAGE_TITLE"/> - Ecosia 베타</translation>
<translation id="3307959934543585795">이 Linux 배포판에서 더 이상 Ecosia을 지원하지 않으므로 Ecosia이 올바르게 작동하지 않을 수 있습니다.</translation>
<translation id="197803137365953132">파일이 개인 및 소셜 네트워크 계정에 피해를 줄 수 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다</translation>
<translation id="6558895515431832002">이 사이트와 위치를 공유하려면 Ecosia에 내 위치 액세스 권한이 있어야 합니다</translation>
<translation id="5487574057737591516">개인 정보를 보호하기 위해 Chromium에서는 4주가 지난 관심분야를 자동 삭제합니다. 인터넷 사용에 따라 특정 관심분야가 목록에 다시 표시될 수 있습니다. Chromium에서 관심분야를 잘못 예측했거나 특정 광고를 보고 싶지 않다면 직접 관심분야를 삭제하세요.</translation>
<translation id="5279514147510747661">Ecosia에서 최신 시스템 업데이트를 설치하는 동안 잠시 기다려 주세요.</translation>
<translation id="5066194399237265772">Ecosia에서 비밀번호를 수정하려고 합니다. 허용하려면 Windows 비밀번호를 입력하세요.</translation>
<translation id="5527463683072221100">Chromium에서 PDF 열기</translation>
<translation id="7348818664647668234">{0,plural, =0{Ecosia 업데이트 출시}=1{Ecosia 업데이트 출시}other{Ecosia 업데이트가 출시된 지 #일 지남}}</translation>
<translation id="5643865575100044307">Chromium 종료 시 기기에 있는 사이트 데이터를 항상 삭제</translation>
<translation id="5982672133249369264">지금 Ecosia을 다시 시작하세요</translation>
<translation id="4811228173434336381">Ecosia</translation>
<translation id="5698481217667032250">이 언어로 Chromium 표시</translation>
<translation id="569897634095159764">인터넷에 연결할 수 없습니다. 프록시 서버를 인증해야 합니다.</translation>
<translation id="5761096224651992291">최근에 사이트를 방문하지 않았습니다. Chromium에서 <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/>, <ph name="PERMISSION_3"/> 권한을 삭제했습니다.</translation>
<translation id="1818520302923047971">Ecosia을 맞춤설정 및 제어합니다. Ecosia을 기본 브라우저로 설정합니다.</translation>
<translation id="5809516625706423866">인터넷에 연결할 수 없습니다(HTTP 401 Unauthorized). 프록시 설정을 확인하시기 바랍니다.</translation>
<translation id="1027331268335328576">Ecosia에 오신 것을 환영합니다.</translation>
<translation id="2942675027725878581">Ecosia에서 다음 항목에 멀웨어가 포함된 것을 발견했습니다.</translation>
<translation id="5889361821821684993">Chromium에서는 브라우저가 가장 안전하게 설정되어 있는지 정기적으로 확인합니다. 검토가 필요한 사항이 있으면 알려 드리겠습니다.</translation>
<translation id="5895138241574237353">다시 시작</translation>
<translation id="5903106910045431592"><ph name="PAGE_TITLE"/> - 네트워크 로그인</translation>
<translation id="5924017743176219022">인터넷에 연결 중...</translation>
<translation id="719484593754925816">Ecosia은 이 탭을 비활성화하여 탐색 환경을 개선하고 리소스를 확보할 수 있습니다.</translation>
<translation id="5941711191222866238">최소화</translation>
<translation id="5972142260211327093">Chromium에서 임의로 나에게 현재 진행 중인 무료 체험을 적용한 경우, 표시되는 광고 및 아래의 예측 관심분야에 방문 기록이 영향을 미칩니다. 개인 정보를 보호하기 위해 Chromium에서는 매월 최소 한 번씩 수시로 관심분야를 삭제합니다. 관심분야는 직접 삭제하지 않는 한 새로고침됩니다.</translation>
<translation id="2988629157092722504">{COUNT,plural, =1{Ecosia을 1분 동안 사용하지 않으면 조직에서 자동으로 종료합니다.}other{Ecosia을 #분 동안 사용하지 않으면 조직에서 자동으로 종료합니다.}}</translation>
<translation id="5704599732514791330">동기화를 시작하려면 Ecosia을 업데이트하세요.</translation>
<translation id="5988505247484123880">방문하는 사이트에서는 일반적으로 사용 경험을 개인화하기 위해 내가 관심을 보인 항목을 기억합니다. 또한 사이트에서는 내 관심분야에 관한 정보를 Chromium에 저장할 수 있습니다.</translation>
<translation id="6003112304606738118">다운로드 중... <ph name="HOURS"/>시간 남음</translation>
<translation id="8347473600923066837">오른쪽 상단의 Ecosia 메뉴에서 북마크, 읽기 모드 등을 열 수 있습니다</translation>
<translation id="6040143037577758943">닫기</translation>
<translation id="6058380562449900225">데이터를 보호하려면 최근에 방문하지 않은 사이트의 권한을 Chromium에서 삭제하도록 허용하세요. 알림은 중지되지 않습니다.</translation>
<translation id="7303930050538184306">&amp;Ecosia에서 열기</translation>
<translation id="2227704215309956084"><ph name="EXTENSION_NAME"/>이(가) Ecosia에 추가됨</translation>
<translation id="2905159584855395810">Ecosia의 속도를 높여보세요</translation>
<translation id="608006075545470555">이 브라우저에 직장 프로필 추가</translation>
<translation id="8296565077892323223">Ecosia을 맞춤설정하고 제어하세요. 업데이트가 출시되었습니다.</translation>
<translation id="6102072151902574948">사용 설정되면 Chromium은 부드러운 스크롤 및 동영상 프레임 속도 같은 시각적 효과와 백그라운드 활동을 제한하여 배터리 전원을 절약합니다.</translation>
<translation id="8419312540998601274">사용 중 • Ecosia에서 이 확장 프로그램의 출처를 확인할 수 없습니다.</translation>
<translation id="6419542773162312746">확장 프로그램이 Ecosia 툴바에 액세스 요청을 표시하도록 허용</translation>
<translation id="4021894801595982809">Ecosia에서 내 Ecosia 계정에 이 비밀번호를 저장하므로 기억하지 않아도 됩니다.</translation>
<translation id="1936361330890313940"><ph name="FILE_NAME"/>은(는) 위험한 파일이므로 Ecosia에서 차단했습니다.</translation>
<translation id="2446603005062458629">Ecosia이 곧 종료되고 데이터가 삭제됩니다</translation>
<translation id="6134968993075716475">세이프 브라우징이 사용 중지되어 있습니다. 사용 설정하는 것이 좋습니다.</translation>
<translation id="4032832945953542360">여기에서 Ecosia 프로필 간에 전환할 수 있습니다.</translation>
<translation id="615103374448673771">사용자가 쿠키를 허용하면 Chromium에서 미리 로드할 때 쿠키를 사용할 수 있습니다.</translation>
<translation id="5032126307005935789">위험한 파일일 수도 있습니다.<ph name="LINE_BREAK"/>비밀번호를 제공하면 Ecosia에서 이 다운로드 항목을 확인할 수 있습니다. 파일에 관한 정보는 Ecosia 세이프 브라우징으로 전송되지만 파일 콘텐츠와 비밀번호는 기기에 보관됩니다.</translation>
<translation id="6182736845697986886">업데이트 서버 내부 오류로 인해 설치할 수 없습니다.</translation>
<translation id="2346323077583431428"><ph name="TARGET_DEVICE_NAME"/>에서 Ecosia에 로그인되어 있는지 확인한 다음 다시 전송해 보세요.</translation>
<translation id="2995860351618948435">컴퓨터에 이미 최신 버전의 Ecosia이 있습니다. 소프트웨어가 작동하지 않으면 Ecosia의 설치를 제거한 뒤 다시 시도하세요.</translation>
<translation id="5690368185132749068">{0,plural, =0{곧 Ecosia이 다시 시작됩니다}=1{1초 후 Ecosia이 다시 시작됩니다}other{#초 후 Ecosia이 다시 시작됩니다}}</translation>
<translation id="1809194740315140401">파일을 다운로드하려면 Ecosia에 저장소 액세스 권한이 필요합니다.</translation>
<translation id="6245734527075554892">Chromium에 저장된 안전하지 않은 사이트 목록을 사용하여 URL을 검사합니다.</translation>
<translation id="4662363689050405237">Ecosia을 기본 브라우저로 설정</translation>
<translation id="6266342355635466082">Chromium에서 업데이트를 확인할 수 없습니다. 인터넷 연결 상태를 확인하세요.</translation>
<translation id="6268381023930128611">Chromium에서 로그아웃</translation>
<translation id="4618410489751241263">이러한 탭은 추가 리소스를 사용하고 있습니다. 성능을 개선하려면 Ecosia에서 이러한 탭을 비활성화하도록 허용하세요.</translation>
<translation id="6416551953415159186">Ecosia 프로필 맞춤설정</translation>
<translation id="6290827346642914212">Chromium 프로필 이름 지정</translation>
<translation id="4882579364090762302">확장 프로그램에서 Ecosia에 로그인하도록 요청합니다</translation>
<translation id="3625533701824359646"><ph name="FILE_NAME"/>은(는) 위험할 수 있으므로 Ecosia에서 차단했습니다.</translation>
<translation id="4943938785458240142">Ecosia이 카메라를 사용 중입니다.</translation>
<translation id="6327105987658262776">사용 가능한 업데이트가 없습니다.</translation>
<translation id="6450895420388847775">Ecosia에서 다른 작업이 진행 중입니다. 나중에 다시 시도해 주세요.</translation>
<translation id="464306605599005355">이제 Ecosia 계정으로 공유 컴퓨터에서 Ecosia을 손쉽게 사용할 수 있습니다.</translation>
<translation id="6735145163744656874">Ecosia은 이러한 탭을 비활성화하여 탐색 환경을 개선하고 빠른 속도를 유지할 수 있습니다.</translation>
<translation id="1284343625991453987">Ecosia 바로가기</translation>
<translation id="7051119589302096163">일반적으로 다운로드하지 않는 파일이며 위험할 가능성이 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다.</translation>
<translation id="7908111389403807005">Ecosia을 제거하시겠습니까?</translation>
<translation id="6375219077595103062">비밀번호 관리자로 연결되는 바로가기를 추가하세요</translation>
<translation id="5610400309434105339"><ph name="BEGIN_BOLD"/>Ecosia의 데이터 사용 방식:<ph name="END_BOLD"/> Ecosia은 내 관심분야를 예측할 수 있습니다. 나중에 사이트를 방문하면 사이트에서 광고 개인 최적화를 위해 내 관심분야를 알려달라고 Ecosia에 요청할 수 있습니다.</translation>
<translation id="7578952608547569314">컴퓨터 화면에 표시된 Ecosia 로고입니다.</translation>
<translation id="3939060118711873999">Ecosia은 빠른 속도로 웹페이지와 애플리케이션을 실행하는 웹 브라우저입니다. 빠르고 안정적이며 사용하기에 편리합니다. Ecosia에 내장된 멀웨어 및 악성 코드 방지 기능을 사용하여 더욱 안전하게 웹을 검색하세요.</translation>
<translation id="5404489723475681578">EcosiaOS 다시 시작</translation>
<translation id="6443470774889161065">Chromium은 사용자가 방문할 때 페이지를 더 빠르게 로드할 수 있도록 사용자가 방문할 가능성이 높은 페이지를 미리 로드합니다.</translation>
<translation id="7877883466657693294">사용 안함 • Ecosia에서 이 확장 프로그램의 출처를 확인할 수 없습니다.</translation>
<translation id="4410570812343670816">Ecosia 프로필에 오신 것을 환영합니다</translation>
<translation id="4371259280767924562">Ecosia에서 계정 삭제</translation>
<translation id="524314285625975879">또한 Ecosia을 시작할 때 표시되는 페이지를 설정합니다.</translation>
<translation id="648319183876919572">향상된 세이프 브라우징은 위험한 웹사이트와 다운로드로부터 사용자를 보호합니다.</translation>
<translation id="6496553866814956056">Ecosia 설치 제거</translation>
<translation id="788366290112401490">Ecosia에서 바로가기가 열립니다</translation>
<translation id="1773882594264682232">로그인한 상태로 Ecosia에서 Ecosia 계정의 비밀번호 등을 사용할 수 있습니다. 설정에서 언제든지 변경할 수 있습니다.</translation>
<translation id="2280934980919215876"><ph name="TIMEOUT_DURATION"/> 동안 사용하지 않으면 조직에서 Ecosia을 종료합니다. 인터넷 사용 기록이 삭제되었습니다. 여기에는 방문 기록, 자동 완성, 다운로드가 포함될 수 있습니다.</translation>
<translation id="8608092457636055141">각 프로필에는 북마크, 방문 기록, 비밀번호 등과 같은 Ecosia 정보가 보관됩니다.</translation>
<translation id="6563921047760808519"><ph name="BEGIN_LINK"/>Chromium에서 데이터를 비공개로 유지하는 방법<ph name="END_LINK"/> 자세히 알아보기</translation>
<translation id="3592624492063123732">다른 Ecosia 프로필의 비밀번호를 보도록 전환할 수 있습니다.</translation>
<translation id="6570579332384693436">맞춤법 오류를 수정하기 위해 Chromium에서 사용자가 입력하는 텍스트를 Google로 전송합니다.</translation>
<translation id="6533266716128249922">Ecosia 알림 설정으로 이동</translation>
<translation id="1722634673917783018">변경사항은 다음에 Ecosia을 다시 시작할 때 적용됩니다.</translation>
<translation id="2537426042760364251">Ecosia에서 주변의 3D 지도를 만들려면 카메라 권한이 필요합니다.</translation>
<translation id="6663852025006259149">사이트가 제대로 작동하지만 Chromium 창을 모두 닫으면 데이터는 전부 삭제됩니다.</translation>
<translation id="6669284030132180248">Google 계정에도 북마크를 저장하면 Chromium에서 제품 가격을 추적하고 가격이 인하되면 알림을 받을 수 있습니다.</translation>
<translation id="6676384891291319759">인터넷 연결</translation>
<translation id="8067423333018528301">로그인 중 오류가 발생하여 EcosiaOS에서 데이터를 동기화할 수 없습니다.</translation>
<translation id="6692797197837897398">Chromium을 나에게 표시되는 광고를 보다 세부적으로 관리할 뿐만 아니라 사이트가 개인 맞춤 광고를 표시할 때 나에 관해 얻을 수 있는 정보를 제한할 수 있습니다.</translation>
<translation id="2173571365716863400">Ecosia에서 사이트에 대한 마이크 권한이 필요합니다.</translation>
<translation id="6712881677154121168">다운로드 오류(<ph name="DOWNLOAD_ERROR"/>)가 발생했습니다.</translation>
<translation id="6648664289472946060">Ecosia의 최신 버전을 사용하기 때문에 프로필을 사용할 수 없습니다.

일부 기능을 사용할 수 없습니다. 다른 프로필 디렉터리를 지정하거나 Ecosia의 새로운 버전을 사용하시기 바랍니다.</translation>
<translation id="6729124504294600478">맞춤설정 및 기타 기능을 사용하려면 웹 및 앱 활동 그리고 연결된 Google 서비스에 Chromium을 포함하세요</translation>
<translation id="4870057811531036437">모든 사용자가 사용할 수 있도록 컴퓨터에 Ecosia이 이미 설치되어 있습니다.</translation>
<translation id="4512092435423703529">모든 기기에서 Ecosia 계정 정보에 액세스하려면 로그인한 후 동기화를 사용 설정하세요.</translation>
<translation id="674245979920622322">최근에 사이트를 방문하지 않았습니다. Chromium에서 <ph name="PERMISSION_1"/>, <ph name="PERMISSION_2"/> 외 권한 <ph name="COUNT"/>개를 삭제했습니다.</translation>
<translation id="7972668220031382654">위험할 수 있는 파일이므로 검사하는 것이 좋습니다.</translation>
<translation id="2441303983090031276">EcosiaOS는 추가 <ph name="BEGIN_LINK_CROS_OSS"/>오픈소스 소프트웨어<ph name="END_LINK_CROS_OSS"/>를 사용하여 개발되었습니다.</translation>
<translation id="1263466865695943046">비밀번호가 유출되면 Ecosia에서 알려줍니다.</translation>
<translation id="684888714667046800">인터넷에 연결할 수 없습니다. 방화벽을 사용하는 경우 <ph name="PRODUCT_EXE_NAME"/>이(가) 허용 목록에 있는지 확인해 주세요.</translation>
<translation id="4600924482853773728">Ecosia - <ph name="PAGE_TITLE"/></translation>
<translation id="1490060441084292633">Ecosia에서 "<ph name="EXTENSION_NAME"/>"에 멀웨어가 포함된 것을 발견했습니다.</translation>
<translation id="6929417474050522668">무료 체험을 사용 설정한 경우 방문하는 사이트에서는 Ad measurement를 활용해 광고의 실적을 측정하는 데 도움이 되는 정보를 Chromium에 요청할 수 있습니다. Ad measurement는 사이트 간에 최소한의 정보만 전송함으로써 크로스 사이트 추적을 제한합니다.</translation>
<translation id="6940431691900807093">이후 방문한 사이트에서 광고 개인 최적화를 위해 내 관심분야를 알려달라고 Chromium에 요청할 수 있습니다. Chromium은 최대 3개의 관심분야를 공유할 수 있습니다.</translation>
<translation id="8283315171506895091">Ecosia 시크릿 창에서 링크 열기(&amp;G)</translation>
<translation id="6978145336957848883">취약한 비밀번호는 추측하기 쉽습니다. Chromium에서 <ph name="BEGIN_LINK"/>안전한 비밀번호를 생성하고 기억하도록 설정<ph name="END_LINK"/>하세요.</translation>
<translation id="6981396265751285733">메모리 절약 모드를 사용 설정하면 Chromium이 비활성 탭에서 메모리를 확보합니다. 이에 따라 활성 탭과 기타 앱에 더 많은 컴퓨터 리소스가 제공되고 Chromium의 빠른 속도가 유지됩니다. 비활성 탭으로 돌아가면 탭이 자동으로 다시 활성화됩니다.</translation>
<translation id="2149148292984034533">EcosiaOS 약관</translation>
<translation id="1831192335802727557">이 사이트에서 마이크에 액세스하려면 Ecosia에 권한이 필요합니다</translation>
<translation id="7011190694940573312">이 운영체제 버전은 지원되지 않으므로 설치에 실패했습니다.</translation>
<translation id="7024536598735240744">압축해제 오류(<ph name="UNPACK_ERROR"/>)가 발생했습니다.</translation>
<translation id="7025789849649390912">설치가 중단되었습니다.</translation>
<translation id="762525592078244189">나만의 Ecosia 만들기</translation>
<translation id="5598074261782651109">Ecosia 업데이트</translation>
<translation id="2838372953389311551">이미지에 유용한 설명이 없으면 Ecosia에서 자동으로 설명을 제공하려고 시도합니다. 설명을 생성하기 위해 이미지가 Ecosia로 전송됩니다.</translation>
<translation id="550507036977517224">Ecosia for Testing 맞춤설정</translation>
<translation id="9091453616111683919"><ph name="EXTENSION_NAME"/> 확장 프로그램을 Ecosia에서 제거</translation>
<translation id="5137471865755621561"><ph name="TIMEOUT_DURATION"/> 동안 사용하지 않으면 조직에서 Ecosia 데이터를 삭제합니다. 여기에는 방문 기록, 자동 완성, 다운로드가 포함될 수 있습니다.</translation>
<translation id="219546601381787154">Ecosia에서 사이트에 대한 카메라 권한이 필요합니다.</translation>
<translation id="2542649989941327712">Ecosia을 실행할 수 없습니다. 다시 시도해 보세요.</translation>
<translation id="7197677400338048821">Chromium에서 비밀번호를 확인할 수 없습니다. 24시간 후 다시 시도해 보세요.</translation>
<translation id="3784023996375784431">언제든지 메시지, 문서 및 다른 앱에서 링크를 클릭하여 Ecosia을 사용하세요</translation>
<translation id="7311066525704006840">작업 관리자 - Ecosia</translation>
<translation id="3816260943154642689">Ecosia에서 예측한 내 관심분야</translation>
<translation id="1720431815870023289">{NUM_EXTENSIONS,plural, =1{Ecosia에서 삭제할 것을 권장합니다.}other{Ecosia에서 삭제할 것을 권장합니다.}}</translation>
<translation id="7309928523159922338">방문하는 사이트에서는 Ad measurement를 활용해 광고의 실적을 측정하는 데 도움이 되는 정보를 Chromium에 요청할 수 있습니다. Ad measurement는 사이트 간에 최소한의 정보만 전송함으로써 크로스 사이트 추적을 제한합니다.</translation>
<translation id="731795002583552498">Chromium 업데이트 중</translation>
<translation id="6673288084648462613">환경설정 파일이 손상되었거나 잘못되었습니다.

Ecosia에서 설정을 복구할 수 없습니다.</translation>
<translation id="7339898014177206373">새 창</translation>
<translation id="4960252760049500399">웹, 북마크 및 기타 Ecosia 콘텐츠가 여기에 저장됩니다.</translation>
<translation id="7158975242722498086">시스템 관리자가 <ph name="TARGET_URL_HOSTNAME"/> 액세스를 위해 <ph name="ALTERNATIVE_BROWSER_NAME"/>을(를) 열도록 Ecosia을 구성했습니다.</translation>
<translation id="6632508343667825745">파일이 <ph name="USER_EMAIL"/> 등의 개인 및 소셜 네트워크 계정에 피해를 줄 수 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다</translation>
<translation id="6180968682827452331">이 확장 프로그램은 더 이상 지원되지 않습니다. 대신 Ecosia에서는 이 프로그램을 삭제할 것을 권장합니다.</translation>
<translation id="5622136942112821750">Ecosia 프로필을 사용하면 모든 Ecosia 데이터를 분리할 수 있습니다. 업무용 데이터와 개인용 데이터를 더 쉽게 분리해 보세요.</translation>
<translation id="3879865245128287988"><ph name="PAGE_TITLE"/> - 개발자용 Ecosia</translation>
<translation id="5055330219314726197">이 사이트에서 카메라에 액세스하려면 Ecosia에 권한이 필요합니다</translation>
<translation id="7458892263350425044">마이크를 사용하려면 <ph name="BEGIN_LINK"/>시스템 설정<ph name="END_LINK"/>에서 Chromium에 액세스 권한을 부여하세요.</translation>
<translation id="1975037445584526511">향후 Ecosia 업데이트를 받으려면 Windows 10 이상이 필요합니다. 이 컴퓨터에서는 Windows 7을 사용 중입니다.</translation>
<translation id="7467949745582939695">Chromium을 다시 시작하시겠습니까?</translation>
<translation id="80155189677487610">이미 실행 중인 Ecosia과 동일한 버전을 설치할 수 없습니다. Ecosia을 종료한 뒤 다시 시도하세요.</translation>
<translation id="751935028865900641">사이트가 정상적으로 작동할 것입니다. Chromium에 로그인한 경우 Google 계정을 제외한 모든 Chromium 창을 닫으면 대부분의 사이트에서 로그아웃됩니다.</translation>
<translation id="7558678848273505235">{0,plural, =1{1분 후 Ecosia이 다시 시작됩니다}other{#분 후 Ecosia이 다시 시작됩니다}}</translation>
<translation id="8228132389897276908">창을 공유하려면 시스템 환경설정에서 Ecosia의 화면 녹화를 허용하세요</translation>
<translation id="7582945390259497898">Chromium에서 내 관심분야를 예측할 수 있습니다. 나중에 사이트를 방문하면 사이트에서 광고 개인 최적화를 위해 내 관심분야를 알려달라고 Chromium에 요청할 수 있습니다.</translation>
<translation id="7583399374488819119"><ph name="COMPANY_NAME"/> 설치 프로그램</translation>
<translation id="7585391435984513350">최근에 사이트를 방문하지 않았습니다. Chromium에서 <ph name="PERMISSION"/> 권한을 삭제했습니다.</translation>
<translation id="4061472199368124600">Ecosia이 카메라와 마이크를 사용 중입니다.</translation>
<translation id="170259281605734125">더욱 업그레이드된 Ecosia</translation>
<translation id="7649070708921625228">도움말</translation>
<translation id="675365189802108507">Ecosia 설정에서 이러한 기능에 관해 자세히 알아볼 수 있습니다.</translation>
<translation id="1508200558303644420">Ecosia이 기본 브라우저로 설정되어 있지 않습니다</translation>
<translation id="7174674455569790401">모든 기기에서 Ecosia을 동기화하고 맞춤설정하세요.</translation>
<translation id="7699779824407626136">Chromium 업데이트</translation>
<translation id="7745317241717453663">인터넷 사용 기록이 기기에서 삭제됩니다. 나중에 데이터를 가져오려면 Chromium에 <ph name="USER_EMAIL"/>(으)로 로그인하세요.</translation>
<translation id="7747138024166251722">설치 프로그램이 임시 디렉터리를 만들지 못했습니다. 디스크 공간 및 설치 권한을 확인해 보세요.</translation>
<translation id="6161025257729272170">Ecosia의 속도를 높여보세요</translation>
<translation id="5669882610631815446"><ph name="PAGE_TITLE"/> - Ecosia Canary</translation>
<translation id="7803986347287457849">내 인터넷 트래픽에 액세스할 수 있는 사용자가 내가 방문하는 사이트를 확인하기가 더 어려워집니다. Chromium은 DNS(도메인 이름 시스템)에서 사이트의 IP 주소를 조회하는 데 보안 연결을 사용합니다.</translation>
<translation id="8301840715671593762">이 계정을 사용하는 Ecosia 프로필이 기기에 이미 존재합니다</translation>
<translation id="7845233973568007926">설치해 주셔서 감사합니다. <ph name="BUNDLE_NAME"/>을(를) 사용하려면 컴퓨터를 다시 시작해야 합니다.</translation>
<translation id="7859018312476869945">주소 표시줄이나 검색창에 검색어를 입력하면 Chromium은 더 나은 추천 검색어를 제공하기 위해 사용자가 입력한 내용을 기본 검색엔진으로 전송합니다. 시크릿 모드에서는 이 기능이 사용 중지되어 있습니다.</translation>
<translation id="3268039966078382323">Ecosia을 최신 버전으로 업데이트하지 못했기 때문에 새로운 기능과 보안 수정 사항이 적용되지 않았습니다.</translation>
<translation id="7872446069773932638">다운로드 중... <ph name="SECONDS"/>초 남았습니다.</translation>
<translation id="5875641815673321623"><ph name="BEGIN_BOLD"/>데이터 관리 방법:<ph name="END_BOLD"/> 개인 정보를 보호하기 위해 Ecosia에서는 4주가 지난 관심분야를 자동 삭제합니다. 인터넷 사용에 따라 특정 관심분야가 목록에 다시 표시될 수 있습니다. Ecosia에서 고려하지 않았으면 하는 관심분야가 있으면 직접 삭제하세요.</translation>
<translation id="4638085384909702681">Ecosia을 기본 브라우저로 설정</translation>
<translation id="7934340546140346950">가능한 경우 Chromium이 비보안 연결을 HTTPS로 자동 업그레이드합니다.</translation>
<translation id="2412381038247037703"><ph name="USER_EMAIL_ADDRESS"/>(으)로 Ecosia에 로그인되어 있습니다. 같은 계정으로 다시 로그인해 주세요.</translation>
<translation id="7975919845073681630">Chromium의 보조 설치이며 기본 브라우저로 설정할 수 없습니다.</translation>
<translation id="851583113375911087">알 수 없는 소스의 확장 프로그램, 앱, 테마는 기기를 손상시킬 수 있습니다. <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>에서 다운로드한 확장 프로그램, 앱, 테마만 설치하는 것이 좋습니다</translation>
<translation id="488806616089631539">Ecosia에 액세스 권한을 부여하면 웹사이트에서 액세스 권한을 요청할 수 있게 됩니다.</translation>
<translation id="80471789339884597">설치해 주셔서 감사합니다. <ph name="BUNDLE_NAME"/>을(를) 사용하려면 모든 브라우저를 다시 시작해야 합니다.</translation>
<translation id="8086881907087796310">컴퓨터가 최소 하드웨어 요구사항을 충족하지 않으므로 설치에 실패했습니다.</translation>
<translation id="1528748166720431933"><ph name="PAGE_TITLE"/> - Ecosia for Testing</translation>
<translation id="5661123757512626239">Ecosia에서 사이트에 대한 위치 정보 액세스 권한이 필요합니다.</translation>
<translation id="143614250230771428">내 도메인에서 동기화를 사용할 수 없으므로 EcosiaOS에서 데이터를 동기화할 수 없습니다.</translation>
<translation id="813913629614996137">초기화 중...</translation>
<translation id="588828970866589779">Ecosia의 JavaScript 및 WebAssembly 엔진에서 추가 보호 기능 사용 설정</translation>
<translation id="6491651957026506753">이 파일은 위험하므로 Ecosia에서 차단했습니다.</translation>
<translation id="8223363452568144035">카메라를 사용하려면 <ph name="BEGIN_LINK"/>시스템 설정<ph name="END_LINK"/>에서 Chromium에 액세스 권한을 부여하세요.</translation>
<translation id="7433581196371819898">Ecosia에서 이 확장 프로그램의 출처를 확인할 수 없습니다. 안전하지 않은 확장 프로그램일 수 있습니다. 더 이상 개인 정보를 비롯한 방문 사이트의 데이터를 확인하고 변경할 수 없도록 Ecosia에서 이 확장 프로그램을 삭제하세요.</translation>
<translation id="2046160555506209000">이미지에 유용한 설명이 없으면 Ecosia에서 자동으로 설명을 제공하려고 시도합니다. 설명을 생성하기 위해 이미지가 Ecosia로 전송됩니다. 이 기능은 언제든지 설정에서 사용 중지할 수 있습니다.</translation>
<translation id="3260765223735049374">새 프로필로 Ecosia에 로그인하시겠습니까?</translation>
<translation id="8266560134891435528">로그인되어 있지 않으므로 Chromium에서 비밀번호를 확인할 수 없습니다.</translation>
<translation id="8286943863733751221">안전하지 않은 사이트 및 다운로드에 대해 <ph name="BEGIN_LINK"/>Chromium에서 경고<ph name="END_LINK"/></translation>
<translation id="5994043198751001258"><ph name="TIMEOUT_DURATION"/> 동안 사용하지 않으면 조직에서 Ecosia을 종료합니다.</translation>
<translation id="8330519371938183845">로그인하여 모든 기기에서 Chromium을 동기화하고 맞춤설정하세요.</translation>
<translation id="8055222671516987714"><ph name="USER_EMAIL_ADDRESS"/>에서 이전에 Ecosia을 사용한 적이 있음</translation>
<translation id="4337034173783952373">모든 기기에서 Ecosia 브라우저 데이터에 액세스하려면 로그인한 후 동기화를 사용 설정하세요</translation>
<translation id="8655983536493871574">향후 Ecosia 업데이트를 받으려면 Windows 10 이상이 필요합니다. 이 컴퓨터에서는 Windows 8을 사용 중입니다.</translation>
<translation id="8355171755788522183">Copyright <ph name="YEAR"/> Ecosia. All rights reserved.</translation>
<translation id="4395802781633621239">모든 기기에서 비밀번호 등을 사용하려면 Ecosia에 로그인하세요. 로그인하면 이 비밀번호가 Ecosia 계정에 저장됩니다.</translation>
<translation id="8268239447047453615">그런 다음 Ecosia을 다시 시작해야 합니다.</translation>
<translation id="5167067155585861308">Ecosia에서 삭제할 것을 권장합니다. <ph name="BEGIN_LINK"/>지원되는 확장 프로그램에 대해 자세히 알아보기<ph name="END_LINK"/></translation>
<translation id="8863497461138396324">이 확장 프로그램은 개발자가 게시 취소했으며, 안전하지 않을 수 있습니다. 더 이상 개인 정보를 비롯한 방문 사이트의 데이터를 확인하고 변경할 수 없도록 Ecosia에서 이 확장 프로그램을 삭제하세요.</translation>
<translation id="6826163993811146231">{0,plural, =1{1일 이내로 Ecosia을 다시 시작해 주세요}other{#일 이내로 Ecosia을 다시 시작해 주세요}}</translation>
<translation id="4033006861724039519">설치 프로그램 아카이브가 손상되었거나 잘못되었습니다. Ecosia을 다시 다운로드하세요.</translation>
<translation id="2829233304432701500">Ecosia은 Windows 10 이상 버전에서 사용할 수 있습니다.</translation>
<translation id="8975930032513941502">선택사항: 진단 및 사용 데이터를 Ecosia에 자동으로 전송하여 EcosiaOS의 기능 및 성능 개선에 참여합니다.</translation>
<translation id="2695952268686253864">Ecosia이 이전 버전임</translation>
<translation id="8522801943730206384">비밀번호를 저장하면 Chromium에서 확인할 수 있습니다</translation>
<translation id="8550334526674375523">이 직장 프로필은 개인 프로필과 완전히 분리됩니다.</translation>
<translation id="8555465886620020932">서비스 오류(<ph name="SERVICE_ERROR"/>)가 발생했습니다.</translation>
<translation id="8568283329061645092">Google 계정으로 로그인하면 Chromium에서 비밀번호를 확인할 수 있습니다.</translation>
<translation id="4817309082638621362">여러 조직에서 Ecosia을 관리합니다.</translation>
<translation id="7129808598331559748">Copyright <ph name="YEAR"/> The Ecosia Authors. All rights reserved.</translation>
<translation id="1851101453239911251"><ph name="BEGIN_BOLD"/>Ecosia의 데이터 사용 방식:<ph name="END_BOLD"/> 사이트에서는 Ecosia에 내 관심분야에 관한 정보를 저장할 수 있습니다. 예를 들어 마라톤화를 구매하려고 사이트를 방문하면 사이트에서 내 관심분야를 마라톤으로 정의할 수 있습니다. 나중에 마라톤 대회에 등록하기 위해 다른 사이트에 방문하면 관심분야를 토대로 마라톤화 광고가 표시될 수 있습니다.</translation>
<translation id="8109744984354428711">Ecosia 실행 중...</translation>
<translation id="2402290209407843024">알 수 없는 오류로 인해 설치에 실패했습니다. Ecosia을 다시 다운로드하세요.</translation>
<translation id="8648201657708811153">Google Chrome for Testing을 기본 브라우저로 설정할 수 없습니다.</translation>
<translation id="6665128960039431910">또한 Ecosia을 시작하거나 검색주소창에서 검색할 때 표시되는 페이지를 설정합니다.</translation>
<translation id="2000339487270823788">나만의 Ecosia</translation>
<translation id="7045045549868370797">Ecosia에 로그인하시겠습니까?</translation>
<translation id="878572486461146056">설치 오류: 네트워크 관리자가 설치를 방지하는 그룹 정책을 적용했습니다: <ph name="INSTALL_ERROR"/></translation>
<translation id="7273750863406285983">이 사이트에서 카메라와 마이크에 액세스하려면 Ecosia에 권한이 필요합니다</translation>
<translation id="1485302026917450654">Ecosia에 로그인하시겠습니까?</translation>
<translation id="8826492472752484139">'비밀번호 관리자'를 클릭합니다</translation>
<translation id="5267683457871579197">EcosiaOS 시스템</translation>
<translation id="4565616259974605182"><ph name="BEGIN_BOLD"/>사용되는 데이터:<ph name="END_BOLD"/> 이 기기에서 Ecosia을 사용해 방문한 사이트의 기록인 방문 기록이 사용됩니다.</translation>
<translation id="8862326446509486874">시스템 수준의 설치 권한이 없습니다. 관리자 권한으로 설치 프로그램을 다시 실행해 보세요.</translation>
<translation id="8880203542552872219">그렇다면 Chromium에 저장된 비밀번호가 새로운 비밀번호와 일치하도록 수정해 주세요.</translation>
<translation id="3966234175958887595">Ecosia에서 비밀번호를 표시하려고 합니다. 허용하려면 Windows 비밀번호를 입력하세요.</translation>
<translation id="8931379085695076764">Chromium은 지난 몇 주간의 방문 기록을 토대로 내 관심분야를 예측할 수 있습니다. 예측 정보는 기기 외부로 전송되지 않습니다.</translation>
<translation id="6346154190168496057">Ecosia을 업데이트하지 못함</translation>
<translation id="93440396576488794">Ecosia Enterprise 로고</translation>
<translation id="8986207147630327271">직장 프로필을 이 브라우저에 추가하고 직장 프로필 제어 권한을 관리자에게 부여합니다.</translation>
<translation id="2985399486579137606">Ecosia 프로필 관리</translation>
<translation id="1597547208646178091">Ecosia에서는 Ecosia의 보안을 강화하기 위해 <ph name="IDS_EXTENSION_WEB_STORE_TITLE"/>에 표시되지 않고 사용자가 모르게 추가되었을 수 있는 다음 확장 프로그램의 사용을 중지했습니다.</translation>
<translation id="2388751143175762498">Ecosia에 로그인</translation>
<translation id="231621248561775155">보관 파일에 멀웨어를 숨길 수 있는 다른 파일이 포함되어 있기 때문에 Ecosia에서 이 다운로드를 차단했습니다</translation>
<translation id="9062666675513499497">다른 Google 서비스에 로그인할 때 Chromium에 로그인</translation>
<translation id="5312730628132049495">Ecosia에 로그인합니다. 계정에 한 번만 로그인하려면 <ph name="GUEST_LINK_BEGIN"/>기기를 게스트로 사용<ph name="GUEST_LINK_END"/>하면 됩니다.</translation>
<translation id="5061261337583604526">Ecosia이 자동으로 종료되었습니다</translation>
<translation id="7268098999602465369">Ecosia이 이전 버전임</translation>
<translation id="6022879254514691681">{0,plural, =1{1시간 후 Ecosia이 다시 시작됩니다}other{#시간 후 Ecosia이 다시 시작됩니다}}</translation>
<translation id="8963533629322868062">향후 Ecosia 업데이트를 받으려면 Windows 10 이상이 필요합니다. 이 컴퓨터에서는 Windows 8.1을 사용 중입니다.</translation>
<translation id="7774247008790177839">새 Ecosia 탭에서 링크 열기(&amp;T)</translation>
<translation id="911206726377975832">인터넷 사용 기록도 삭제하시겠습니까?</translation>
<translation id="7580831958727159171">시험 기간 중에는 사이트에서 광고 표시를 위해 사용하는 관심분야의 주제를 내가 확인하고 삭제할 수 있습니다. Ecosia에서는 사용자의 최근 방문 기록을 기반으로 관심분야를 추정합니다.</translation>
<translation id="8901409988302458368">시스템 관리자가 <ph name="TARGET_URL_HOSTNAME"/> 액세스를 위해 대체 브라우저를 열도록 Ecosia을 구성했습니다.</translation>
<translation id="1523806373970723624">다시 실행하여 Ecosia 업데이트</translation>
<translation id="2470806471563820591">Ecosia(mDNS-In)</translation>
<translation id="4767994371234572952">나만의 Ecosia 만들기</translation>
<translation id="6933283849886243832">Windows XP 또는 Windows Vista에서 더 이상 Ecosia을 지원하지 않으므로 Ecosia이 올바르게 작동하지 않을 수 있습니다</translation>
<translation id="942598560705308788">Chromium이 관리하는 인증서</translation>
<translation id="8078678931242443254">Ecosia 사용자 선택</translation>
<translation id="12795904718916112">Ecosia의 가장 강력한 보안 기능을 이용하세요</translation>
<translation id="983803489796659991">업데이트 서버에 애플리케이션에 대한 해시 데이터가 없어 설치할 수 없습니다.</translation>
<translation id="5612740201368556834">계정 없이 Ecosia 사용</translation>
<translation id="6235001546696543832">The Ecosia Authors</translation>
<translation id="992780518932311116">위치를 사용하려면 <ph name="BEGIN_LINK"/>시스템 설정<ph name="END_LINK"/>에서 Chromium에 액세스 권한을 부여하세요.</translation>
</translationbundle>
