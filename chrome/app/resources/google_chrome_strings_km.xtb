<translation id="7849498640944199147">ដើម្បីផ្ញើ​លេខទូរសព្ទពី <ph name="ORIGIN"/> ទៅទូរសព្ទ Android របស់អ្នក សូមចូល Ecosia នៅលើឧបករណ៍​ទាំងពីរ។</translation>
<translation id="7910693244647744044">អ្នកបានបើក​ការរុករកដោយ​សុវត្ថិភាពបន្ថែមនៅក្នុង​គណនីរបស់អ្នក។ ឥឡូវនេះ យកវាសម្រាប់ Ecosia។</translation>
<translation id="8986207147630327271">អ្នកកំពុងបញ្ចូលកម្រងព័ត៌មានការងារទៅក្នុងកម្មវិធីរុករកតាមអ៊ីនធឺណិតនេះ និងផ្ដល់លទ្ធភាពឱ្យអ្នកគ្រប់គ្រងរបស់អ្នកគ្រប់គ្រងតែកម្រងព័ត៌មានការងារប៉ុណ្ណោះ។</translation>
<translation id="8989968390305463310">ប្រវត្តិរុករក​តាមអ៊ីនធឺណិត​របស់អ្នក​មានឥទ្ធិពលលើ​ការផ្សាយពាណិជ្ជកម្មដែល​អ្នកឃើញ និង​ចំណាប់អារម្មណ៍​ដូចដែលបានប៉ាន់ស្មាន​ខាងក្រោម។ ដើម្បី​ការពារ​ឯកជនភាព​របស់អ្នក Chrome លុបចំណាប់អារម្មណ៍​របស់អ្នក​ដោយស្វ័យប្រវត្តិ​ជាបន្តបន្ទាប់​រៀងរាល់ខែ។ ចំណាប់អារម្មណ៍​អាចផ្ទុក​ឡើងវិញ ប្រសិនបើអ្នក​មិនដកវាចេញទេ។</translation>
<translation id="7348818664647668234">{0,plural, =0{មាន​កំណែថ្មី​របស់ Ecosia ហើយ}=1{មាន​កំណែថ្មី​របស់ Ecosia ហើយ}other{មាន​កំណែថ្មី​របស់ Ecosia រយៈពេល # ថ្ងៃហើយ}}</translation>
<translation id="9003498785844995646">នៅពេល​បើក នោះ Chrome សន្សំ​ថាមពល​ថ្ម​ដោយ​ដាក់កំហិត​សកម្មភាព​ផ្ទៃខាងក្រោយ និង​បែបផែន​ដែលមើលឃើញ ដូចជា​ការរំកិលរលូន និង​អត្រាហ្វ្រេម​វីដេអូជាដើម។ <ph name="BEGIN_LINK"/>ស្វែងយល់បន្ថែម<ph name="END_LINK"/> ឬ​<ph name="BEGIN_LINK_2"/>ផ្ញើ​មតិកែលម្អ<ph name="END_LINK_2"/></translation>
<translation id="9047384314208087523">ប្រព័ន្ធ EcosiaOS Flex</translation>
<translation id="5675757883980078189">Ecosia តម្រូវឲ្យមានប្រព័ន្ធប្រតិបត្តិការ Windows 7 ឬខ្ពស់ជាងនេះ។</translation>
<translation id="911206726377975832">លុបទិន្នន័យរុករករបស់អ្នកផងដែរ?</translation>
<translation id="9138603949443464873">ដើម្បី​អនុវត្ត​ការផ្លាស់ប្ដូររបស់អ្នក សូម​ចាប់ផ្ដើម​ Chrome ឡើងវិញ</translation>
<translation id="9195993889682885387">Chrome អាចប៉ាន់ស្មាន​អំពីចំណាប់អារម្មណ៍​របស់អ្នក ដោយផ្អែកលើ​ប្រវត្តិ​រុករក​តាមអ៊ីនធឺណិត​របស់អ្នក​ពីពីរបីសប្ដាហ៍​ចុងក្រោយ។ ព័ត៌មាននេះ​ស្ថិតនៅលើ​ឧបករណ៍​របស់អ្នក។</translation>
<translation id="5704599732514791330">អាប់ដេត Ecosia ដើម្បីចាប់ផ្តើមសមកាលកម្ម</translation>
<translation id="838842459108103907">ប្ដូរ Ecosia តាមបំណង</translation>
<translation id="3070276123152913305">ចាប់ផ្ដើម EcosiaOS Flex ឡើងវិញ</translation>
<translation id="4512092435423703529">ដើម្បីចូលប្រើទិន្នន័យ Ecosia នៅលើឧបករណ៍ទាំងអស់របស់អ្នក សូមចូលគណនី រួចបើក​សម​កាល​កម្ម។</translation>
<translation id="7972668220031382654">Ecosia ណែនាំឱ្យស្កេនឯកសារនេះ ដោយសារវាអាចបង្កគ្រោះថ្នាក់។</translation>
<translation id="989369509083708165">Google Chrome គឺជា​កម្មវិធី​រុករក​តាមអ៊ីនធឺណិត​លំនាំដើម​របស់​អ្នក</translation>
<translation id="4614106433017753369"><ph name="SHORTCUT"/> អាចប្ដូររវាងកម្រងព័ត៌មាន Ecosia</translation>
