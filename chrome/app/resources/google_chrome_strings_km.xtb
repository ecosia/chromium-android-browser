<translation id="796435732739009892">Ecosia បានទប់ស្កាត់ឯកសារនេះ ដោយសារប្រភេទឯកសារនេះមានគ្រោះថ្នាក់</translation>
<translation id="8570641140903702642">Ecosia Canary</translation>
<translation id="6718055545215052843">ដើម្បីទទួលបានកំណែថ្មីរបស់ Ecosia ក្នុងពេលអនាគត អ្នកនឹងត្រូវការ macOS 10.13 ឬកំណែខ្ពស់ជាងនេះ។ កុំព្យូទ័រនេះកំពុងប្រើ OS X 10.11។</translation>
<translation id="5098668839038261629">នៅពេលបើក អ្នកក៏នឹងត្រូវចេញពី Chrome ផងដែរ</translation>
<translation id="7782767522222146179">ស្វែងយល់ពីកម្មវិធី ហ្គេម កម្មវិធីបន្ថែម និងធីមដ៏អស្ចារ្យសម្រាប់ Ecosia។</translation>
<translation id="6416551953415159186">ប្ដូរកម្រងព័ត៌មាន Ecosia របស់អ្នកតាមបំណង</translation>
<translation id="1859120614572957305">សូម​ស្វាគមន៍​មក​កាន់ Ecosia។ បាន​បើក​វិនដូ​របស់​កម្មវិធីរុករកតាមអ៊ីនធឺណិត​ថ្មី</translation>
<translation id="6648664289472946060">ទម្រង់របស់អ្នកមិនអាចត្រូវបានប្រើទេ ពីព្រោះវាចេញមកពីកំណែថ្មីជាងមុននៃ Ecosia។

លក្ខណៈពិសេសមួយចំនួនមិនមានទេ។ សូមបញ្ជាក់ពីថតឯកសារទម្រង់ផ្សេង ឬប្រើកំណែ Ecosia ថ្មីជាងមុន។</translation>
<translation id="6960183526681645011">ប្រសិនបើអ្នកចែករំលែកឧបករណ៍ណាមួយ មិត្តភ័ក្ដិ និងគ្រួសាររបស់អ្នកអាចរុករកដាច់ដោយឡែក ព្រមទាំងរៀបចំ Ecosia តាមអ្វីដែលពួកគេចង់បាន</translation>
<translation id="1869027055332251164">ភ្ញៀវអាចប្រើ Ecosia ដោយមិនមានបន្សល់ទុកអ្វីឡើយ។</translation>
<translation id="143614250230771428">EcosiaOS មិនអាចធ្វើ​សម​កាល​កម្មទិន្នន័យរបស់អ្នកបានទេ ដោយសារមិនអាចប្រើ​សម​កាល​កម្មនៅក្នុងដែនរបស់អ្នក។</translation>
<translation id="1809194740315140401">Ecosia ត្រូវការ​ការអនុញ្ញាត​ឱ្យចូលប្រើ​ទំហំផ្ទុក ដើម្បីទាញយក​ឯកសារ</translation>
<translation id="8975930032513941502">មិនតម្រូវ៖ ជួយកែលម្អ​មុខងារ និងប្រតិបត្តិការ EcosiaOS ដោយផ្ញើ​ទិន្នន័យប្រើប្រាស់ និងការវិភាគ​ទៅ Ecosia ដោយស្វ័យប្រវត្តិ។</translation>
<translation id="5357889879764279201">ទទួលជំនួយពាក់ព័ន្ធនឹង ChromeOS Flex</translation>
<translation id="6665128960039431910">វាក៏គ្រប់គ្រងអ្វីដែលទំព័របានបង្ហាញផងដែរ នៅពេលអ្នកចាប់ផ្តើម Ecosia ឬស្វែងរកពីប្រអប់អូមនី។</translation>
<translation id="1861504561909287316">ចែករំលែក​ផ្ទាំង Ecosia</translation>
<translation id="5412485296464121825">គេហទំព័រអាច​រក្សាទុក​ព័ត៌មានជាមួយ Chrome អំពីចំណាប់អារម្មណ៍​របស់អ្នក។ ឧទាហរណ៍ ប្រសិនបើអ្នក​ចូលមើល​គេហទំព័រ ដើម្បីទិញស្បែកជើង​សម្រាប់រត់ម៉ារ៉ាតុង នោះគេហទំព័រនោះ​ប្រហែលជាកំណត់​ចំណាប់អារម្មណ៍​របស់អ្នក​ថាជាការរត់ម៉ារ៉ាតុង។ ក្រោយមកទៀត ប្រសិនបើអ្នកចូលមើល​គេហទំព័រផ្សេង ដើម្បីចុះឈ្មោះ​ចូលរួមការប្រណាំង គេហទំព័រនោះ​អាចបង្ហាញ​ការផ្សាយពាណិជ្ជកម្ម​អំពីស្បែកជើងសម្រាប់​រត់ប្រណាំងដល់អ្នក ដោយផ្អែកលើ​ចំណាប់អារម្មណ៍​របស់អ្នក។</translation>
<translation id="6673288084648462613">៝ឯកសារចំណូលចិត្តរបស់អ្នកមានបញ្ហា ឬគ្មានសុពលភាព។

Ecosia មិនអាចសង្គ្រោះការកំណត់របស់អ្នកទេ។</translation>
<translation id="5524761631371622910">នៅពេល​ស្ថិតក្នុង​ការសាកល្បង ហើយប្រសិនបើ Chrome បានដាក់អ្នក​ដោយចៃដន្យ​នៅក្នុងការសាកល្បង​សកម្ម នោះប្រវត្តិ​រុករក​តាមអ៊ីនធឺណិត​របស់អ្នក​មានឥទ្ធិពលលើ​ការផ្សាយពាណិជ្ជកម្ម​ដែលអ្នកឃើញ និងចំណាប់អារម្មណ៍​ដូចដែលបានប៉ាន់ស្មាន​ខាងក្រោម។ ដើម្បី​ការពារ​ឯកជនភាព​របស់អ្នក Chrome លុបចំណាប់អារម្មណ៍​របស់អ្នក​ជាបន្តបន្ទាប់​រៀងរាល់ខែ។</translation>
